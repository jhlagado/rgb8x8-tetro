EE52   08 45 58 20 41 46 2C 41 46 A7 DB   08H,45H,58H,20H,41H,46H,2CH,41H,46H,0A7H   ;EX AF,AF'
EE5C   0F 52 52 43 C1         DB   0FH,52H,52H,43H,0C1H   ;RRCA
EE61   17 52 4C C1            DB   17H,52H,4CH,0C1H   ;RLA
EE65   1F 52 52 C1            DB   1FH,52H,52H,0C1H   ;RRA
EE69   27 44 41 C1            DB   27H,44H,41H,0C1H   ;DAA
EE6D   2F 43 50 CC            DB   2FH,43H,50H,0CCH   ;CPL
EE71   37 53 43 C6            DB   37H,53H,43H,0C6H   ;SCF
EE75   3F 43 43 C6            DB   3FH,43H,43H,0C6H   ;CCF
EE79   76 48 41 4C D4         DB   76H,48H,41H,4CH,0D4H   ;HALT
EE7E   C9 52 45 D4            DB   0C9H,52H,45H,0D4H   ;RET
EE82   D9 45 58 D8            DB   0D9H,45H,58H,0D8H   ;EXX
EE86   E3 45 58 20 28 53 50 29 2C 48 CC DB   0E3H,45H,58H,20H,28H,53H,50H,29H,2CH,48H,0CCH   ;EX (SP),HL
EE91   E9 4A 50 20 28 48 4C A9 DB   0E9H,4AH,50H,20H,28H,48H,4CH,0A9H   ;JP (HL)
EE99   EB 45 58 20 44 45 2C 48 CC DB   0EBH,45H,58H,20H,44H,45H,2CH,48H,0CCH   ;EX DE,HL
EEA2   F3 44 C9               DB   0F3H,44H,0C9H   ;DI
EEA5   F9 4C 44 20 53 50 2C 48 CC DB   0F9H,4CH,44H,20H,53H,50H,2CH,48H,0CCH   ;LD SP,HL
EEAE   FB 45 C9               DB   0FBH,45H,0C9H   ;EI
EEB1                             ; 
EEB1                TABLEEXC:      
EEB1   44 4E 45 C7            DB   44H,4EH,45H,0C7H   ;NEG
EEB5   45 52 45 54 CE         DB   45H,52H,45H,54H,0CEH   ;RETN
EEBA   46 49 4D 20 B0         DB   46H,49H,4DH,20H,0B0H   ;IM 0
EEBF   47 4C 44 20 49 2C C1   DB   47H,4CH,44H,20H,49H,2CH,0C1H   ;LD I,A
EEC6   4D 52 45 54 C9         DB   4DH,52H,45H,54H,0C9H   ;RETI
EECB   4F 4C 44 20 52 2C C1   DB   4FH,4CH,44H,20H,52H,2CH,0C1H   ;LD R,A
EED2   56 49 4D 20 B1         DB   56H,49H,4DH,20H,0B1H   ;IM 1
EED7   57 4C 44 20 41 2C C9   DB   57H,4CH,44H,20H,41H,2CH,0C9H   ;LD A,I
EEDE   5E 49 4D 20 B2         DB   5EH,49H,4DH,20H,0B2H   ;IM 2
EEE3   5F 4C 44 20 41 2C D2   DB   5FH,4CH,44H,20H,41H,2CH,0D2H   ;LD A,R
EEEA   67 52 52 C4            DB   67H,52H,52H,0C4H   ;RRD
EEEE   6F 52 4C C4            DB   6FH,52H,4CH,0C4H   ;RLD
EEF2   A0 4C 44 C9            DB   0A0H,4CH,44H,0C9H   ;LDI
EEF6   A1 43 50 C9            DB   0A1H,43H,50H,0C9H   ;CPI
EEFA   A2 49 4E C9            DB   0A2H,49H,4EH,0C9H   ;INI
EEFE   A3 4F 55 54 C9         DB   0A3H,4FH,55H,54H,0C9H   ;OUTI
EF03   A8 4C 44 C4            DB   0A8H,4CH,44H,0C4H   ;LDD
EF07   A9 43 50 C4            DB   0A9H,43H,50H,0C4H   ;CPD
EF0B   AA 49 4E C4            DB   0AAH,49H,4EH,0C4H   ;IND
EF0F   AB 4F 55 54 C4         DB   0ABH,4FH,55H,54H,0C4H   ;OUTD
EF14   B0 4C 44 49 D2         DB   0B0H,4CH,44H,49H,0D2H   ;LDIR
EF19   B1 43 50 49 D2         DB   0B1H,43H,50H,49H,0D2H   ;CPIR
EF1E   B2 49 4E 49 D2         DB   0B2H,49H,4EH,49H,0D2H   ;INIR
EF23   B3 4F 54 49 D2         DB   0B3H,4FH,54H,49H,0D2H   ;OTIR
EF28   B8 4C 44 44 D2         DB   0B8H,4CH,44H,44H,0D2H   ;LDDR
EF2D   B9 43 50 44 D2         DB   0B9H,43H,50H,44H,0D2H   ;CPDR
EF32   BA 49 4E 44 D2         DB   0BAH,49H,4EH,44H,0D2H   ;INDR
EF37   BB 4F 54 44 D2         DB   0BBH,4FH,54H,44H,0D2H   ;OTDR
EF3C                             ; 
EF3C                TABLEREG:      
EF3C   42 43                  DB   42H,43H   ;BC
EF3E   44 45                  DB   44H,45H   ;DE
EF40   48 4C                  DB   48H,4CH   ;HL
EF42   2C 41                  DB   2CH,41H   ;,A
EF44   28 48 4C 29            DB   28H,48H,4CH,29H   ;(HL)
EF48   28 49 58 2B 20 1F 29   DB   28H,49H,58H,2BH,20H,1FH,29H   ;(IX+__)
EF4F   28 49 59 2B 20 1F 29   DB   28H,49H,59H,2BH,20H,1FH,29H   ;(IY+__)
EF56                             ; 
EF56                TABLESREG:      
EF56   42                     DB   42H   ;B
EF57   43                     DB   43H   ;C
EF58   44                     DB   44H   ;D
EF59   45                     DB   45H   ;E
EF5A   48                     DB   48H   ;H
EF5B   4C                     DB   4CH   ;L
EF5C   53                     DB   53H   ;S
EF5D   50                     DB   50H   ;P
EF5E   28 43 29               DB   28H,43H,29H   ;(C)
EF61                             ; 
EF61   FF FF FF FF FF FF FF FF FF FF DB   0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH,0FFH   ;FILL
EF6B                             ;Sound and Music Routine.
EF6B                             ;------------------------
EF6B                             ; Based on Mon1 routine by J. Hardy and modified to work at 4Mhz
EF6B                             ; By B. Chiha
EF6B                             ; This routine will play a series of notes based on data in memory
EF6B                             ; To play a note use a reference between 01H and 18H.  Where
EF6B                             ; 01H is the lowest and 18h is the highest.  Use 00H to make a pause
EF6B                             ; and any value greater then 18H to exit.
EF6B                             ; 
EF6B                             ; Note reference table is as follows:
EF6B                             ; +-----------+
EF6B                             ; |  G  | 01H |
EF6B                             ; |  G# | 02H |     Exit = 1FH
EF6B                             ; |  A  | 03H |
EF6B                             ; |  A# | 04H |
EF6B                             ; |  B  | 05H |
EF6B                             ; |  C  | 06H |
EF6B                             ; |  C# | 07H |
EF6B                             ; |  D  | 08H |
EF6B                             ; |  D# | 09H |
EF6B                             ; |  E  | 0AH |
EF6B                             ; |  F  | 0BH |
EF6B                             ; |  F# | 0CH |
EF6B                             ; |  G  | 0DH |
EF6B                             ; |  G# | 0EH |
EF6B                             ; |  A  | 0FH |
EF6B                             ; |  A# | 10H |
EF6B                             ; |  B  | 11H |
EF6B                             ; |  C  | 12H |
EF6B                             ; |  C# | 13H |
EF6B                             ; |  D  | 14H |
EF6B                             ; |  D# | 15H |
EF6B                             ; |  E  | 16H |
EF6B                             ; |  F  | 17H |
EF6B                             ; |  F# | 18H |
EF6B                             ; +-----------+
EF6B                PLAYTUNEMENU:      
EF6B   21 F5 EF               LD   hl,tuneParams   ;get tune parameters
EF6E   CD BD CF               CALL   paramDriver   ;collect parameters
EF71   ED 5B C0 08            LD   de,(DATA_FROM)   ;get start address
EF75                PLAYTUNE:      
EF75   1A                     LD   a,(de)   ;put note index in A
EF76   13                     INC   de   ;move to next note
EF77   FE 19                  CP   19H   ;is it of of range?
EF79   D0                     RET   nc   ;exit if it is
EF7A   B7                     OR   a   ;is it a pause?
EF7B   28 19                  JR   z,tunePause   ;yes, do a pause
EF7D   21 C5 EF               LD   hl,FREQ_TABLE   ;load HL with frequency table
EF80   3D                     DEC   a   ;fix indexing
EF81   87                     ADD   a,a   ;double A
EF82   85                     ADD   a,l   ;index HL
EF83   6F                     LD   l,a   ;and
EF84   3E 00                  LD   a,0   ;ensure
EF86   8C                     ADC   a,h   ;H is set
EF87   67                     LD   h,a   ;correctly
EF88   7E                     LD   a,(hl)   ;get wavelength
EF89   C5                     PUSH   bc   ;save BC
EF8A   47                     LD   b,a   
EF8B   23                     INC   hl   
EF8C   7E                     LD   a,(hl)   ;get frequency
EF8D   6F                     LD   l,a   ;set HL = A
EF8E   26 00                  LD   h,0   
EF90   CD A7 EF               CALL   playNote   ;play the tone
EF93   C1                     POP   bc   ;restore BC
EF94   18 DF                  JR   playTune   ;play next note
EF96                TUNEPAUSE:      
EF96   E5                     PUSH   hl   ;save HL
EF97   21 00 20               LD   hl,2000h   ;some time delay
EF9A   D5                     PUSH   de   ;save DE
EF9B   11 01 00               LD   de,1   ;load DE with 1
EF9E   ED 52                  SBC   hl,de   ;subtract 1 from HL
EFA0   D2 9E EF               JP   nc,$-2   ;repeat subtraction until HL=0
EFA3   D1                     POP   de   ;restore DE
EFA4   E1                     POP   hl   ;restore HL
EFA5   18 CE                  JR   playTune   ;play next note
EFA7                             ; Play a note.  Play a note with a given frequency and wavelength
EFA7                             ; Input: HL = frequency (01-7F)
EFA7                             ;        B = wavelength (00-FF)
EFA7                             ; Destroys: HL, BC, A
EFA7                PLAYNOTE:      
EFA7   29                     ADD   hl,hl   ;double HL
EFA8   29                     ADD   hl,hl   ;double again for 4Mhz
EFA9   AF                     XOR   a   ;clear A
EFAA   D5                     PUSH   de   ;save DE
EFAB   11 01 00               LD   de,1   ;set DE=1
EFAE   48                     LD   c,b   ;save wavelength
EFAF                NOTELOOP:      
EFAF   D3 01                  OUT   (DIGITS),a   ;toggle speaker bit
EFB1   06 03                  LD   b,3   ;elongate wavelength
EFB3   C5                     PUSH   bc   ;save BC
EFB4   41                     LD   b,c   ;get wavelength
EFB5   10 FE                  DJNZ   $   ;loop for wavelength
EFB7   C1                     POP   bc   ;restore BC
EFB8   10 F9                  DJNZ   $-5   ;loop 3 times
EFBA   EE 80                  XOR   80H   ;invert bit 7 of A (speaker bit)
EFBC   ED 52                  SBC   hl,de   ;HL = HL - 1
EFBE   20 EF                  JR   nz,noteLoop   ;repeat for frequency
EFC0   D1                     POP   de   ;restore DE
EFC1   AF                     XOR   a   ;clear a
EFC2   D3 01                  OUT   (DIGITS),a   ;clear speaker bit
EFC4   C9                     RET      
EFC5                             ; frequency table, contains wavelength and frequency combined sequentially
EFC5                FREQ_TABLE:      
EFC5   8C 19 83 1A 7C 1C 75 1D DB   8CH,19H,83H,1AH,7CH,1CH,75H,1DH   
EFCD   70 1E 67 20 62 23 5C 25 DB   70H,1EH,67H,20H,62H,23H,5CH,25H   
EFD5   57 27 52 29 4E 2C 48 2E DB   57H,27H,52H,29H,4EH,2CH,48H,2EH   
EFDD   45 31 41 33 3C 37 39 3A DB   45H,31H,41H,33H,3CH,37H,39H,3AH   
EFE5   36 3D 32 41 2F 45 2C 49 DB   36H,3DH,32H,41H,2FH,45H,2CH,49H   
EFED   2A 4D 27 52 25 57 23 5C DB   2AH,4DH,27H,52H,25H,57H,23H,5CH   
EFF5                TUNEPARAMS:      
EFF5   01                     DB   1   ;Three parameters
EFF6   54 55 4E 45 20 20      DB   "TUNE  "   ;7seg text
EFFC   3D 20 45 6E 74 65 72 20 50 61 72 61 6D 65 74 65 72 73 20 3D 00 DB   "= Enter Parameters =",0   ;Parameter title
F011   53 74 61 72 74 20 41 64 64 72 65 73 73 3A 00 DB   "Start Address:",0   ;Text and Address
F020   C0 08                  DW   DATA_FROM   
F022                             ;Command block registers
F022                PATA_ADDR:   EQU   20H   ; Base address A5
F022                REG_DATA:   EQU   PATA_ADDR+000B   ;Data Register
F022                REG_ERR:   EQU   PATA_ADDR+001B   ;Read: Error
F022                REG_FR:   EQU   PATA_ADDR+001B   ;Write: Features
F022                REG_SC:   EQU   PATA_ADDR+010B   ;Sector Count
F022                REG_SN:   EQU   PATA_ADDR+011B   ;Sector Number
F022                REG_LBA7:   EQU   PATA_ADDR+011B   ;LBA Bits 0-7
F022                REG_CYLO:   EQU   PATA_ADDR+100B   ;Cylinder Low
F022                REG_LBA15:   EQU   PATA_ADDR+100B   ;LBA Bits 8-15
F022                REG_CYHI:   EQU   PATA_ADDR+101B   ;Cylinder High
F022                REG_LBA23:   EQU   PATA_ADDR+101B   ;LBA Bits 16-23
F022                REG_DH:   EQU   PATA_ADDR+110B   ;Drive/Head
F022                REG_LBA27:   EQU   PATA_ADDR+110B   ;LBA Bits 24-27
F022                REG_STATUS:   EQU   PATA_ADDR+111B   ;Read: Status
F022                REG_CMD:   EQU   PATA_ADDR+111B   ;Write: Command
F022                REG_DATA_HI:   EQU   PATA_ADDR+1000B   ;Data Register High Byte
F022                             ;Status flags (bits)
F022                F_BSY:    EQU   7   ;Drive busy
F022                F_DRDY:   EQU   6   ;Drive ready for command
F022                F_DSC:    EQU   4   ;Drive head settled over sector
F022                F_DRQ:    EQU   3   ;Drive ready for r/w
F022                F_ERR:    EQU   1   ;Drive error
F022                             ;Features flags
F022                F_ENA8BIT:   EQU   01H   ;Enable 8-bit mode
F022                F_DIS8BIT:   EQU   81H   ;Disable 8-bit mode
F022                             ;Drive commands
F022                CMD_INITPAR:   EQU   091H   ;Init drive parameters
F022                CMD_READ:   EQU   020H   ;Read sector w. retry
F022                CMD_WRITE:   EQU   030H   ;Write sector w. retry
F022                CMD_IDENTIFY:   EQU   0ECH   ;Identify device
F022                CMD_SETFR:   EQU   0EFH   ;Set Features
F022                CMD_DIAG:   EQU   090H   ;Drive diagnosis
F022                             ;Constants
F022                C_RETRIES:   EQU   0FFH   ;Number of retries for busy disk
F022                C_FILENO:   EQU   0897H   ;Address of File number menu selection
F022                C_MCB:    EQU   0888H   ;Master Control Block
F022                C_SERIDLE:   EQU   00000101B   ;Serial Idle state
F022                C_SERCS:   EQU   11111011B   ;Serial Chip Select state
F022                             ;MON3 API Calls
F022                API_STR2LCD:   EQU   0DH   ;string to LCD
F022                API_CHR2LCD:   EQU   0EH   ;character to LCD
F022                API_CMD2LCD:   EQU   0FH   ;command to LCD
F022                API_MENU:   EQU   1FH   ;menu driver
F022                API_PARAM:   EQU   20H   ;parameter driver
F022                API_MENUPOP:   EQU   2FH   ;menu pop
F022                             ;RAM Locations
F022                HIGH_RAM:   EQU   0800H   ;High RAM
F022                DISK_BUFF:   EQU   HIGH_RAM - 200H   ;Disk data buffer (512 bytes)
F022                             ;FAT32 Configuration data
F022                DATA_START:   EQU   DISK_BUFF - 4   ;Data start sector
F022                ROOT_CLUS:   EQU   DATA_START - 4   ;Cluster number of the Root Directory / File
F022                ROOT_START:   EQU   ROOT_CLUS - 4   ;Root directory start sector
F022                FAT_START:   EQU   ROOT_START - 4   ;Start sector to first FAT
F022                PART_START:   EQU   FAT_START - 4   ;First sector of partition
F022                FAT_COUNT:   EQU   PART_START - 1   ;Number of FATs
F022                FAT_SIZE:   EQU   FAT_COUNT - 4   ;FAT size in sectors
F022                RSVD_SEC:   EQU   FAT_SIZE - 2   ;Number of reserved sectors
F022                CLUS_SEC:   EQU   RSVD_SEC - 1   ;Size of a cluster (in sectors)
F022                VOL_LABEL:   EQU   CLUS_SEC - 11   ;Name of Volume Label
F022                             ;File Control Block
F022                FCB_NAME:   EQU   VOL_LABEL - 12   ;File Name
F022                FCB_NSEC:   EQU   FCB_NAME - 4   ;Next sector
F022                FCB_ADDR:   EQU   FCB_NSEC - 2   ;TEC Address of file
F022                FCB_SCNT:   EQU   FCB_ADDR - 1   ;Sector counter
F022                             ;SD Card Read/Write Command
F022                SD_CMD:   EQU   FCB_SCNT - 6   ;SD Read Command
F022                             ;Root File clusters (4 bytes) and file size (2 bytes)
F022                RFC_LIST:   EQU   SD_CMD - 400   ;Root file cluster / file size list (8 bytes / file)
F022                             ;Directory Configuration, Max entries = (886 - 27 ) / 15 = 49 MAX
F022                DIR_CFG:   EQU   RFC_LIST - 816   ;100H
F022                LOADFROMDISK:      
F022   CD 2C F0               CALL   initDisk   ;Mount and get Root Directory
F025   21 00 01               LD   hl,DIR_CFG   
F028   0E 1F                  LD   c,API_MENU   ;menu driver
F02A   D7                     RST   10H   ;mon3 API Call
F02B   C9                     RET      
F02C                INITDISK:      
F02C                             ;mount the volume and display the root directory
F02C                             ;check for SD and if present, initialize it
F02C   3A 88 08               LD   a,(C_MCB)   ;Get MCB
F02F   E6 80                  AND   MCB_SD_CARD   ;Check if Bit 7 set?
F031   C4 03 F8               CALL   nz,initSD   ;yes, init SD Card
F034   CD 8B F1               CALL   FATmount   ;Mount the Drive
F037   CD 96 F2               CALL   FATgetRootDir   ;List root directory
F03A   C9                     RET      
F03B                INITPATA1:      
F03B   CD 3F F0               CALL   waitBusy   ;Wait for Busy flag to clear
F03E                             ; ld a,F_ENA8BIT              ;Features register 8 bit mode
F03E                             ; out (REG_FR),a
F03E                             ; ld a,CMD_SETFR              ;Send set features command
F03E                             ; out (REG_CMD),a
F03E                             ; call waitDriveReady         ;Wait for Busy flag to clear
F03E   C9                     RET      
F03F                             ;wait until busy flag is unset
F03F                             ;return:  carry not set = device is ready
F03F                             ;         carry set = device timeout
F03F                             ;         A = error register if carry is set (could be zero if just a time out)
F03F                             ;         HL = error message if carry is set
F03F                WAITBUSY:      
F03F   C5                     PUSH   bc   ;save BC
F040   A7                     AND   a   ;clear carry flag
F041   06 FF                  LD   b,C_RETRIES   ;number of retries to timeout
F043                WAITLOOP1:      
F043   DB 27                  IN   a,(REG_STATUS)   ;Read Status register
F045   E6 C1                  AND   11000001B   ;Only bits 7,6 and 0 are needed
F047   EE 40                  XOR   01000000B   ;Flip disk ready bit
F049   28 13                  JR   z,waitExit   ;all good, just exit
F04B   0E 00                  LD   c,0   ;sub delay
F04D                WAITLOOP2:      
F04D   0D                     DEC   c   ;mini loop
F04E   20 FD                  JR   nz,waitLoop2   
F050   10 F1                  DJNZ   waitLoop1   
F052   37                     SCF      ;error if here
F053   21 B0 F8               LD   hl,MSG_TIMEOUT   
F056   CB 47                  BIT   0,a   ;check if error bit set
F058   3E 00                  LD   a,0   ;default to zero
F05A   28 02                  JR   z,waitExit   ;no error bit set, just exit
F05C   DB 21                  IN   a,(REG_ERR)   ;get error register
F05E                WAITEXIT:      
F05E   C1                     POP   bc   ;restore BC
F05F   C9                     RET      
F060                             ;wait for data request to be set.  Meaning data is ready to be sent/received
F060                             ;return:  carry not set = data requested
F060                             ;         carry set = not data requested (error)
F060                             ;         A = error register if carry is set (could be zero if just a no data request)
F060                             ;         HL = error message if carry is set
F060                WAITDATAREQUEST:      
F060   C5                     PUSH   bc   ;save BC
F061   A7                     AND   a   ;clear carry flag
F062   01 FF FF               LD   bc,C_RETRIES * 256 + C_RETRIES   ;mega delay as drive head could take a time
F065                WAITDRLOOP1:      
F065   DB 27                  IN   a,(REG_STATUS)   ;Read Status register
F067   CB 5F                  BIT   3,a   ;check data request bit
F069   20 11                  JR   nz,waitDRExit   ;its set, all good
F06B   0B                     DEC   bc   ;mini loop
F06C   79                     LD   a,c   
F06D   B0                     OR   b   
F06E   20 F5                  JR   nz,waitDRLoop1   
F070   37                     SCF      ;error if here
F071   21 BE F8               LD   hl,MSG_DRQST   
F074   CB 47                  BIT   0,a   ;check if error bit set
F076   3E 00                  LD   a,0   ;default to zero
F078   28 02                  JR   z,waitDRExit   ;no error bit set, just exit
F07A   DB 21                  IN   a,(REG_ERR)   ;get error register
F07C                WAITDREXIT:      
F07C   C1                     POP   bc   ;restore BC
F07D   C9                     RET      
F07E                             ;read a sector from the disk and store in data buffer pointed from HL
F07E                             ;Input: BCDE = LBA sector address 3,2,1 and 0
F07E                             ;       HL = Address of data buffer (512 bytes)
F07E                             ;Output:  carry not set = data read
F07E                             ;         carry set = data not read (error)
F07E                IDEREADSECTOR:      
F07E   C5                     PUSH   bc   ;save BC
F07F   E5                     PUSH   hl   ;save HL
F080   D5                     PUSH   de   ;save DE
F081   3A 88 08               LD   a,(C_MCB)   ;Get MCB
F084   E6 80                  AND   MCB_SD_CARD   ;Check if Bit 7 set?
F086   28 2E                  JR   z,readPATA   ;no, read PATA
F088                             ;read from SD card as its present
F088   3E 01                  LD   a,1   
F08A   32 C5 05               LD   (SD_CMD+5),a   ;set return
F08D   EB                     EX   de,hl   ;swap DE and HL
F08E   7D                     LD   a,l   ;LBA 0
F08F   32 C4 05               LD   (SD_CMD+4),a   ;set LBA 0-7
F092   7C                     LD   a,h   ;LBA 1
F093   32 C3 05               LD   (SD_CMD+3),a   ;set LBA 8-15
F096   79                     LD   a,c   ;LBA 2
F097   32 C2 05               LD   (SD_CMD+2),a   ;set LBA 16-23
F09A   78                     LD   a,b   ;LBA 3
F09B   32 C1 05               LD   (SD_CMD+1),a   ;set LBA 24-27
F09E   3A A1 F9               LD   a,(spiCMD17)   ;Read command
F0A1   32 C0 05               LD   (SD_CMD),a   ;set command id
F0A4   21 C0 05               LD   hl,SD_CMD   ;Read command
F0A7   CD 9B F7               CALL   sendSPICommand   
F0AA   B7                     OR   a   
F0AB   21 FB F8               LD   hl,MSG_BPB   
F0AE   20 2C                  JR   nz,doERR   ;error
F0B0   EB                     EX   de,hl   ;swap DE and HL
F0B1   CD BC F7               CALL   readSPIBlock   
F0B4   18 22                  JR   rsExit   ;exit cleanly
F0B6                             ;read from PATA drive
F0B6                READPATA:      
F0B6   CD 3F F0               CALL   waitBusy   ;is the drive ready?
F0B9   38 21                  JR   c,doERR   ;no, error
F0BB   CD 5F F1               CALL   setLBA   ;set up LBA
F0BE   CD 3F F0               CALL   waitBusy   ;is the drive ready?
F0C1   38 19                  JR   c,doERR   ;no, error
F0C3   3E 20                  LD   a,CMD_READ   ;set read command
F0C5   D3 27                  OUT   (REG_CMD),a   
F0C7   CD 60 F0               CALL   waitDataRequest   ;Is the drive ready to send data?
F0CA   38 10                  JR   c,doERR   ;no, error
F0CC   06 00                  LD   b,0   ;256 words (512 bytes)
F0CE                RSLOOP:      
F0CE   DB 20                  IN   a,(REG_DATA)   ;get low byte of ide data word first	
F0D0   77                     LD   (hl),a   ;store low byte
F0D1   23                     INC   hl   
F0D2   DB 28                  IN   a,(REG_DATA_HI)   ;get high byte of ide data word from latch
F0D4   77                     LD   (hl),a   
F0D5   23                     INC   hl   
F0D6   10 F6                  DJNZ   rsloop   
F0D8                RSEXIT:      
F0D8   D1                     POP   de   ;restore DE
F0D9   E1                     POP   hl   ;restore HL
F0DA   C1                     POP   bc   ;restore BC
F0DB   C9                     RET      
F0DC                             ;general error output routine.
F0DC                             ;Input: HL = address of ASCII string
F0DC                             ;       A = error register
F0DC                DOERR:       
F0DC   06 01                  LD   b,01H   ;clear LCD
F0DE   0E 0F                  LD   c,API_CMD2LCD   ;command to LCD
F0E0   D7                     RST   10H   ;mon3 API Call
F0E1   F5                     PUSH   af   ;save error register
F0E2   E5                     PUSH   hl   ;save error message
F0E3   21 CE F8               LD   hl,MSG_IOERR   ;set read message
F0E6   0E 0D                  LD   c,API_STR2LCD   ;string to LCD
F0E8   D7                     RST   10H   ;mon3 API Cal
F0E9   06 C0                  LD   b,0C0H   ;second row
F0EB   0E 0F                  LD   c,API_CMD2LCD   ;command to LCD
F0ED   D7                     RST   10H   ;mon3 API Call
F0EE   E1                     POP   hl   
F0EF   0E 0D                  LD   c,API_STR2LCD   ;string to LCD
F0F1   D7                     RST   10H   ;mon3 API Cal
F0F2   F1                     POP   af   ;restore error register
F0F3   CD 76 F1               CALL   AtoLCD   ;display error register
F0F6   CF                     RST   08H   ;wait for key press
F0F7   37                     SCF      ;set carry for error
F0F8   D1                     POP   de   ;restore DE
F0F9   E1                     POP   hl   ;restore HL
F0FA   C1                     POP   bc   ;restore BC
F0FB   C7                     RST   00H   ;reboot
F0FC                             ;write a sector to the disk.
F0FC                             ;Input: BCDE = LBA sector address 3,2,1 and 0
F0FC                             ;       HL = Address of data buffer (512 bytes)
F0FC                             ;Output:  carry not set = data read
F0FC                             ;         carry set = data not read (error)
F0FC                IDEWRITESECTOR:      
F0FC   C5                     PUSH   bc   ;save BC
F0FD   E5                     PUSH   hl   ;save HL
F0FE   D5                     PUSH   de   ;save DE
F0FF   3A 88 08               LD   a,(C_MCB)   ;Get MCB
F102   E6 80                  AND   MCB_SD_CARD   ;Check if Bit 7 set?
F104   28 32                  JR   z,writePATA   ;no, write PATA
F106                             ;write to SD card as its present
F106   3E 01                  LD   a,1   
F108   32 C5 05               LD   (SD_CMD+5),a   ;set return
F10B   EB                     EX   de,hl   ;swap DE and HL
F10C   7D                     LD   a,l   ;LBA 0
F10D   32 C4 05               LD   (SD_CMD+4),a   ;set LBA 0-7
F110   7C                     LD   a,h   ;LBA 1
F111   32 C3 05               LD   (SD_CMD+3),a   ;set LBA 8-15
F114   79                     LD   a,c   ;LBA 2
F115   32 C2 05               LD   (SD_CMD+2),a   ;set LBA 16-23
F118   78                     LD   a,b   ;LBA 3
F119   32 C1 05               LD   (SD_CMD+1),a   ;set LBA 24-27
F11C   3A A7 F9               LD   a,(spiCMD24)   ;Write command
F11F   32 C0 05               LD   (SD_CMD),a   ;set command id
F122   21 C0 05               LD   hl,SD_CMD   ;Write command
F125   CD 9B F7               CALL   sendSPICommand   
F128   B7                     OR   a   
F129   21 FB F8               LD   hl,MSG_BPB   
F12C   20 AE                  JR   nz,doERR   ;error
F12E   EB                     EX   de,hl   ;swap DE and HL
F12F   CD DB F7               CALL   writeSPIBlock   
F132   FE 05                  CP   05h   ;check if write was successful
F134   20 A6                  JR   nz,doERR   ;no, error
F136   18 A0                  JR   rsExit   ;exit cleanly
F138                WRITEPATA:      
F138   CD 3F F0               CALL   waitBusy   ;is the drive ready?
F13B   38 9F                  JR   c,doERR   ;no, error
F13D   CD 5F F1               CALL   setLBA   ;set up LBA
F140   CD 3F F0               CALL   waitBusy   ;is the drive ready?
F143   38 97                  JR   c,doERR   ;no, error
F145   3E 30                  LD   a,CMD_WRITE   ;set write command
F147   D3 27                  OUT   (REG_CMD),a   
F149   CD 60 F0               CALL   waitDataRequest   ;Is the drive ready to send data?
F14C   38 8E                  JR   c,doERR   ;no, error
F14E   06 00                  LD   b,0   ;256 words (512 bytes)
F150                WSLOOP1:      
F150   7E                     LD   a,(hl)   ;get low byte
F151   4F                     LD   c,a   ;store in C
F152   23                     INC   hl   
F153   7E                     LD   a,(hl)   ;get high byte
F154   D3 28                  OUT   (REG_DATA_HI),a   ;send high byte to latch
F156   79                     LD   a,c   ;get low byte in A
F157   D3 20                  OUT   (REG_DATA),a   ;send low byte and output entire word
F159   23                     INC   hl   
F15A   10 F4                  DJNZ   wsloop1   
F15C   C3 D8 F0               JP   rsExit   ;exit cleanly
F15F                             ;read disk information
F15F                             ;Input:   HL = Address of data buffer (512 bytes)
F15F                             ;Output:  carry not set = data read
F15F                             ;         carry set = data not read (error)
F15F                             ; IDEdiskInfo:
F15F                             ;         push bc                     ;save BC
F15F                             ;         push hl                     ;save HL
F15F                             ;         call waitBusy               ;is the drive ready?
F15F                             ;         jr c,doERR                  ;no, error
F15F                             ;         call setLBA                 ;set up LBA
F15F                             ;         call waitBusy               ;is the drive ready?
F15F                             ;         jr c,doERR                  ;no, error
F15F                             ;         ld a,CMD_IDENTIFY           ;set identify command
F15F                             ;         out (REG_CMD),a
F15F                             ;         call waitDataRequest        ;Is the drive ready to send data?
F15F                             ;         jr c,doERR                  ;no, error
F15F                             ;         ld b,0                      ;256 words (512 bytes)
F15F                             ; idloop:
F15F                             ;         in a,(REG_DATA)	            ;get low byte of ide data word first
F15F                             ;         ld c,a                      ;store in C	
F15F                             ;         in a,(REG_DATA_HI)          ;get high byte of ide data word from latch
F15F                             ;         ld (hl),a                   ;store low byte
F15F                             ;         inc hl
F15F                             ;         ld (hl),c
F15F                             ;         inc hl
F15F                             ;         djnz idloop
F15F                             ;         jr rsExit                   ;exit cleanly
F15F                             ; Set sector count and LBA registers of the drive
F15F                             ; Input: BCDE = LBA sector address 3,2,1 and 0
F15F                             ; Destory: None
F15F                SETLBA:      
F15F   F5                     PUSH   af   
F160                             ;sector count
F160   3E 01                  LD   a,01H   
F162   D3 22                  OUT   (REG_SC),a   ;set sector count
F164   7B                     LD   a,e   ;LBA 0
F165   D3 23                  OUT   (REG_LBA7),a   ;set LBA 0-7
F167   7A                     LD   a,d   ;LBA 1
F168   D3 24                  OUT   (REG_LBA15),a   ;set LBA 8-15
F16A   79                     LD   a,c   ;LBA 2
F16B   D3 25                  OUT   (REG_LBA23),a   ;set LBA 16-23
F16D   78                     LD   a,b   ;LBA 3
F16E   E6 0F                  AND   00001111B   ;only bits 0-3 are LBA 3
F170   F6 E0                  OR   11100000B   ;select LBA and master drive
F172   D3 26                  OUT   (REG_LBA27),a   ;set LBA 24-27
F174   F1                     POP   af   
F175   C9                     RET      
F176                             ;A to LCD.  Display register A to the LCD screen
F176                ATOLCD:      
F176   F5                     PUSH   af   ;save AF
F177   1F                     RRA      ;move high
F178   1F                     RRA      ;nibble to low nibble
F179   1F                     RRA      
F17A   1F                     RRA      
F17B   CD 7F F1               CALL   lowNibToString1   ;get lower nibble and save in DE
F17E   F1                     POP   af   ;restore AF
F17F                LOWNIBTOSTRING1:      
F17F   E6 0F                  AND   0FH   ;mask out high nibble
F181   C6 90                  ADD   a,90H   ;convert to
F183   27                     DAA      ;ASCII
F184   CE 40                  ADC   a,40H   ;using this
F186   27                     DAA      ;amazing routine
F187   0E 0E                  LD   c,API_CHR2LCD   ;character to LCD
F189   D7                     RST   10H   ;mon3 API Cal
F18A   C9                     RET      ;exit back
F18B                             ;Mount the Disk and configure the FAT data for IO
F18B                FATMOUNT:      
F18B                             ;get the Master Boot Record located at sector 0 of the disk
F18B   01 00 00               LD   bc,0000H   ;high lba
F18E   11 00 00               LD   de,0000H   ;low lba
F191   21 00 06               LD   hl,DISK_BUFF   ;allocate disk buffer
F194   CD 7E F0               CALL   IDEreadSector   ;get block
F197   DA 55 F2               JP   c,FATerror1   ;error
F19A                             ;check 55AAH on MBR trailer
F19A   3A FE 07               LD   a,(DISK_BUFF + 01FEH)   
F19D   FE 55                  CP   55H   
F19F   C2 5A F2               JP   nz,FATerror2   ;error
F1A2   3A FF 07               LD   a,(DISK_BUFF + 01FFH)   
F1A5   FE AA                  CP   0AAH   
F1A7   C2 5A F2               JP   nz,FATerror2   ;error
F1AA                             ;get partition start
F1AA   01 04 00               LD   bc,0004H   ;4 bytes
F1AD   21 C6 07               LD   hl,DISK_BUFF + 01C6H   ;source of partition 1
F1B0   11 EC 05               LD   de,PART_START   ;destination
F1B3   ED B0                  LDIR      ;copy it
F1B5                             ;read Bios Parameter Block (BPB)
F1B5   ED 4B EE 05            LD   bc,(PART_START + 2)   ;high lba
F1B9   ED 5B EC 05            LD   de,(PART_START)   ;low lba
F1BD   21 00 06               LD   hl,DISK_BUFF   ;allocate disk buffer
F1C0   CD 7E F0               CALL   IDEreadSector   ;get block
F1C3   DA 5F F2               JP   c,FATerror3   ;error
F1C6                             ;check Bytes per sector is 512
F1C6   3A 0B 06               LD   a,(DISK_BUFF + 0BH)   
F1C9   B7                     OR   a   ;zero
F1CA   C2 64 F2               JP   nz,FATerror4   ;error
F1CD   3A 0C 06               LD   a,(DISK_BUFF + 0CH)   
F1D0   FE 02                  CP   02H   
F1D2   C2 64 F2               JP   nz,FATerror4   ;error
F1D5                             ;get volume label
F1D5   01 11 00               LD   bc,0011H   ;1 bytes
F1D8   21 47 06               LD   hl,DISK_BUFF + 47H   ;source of volume lable
F1DB   11 D9 05               LD   de,VOL_LABEL   ;destination
F1DE   ED B0                  LDIR      ;copy it
F1E0                             ;get cluster size
F1E0   3A 0D 06               LD   a,(DISK_BUFF + 0DH)   
F1E3   32 E4 05               LD   (CLUS_SEC),a   
F1E6   32 C6 05               LD   (FCB_SCNT),a   ;and set it to sector count
F1E9                             ;get reserve sector count
F1E9   2A 0E 06               LD   hl,(DISK_BUFF + 0EH)   
F1EC   22 E5 05               LD   (RSVD_SEC),hl   
F1EF                             ;get Root Cluster
F1EF   01 04 00               LD   bc,0004H   ;4 bytes
F1F2   21 2C 06               LD   hl,DISK_BUFF + 2CH   ;source of RootClus
F1F5   11 F8 05               LD   de,ROOT_CLUS   ;destination
F1F8   ED B0                  LDIR      ;copy it
F1FA                             ;get FAT count
F1FA   3A 10 06               LD   a,(DISK_BUFF + 10H)   
F1FD   32 EB 05               LD   (FAT_COUNT),a   
F200                             ;get FAT size
F200   01 04 00               LD   bc,0004H   ;4 bytes
F203   21 24 06               LD   hl,DISK_BUFF + 24H   ;source of FATSz32
F206   11 E7 05               LD   de,FAT_SIZE   ;destination
F209   ED B0                  LDIR      ;copy it
F20B                             ;calculate FAT start
F20B   2A EC 05               LD   hl,(PART_START)   ;FAT START = PART START + RESERVED SECTORS
F20E   ED 4B E5 05            LD   bc,(RSVD_SEC)   
F212   09                     ADD   hl,bc   ;add lower parts together
F213   22 F0 05               LD   (FAT_START),hl   ;save to lower of fat start
F216   2A EE 05               LD   hl,(PART_START + 2)   
F219   01 00 00               LD   bc,0000H   ;upper part
F21C   ED 4A                  ADC   hl,bc   ;add high parts with carry together
F21E   22 F2 05               LD   (FAT_START + 2),hl   ;save to higher of fat start
F221                             ;calculate Data Start Sector = FAT_START + (FAT_COUNT * FAT_SIZE)
F221   3A EB 05               LD   a,(FAT_COUNT)   ;get number of FATs
F224   ED 5B E7 05            LD   de,(FAT_SIZE)   ;get lower byte
F228   ED 4B E9 05            LD   bc,(FAT_SIZE+2)   ;get upper byte
F22C   CD 3E FA               CALL   BCDEtimeA   ;get product
F22F   ED 5B F0 05            LD   de,(FAT_START)   
F233   ED 4B F2 05            LD   bc,(FAT_START+2)   ;get fat start
F237   DD 19                  ADD   ix,de   ;add lower word
F239   ED 4A                  ADC   hl,bc   ;add upper word
F23B   DD 22 FC 05            LD   (DATA_START),ix   ;save ROOT_START
F23F   22 FE 05               LD   (DATA_START+2),hl   
F242                             ;calculate Root Directory.  This is the Root Cluster
F242   ED 5B F8 05            LD   de,(ROOT_CLUS)   ;get root cluster number
F246   ED 4B FA 05            LD   bc,(ROOT_CLUS+2)   
F24A   CD AE F4               CALL   FATgetSector   ;get root cluster sector
F24D   DD 22 F4 05            LD   (ROOT_START),ix   ;save root directory
F251   22 F6 05               LD   (ROOT_START+2),hl   
F254   C9                     RET      
F255                FATERROR1:      
F255   21 DE F8               LD   hl,MSG_MBR   ;Master Boot Record
F258   18 37                  JR   FATerror   
F25A                FATERROR2:      
F25A   21 EE F8               LD   hl,MSG_MBR_BAD   ;MBR Illegal
F25D   18 32                  JR   FATerror   
F25F                FATERROR3:      
F25F   21 FB F8               LD   hl,MSG_BPB   ;BPB failure
F262   18 2D                  JR   FATerror   
F264                FATERROR4:      
F264   21 0A F9               LD   hl,MSG_BPS   ;Bytes per sector
F267   18 28                  JR   FATerror   
F269                FATERROR5:      
F269   21 1A F9               LD   hl,MSG_ROOT   ;Root dir error
F26C   18 23                  JR   FATerror   
F26E                FATERROR6:      
F26E   21 29 F9               LD   hl,MSG_FILE   ;File not found
F271   18 1E                  JR   FATerror   
F273                FATERROR7:      
F273   21 39 F9               LD   hl,MSG_INTEL   ;Bad Checksum
F276   18 19                  JR   FATerror   
F278                FATERROR8:      
F278   21 47 F9               LD   hl,MSG_NOSDCARD   ;No SD Card
F27B   18 14                  JR   FATerror   
F27D                FATERROR9:      
F27D   21 53 F9               LD   hl,MSG_OCR   ;OCR Read Fail
F280   18 0F                  JR   FATerror   
F282                FATERROR10:      
F282   21 62 F9               LD   hl,MSG_SDINVALID   ;Invalid SDCard
F285   18 0A                  JR   FATerror   
F287                FATERROR11:      
F287   21 72 F9               LD   hl,MSG_SDCMD16   ;CMD16 Failed
F28A   18 05                  JR   FATerror   
F28C                FATERROR12:      
F28C   21 80 F9               LD   hl,MSG_TOOBIG   ;Address too large
F28F   18 00                  JR   FATerror   
F291                FATERROR:      
F291   C5                     PUSH   bc   ;save BC
F292   E5                     PUSH   hl   ;save HL
F293   C3 DC F0               JP   doERR   ;display the error
F296                             ;Get the root directory.  Only look at visiable, short name files.  Fill out
F296                             ;menu data structure with directory listing
F296                FATGETROOTDIR:      
F296                             ;create menu configuration
F296   11 00 01               LD   de,DIR_CFG   ;get menu config
F299   AF                     XOR   a   ;clear count
F29A   12                     LD   (de),a   
F29B   13                     INC   de   
F29C   21 6A F3               LD   hl,MENU_SEG   ;get menu segments
F29F   01 0E 00               LD   bc,14   
F2A2   ED B0                  LDIR      ;copy segment/menu text
F2A4   21 D9 05               LD   hl,VOL_LABEL   ;get volumen label
F2A7   01 0B 00               LD   bc,11   
F2AA   ED B0                  LDIR      
F2AC   AF                     XOR   a   
F2AD   12                     LD   (de),a   ;zero terminate string
F2AE   13                     INC   de   
F2AF   D5                     PUSH   de   
F2B0                             ;iterate through the 32 byte directory enties, and single out visable short files
F2B0   21 00 06               LD   hl,DISK_BUFF   
F2B3   ED 5B F4 05            LD   de,(ROOT_START)   
F2B7   ED 4B F6 05            LD   bc,(ROOT_START+2)   
F2BB   CD 8B F4               CALL   FATreadSector   
F2BE   DD 21 E0 05            LD   ix,DISK_BUFF-32   ;start of diretory buffer
F2C2   D1                     POP   de   
F2C3                DIRLOOP:      
F2C3   D5                     PUSH   de   
F2C4   01 20 00               LD   bc,32   ;skip to next directory entry (32 bytes)
F2C7   DD 09                  ADD   ix,bc   
F2C9   21 00 08               LD   hl,HIGH_RAM   ;check if end of sector
F2CC   B7                     OR   a   ;clear carry
F2CD   DD E5                  PUSH   ix   
F2CF   C1                     POP   bc   
F2D0   ED 42                  SBC   hl,bc   
F2D2   20 12                  JR   nz,skipLoadNextSec   
F2D4                             ;load next sector
F2D4   21 00 06               LD   hl,DISK_BUFF   
F2D7   ED 5B C9 05            LD   de,(FCB_NSEC)   
F2DB   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F2DF   CD 8B F4               CALL   FATreadSector   
F2E2   DD 21 00 06            LD   ix,DISK_BUFF   ;start of new diretory sector
F2E6                SKIPLOADNEXTSEC:      
F2E6   D1                     POP   de   
F2E7   DD 7E 00               LD   a,(ix+0)   ;check first character
F2EA   FE 00                  CP   00H   ;is it end of directory listing?
F2EC   C8                     RET   z   ;yes, all done, exit
F2ED   FE E5                  CP   0E5H   ;is it a deleted file?
F2EF   28 D2                  JR   z,dirLoop   ;ignore
F2F1   DD 7E 0B               LD   a,(ix+11)   ;get attribute byte
F2F4   FE 20                  CP   20H   ;must be ATTR_ARCHIVE only
F2F6   20 CB                  JR   nz,dirLoop   ;ignore if otherwise
F2F8                             ;good file, copy it to menu configuration
F2F8   01 08 00               LD   bc,8   ;get main part of file name
F2FB   DD E5                  PUSH   ix   
F2FD   E1                     POP   hl   
F2FE                SPACELOOP:      
F2FE   7E                     LD   a,(hl)   ;get character
F2FF   FE 20                  CP   " "   ;is it a space?
F301   28 05                  JR   z,mainDone   
F303   ED A0                  LDI      
F305   EA FE F2               JP   pe,spaceLoop   
F308                MAINDONE:      
F308   09                     ADD   hl,bc   ;move hl to correct position
F309   3E 2E                  LD   a,"."   ;separate with a dot
F30B   12                     LD   (de),a   ;zero terminate string
F30C   13                     INC   de   
F30D   01 03 00               LD   bc,3   ;get extension part of file name
F310                EXTLOOP:      
F310   7E                     LD   a,(hl)   ;get first character
F311   FE 20                  CP   " "   ;is it a space?
F313   28 05                  JR   z,extDone   ;yes, no extension
F315   ED A0                  LDI      
F317   EA 10 F3               JP   pe,extLoop   ;no, copy extension
F31A                EXTDONE:      
F31A   AF                     XOR   a   
F31B   12                     LD   (de),a   ;zero terminate string
F31C   13                     INC   de   
F31D   01 78 F3               LD   bc,FATfileLoader   ;get address of function
F320   79                     LD   a,c   
F321   12                     LD   (de),a   
F322   13                     INC   de   
F323   78                     LD   a,b   
F324   12                     LD   (de),a   ;store it in menu config
F325   13                     INC   de   
F326   3A 00 01               LD   a,(DIR_CFG)   ;get menu count
F329   F5                     PUSH   af   ;store menu count
F32A                             ;store cluster number and file size
F32A   21 30 04               LD   hl,RFC_LIST   
F32D   4F                     LD   c,a   
F32E   06 00                  LD   b,0   ;clear B
F330                             ;calculate index to RFC_LIST
F330   B7                     OR   a   ;clear carry
F331   CB 11                  RL   c   ;x2
F333   CB 11                  RL   c   ;x4
F335   CB 11                  RL   c   ;x8
F337   30 01                  JR   nc,$+3   
F339   04                     INC   b   ;add 1 if carry set
F33A   09                     ADD   hl,bc   ;add to RFC_LIST
F33B   DD 7E 1A               LD   a,(ix+26)   ;First cluster low word
F33E   77                     LD   (hl),a   
F33F   23                     INC   hl   
F340   DD 7E 1B               LD   a,(ix+27)   ;First cluster low word
F343   77                     LD   (hl),a   
F344   23                     INC   hl   
F345   DD 7E 14               LD   a,(ix+20)   ;First cluster high word
F348   77                     LD   (hl),a   
F349   23                     INC   hl   
F34A   DD 7E 15               LD   a,(ix+21)   ;First cluster high word
F34D   77                     LD   (hl),a   
F34E   23                     INC   hl   
F34F   DD 7E 1C               LD   a,(ix+28)   ;File size low word
F352   77                     LD   (hl),a   
F353   23                     INC   hl   
F354   DD 7E 1D               LD   a,(ix+29)   ;File size low word
F357   77                     LD   (hl),a   
F358   23                     INC   hl   
F359   DD 7E 1E               LD   a,(ix+30)   ;File size high word
F35C   77                     LD   (hl),a   
F35D   23                     INC   hl   
F35E   DD 7E 1F               LD   a,(ix+31)   ;File size high word
F361   77                     LD   (hl),a   
F362   F1                     POP   af   ;restore menu count
F363   3C                     INC   a   
F364   32 00 01               LD   (DIR_CFG),a   ;save menu count
F367   C3 C3 F2               JP   dirLoop   ;repeat
F36A   4C 4F 41 44 2D 2D 56 6F 6C 75 6D 65 3A 20 MENU_SEG:   DB   "LOAD--Volume: "   
F378                             ;Load a file from menu.  First get the file number in the menu.  Use this
F378                             ;to index the RFC_LIST to get the file cluster and file size.  Save file name
F378                             ;to FCB_NAME and Finally, ask for an address to load to and load the cluster to
F378                             ;that address
F378                FATFILELOADER:      
F378                             ;get file name
F378   CD 31 F5               CALL   saveFileName   ;save the file name to FCB_NAME
F37B                             ;see if its an Intel Hex File *.hex extension
F37B   21 CD 05               LD   hl,FCB_NAME   ;name of file
F37E   01 09 00               LD   bc,9   ;up to 9 chars for file name
F381   3E 2E                  LD   a,"."   ;file extension separator
F383   ED B1                  CPIR      ;move hl to extension
F385   11 F1 F3               LD   de,HEX_EXT   
F388                             ;check extension for .hex
F388   CD 7F F6               CALL   cpstr   ;compare file extension
F38B   28 5A                  JR   z,HEXfile   ;its a hex file, load as intel hex file
F38D                             ;Load file as binary
F38D                             ;get save address via parameter driver
F38D   3A 97 08               LD   a,(C_FILENO)   ;map to mon3 Menu data for selected menu entry
F390   F5                     PUSH   af   ;save file number
F391   21 BF F9               LD   hl,LOAD_CFG   ;load parameter configuration
F394   0E 20                  LD   c,API_PARAM   ;parameter driver
F396   D7                     RST   10H   ;mon3 API Call
F397   F1                     POP   af   
F398                             ;get cluster from RFC_LIST
F398   32 97 08               LD   (C_FILENO),a   ;map to mon3 Menu data for selected menu entry
F39B   CD 63 F5               CALL   getFirstCluster   ;get first cluster of file selected
F39E   DD E5                  PUSH   ix   ;save file size
F3A0   CD AE F4               CALL   FATgetSector   ;get sector of cluster
F3A3   21 00 06               LD   hl,DISK_BUFF   
F3A6   ED 5B C9 05            LD   de,(FCB_NSEC)   
F3AA   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F3AE   CD 8B F4               CALL   FATreadSector   ;read sector of file
F3B1                             ;keep going until all bytes are copied.
F3B1   DD 21 00 08            LD   ix,HIGH_RAM   ;end of sector
F3B5   C1                     POP   bc   ;get file size
F3B6   21 00 06               LD   hl,DISK_BUFF   ;source
F3B9   ED 5B C7 05            LD   de,(FCB_ADDR)   ;destination
F3BD                FILECOPYLOOP:      
F3BD   ED A0                  LDI      
F3BF   E2 ED F3               JP   po,fileLoaded   ;no data left
F3C2   7A                     LD   a,d   ;check for max address 0x0000
F3C3   B3                     OR   e   
F3C4   28 27                  JR   z,fileLoaded   
F3C6   DD 7D                  LD   a,ixl   
F3C8   BD                     CP   l   
F3C9   20 F2                  JR   nz,fileCopyLoop   ;check if next sector needed
F3CB   DD 7C                  LD   a,ixh   
F3CD   BC                     CP   h   
F3CE   20 ED                  JR   nz,fileCopyLoop   ;check if next sector needed
F3D0                             ;load next sector
F3D0   C5                     PUSH   bc   
F3D1   D5                     PUSH   de   
F3D2   21 00 06               LD   hl,DISK_BUFF   
F3D5   ED 5B C9 05            LD   de,(FCB_NSEC)   
F3D9   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F3DD   CD 8B F4               CALL   FATreadSector   
F3E0   21 00 06               LD   hl,DISK_BUFF   ;source
F3E3   D1                     POP   de   
F3E4   C1                     POP   bc   
F3E5   18 D6                  JR   fileCopyLoop   
F3E7                HEXFILE:      
F3E7                             ;must be hex file
F3E7   CD F5 F3               CALL   loadHEX   ;load intel hex file
F3EA   C2 73 F2               JP   nz,FATerror7   ;error
F3ED                FILELOADED:      
F3ED                             ;pop menu off
F3ED   0E 2F                  LD   c,API_MENUPOP   ;menu pop off
F3EF   D7                     RST   10H   ;mon3 API Call
F3F0   C9                     RET      
F3F1   48 45 58 00  HEX_EXT:   DB   "HEX",0   
F3F5                             ;Load a intel HEX file from menu.  First get the file number in the menu.  Use this
F3F5                             ;to index the RFC_LIST to get the file cluster and file size.  Then iterate through
F3F5                             ;the data converting it to binary
F3F5                LOADHEX:      
F3F5                             ;get cluster from RFC_LIST
F3F5   3A 97 08               LD   a,(C_FILENO)   ;map to mon3 Menu data for selected menu entry
F3F8   CD 63 F5               CALL   getFirstCluster   ;get first cluster of file selected
F3FB   CD AE F4               CALL   FATgetSector   ;get sector of cluster
F3FE   21 00 06               LD   hl,DISK_BUFF   
F401   ED 5B C9 05            LD   de,(FCB_NSEC)   
F405   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F409   CD 8B F4               CALL   FATreadSector   ;read sector of file
F40C                             ;keep going until all bytes are copied.
F40C   DD 21 00 08            LD   ix,HIGH_RAM   ;end of sector
F410   FD 21 00 06            LD   iy,DISK_BUFF   ;source
F414                INTELLOADER1:      
F414   0E 00                  LD   c,0   ;clear checksum
F416                             ;Get header information
F416                INTELMARK1:      
F416   CD 68 F4               CALL   checkEndBuff   ;check if reached end of buffer
F419   FD 7E 00               LD   a,(iy+0)   ;get byte
F41C   FD 23                  INC   iy   ;move to next char
F41E   FE 3A                  CP   ":"   ;Is byte received a colon?
F420   20 F4                  JR   nz,intelMark1   ;No, loop until a colon is found
F422   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Length)
F425   47                     LD   b,a   ;Store Record Length in B
F426   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Destination address)
F429   67                     LD   h,a   ;Store High Address byte in H
F42A   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Destination address)
F42D   6F                     LD   l,a   ;Store Low Address byte in L
F42E   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Record Type)
F431   20 0D                  JR   nz,intelCheckSum1   ;Anything non zero treat as EOF
F433                             ;C=checksum, B=number of bytes, HL=destination address
F433                             ;Load bytes to (HL), B times
F433                INTELLOAD1:      
F433   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Data)
F436   77                     LD   (hl),a   ;store data in RAM
F437   23                     INC   hl   ;move to next RAM location
F438   10 F9                  DJNZ   intelLoad1   ;repeat until B=0
F43A   CD 40 F4               CALL   intelCheckSum1   ;Get checksum value
F43D   28 D5                  JR   z,intelLoader1   ;Line is processed and okay, get next line
F43F   C9                     RET      ;Exit with zero flag not set (load error)
F440                INTELCHECKSUM1:      
F440   CD 46 F4               CALL   getHexByte1   ;Convert ASCII to Byte (Checksum)
F443   79                     LD   a,c   ;Final Checksum is zero if okay
F444   B7                     OR   a   ;set zero flag
F445   C9                     RET      ;get next line or exit
F446                             ;Get ASCII character from FTDI AND convert it to a byte
F446                             ;IE: "D3" -> 0D3H
F446                GETHEXBYTE1:      
F446   CD 57 F4               CALL   getHexChar1   ;Get first Hex character from FTDI
F449   07                     RLCA      ;Move lower nibble
F44A   07                     RLCA      ;(first character)
F44B   07                     RLCA      ;to upper
F44C   07                     RLCA      ;nibble in A
F44D   57                     LD   d,a   ;store it in D
F44E   CD 57 F4               CALL   getHexChar1   ;Get second Hex character from FTDI
F451   B2                     OR   d   ;make a byte
F452                             ;add byte to checksum
F452   F5                     PUSH   af   ;save AF
F453   81                     ADD   a,c   ;add existing checksum C to current byte
F454   4F                     LD   c,a   ;load total back to C
F455   F1                     POP   af   ;restore AF
F456   C9                     RET      
F457                GETHEXCHAR1:      
F457   CD 68 F4               CALL   checkEndBuff   ;check if reached end of buffer
F45A   FD 7E 00               LD   a,(iy+0)   ;Get next byte
F45D   FD 23                  INC   iy   
F45F   CB 77                  BIT   6,a   ;is the chracter 0-9 or A-F?
F461   28 02                  JR   z,$+4   ;Its 0-9 skip A-F adjustment
F463   C6 09                  ADD   a,9   ;add 9 to fix A-F
F465   E6 0F                  AND   0FH   ;mask out high nibble and convert to binary
F467   C9                     RET      
F468                             ;Check if End of disk buffer and get a new one if at end
F468                CHECKENDBUFF:      
F468   DD 7D                  LD   a,ixl   
F46A   FD BD                  CP   iyl   
F46C   C0                     RET   nz   ;different
F46D   DD 7C                  LD   a,ixh   
F46F   FD BC                  CP   iyh   
F471   C0                     RET   nz   ;different
F472                             ;load next sector
F472   C5                     PUSH   bc   
F473   D5                     PUSH   de   
F474   E5                     PUSH   hl   
F475   21 00 06               LD   hl,DISK_BUFF   
F478   ED 5B C9 05            LD   de,(FCB_NSEC)   
F47C   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F480   CD 8B F4               CALL   FATreadSector   
F483   FD 21 00 06            LD   iy,DISK_BUFF   ;source
F487   E1                     POP   hl   
F488   D1                     POP   de   
F489   C1                     POP   bc   
F48A   C9                     RET      
F48B                             ;Read a Sector and fill out next sector in cluster.  If end of cluster,
F48B                             ;get the next cluster and sector from File Allocation Table (FAT)
F48B                             ;Input: BCDE = LBA sector address 3,2,1 and 0
F48B                             ;       HL = Address of data buffer (512 bytes)
F48B                             ;Output: FCB_NSEC set to next sector
F48B                FATREADSECTOR:      
F48B                             ;check if all sectors in cluster have been read
F48B   3A C6 05               LD   a,(FCB_SCNT)   ;get current sector count
F48E   B7                     OR   a   ;is it zero
F48F   20 03                  JR   nz,readSector1   ;no, just read sector
F491   CD D5 F4               CALL   FATgetFAT   ;get next cluster from FAT
F494                READSECTOR1:      
F494   CD 7E F0               CALL   IDEreadSector   
F497   DA 69 F2               JP   c,FATerror5   ;error
F49A                             ;fill FCB Next Sector
F49A   21 01 00               LD   hl,0001H   
F49D   19                     ADD   hl,de   
F49E   22 C9 05               LD   (FCB_NSEC),hl   
F4A1   21 00 00               LD   hl,0000H   
F4A4   ED 4A                  ADC   hl,bc   
F4A6   22 CB 05               LD   (FCB_NSEC+2),hl   
F4A9   21 C6 05               LD   hl,FCB_SCNT   ;get current sector count
F4AC   35                     DEC   (hl)   ;decrease by one
F4AD   C9                     RET      
F4AE                             ;Get the sector based off a cluster number
F4AE                             ;Uses the formula ((Cluster Number - 2) * Sectors Per Cluster) + Data Start
F4AE                             ;Input: BCDE = 32 bit cluster number
F4AE                             ;Output: HLIX = 32 bit sector number
F4AE                             ;        (FCB_NSEC) = HLIX
F4AE                FATGETSECTOR:      
F4AE   3E 02                  LD   a,2   ;cluster base
F4B0   2F                     CPL      ;take 2 from cluster number
F4B1   37                     SCF      
F4B2   8B                     ADC   a,e   
F4B3   5F                     LD   e,a   
F4B4   38 05                  JR   c,nodec   
F4B6   15                     DEC   d   
F4B7   F2 BB F4               JP   p,nodec   
F4BA   0B                     DEC   bc   
F4BB                NODEC:       
F4BB   3A E4 05               LD   a,(CLUS_SEC)   ;get clusters per sector
F4BE   CD 3E FA               CALL   BCDEtimeA   ;get sector of cluster
F4C1   ED 4B FC 05            LD   bc,(DATA_START)   ;get low byte of data start
F4C5   DD 09                  ADD   ix,bc   ;get addition
F4C7   ED 4B FE 05            LD   bc,(DATA_START+2)   ;get high byte of data start
F4CB   ED 4A                  ADC   hl,bc   ;get addition
F4CD                             ;save in FCB_NSEC
F4CD   DD 22 C9 05            LD   (FCB_NSEC),ix   
F4D1   22 CB 05               LD   (FCB_NSEC+2),hl   
F4D4   C9                     RET      
F4D5                             ;set next cluster and sector from FAT
F4D5                             ;(Current Cluster * 4) + FAT_START
F4D5                             ;Get sector in FAT where cluster is
F4D5                             ;Returns BCDE = LBA sector address 3,2,1 and 0
F4D5                             ;        HL = Disk Buffer
F4D5                FATGETFAT:      
F4D5   2A F8 05               LD   hl,(ROOT_CLUS)   ;get current cluster
F4D8   ED 5B FA 05            LD   de,(ROOT_CLUS+2)   
F4DC   0E 80                  LD   c,128   
F4DE   CD 5B FA               CALL   DEHLDivC   ;(Current Cluster  / 128)
F4E1   F5                     PUSH   af   ;store remainder
F4E2                             ;DEHL = cc/128
F4E2   ED 4B F0 05            LD   bc,(FAT_START)   
F4E6   09                     ADD   hl,bc   
F4E7   EB                     EX   de,hl   
F4E8   ED 4B F2 05            LD   bc,(FAT_START+2)   ;get fat start
F4EC   ED 4A                  ADC   hl,bc   
F4EE   E5                     PUSH   hl   
F4EF   C1                     POP   bc   
F4F0                             ;BCDE = LBA sector address 3,2,1 and 0
F4F0   21 00 06               LD   hl,DISK_BUFF   
F4F3   CD 7E F0               CALL   IDEreadSector   ;get sector of FAT for cluster
F4F6   F1                     POP   af   ;get remainder from AF to get offset
F4F7   5F                     LD   e,a   
F4F8   16 00                  LD   d,0   
F4FA   01 00 00               LD   bc,0   
F4FD   3E 04                  LD   a,4   
F4FF   DD E5                  PUSH   ix   
F501   CD 3E FA               CALL   BCDEtimeA   ;multipy it by 4.  Result in IX
F504                             ;Index DISK_BUFF to next cluster
F504   DD E5                  PUSH   ix   
F506   D1                     POP   de   
F507   21 00 06               LD   hl,DISK_BUFF   
F50A   19                     ADD   hl,de   
F50B                             ;HL is now pointing to next cluster
F50B   5E                     LD   e,(hl)   ;BCDE = cluster number in HL
F50C   23                     INC   hl   
F50D   56                     LD   d,(hl)   
F50E   23                     INC   hl   
F50F   4E                     LD   c,(hl)   
F510   23                     INC   hl   
F511   46                     LD   b,(hl)   
F512   ED 53 F8 05            LD   (ROOT_CLUS),de   ;save root cluster
F516   ED 43 FA 05            LD   (ROOT_CLUS+2),bc   
F51A   3A E4 05               LD   a,(CLUS_SEC)   ;get cluster sector
F51D   32 C6 05               LD   (FCB_SCNT),a   ;and set it to sector count
F520                             ;read sector of cluster
F520   CD AE F4               CALL   FATgetSector   ;get sector of cluster
F523   21 00 06               LD   hl,DISK_BUFF   
F526   ED 5B C9 05            LD   de,(FCB_NSEC)   
F52A   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F52E   DD E1                  POP   ix   
F530   C9                     RET      
F531                             ;Save file name from menu to FCB_NAME
F531                             ;Output: FCB_NAME populated with file name selected
F531                SAVEFILENAME:      
F531   21 07 01               LD   hl,DIR_CFG + 7   ;start from menu title
F534   01 7D 03               LD   bc,893   ;size of max menu
F537   AF                     XOR   a   
F538   ED B1                  CPIR      ;skip menu title
F53A   3A 97 08               LD   a,(C_FILENO)   ;map to mon3 Menu data for selected menu entry
F53D                TITLELOOP:      
F53D   B7                     OR   a   ;is it zero?
F53E   28 0D                  JR   z,saveTitle   
F540   57                     LD   d,a   ;save file number
F541   AF                     XOR   a   
F542   ED B1                  CPIR      ;find next file name
F544   23                     INC   hl   ;skip menu routine function
F545   23                     INC   hl   
F546   E2 6E F2               JP   po,FATerror6   ;file not found
F549   15                     DEC   d   
F54A   7A                     LD   a,d   
F54B   18 F0                  JR   titleLoop   ;loop again until title is found
F54D                SAVETITLE:      
F54D   01 0C 00               LD   bc,12   ;up to 12 bytes
F550   11 CD 05               LD   de,FCB_NAME   ;save file name
F553                SAVELOOP:      
F553   ED A0                  LDI      ;copy it
F555   7E                     LD   a,(hl)   
F556   B7                     OR   a   ;is it zero?
F557   20 FA                  JR   nz,saveLoop   
F559                             ;fill rest with spaces
F559   B1                     OR   c   ;are there none left?
F55A   C8                     RET   z   
F55B   41                     LD   b,c   
F55C   3E 20                  LD   a," "   ;space
F55E                FILLLOOP:      
F55E   12                     LD   (de),a   
F55F   13                     INC   de   
F560   10 FC                  DJNZ   fillLoop   
F562   C9                     RET      
F563                             ;Get first cluster of file selected on menu
F563                             ;Input: A = index of file selected from menu
F563                             ;Output: BCDE = 32 bit cluster number
F563                             ;        IX = file size
F563                             ;        (ROOT_CLUS) = BCDE
F563                             ;Destroy: HL,A
F563                GETFIRSTCLUSTER:      
F563   3C                     INC   a   ;move to next entry as I want to look back
F564   21 30 04               LD   hl,RFC_LIST   
F567   4F                     LD   c,a   
F568   06 00                  LD   b,0   ;clear B
F56A                             ;calculate index to RFC_LIST
F56A   B7                     OR   a   ;clear carry
F56B   CB 11                  RL   c   ;x2
F56D   CB 11                  RL   c   ;x4
F56F   CB 11                  RL   c   ;x8
F571   30 01                  JR   nc,$+3   
F573   04                     INC   b   ;add 1 if carry set
F574   09                     ADD   hl,bc   ;add to RFC_LIST
F575                             ;HL is now pointing to RFC_LIST
F575                             ;get file size
F575   2B                     DEC   hl   
F576   2B                     DEC   hl   
F577   2B                     DEC   hl   
F578   46                     LD   b,(hl)   
F579   2B                     DEC   hl   
F57A   4E                     LD   c,(hl)   
F57B   C5                     PUSH   bc   ;save for after cluster load
F57C   DD E1                  POP   ix   
F57E                             ;check for zero file size and make FFFF.  Can only load a max AFFF bytes
F57E   DD 7D                  LD   a,ixl   
F580   B7                     OR   a   
F581   20 07                  JR   nz,getCluster   
F583   DD 7C                  LD   a,ixh   
F585   B7                     OR   a   
F586   20 02                  JR   nz,getCluster   
F588   DD 2B                  DEC   ix   
F58A                GETCLUSTER:      
F58A   2B                     DEC   hl   
F58B                             ;get cluster number
F58B   46                     LD   b,(hl)   ;BCDE = cluster number in HL
F58C   2B                     DEC   hl   
F58D   4E                     LD   c,(hl)   
F58E   2B                     DEC   hl   
F58F   56                     LD   d,(hl)   
F590   2B                     DEC   hl   
F591   5E                     LD   e,(hl)   
F592   ED 53 F8 05            LD   (ROOT_CLUS),de   ;save root cluster
F596   ED 43 FA 05            LD   (ROOT_CLUS+2),bc   
F59A   3A E4 05               LD   a,(CLUS_SEC)   ;get cluster sector
F59D   32 C6 05               LD   (FCB_SCNT),a   ;and set it to sector count
F5A0   C9                     RET      
F5A1                             ;Open a file from the disk
F5A1                             ;Input: HL = Pointer to a ZERO terminated file name
F5A1                             ;Output: C_FILENO = (0897H) index of file in RFC_LIST or Directory Listing
F5A1                OPENFILE:      
F5A1   E5                     PUSH   hl   
F5A2   CD 2C F0               CALL   initDisk   ;Mount and get Root Directory`
F5A5   E1                     POP   hl   
F5A6                             ;Search the DIR_CFG for the file name
F5A6   EB                     EX   de,hl   
F5A7   21 00 01               LD   hl,DIR_CFG   
F5AA   46                     LD   b,(hl)   ;get menu count
F5AB   21 07 01               LD   hl,DIR_CFG + 7   ;start from menu title
F5AE   AF                     XOR   a   
F5AF   32 97 08               LD   (C_FILENO),a   ;clear file number
F5B2                SKIPTITLE:      
F5B2   7E                     LD   a,(hl)   ;get next character
F5B3   23                     INC   hl   
F5B4   B7                     OR   a   ;is it zero?
F5B5   20 FB                  JR   nz,skipTitle   ;no, keep checking
F5B7   EB                     EX   de,hl   
F5B8                FINDLOOP:      
F5B8   E5                     PUSH   hl   ;save file name pointer
F5B9                FINDLOOP1:      
F5B9   1A                     LD   a,(de)   ;get file name character
F5BA   BE                     CP   (hl)   ;compare with file name
F5BB   13                     INC   de   
F5BC   23                     INC   hl   
F5BD   20 05                  JR   nz,noMatch   ;no match, update C_FILENO
F5BF   B7                     OR   a   ;is it zero? If still here must have a match
F5C0   20 F7                  JR   nz,findLoop1   ;yes, check next character
F5C2   E1                     POP   hl   ;fix stack
F5C3   C9                     RET      ;yes, file found, return
F5C4                NOMATCH:      
F5C4                             ;no match, update C_FILENO
F5C4   21 97 08               LD   hl,C_FILENO   ;get file number
F5C7   34                     INC   (hl)   ;increment file number
F5C8                             ;get to next file name
F5C8                FINDLOOP2:      
F5C8   1A                     LD   a,(de)   ;get next character
F5C9   13                     INC   de   
F5CA   B7                     OR   a   ;is it zero?
F5CB   20 FB                  JR   nz,findLoop2   ;no, keep checking
F5CD   E1                     POP   hl   ;restore file name pointer
F5CE   13                     INC   de   ;skip address
F5CF   13                     INC   de   ; 
F5D0   10 E6                  DJNZ   findLoop   ;decrement file count
F5D2                             ;if we get here, file not found;
F5D2   C3 6E F2               JP   FATerror6   ;no files in menu
F5D5                             ;Read Sector on file
F5D5                             ;Will read a sector of 512 bytes from a file
F5D5                             ;IE: Sector 0 = 0-511 bytes
F5D5                             ;    Sector 1 = 512-1023 bytes
F5D5                             ;    Sector 2 = 1024-1535 bytes etc
F5D5                             ;Requires the openFile to be called first (and once only)
F5D5                             ;Input: HLDE = block in bytes on file to retreive 3,2,1 and 0
F5D5                             ;Output: Stores sector in DISK_BUFF 0600H to 07FFH (512 bytes)
F5D5                READSECTOR:      
F5D5   E5                     PUSH   hl   ;save HL    ;make BC=HL
F5D6   D5                     PUSH   de   
F5D7   3A 97 08               LD   a,(C_FILENO)   ;get index
F5DA   21 30 04               LD   hl,RFC_LIST   
F5DD   4F                     LD   c,a   
F5DE   06 00                  LD   b,0   ;clear B
F5E0                             ;calculate index to RFC_LIST
F5E0   B7                     OR   a   ;clear carry
F5E1   CB 11                  RL   c   ;x2
F5E3   CB 11                  RL   c   ;x4
F5E5   CB 11                  RL   c   ;x8
F5E7   30 01                  JR   nc,$+3   
F5E9   04                     INC   b   ;add 1 if carry set
F5EA   09                     ADD   hl,bc   ;add to RFC_LIST
F5EB                             ;HL is now pointing to RFC_LIST
F5EB                             ;save data to ROOT_CLUS
F5EB   5E                     LD   e,(hl)   
F5EC   23                     INC   hl   
F5ED   56                     LD   d,(hl)   
F5EE   23                     INC   hl   
F5EF   ED 53 F8 05            LD   (ROOT_CLUS),de   
F5F3   5E                     LD   e,(hl)   
F5F4   23                     INC   hl   
F5F5   56                     LD   d,(hl)   
F5F6   ED 53 FA 05            LD   (ROOT_CLUS+2),de   
F5FA                             ;work out which cluster the sector is in.
F5FA   D1                     POP   de   
F5FB   C1                     POP   bc   ;hl
F5FC                             ;check file size BCDE
F5FC   23                     INC   hl   
F5FD   23                     INC   hl   
F5FE   23                     INC   hl   
F5FF   23                     INC   hl   ;get to MSB
F600   7E                     LD   a,(hl)   
F601   B8                     CP   b   ;if carry too large
F602   DA 8C F2               JP   c,FATerror12   ;too large
F605   20 16                  JR   nz,sizeCheckDone   ;file size okay
F607   2B                     DEC   hl   
F608   7E                     LD   a,(hl)   
F609   B9                     CP   c   ;if carry too large
F60A   DA 8C F2               JP   c,FATerror12   ;too large
F60D   20 0E                  JR   nz,sizeCheckDone   ;file size okay
F60F   2B                     DEC   hl   
F610   7E                     LD   a,(hl)   
F611   BA                     CP   d   ;if carry too large
F612   DA 8C F2               JP   c,FATerror12   ;too large
F615   20 06                  JR   nz,sizeCheckDone   ;file size okay
F617   2B                     DEC   hl   
F618   7E                     LD   a,(hl)   
F619   BB                     CP   e   ;if carry too large
F61A   DA 8C F2               JP   c,FATerror12   ;too large
F61D                SIZECHECKDONE:      
F61D                             ;set HL with 512 * CLUS_SEC
F61D   3A E4 05               LD   a,(CLUS_SEC)   ;get cluster sector
F620   07                     RLCA      ;x2
F621   67                     LD   h,a   ;save x2 in H
F622   2E 00                  LD   l,0   
F624   3E FF                  LD   a,0FFH   ;cluster counter
F626   F5                     PUSH   af   ;save cluster number
F627                CLUSTERLOOP:      
F627   F1                     POP   af   ;restore cluster number
F628   3C                     INC   a   ;increment cluster number
F629   F5                     PUSH   af   ;save cluster number
F62A   CD 6C FA               CALL   BCDEminusHL   ;subtract until overflow
F62D   30 F8                  JR   nc,clusterLoop   ;loop until all clusters are done
F62F   F1                     POP   af   ;restore cluster number
F630   19                     ADD   hl,de   ;store byte remainder in HL
F631                             ;find the correct cluster in the FAT
F631   E5                     PUSH   hl   
F632                FATLOOP:      
F632   B7                     OR   a   ;is it zero?
F633   28 08                  JR   z,fatLoopExit   
F635   F5                     PUSH   af   
F636   CD D5 F4               CALL   FATgetFAT   ;get next cluster from FAT
F639   F1                     POP   af   ;restore AF
F63A   3D                     DEC   a   
F63B   18 F5                  JR   fatLoop   ;loop until all clusters are done
F63D                FATLOOPEXIT:      
F63D   ED 5B F8 05            LD   de,(ROOT_CLUS)   ;get root cluster
F641   ED 4B FA 05            LD   bc,(ROOT_CLUS+2)   
F645                             ;read sector of cluster
F645   CD AE F4               CALL   FATgetSector   ;get sector of cluster
F648   ED 5B C9 05            LD   de,(FCB_NSEC)   
F64C   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F650   E1                     POP   hl   ;restore HL byte remainder.  index for lba
F651                             ; hl is now in bytes, need to divide by 512 to get lba index
F651                             ; do a shift right of h and make l=h and h=0
F651   CB 3C                  SRL   h   
F653   6C                     LD   l,h   
F654   26 00                  LD   h,0   ;make h=0
F656   19                     ADD   hl,de   
F657   EB                     EX   de,hl   ;HL now has lba
F658   30 01                  JR   nc,$+3   ;skip update of BC by one if not carry
F65A   03                     INC   bc   
F65B                             ;Now have lba in BCDE
F65B   ED 53 C9 05            LD   (FCB_NSEC),de   ;save lba in FCB_NSEC for saving if needed
F65F   ED 43 CB 05            LD   (FCB_NSEC+2),bc   
F663   21 00 06               LD   hl,DISK_BUFF   ;source
F666   CD 7E F0               CALL   IDEreadSector   ;read sector of file
F669   DA 69 F2               JP   c,FATerror5   ;error reading sector
F66C   C9                     RET      
F66D                             ;Write a sector to file
F66D                             ;Will save a sector of 512 bytes to a file
F66D                             ;Input: Requires readSector to be called first.  This will load the sector for
F66D                             ;       editing.  Then when done, call this routine to save the sector back to the disk
F66D                             ;       Data to save is in DISK_BUFF 0600H to 07FFH (512 bytes)
F66D                WRITESECTOR:      
F66D   ED 5B C9 05            LD   de,(FCB_NSEC)   
F671   ED 4B CB 05            LD   bc,(FCB_NSEC+2)   
F675   21 00 06               LD   hl,DISK_BUFF   ;source
F678   CD FC F0               CALL   IDEwriteSector   ;write sector of file
F67B   DA 69 F2               JP   c,FATerror5   ;error writing sector
F67E   C9                     RET      
F67F                             ;Compare two strings at HL and DE
F67F                             ;returns z if they are equal
F67F                             ;returns c if DE points to the smaller string
F67F                             ;returns nc if DE is the bigger (or equal) string.
F67F                CPSTR:       
F67F   1A                     LD   a,(de)   ;string 1
F680   BE                     CP   (hl)   ;string 2
F681   13                     INC   de   
F682   23                     INC   hl   
F683   C0                     RET   nz   ;not equal, return
F684   1A                     LD   a,(de)   
F685   B7                     OR   a   ;end of string?
F686   20 F7                  JR   nz,cpstr   ;no check next character
F688   C9                     RET      
F689                             ;Save all RAM to disk.  Requires a 64kb file called "MYDATA.TEC" to be present on the disk.
F689                             ;RAM from 0000H to BFFFH is saved to the file, plus the expansion RAM from 8000H to BFFFH.
F689                SAVERAM:      
F689   21 EA F9               LD   hl,RAM_FILE   
F68C   CD A1 F5               CALL   openFile   ;open the file
F68F                             ;clear LCD
F68F   21 0A FA               LD   hl,SAVING_TEXT   
F692   CD 3F F7               CALL   setupLCD   
F695   06 80                  LD   b,80h   ;sectors to save, 60h normal sectors + 20h expansion RAM sectors
F697   21 00 00               LD   hl,0000h   ;byte address to save
F69A                             ;read file into ram
F69A   11 00 00               LD   de,0000h   ;start at sector 0
F69D                SAVERAMLOOP:      
F69D   D5                     PUSH   de   
F69E   C5                     PUSH   bc   
F69F   E5                     PUSH   hl   
F6A0   06 C9                  LD   b,0C9H   
F6A2   CD 9C C5               CALL   commandToLCD   ;update LCD
F6A5   CD B6 C5               CALL   HLtoLCD   ;write address to LCD
F6A8   EB                     EX   de,hl   
F6A9   06 9D                  LD   b,09DH   
F6AB   CD 9C C5               CALL   commandToLCD   ;update LCD
F6AE   CD B6 C5               CALL   HLtoLCD   ;sector address to LCD
F6B1   EB                     EX   de,hl   
F6B2   CD 62 F7               CALL   sectorToBytes   ;Convert sector number to byte address
F6B5                             ;load sector (512 bytes) to ram 0600h-07FFh
F6B5   CD D5 F5               CALL   readSector   
F6B8                             ;save ram to disk
F6B8   E1                     POP   hl   
F6B9   11 00 06               LD   de,0600h   ;destination address in memory
F6BC   01 00 02               LD   bc,512   ;sector size
F6BF   ED B0                  LDIR      ;copy ram to disk buffer
F6C1                             ;write the sector back to disk
F6C1   E5                     PUSH   hl   ;save current address
F6C2   CD 6D F6               CALL   writeSector   
F6C5   E1                     POP   hl   
F6C6   C1                     POP   bc   
F6C7   D1                     POP   de   
F6C8   13                     INC   de   ;increment sector number
F6C9   78                     LD   a,b   
F6CA   FE 21                  CP   21h   ;check if we are up to the expansion RAM sectors
F6CC   20 06                  JR   nz,skipExp   ;if no, skip
F6CE   CD 2E F7               CALL   setExpandFlag   
F6D1   21 00 80               LD   hl,8000h   ;reset address to expansion RAM
F6D4                SKIPEXP:      
F6D4   10 C7                  DJNZ   saveRAMLoop   ;decrement counter and loop if not zero
F6D6                             ;unset expansion RAM flag
F6D6   3E 00                  LD   a,00h   
F6D8   C3 1D D0               JP   setExpand   ;unset expand flag
F6DB                             ;Load disk file to RAM.  Requires a 64kb file called "MYDATA.TEC" to be present on the disk.
F6DB                             ;RAM from 0000H to BFFFH is loaded from the file, plus the expansion RAM from 8000H to BFFFH.
F6DB                LOADRAM:      
F6DB                             ;load file from disk to ram
F6DB   21 EA F9               LD   hl,RAM_FILE   
F6DE   CD A1 F5               CALL   openFile   
F6E1                             ;clear LCD
F6E1   21 F5 F9               LD   hl,LOADING_TEXT   
F6E4   CD 3F F7               CALL   setupLCD   
F6E7                             ;read file into ram
F6E7   06 80                  LD   b,80h   ;sectors to load, 60h normal sectors + 20h expansion RAM sectors
F6E9   11 00 00               LD   de,0000h   ;start at sector 0
F6EC                LOADLOOP:      
F6EC   D5                     PUSH   de   
F6ED   C5                     PUSH   bc   
F6EE   06 9D                  LD   b,09DH   
F6F0   CD 9C C5               CALL   commandToLCD   ;update LCD
F6F3   62                     LD   h,d   
F6F4   6B                     LD   l,e   
F6F5   CD B6 C5               CALL   HLtoLCD   ;write address to LCD
F6F8   CD 62 F7               CALL   sectorToBytes   ;Convert sector number to byte address
F6FB   D5                     PUSH   de   
F6FC                             ;load sector (512 bytes) to ram 0600h-07FFh
F6FC   CD D5 F5               CALL   readSector   
F6FF                             ;copy disk ram to memory
F6FF   D1                     POP   de   
F700   C1                     POP   bc   
F701   C5                     PUSH   bc   
F702   78                     LD   a,b   
F703   FE 21                  CP   21h   ;if sectors 60h-7Fh load to expansion RAM
F705   30 05                  JR   nc,skipExp2   
F707   21 00 C0               LD   hl,0C000h   ;Do a subtraction with and addition and wrap around!
F70A   19                     ADD   hl,de   
F70B   EB                     EX   de,hl   
F70C                SKIPEXP2:      
F70C   06 C9                  LD   b,0C9H   
F70E   CD 9C C5               CALL   commandToLCD   ;update LCD
F711   62                     LD   h,d   
F712   6B                     LD   l,e   
F713   CD B6 C5               CALL   HLtoLCD   ;write sector to LCD
F716   01 00 02               LD   bc,512   ;sector size in bytes
F719   21 00 06               LD   hl,0600h   ;source address in memory
F71C   ED B0                  LDIR      ;fill in the RAM
F71E                             ;increment sector number
F71E   C1                     POP   bc   
F71F   D1                     POP   de   
F720   13                     INC   de   ;increment sector number
F721   78                     LD   a,b   
F722   FE 21                  CP   21h   ;check if we are up to the expansion RAM sectors
F724   CC 2E F7               CALL   z,setExpandFlag   
F727   10 C3                  DJNZ   loadLoop   ;decrement counter and loop if not zero
F729                             ;unset expansion RAM flag
F729   3E 00                  LD   a,00h   
F72B   C3 1D D0               JP   setExpand   ;unset expansion RAM flag
F72E                             ; Set Expand flag with LCD update
F72E                SETEXPANDFLAG:      
F72E   3E 04                  LD   a,04h   ;expand flag
F730   CD 1D D0               CALL   setExpand   
F733   C5                     PUSH   bc   
F734   06 DD                  LD   b,0DDH   
F736   CD 9C C5               CALL   commandToLCD   ;update LCD
F739   C1                     POP   bc   
F73A   3E 59                  LD   a,"Y"   
F73C   C3 98 C5               JP   charToLCD   ;write "Y" to LCD
F73F                             ;Set up LCD
F73F                             ;Input: HL = first line of LCD
F73F                SETUPLCD:      
F73F   06 01                  LD   b,01H   ;clear LCD instruction
F741   CD 9C C5               CALL   commandToLCD   ;update LCD
F744   CD 83 C5               CALL   stringToLCD   ;write text
F747   06 C0                  LD   b,0C0H   ;set cursor to row 2
F749   CD 9C C5               CALL   commandToLCD   ;update LCD
F74C   21 1F FA               LD   hl,GENERAL_TEXT   
F74F   CD 83 C5               CALL   stringToLCD   ;write text
F752   06 94                  LD   b,94H   ;set cursor to row 3
F754   CD 9C C5               CALL   commandToLCD   ;update LCD
F757   CD 83 C5               CALL   stringToLCD   ;write text
F75A   06 D4                  LD   b,0D4H   ;set cursor to row 4
F75C   CD 9C C5               CALL   commandToLCD   ;update LCD
F75F   C3 83 C5               JP   stringToLCD   ;write text
F762                             ; Convert a sector number to actual byte address.  This routine multiplies the sector number by 512
F762                             ; and returns the result in HLDE.  The result is the byte address of the start of the sector in memory.
F762                             ; Input: DE = Sector number (0-based)
F762                             ; Output: HLDE = Byte address of the start of the sector in memory
F762                SECTORTOBYTES:      
F762                             ;DE x 512
F762   B7                     OR   a   ;Clear carry
F763   CB 13                  RL   e   
F765   CB 12                  RL   d   ;x2
F767   3E 00                  LD   a,0   
F769   67                     LD   h,a   ;Add carry to H if necessary
F76A   8C                     ADC   a,h   ;Multiply by 256
F76B   67                     LD   h,a   ;H = carry
F76C   6A                     LD   l,d   ;L = D
F76D   53                     LD   d,e   ;D = E
F76E   1E 00                  LD   e,0   ;E = 0
F770   C9                     RET      
F771                             ;Check if SD card is present
F771                             ;This routine checks if the SD card is present by calling CMD0.
F771                             ;Input: None
F771                             ;Output: Zero set if SD card is present
F771                CHECKSDCARDPRESENT:      
F771   C5                     PUSH   bc   
F772   0E 0A                  LD   c,10   ; Number of retries for SD card detection
F774                SDINIT1:      
F774   CD 5F F8               CALL   spiInit   ; set SD interface to idle state
F777   06 50                  LD   b,80   ; toggle clk 80 times
F779   3E 05                  LD   a,C_SERIDLE   ; set CS and MOSI high
F77B                SDRESET:      
F77B   D3 FD                  OUT   (SDIO),a   
F77D   CB CF                  SET   1,a   ; set CLK
F77F   D3 FD                  OUT   (SDIO),a   
F781   00                     NOP      
F782   CB 8F                  RES   1,a   ; clear CLK
F784   D3 FD                  OUT   (SDIO),a   
F786   10 F3                  DJNZ   sdReset   
F788                             ;Reset card to SPI mode
F788   21 8F F9               LD   hl,spiCMD0   ; Initialize the SD card
F78B   CD 9B F7               CALL   sendSPICommand   ; should come back as 01 if card present
F78E   FE 01                  CP   01h   
F790   28 07                  JR   z,sdReset2   ; SD card detected
F792   0D                     DEC   c   ; card not detected, decrement retry count
F793   28 02                  JR   z,sdReset1   ; no more retries, exit
F795   18 DD                  JR   sdInit1   ; and try again
F797                SDRESET1:      
F797   F6 01                  OR   1   ;reset zero flag
F799                SDRESET2:      
F799   C1                     POP   bc   
F79A   C9                     RET      
F79B                             ; Send a command to the SD card
F79B                             ; Input: HL = Pointer to command buffer
F79B                             ; Output: A = Response byte
F79B                SENDSPICOMMAND:      
F79B   C5                     PUSH   bc   ;Save BC
F79C   D5                     PUSH   de   ;Save DE
F79D   06 06                  LD   b,6   ; Number of bytes to send
F79F                SENDLOOP1:      
F79F   4E                     LD   c,(hl)   ; Load byte to send
F7A0   CD 8C F8               CALL   spiWrite   ; Send byte
F7A3   23                     INC   hl   ; Increment HL to point to next byte
F7A4   10 F9                  DJNZ   sendLoop1   ; Repeat for all bytes
F7A6   CD AC F7               CALL   readSPIByte   ; Read response byte
F7A9   D1                     POP   de   ; Restore DE
F7AA   C1                     POP   bc   ; Restore BC
F7AB   C9                     RET      
F7AC                             ; Read a byte from the SD card
F7AC                             ; Input: None
F7AC                             ; Output: A = Read byte
F7AC                READSPIBYTE:      
F7AC   C5                     PUSH   bc   
F7AD   D5                     PUSH   de   
F7AE   06 20                  LD   b,32   ; wait up to 32 tries, but should need 1-2
F7B0                READLOOP:      
F7B0   CD 66 F8               CALL   spiRead   ; get value in A
F7B3   FE FF                  CP   0ffh   
F7B5   20 02                  JR   nz,$+4   
F7B7   10 F7                  DJNZ   readLoop   
F7B9   D1                     POP   de   
F7BA   C1                     POP   bc   
F7BB   C9                     RET      
F7BC                             ; Read a block from the SD card
F7BC                             ; Input: HL = Buffer to read to (512 bytes)
F7BC                             ; Note: Set up Read Command LBA prior to this call
F7BC                READSPIBLOCK:      
F7BC   01 00 02               LD   bc,512   
F7BF                READBLOCKBUSY:      
F7BF   CD 66 F8               CALL   spiRead   
F7C2   FE FF                  CP   0FFH   
F7C4   28 F9                  JR   z,readBlockBusy   
F7C6   FE FE                  CP   0FEH   ;start token
F7C8   20 F5                  JR   nz,readBlockBusy   ;ignore
F7CA                READBLOCKLOOP:      
F7CA   CD 66 F8               CALL   spiRead   
F7CD   77                     LD   (hl),a   
F7CE   23                     INC   hl   
F7CF   0B                     DEC   bc   
F7D0   78                     LD   a,b   
F7D1   B1                     OR   c   
F7D2   20 F6                  JR   nz,readBlockLoop   
F7D4                             ;read CRC (two bytes)
F7D4   CD 66 F8               CALL   spiRead   
F7D7   CD 66 F8               CALL   spiRead   
F7DA   C9                     RET      
F7DB                             ; Write a block to the SD card
F7DB                             ; Input: HL = Buffer to write from (512 bytes)
F7DB                             ; Output: A = Result of write operation, 05H for success
F7DB                             ; Note: Set up Write Command LBA prior to this call
F7DB                WRITESPIBLOCK:      
F7DB   0E FE                  LD   c,0FEH   ; send start block token
F7DD   CD 8C F8               CALL   spiWrite   
F7E0   11 00 02               LD   de,512   
F7E3                WRITEBLOCKLOOP:      
F7E3   4E                     LD   c,(hl)   ; Load byte to send
F7E4   CD 8C F8               CALL   spiWrite   ; Send byte
F7E7   23                     INC   hl   ; Increment HL to point to next byte
F7E8   1B                     DEC   de   
F7E9   7A                     LD   a,d   
F7EA   B3                     OR   e   
F7EB   20 F6                  JR   nz,writeBlockLoop   ; Repeat for all bytes
F7ED                             ;send dummy CRC (0xFF, 0xFF)
F7ED   0E FF                  LD   c,0FFH   
F7EF   CD 8C F8               CALL   spiWrite   ; send dummy CRC byte 1
F7F2   CD 8C F8               CALL   spiWrite   ; send dummy CRC byte 2
F7F5                             ; Read the response token
F7F5   CD AC F7               CALL   readSPIByte   ; get the write response token
F7F8   4F                     LD   c,a   ; save result into C
F7F9                             ; Wait for the card to finish writing
F7F9                WAITDONELOOP:      
F7F9   CD 66 F8               CALL   spiRead   ; 00 = busy - wait for card to finish
F7FC   B7                     OR   a   
F7FD   28 FA                  JR   z,waitDoneLoop   ; wait until card is not busy
F7FF   79                     LD   a,c   ; restore result to A register
F800   E6 1F                  AND   1FH   ; return code 05 = success
F802   C9                     RET      
F803                             ; Initialize the SD card.  Call this routine to set up the SD card for use.
F803                             ; Steps through the initialisation process for the SD card
F803                             ; Calling CMD0, CMD8, CMD55, CMD41, CMD58, and CMD16
F803                             ; Throws errors if any of the commands fail
F803                INITSD:      
F803                             ; Check if SD card is present
F803   CD 71 F7               CALL   checkSDCardPresent   
F806   C2 78 F2               JP   nz,FATerror8   ; No SD card, error
F809                             ;Check voltage compatibility (2.7-3.6V, check pattern 0xAA)
F809   21 95 F9               LD   hl,spiCMD8   
F80C   CD 9B F7               CALL   sendSPICommand   ;returns 5 responses
F80F   FE 01                  CP   1   ;first response
F811   20 07                  JR   nz,sendCMD55   
F813                             ;get the next 4 responses
F813   06 04                  LD   b,4   
F815                CMD8LOOP:      
F815   CD AC F7               CALL   readSPIByte   
F818   10 FB                  DJNZ   cmd8loop   
F81A                SENDCMD55:      
F81A                             ;Initialize card (send CMD55 + CMD41 repeatedly)
F81A   11 00 C0               LD   de,0C000H   
F81D                CMD55DELAY:      
F81D   1B                     DEC   de   
F81E   7A                     LD   a,d   
F81F   B3                     OR   e   
F820   20 FB                  JR   nz,cmd55delay   
F822   21 AD F9               LD   hl,spiCMD55   
F825   CD 9B F7               CALL   sendSPICommand   
F828   21 B9 F9               LD   hl,spiACMD41   
F82B   CD 9B F7               CALL   sendSPICommand   
F82E   B7                     OR   a   
F82F   20 E9                  JR   nz,sendCMD55   
F831                             ;Read OCR to check addressing mode
F831   21 B3 F9               LD   hl,spiCMD58   
F834   CD 9B F7               CALL   sendSPICommand   
F837   B7                     OR   a   
F838   C2 7D F2               JP   nz,FATerror9   ;SD Failed OCR check
F83B   06 04                  LD   b,4   
F83D   21 00 06               LD   hl,DISK_BUFF   
F840                CMD58LOOP:      
F840   CD AC F7               CALL   readSPIByte   
F843   77                     LD   (hl),a   
F844   23                     INC   hl   
F845   10 F9                  DJNZ   cmd58loop   
F847   3A 00 06               LD   a,(DISK_BUFF)   ;bit 7 = valid, bit 6 = SDHC if 1, SDSC if 0
F84A   E6 C0                  AND   0C0H   ;80h = SDSC, C0h = SDHC
F84C   CB 7F                  BIT   7,a   
F84E   CA 82 F2               JP   z,FATerror10   ;Invalid SD card
F851   FE 80                  CP   80H   ;check if SDSC
F853   C0                     RET   nz   
F854                             ;SDSC card, set block size to 512 bytes
F854   21 9B F9               LD   hl,spiCMD16   
F857   CD 9B F7               CALL   sendSPICommand   
F85A   B7                     OR   a   
F85B   C2 87 F2               JP   nz,FATerror11   ;SD Failed CMD16
F85E   C9                     RET      
F85F                             ; SD Card Interface:
F85F                             ; - Bit 0: MOSI (Master Out Slave In)
F85F                             ; - Bit 1: CLK (Clock)
F85F                             ; - Bit 2: CS (Chip Select)
F85F                             ; - Bit 7: MISO (Master In Slave Out)
F85F                             ;SPI Init Routine.
F85F                             ;Initialize the SPI interface for SD card communication
F85F                SPIINIT:      
F85F   F5                     PUSH   af   ;Save A
F860   3E 05                  LD   a,C_SERIDLE   
F862   D3 FD                  OUT   (SDIO),a   ;Set SDIO to idle state
F864   F1                     POP   af   ;Restore A
F865   C9                     RET      
F866                             ;SPI Read Routine.
F866                             ;Read a byte from the SD card
F866                             ;Input: None
F866                             ;Output: A = Read byte
F866                SPIREAD:      
F866   C5                     PUSH   bc   ;Save BC
F867   D5                     PUSH   de   ;Save DE
F868   06 08                  LD   b,8   ;8 bits to read
F86A   1E 00                  LD   e,0   ;Result
F86C                SPIREADLOOP:      
F86C   3E 05                  LD   a,C_SERIDLE   
F86E   E6 FB                  AND   C_SERCS   ;CS bit
F870   D3 FD                  OUT   (SDIO),a   ;Set CS
F872   00                     NOP      ;Wait for CS to settle
F873   CB CF                  SET   1,a   ;Set CLK
F875   D3 FD                  OUT   (SDIO),a   ;Send clock pulse
F877   4F                     LD   c,a   ;Backup A
F878   DB FD                  IN   a,(SDIO)   ;Read MISO
F87A   17                     RLA      ;Shift left
F87B   CB 13                  RL   e   ;Shift result left
F87D   79                     LD   a,c   ;Restore A
F87E   E6 FD                  AND   0FDh   ;Clear CLK
F880   D3 FD                  OUT   (SDIO),a   ;Clear CLK
F882   10 E8                  DJNZ   spiReadLoop   ;Repeat for all bits
F884   3E 05                  LD   a,C_SERIDLE   ;Set Idle state, MOSI high, CLK low, CS high
F886   D3 FD                  OUT   (SDIO),a   ;Output to SD Card
F888   7B                     LD   a,e   ;Get result
F889   D1                     POP   de   ;Restore DE
F88A   C1                     POP   bc   ;Restore BC
F88B   C9                     RET      
F88C                             ;SPI Write Routine.
F88C                             ;Write a byte to the SD card
F88C                             ;Input: C = Byte to write
F88C                             ;Output: None
F88C                SPIWRITE:      
F88C   F5                     PUSH   af   ;Save A
F88D   C5                     PUSH   bc   ;Save BC
F88E   06 08                  LD   b,8   ;8 bits to write
F890                SPIWRITELOOP:      
F890   3E 05                  LD   a,C_SERIDLE   
F892   E6 FB                  AND   C_SERCS   ;CS bit
F894   CB 79                  BIT   7,c   ;Check if bit 7 is set
F896   20 02                  JR   nz,$+4   
F898   CB 87                  RES   0,a   ;Set data bit
F89A   D3 FD                  OUT   (SDIO),a   ;Set CS and MOSI
F89C   F6 02                  OR   02h   ;Set CLK
F89E   D3 FD                  OUT   (SDIO),a   ;Send clock pulse
F8A0   00                     NOP      ;Wait for clock pulse
F8A1   E6 FD                  AND   0FDh   ;Clear CLK
F8A3   D3 FD                  OUT   (SDIO),a   ;Clear CLK
F8A5   CB 01                  RLC   c   ;Shift left for next bit
F8A7   10 E7                  DJNZ   spiWriteLoop   ;Repeat for all bits
F8A9   3E 05                  LD   a,C_SERIDLE   ;Set Idle state, MOSI high, CLK low, CS high
F8AB   D3 FD                  OUT   (SDIO),a   ;Output to SD Card
F8AD   C1                     POP   bc   ;Restore BC
F8AE   F1                     POP   af   ;Restore A
F8AF   C9                     RET      
F8B0                             ;Messages (Max 15 characters plus 1 space)
F8B0   44 69 73 6B 20 54 69 6D 65 6F 75 74 20 00 MSG_TIMEOUT:   DB   "Disk Timeout ",0   
F8BE   44 61 74 61 20 4E 6F 74 20 52 65 61 64 79 20 00 MSG_DRQST:   DB   "Data Not Ready ",0   
F8CE   49 44 45 20 45 52 52 20 49 4F 20 42 61 64 20 00 MSG_IOERR:   DB   "IDE ERR IO Bad ",0   
F8DE   43 61 6E 27 74 20 72 65 61 64 20 4D 42 52 20 00 MSG_MBR:   DB   "Can't read MBR ",0   
F8EE   4D 42 52 20 49 6C 6C 65 67 61 6C 20 00 MSG_MBR_BAD:   DB   "MBR Illegal ",0   
F8FB   42 50 42 20 52 65 61 64 20 46 61 69 6C 20 00 MSG_BPB:   DB   "BPB Read Fail ",0   
F90A   42 79 74 2F 53 65 63 20 21 3D 20 35 31 32 20 00 MSG_BPS:   DB   "Byt/Sec != 512 ",0   
F91A   52 6F 6F 74 20 44 69 72 20 52 65 61 64 20 00 MSG_ROOT:   DB   "Root Dir Read ",0   
F929   46 69 6C 65 20 4E 6F 74 20 46 6F 75 6E 64 20 00 MSG_FILE:   DB   "File Not Found ",0   
F939   42 61 64 20 43 68 65 63 6B 73 75 6D 20 00 MSG_INTEL:   DB   "Bad Checksum ",0   
F947   4E 6F 20 53 44 20 43 61 72 64 20 00 MSG_NOSDCARD:   DB   "No SD Card ",0   
F953   4F 43 52 20 52 65 61 64 20 46 61 69 6C 20 00 MSG_OCR:   DB   "OCR Read Fail ",0   
F962   49 6E 76 61 6C 69 64 20 53 44 43 61 72 64 20 00 MSG_SDINVALID:   DB   "Invalid SDCard ",0   
F972   43 4D 44 31 36 20 46 61 69 6C 65 64 20 00 MSG_SDCMD16:   DB   "CMD16 Failed ",0   
F980   41 64 64 72 2E 20 54 6F 6F 20 42 69 67 20 00 MSG_TOOBIG:   DB   "Addr. Too Big ",0   
F98F                             ;SD Card Commands
F98F   40 00 00 00 00 95 SPICMD0:   DB   40h,0,0,0,0,95h   ; reset         R1
F995   48 00 00 01 AA 87 SPICMD8:   DB   48h,0,0,1,0AAh,87h   ; send_if_cond  R7
F99B   50 00 00 02 00 01 SPICMD16:   DB   50h,0,0,2,0,1h   ; Set sector size to 512 bytes   R1
F9A1   51 00 00 00 00 01 SPICMD17:   DB   51h,0,0,0,0,1h   ; read single block R1
F9A7   58 00 00 00 00 01 SPICMD24:   DB   58h,0,0,0,0,1h   ; write single block	R1
F9AD   77 00 00 00 00 01 SPICMD55:   DB   77h,0,0,0,0,1h   ; APP_CMD       R1
F9B3   7A 00 00 00 00 01 SPICMD58:   DB   7Ah,0,0,0,0,1h   ; READ_OCR      R3
F9B9   69 40 00 00 00 01 SPIACMD41:   DB   69h,40h,0,0,0,1h   ; send_OP_COND  R1
F9BF                             ;Parameter Configuration for Load and Save addresses
F9BF                LOAD_CFG:      
F9BF   01                     DB   1   ;one parameters
F9C0   41 44 44 52 45 53      DB   "ADDRES"   ;7seg Text
F9C6   20 46 69 6C 65 20 4C 6F 61 64 20 41 64 64 72 65 73 73 20 00 DB   " File Load Address ",0   ;Parameter title
F9DA   4C 6F 61 64 20 54 6F 20 41 64 64 72 3A 00 DB   "Load To Addr:",0   ;Text and Address
F9E8   C7 05                  DW   FCB_ADDR   
F9EA                             ;RAM File Constants
F9EA   4D 59 44 41 54 41 2E 54 45 43 00 RAM_FILE:   DB   "MYDATA.TEC",0   
F9F5   2D 2D 20 52 65 73 74 6F 72 65 20 42 61 63 6B 75 70 20 2D 2D 00 LOADING_TEXT:   DB   "-- Restore Backup --",0   
FA0A   2D 2D 3D 3D 20 52 41 4D 20 42 61 63 6B 75 70 20 3D 3D 2D 2D 00 SAVING_TEXT:   DB   "--== RAM Backup ==--",0   
FA1F                GENERAL_TEXT:      
FA1F   41 64 64 72 65 73 73 3A 20 00 DB   "Address: ",0   
FA29   53 65 63 74 6F 72 3A 20 20 00 DB   "Sector:  ",0   
FA33   45 78 70 61 6E 64 3A 20 20 4E 00 DB   "Expand:  N",0   
FA3E                             ;Mathematical Routines
FA3E                             ;---------------------
FA3E                             ;32 bit times 8 bit routine.
FA3E                             ;Input: DEBC = first operand
FA3E                             ;       A = second operand
FA3E                             ;Output: AHLIX = 40-bit result
FA3E                             ;        carry reset
FA3E                             ;        z set if top 8 bits are 0
FA3E                BCDETIMEA:      
FA3E   21 00 00               LD   hl,0000H   
FA41   DD 21 00 00            LD   ix,0000H   
FA45   CD 48 FA               CALL   $+3   
FA48   CD 4B FA               CALL   $+3   
FA4B   CD 4E FA               CALL   $+3   
FA4E   DD 29                  ADD   ix,ix   
FA50   ED 6A                  ADC   hl,hl   
FA52   8F                     ADC   a,a   
FA53   D0                     RET   nc   
FA54   DD 19                  ADD   ix,de   
FA56   ED 4A                  ADC   hl,bc   
FA58   CE 00                  ADC   a,0   
FA5A   C9                     RET      
FA5B                             ;32 bit divide by 8 bit routine.
FA5B                             ;Input: DEHL = numerator
FA5B                             ;       C = denominator
FA5B                             ;Output: DEHL = quotient
FA5B                             ;        A = remainder,
FA5B                             ;Destroys: B
FA5B                DEHLDIVC:      
FA5B   06 20                  LD   b,32   
FA5D   AF                     XOR   a   
FA5E                DIVLOOP:      
FA5E   29                     ADD   hl,hl   
FA5F   CB 13                  RL   e   
FA61   CB 12                  RL   d   
FA63   17                     RLA      
FA64   B9                     CP   c   
FA65   38 02                  JR   c,divlbl   
FA67   2C                     INC   l   
FA68   91                     SUB   c   
FA69                DIVLBL:      
FA69   10 F3                  DJNZ   divloop   
FA6B   C9                     RET      
FA6C                             ; Subtract HL from BCDE (BCDE = BCDE - HL)
FA6C                             ; BC = high 16 bits, DE = low 16 bits
FA6C                             ; Result stored in BCDE
FA6C                             ; Note: Assumes L is zero (L is not used in subtraction)
FA6C                BCDEMINUSHL:      
FA6C   7A                     LD   a,d   ; Load high byte of DE into A
FA6D   94                     SUB   h   ; Subtract high byte of HL with carry (borrow) from A
FA6E   57                     LD   d,a   ; Store result back in D
FA6F   79                     LD   a,c   ; Load high byte of BC into A
FA70   DE 00                  SBC   a,0   ; Subtract any remaining borrow from C
FA72   4F                     LD   c,a   ; Store result back in C
FA73   78                     LD   a,b   ; Load high-high byte of BC into A
FA74   DE 00                  SBC   a,0   ; Subtract any remaining borrow from B
FA76   47                     LD   b,a   ; Store result back in B
FA77   C9                     RET      
FA78                             ; ----------------------------------------------------------------------------
FA78                             ; 
FA78                             ; DS1302 RTC API Routines for MON3 - For use with GPIO RTC Card
FA78                             ; 
FA78                             ; Written By Craig Hart, 2024
FA78                             ; 
FA78                             ; ----------------------------------------------------------------------------
FA78                             ; 
FA78                             ; C register - API Call #
FA78                             ; B register - API Function
FA78                             ; 
FA78                             ; Calls return C=1 if failed, C=0 if success
FA78                             ; 
FA78                RTCAPI:      
FA78   78                     LD   a,b   
FA79   FE 13                  CP   DSAPIFnMax   ; Valid API Number?
FA7B   38 02                  JR   c,APIOk   
FA7D   37           APIERR:   SCF      ; set C flag = Error
FA7E   C9                     RET      
FA7F   87           APIOK:    ADD   a,a   ; 2 byte table
FA80   E5                     PUSH   hl   
FA81   C5                     PUSH   bc   
FA82   06 00                  LD   b,0   
FA84   4F                     LD   c,a   
FA85   21 B1 FF               LD   hl,DSAPIFunctions   
FA88   09                     ADD   hl,bc   
FA89   4E                     LD   c,(hl)   
FA8A   23                     INC   hl   
FA8B   46                     LD   b,(hl)   
FA8C   C5                     PUSH   bc   
FA8D   DD E1                  POP   ix   
FA8F   C1                     POP   bc   
FA90   E1                     POP   hl   
FA91   DD E9                  JP   (ix)   
FA93                             ; ----------------------------------------------------------------------------
FA93                             ; Determine if a DS1302 is pesent
FA93                             ; 
FA93                             ; If all registers return FFh, no DS1302 exists
FA93                             ; ----------------------------------------------------------------------------
FA93                CHECKDS1302PRESENT:      
FA93   D5                     PUSH   de   
FA94   11 00 8E               LD   de,8E00H   ; clear write protect bit
FA97   CD 6F FC               CALL   rtc_wr   
FA9A   11 00 90               LD   de,9000H   ; clear trickle charge bits
FA9D   CD 6F FC               CALL   rtc_wr   
FAA0   16 81                  LD   d,81H   
FAA2   CD 84 FC               CALL   rtc_rd   
FAA5   FE 5A                  CP   5AH   ; should come back 00..59h
FAA7   30 0C                  JR   nc,noDS1302   
FAA9   16 8B                  LD   d,8BH   
FAAB   CD 84 FC               CALL   rtc_rd   
FAAE   FE 08                  CP   08H   ; should come back 01..07
FAB0   30 03                  JR   nc,noDS1302   
FAB2   D1                     POP   de   
FAB3   B7                     OR   a   ; clear C flag
FAB4   C9                     RET      
FAB5                NODS1302:      
FAB5   D1                     POP   de   
FAB6   37                     SCF      ; set C flag
FAB7   C9                     RET      
FAB8                             ; ----------------------------------------------------------------------------
FAB8                             ; Reset the DS1302 fully to a known date/time condition
FAB8                             ; does not clear RTC bytes
FAB8                             ; ----------------------------------------------------------------------------
FAB8                RESETDS1302:      
FAB8   D5                     PUSH   de   
FAB9   11 00 8E               LD   de,8E00H   ; clear write protect bit
FABC   CD 6F FC               CALL   rtc_wr   
FABF   11 00 90               LD   de,9000H   ; clear trickle charge bits
FAC2   CD 6F FC               CALL   rtc_wr   
FAC5   11 00 80               LD   de,8000H   ; seconds 00
FAC8   CD 6F FC               CALL   rtc_wr   
FACB   11 00 82               LD   de,8200H   ; minutes 00
FACE   CD 6F FC               CALL   rtc_wr   
FAD1   11 90 84               LD   de,8490H   ; hours 01, 12 hour mode
FAD4   CD 6F FC               CALL   rtc_wr   
FAD7   11 01 86               LD   de,8601H   ; date 01
FADA   CD 6F FC               CALL   rtc_wr   
FADD   11 01 88               LD   de,8801H   ; month 01
FAE0   CD 6F FC               CALL   rtc_wr   
FAE3   11 01 8A               LD   de,8A01H   ; day 01 (Monday)
FAE6   CD 6F FC               CALL   rtc_wr   
FAE9   11 00 8C               LD   de,8C00H   ; year 00 (2000)
FAEC   CD 6F FC               CALL   rtc_wr   
FAEF   D1                     POP   de   
FAF0   B7                     OR   a   ; clear Z flag
FAF1   C9                     RET      
FAF2                             ; ----------------------------------------------------------------------------
FAF2                             ; Returns time
FAF2                             ; 
FAF2                             ; H = hour      ; bit 5 = am/pm flag (in 12 hr mode). 1=PM
FAF2                             ; L = minute
FAF2                             ; D = second
FAF2                             ; ----------------------------------------------------------------------------
FAF2                GETTIME:      
FAF2   16 85                  LD   d,85H   ; hour
FAF4   CD 84 FC               CALL   rtc_rd   
FAF7   E6 3F                  AND   3FH   ; strip off bits
FAF9   67                     LD   h,a   
FAFA   16 83                  LD   d,83H   ; min
FAFC   CD 84 FC               CALL   rtc_rd   
FAFF   6F                     LD   l,a   
FB00   16 81                  LD   d,81H   ; sec
FB02   CD 84 FC               CALL   rtc_rd   
FB05   57                     LD   d,a   
FB06   B7                     OR   a   
FB07   C9                     RET      
FB08                             ; ----------------------------------------------------------------------------
FB08                             ; Sets time; preserves 12/24 hour mode
FB08                             ; 
FB08                             ; H = hour             ; bit 5 = am/pm in 12hr mode
FB08                             ; L = minute
FB08                             ; D = second
FB08                             ; ----------------------------------------------------------------------------
FB08                SETTIME:      
FB08   5A                     LD   e,d   
FB09   16 80                  LD   d,80H   ; secs
FB0B   CD 6F FC               CALL   rtc_wr   
FB0E   7C                     LD   a,h   ; mask off junk bits
FB0F   E6 3F                  AND   3FH   
FB11   67                     LD   h,a   
FB12   CD 7D FB               CALL   get1224Mode   ; get 12/24 flag
FB15   B4                     OR   h   
FB16   5F                     LD   e,a   
FB17   16 84                  LD   d,84H   ; hour
FB19   CD 6F FC               CALL   rtc_wr   
FB1C   5D                     LD   e,l   
FB1D   16 82                  LD   d,82H   ; mins
FB1F   CD 6F FC               CALL   rtc_wr   
FB22   B7                     OR   a   
FB23   C9                     RET      
FB24                             ; ----------------------------------------------------------------------------
FB24                             ; Returns date
FB24                             ; 
FB24                             ; H = date
FB24                             ; L = month
FB24                             ; DE = year 2000..2099
FB24                             ; ----------------------------------------------------------------------------
FB24                GETDATE:      
FB24   C5                     PUSH   bc   
FB25   16 87                  LD   d,87H   ; date
FB27   CD 84 FC               CALL   rtc_rd   
FB2A   67                     LD   h,a   
FB2B   16 89                  LD   d,89H   ; month
FB2D   CD 84 FC               CALL   rtc_rd   
FB30   6F                     LD   l,a   
FB31   16 8D                  LD   d,8DH   ; year
FB33   CD 84 FC               CALL   rtc_rd   
FB36   5F                     LD   e,a   
FB37   16 20                  LD   d,20H   ; Add "20"xxh
FB39   C1                     POP   bc   
FB3A   B7                     OR   a   
FB3B   C9                     RET      
FB3C                             ; ----------------------------------------------------------------------------
FB3C                             ; sets date
FB3C                             ; 
FB3C                             ; H = date
FB3C                             ; L = month
FB3C                             ; DE = year (Decimal) 2000..2099
FB3C                             ; ----------------------------------------------------------------------------
FB3C                SETDATE:      
FB3C   16 8C                  LD   d,8CH   ; year  (just ignore "20"xxh)
FB3E   CD 6F FC               CALL   rtc_wr   
FB41   16 88                  LD   d,88H   ; month
FB43   5D                     LD   e,l   
FB44   CD 6F FC               CALL   rtc_wr   
FB47   16 86                  LD   d,86H   ; date
FB49   5C                     LD   e,h   
FB4A   CD 6F FC               CALL   rtc_wr   
FB4D   B7                     OR   a   
FB4E   C9                     RET      
FB4F                             ; ----------------------------------------------------------------------------
FB4F                             ; Returns day in D
FB4F                             ; returns HL points to day ASCIIZ String
FB4F                             ; ----------------------------------------------------------------------------
FB4F                GETDAY:      
FB4F   16 8B                  LD   d,8BH   ; day
FB51   CD 84 FC               CALL   rtc_rd   
FB54   E6 07                  AND   07H   
FB56   57                     LD   d,a   
FB57   21 4E FF               LD   hl,daysList   
FB5A   3D                     DEC   a   
FB5B   FE 00                  CP   0   
FB5D   28 09                  JR   z,foundDay   
FB5F   47                     LD   b,a   
FB60                DAYLOOP:      
FB60   7E                     LD   a,(HL)   
FB61   23                     INC   hl   
FB62   FE 00                  CP   0   
FB64   20 FA                  JR   nz,dayLoop   
FB66   10 F8                  DJNZ   dayLoop   
FB68                FOUNDDAY:      
FB68   B7                     OR   a   
FB69   C9                     RET      
FB6A                             ; ----------------------------------------------------------------------------
FB6A                             ; sets day from D - 01..07
FB6A                             ; ----------------------------------------------------------------------------
FB6A                SETDAY:      
FB6A   7A                     LD   a,d   
FB6B   FE 00                  CP   0   
FB6D   20 02                  JR   nz,validDay   
FB6F   37                     SCF      
FB70   C9                     RET      
FB71                VALIDDAY:      
FB71   D5                     PUSH   de   
FB72   E6 07                  AND   07H   
FB74   5F                     LD   e,a   
FB75   16 8A                  LD   d,8AH   ; day
FB77   CD 6F FC               CALL   rtc_wr   
FB7A   D1                     POP   de   
FB7B   B7                     OR   a   
FB7C   C9                     RET      
FB7D                             ; ----------------------------------------------------------------------------
FB7D                             ; Returns 12hr / 24hr mode. A = 00h = 24 hour mode, 80h = 12 hr mode
FB7D                             ; ----------------------------------------------------------------------------
FB7D                GET1224MODE:      
FB7D   D5                     PUSH   de   
FB7E   16 85                  LD   d,85H   ; hour
FB80   CD 84 FC               CALL   rtc_rd   
FB83   E6 80                  AND   80H   ; mask bits
FB85   D1                     POP   de   
FB86   B7                     OR   a   
FB87   C9                     RET      
FB88                             ; ----------------------------------------------------------------------------
FB88                             ; Sets 12hr mode
FB88                             ; no prameters
FB88                             ; ----------------------------------------------------------------------------
FB88                SET12HRMODE:      
FB88   16 85                  LD   d,85H   ; hour
FB8A   CD 84 FC               CALL   rtc_rd   
FB8D   CB 7F                  BIT   7,a   ; is it already 12 hr mode?
FB8F   28 02                  JR   z,pr12   
FB91   37                     SCF      ; already 12 hour mode dude!
FB92   C9                     RET      
FB93   E6 3F        PR12:     AND   3FH   ; 24 hour to 12 hour - strip bits
FB95   FE 00                  CP   00H   
FB97   20 04                  JR   nz,notMidnight   
FB99   3E 92                  LD   a,92H   ; 12am + 12 hour flag
FB9B   18 34                  JR   setHour   
FB9D                NOTMIDNIGHT:      
FB9D   FE 12                  CP   12H   
FB9F   28 09                  JR   z,setpm   ; 12pm exactly?
FBA1   30 04                  JR   nc,ispm   ; >12 ?
FBA3   F6 80                  OR   80H   ; <12, so hours same, set 12 hour flag
FBA5   18 2A                  JR   setHour   
FBA7   D6 12        ISPM:     SUB   12H   ; convert to 12 hr time
FBA9   27                     DAA      
FBAA   F6 A0        SETPM:    OR   0A0H   ; set 12 hour flag + PM fag
FBAC   18 23                  JR   setHour   
FBAE                             ; ----------------------------------------------------------------------------
FBAE                             ; Sets 24hr mode
FBAE                             ; no prameters
FBAE                             ; ----------------------------------------------------------------------------
FBAE                SET24HRMODE:      
FBAE   16 85                  LD   d,85H   ; hour
FBB0   CD 84 FC               CALL   rtc_rd   
FBB3   CB 7F                  BIT   7,a   ; is it already 24 hr mode?
FBB5   20 02                  JR   nz,pr24   
FBB7   37                     SCF      ; already 24 hour mode dude!
FBB8   C9                     RET      
FBB9   E6 3F        PR24:     AND   3FH   ; strip bits 7 and 6 to set 24h mode
FBBB   CB 6F                  BIT   5,a   ; was it pm?
FBBD   28 0B                  JR   z,fixt   ; am? if so am is same as 24hr
FBBF   E6 1F                  AND   1FH   ; clear PM flag
FBC1   FE 12                  CP   12H   ; is it 12pm? no change
FBC3   28 0C                  JR   z,setHour   
FBC5   C6 12                  ADD   a,12H   ; adjust by adding 12 hours
FBC7   27                     DAA      ; in BCD
FBC8   18 07                  JR   setHour   
FBCA   FE 12        FIXT:     CP   12H   ; 12am = 00 hours
FBCC   20 01                  JR   nz,nofix   
FBCE   AF                     XOR   a   
FBCF   E6 1F        NOFIX:    AND   1FH   ; clear PM flag
FBD1                             ; sethour is a Shared function of above 2 calls
FBD1                SETHOUR:      
FBD1   5F                     LD   e,a   ; set clock
FBD2   16 84                  LD   d,84H   
FBD4   CD 6F FC               CALL   rtc_wr   
FBD7   B7                     OR   a   
FBD8   C9                     RET      
FBD9                             ; ----------------------------------------------------------------------------
FBD9                             ; formatTime takes in a time, and outputs it as a well structured string
FBD9                             ; 
FBD9                             ; note -- must supply bit 7 if 12hr!!!
FBD9                             ; 
FBD9                             ; H = hour      ; bit 7 = 12/24hr. bit 5 = am/pm flag (in 12 hr mode). 1=PM
FBD9                             ; L = minute
FBD9                             ; D = second
FBD9                             ; 
FBD9                             ; IY = pointer to where to write output
FBD9                             ; ----------------------------------------------------------------------------
FBD9                FORMATTIME:      
FBD9   D5                     PUSH   de   
FBDA   FD E5                  PUSH   iy   
FBDC   D1                     POP   de   
FBDD   7C                     LD   a,h   ; get hours
FBDE   CB 7F                  BIT   7,a   ; 1 = 12 hour
FBE0   28 02                  JR   z,is24   
FBE2   E6 1F                  AND   1FH   
FBE4   E6 3F        IS24:     AND   3FH   
FBE6   CD CE C8               CALL   AToString   
FBE9   3E 3A                  LD   a,":"   ; add deliminator
FBEB   12                     LD   (de),a   
FBEC   13                     INC   de   
FBED   7D                     LD   a,l   ; get minutes
FBEE   CD CE C8               CALL   AToString   
FBF1   3E 3A                  LD   a,":"   ; add deliminator
FBF3   12                     LD   (de),a   
FBF4   13                     INC   de   
FBF5   C1                     POP   bc   
FBF6   78                     LD   a,b   ; set seconds
FBF7   CD CE C8               CALL   AToString   
FBFA   7C                     LD   a,h   ; work out if AM or PM, or 24 hour mode
FBFB   CB 7F                  BIT   7,a   
FBFD   28 14                  JR   z,noampm   ; skip AM/PM if 24 hour mode
FBFF   3E 20                  LD   a," "   ; add space
FC01   12                     LD   (de),a   
FC02   13                     INC   de   
FC03   06 41                  LD   b,"A"   
FC05   7C                     LD   a,h   ; is it AM or PM
FC06   E6 20                  AND   20H   
FC08   28 02                  JR   z,isam   
FC0A   06 50                  LD   b,"P"   
FC0C   78           ISAM:     LD   a,b   ; copy 2 bytes AM or PM to buffer
FC0D   12                     LD   (de),a   
FC0E   13                     INC   de   
FC0F   3E 4D                  LD   a,"M"   
FC11   12                     LD   (de),a   
FC12   13                     INC   de   
FC13   AF           NOAMPM:   XOR   a   ; null terminate string
FC14   12                     LD   (de),a   
FC15   C9                     RET      
FC16                             ; ----------------------------------------------------------------------------
FC16                             ; formatDate takes in a date, and outputs it as a well structured string
FC16                             ; 
FC16                             ; H = date
FC16                             ; L = month
FC16                             ; DE = year
FC16                             ; 
FC16                             ; IY = pointer to where to write output
FC16                             ; ----------------------------------------------------------------------------
FC16                FORMATDATE:      
FC16   D5                     PUSH   de   
FC17   FD E5                  PUSH   iy   
FC19   D1                     POP   de   
FC1A   7C                     LD   a,h   
FC1B   CD CE C8               CALL   AToString   
FC1E   3E 2F                  LD   a,"/"   
FC20   12                     LD   (de),a   
FC21   13                     INC   de   
FC22   7D                     LD   a,l   
FC23   CD CE C8               CALL   AToString   
FC26   3E 2F                  LD   a,"/"   
FC28   12                     LD   (de),a   
FC29   13                     INC   de   
FC2A   C1                     POP   bc   ; year now in BC
FC2B   78                     LD   a,b   
FC2C   CD CE C8               CALL   AToString   
FC2F   79                     LD   a,c   
FC30   CD CE C8               CALL   AToString   
FC33   3E 00                  LD   a,0   
FC35   12                     LD   (de),a   
FC36   C9                     RET      
FC37                             ; ----------------------------------------------------------------------------
FC37                             ; Input:        D = byte to return 0..30
FC37                             ; Output:       A = byte read
FC37                             ; ----------------------------------------------------------------------------
FC37                READRTCBYTE:      
FC37   7A                     LD   a,d   
FC38   16 00                  LD   d,0   
FC3A   FE 1F                  CP   31   
FC3C   D0                     RET   nc   ;exit if greater then 30
FC3D   87                     ADD   a,a   ;Double in to get read index
FC3E   C6 C1                  ADD   a,0C1H   
FC40   57                     LD   d,a   
FC41   CD 84 FC               CALL   rtc_rd   
FC44   B7                     OR   a   
FC45   C9                     RET      
FC46                             ; ----------------------------------------------------------------------------
FC46                             ; Input:        DE = register and byte to write, D=0..30
FC46                             ; ----------------------------------------------------------------------------
FC46                WRITERTCBYTE:      
FC46   7A                     LD   a,d   
FC47   FE 1F                  CP   31   
FC49   D0                     RET   nc   ;exit if greater then 30
FC4A   87                     ADD   a,a   ;Double it to get write index
FC4B   C6 C0                  ADD   a,0C0H   
FC4D   57                     LD   d,a   
FC4E   CD 6F FC               CALL   rtc_wr   
FC51   B7                     OR   a   
FC52   C9                     RET      
FC53                             ; ----------------------------------------------------------------------------
FC53                             ; Reads all 31 RTC RAM bytes to userbuffer
FC53                             ; input: HL = location to write to (31 bytes to be written)
FC53                             ; ----------------------------------------------------------------------------
FC53                BURSTRTCREAD:      
FC53   C5                     PUSH   bc   
FC54   D5                     PUSH   de   
FC55   0E FC                  LD   c,RTC_PORT   
FC57   3E 10                  LD   a,10H   ; raise CS, enable data out
FC59   ED 79                  OUT   (c),a   
FC5B   16 FF                  LD   d,0FFH   ; ram burst
FC5D   CD 97 FC               CALL   bytelpW   ; write D to select the register
FC60   06 1F                  LD   b,31   
FC62   CD A9 FC     BREAD:    CALL   bytelpR   ; read value (into D)
FC65   72                     LD   (hl),d   
FC66   23                     INC   hl   
FC67   10 F9                  DJNZ   bRead   
FC69   AF                     XOR   a   ; drop CS & clear CF
FC6A   ED 79                  OUT   (c),a   
FC6C   D1                     POP   de   
FC6D   C1                     POP   bc   
FC6E   C9                     RET      
FC6F                             ; ----------------------------------------------------------------------------
FC6F                             ; Write cycle. Writes 2 bytes
FC6F                             ; D = command/register
FC6F                             ; E = data byte
FC6F                             ; ----------------------------------------------------------------------------
FC6F                RTC_WR:      
FC6F   F5                     PUSH   af   
FC70   C5                     PUSH   bc   
FC71   0E FC                  LD   c,RTC_PORT   
FC73   3E 10                  LD   a,10H   ; raise CS, enable data in
FC75   ED 79                  OUT   (c),a   
FC77   CD 97 FC               CALL   bytelpW   ; write D to select the register
FC7A   53                     LD   d,e   
FC7B   CD 97 FC               CALL   bytelpW   ; write E - the data
FC7E   AF                     XOR   a   ; drop CS
FC7F   ED 79                  OUT   (c),a   
FC81   C1                     POP   bc   
FC82   F1                     POP   af   
FC83   C9                     RET      
FC84                             ; ----------------------------------------------------------------------------
FC84                             ; Read cycle. Writes command and reads result
FC84                             ; D = command/register needed
FC84                             ; A = result
FC84                             ; ----------------------------------------------------------------------------
FC84                RTC_RD:      
FC84   C5                     PUSH   bc   
FC85   0E FC                  LD   c,RTC_PORT   
FC87   3E 10                  LD   a,10H   ; raise CS, enable data out
FC89   ED 79                  OUT   (c),a   
FC8B   CD 97 FC               CALL   bytelpW   ; write D to select the register
FC8E   CD A9 FC               CALL   bytelpR   ; read value (into D)
FC91   AF                     XOR   a   ; drop CS
FC92   ED 79                  OUT   (c),a   
FC94   7A                     LD   a,d   ; return value in A
FC95   C1                     POP   bc   
FC96   C9                     RET      
FC97                             ; ----------------------------------------------------------------------------
FC97                             ; write one byte to the DS1302
FC97                             ; byte in D
FC97                             ; ----------------------------------------------------------------------------
FC97                BYTELPW:      
FC97   C5                     PUSH   bc   
FC98   06 08                  LD   b,8   
FC9A   CB 3A        BLP:      SRL   d   ; data bit 0 to carry
FC9C   3E 20                  LD   a,20H   
FC9E   1F                     RRA      ; carry to data bit 7
FC9F   ED 79                  OUT   (c),a   ; setup bus - drops clock
FCA1   F6 40                  OR   40H   ; raise CLK
FCA3   ED 79                  OUT   (c),a   
FCA5   10 F3                  DJNZ   blp   
FCA7   C1                     POP   bc   
FCA8   C9                     RET      
FCA9                             ; ----------------------------------------------------------------------------
FCA9                             ; Read one byte from the DS1302
FCA9                             ; byte read is returned in D
FCA9                             ; ----------------------------------------------------------------------------
FCA9                BYTELPR:      
FCA9   C5                     PUSH   bc   
FCAA   06 08                  LD   b,8   
FCAC   16 00                  LD   d,0   
FCAE   3E 30        BLP2:     LD   a,30H   
FCB0   F6 40                  OR   40H   ; raise CLK
FCB2   ED 79                  OUT   (c),a   
FCB4   E6 BF                  AND   0BFH   ; drop CLK
FCB6   ED 79                  OUT   (c),a   
FCB8   ED 58                  IN   e,(c)   ; read value
FCBA   CB 3B                  SRL   e   
FCBC   CB 1A                  RR   d   
FCBE   10 EE                  DJNZ   blp2   
FCC0   C1                     POP   bc   
FCC1   C9                     RET      
FCC2                             ; ----------------------------------------------------------------------------
FCC2                             ; Conversion routine - BCD to true Binary
FCC2                             ; input:  A = BCD value
FCC2                             ; output: A = binary value
FCC2                             ; ----------------------------------------------------------------------------
FCC2                BCDTOBIN:      
FCC2   C5                     PUSH   bc   
FCC3   4F                     LD   c,a   
FCC4   E6 F0                  AND   0F0H   
FCC6   CB 3F                  SRL   a   
FCC8   47                     LD   b,a   
FCC9   CB 3F                  SRL   a   
FCCB   CB 3F                  SRL   a   
FCCD   80                     ADD   a,b   
FCCE   47                     LD   b,a   
FCCF   79                     LD   a,c   
FCD0   E6 0F                  AND   0FH   
FCD2   80                     ADD   a,b   
FCD3   C1                     POP   bc   
FCD4   C9                     RET      
FCD5                             ; ----------------------------------------------------------------------------
FCD5                             ; Conversion routine - Binary to BCD
FCD5                             ; input:  A = binary value
FCD5                             ; output: A = BCD value
FCD5                             ; ----------------------------------------------------------------------------
FCD5                BINTOBCD:      
FCD5   C5                     PUSH   bc   
FCD6   06 0A                  LD   b,10   
FCD8   0E FF                  LD   c,-1   
FCDA   0C           DIV10:    INC   c   
FCDB   90                     SUB   b   
FCDC   30 FC                  JR   nc,div10   
FCDE   80                     ADD   a,b   
FCDF   47                     LD   b,a   
FCE0   79                     LD   a,c   
FCE1   87                     ADD   a,a   
FCE2   87                     ADD   a,a   
FCE3   87                     ADD   a,a   
FCE4   87                     ADD   a,a   
FCE5   B0                     OR   b   
FCE6   C1                     POP   bc   
FCE7   C9                     RET      
FCE8                             ; ----------------------------------------------------------------------------
FCE8                             ; Stand Alone, RTC configuration and PRAM Viewer
FCE8                             ; Setting time:
FCE8                             ;       0 sets hours
FCE8                             ;       1 sets minutes
FCE8                             ;       2 resets seconds to 00
FCE8                             ;       3 toggles 12/24 hour time
FCE8                             ; 
FCE8                             ; Setting calendar:
FCE8                             ;       4 sets day of week
FCE8                             ;       5 sets date
FCE8                             ;       6 sets month
FCE8                             ;       7 sets year
FCE8                             ; 
FCE8                             ; Special Keys:
FCE8                             ; 
FCE8                             ; A - Reset the DS1302 to 01/01/2000, 01:00.00am & 12hr mode
FCE8                             ; D - DUMPs the RTC RAM to LCD (Addr to exit dump mode) where
FCE8                             ;       + Moves down RAM list
FCE8                             ;       - Moves up RAM list
FCE8                             ;       AD Exits back to RTC Setup
FCE8                             ; Addr - Exit
FCE8                             ; ----------------------------------------------------------------------------
FCE8                RTCSETUP:      
FCE8                             ; clear the LCD
FCE8   06 01                  LD   b,01H   ;clear LCD
FCEA   0E 0F                  LD   c,15   ;command to LCD
FCEC   D7                     RST   10H   
FCED                             ; setup RTC chip
FCED   CD 93 FA               CALL   checkDS1302Present   
FCF0                             ;Carry set = No RTC
FCF0   30 22                  JR   nc,clockLoop   ;RTC Found, continue with program
FCF2   21 FF FC               LD   hl,noRTC   ;Load HL with no RTC Found text
FCF5   0E 0D                  LD   c,13   ;string to LCD
FCF7   D7                     RST   10H   
FCF8   11 48 FF               LD   de,segDisp   
FCFB   E7                     RST   20H   
FCFC   30 FA                  JR   nc,$-4   
FCFE   C9                     RET      ;exit back to calling routine
FCFF   52 54 43 20 4D 6F 64 75 6C 65 20 6E 6F 74 20 66 6F 75 6E 64 00 NORTC:   DB   "RTC Module not found",0   
FD14                             ; Main Loop
FD14                CLOCKLOOP:      
FD14                             ; read RTC and store time
FD14   CD 11 FF               CALL   getRTCTime   
FD17                             ; display time and date on LCD
FD17   3A 01 09               LD   a,(RTC_OSEC)   ;get old seconds
FD1A   47                     LD   b,a   ;save old seconds
FD1B   3A 00 09               LD   a,(RTC_SECS)   ;get current seconds
FD1E   B8                     CP   b   ;are they the same?
FD1F   28 59                  JR   z,keyRTC   ;yes, skip updating LCD
FD21                             ; seconds have changed, update LCD
FD21   32 01 09               LD   (RTC_OSEC),a   ;save new seconds in old
FD24                RTCUPDATE:      
FD24   06 02                  LD   b,02H   ;set LCD Cursor to top left
FD26   0E 0F                  LD   c,15   ;command to LCD
FD28   D7                     RST   10H   
FD29   CD 11 FF               CALL   getRTCTime   
FD2C                             ;format time
FD2C   FD 21 08 09            LD   iy,RTC_BUFF   ;get LCD buffer
FD30   CD D9 FB               CALL   formatTime   
FD33   21 08 09               LD   hl,RTC_BUFF   ;get new buffer
FD36   0E 0D                  LD   c,13   ;string to LCD
FD38   D7                     RST   10H   
FD39                             ; LCD section, calendar
FD39   06 C0                  LD   b,0C0H   ;Cursor to row 2
FD3B   0E 0F                  LD   c,15   ;command to LCD
FD3D   D7                     RST   10H   
FD3E   CD 4F FB               CALL   getDay   ;get Day as a string
FD41   0E 0D                  LD   c,13   ;string to LCD
FD43   D7                     RST   10H   
FD44   FD 21 08 09            LD   iy,RTC_BUFF   ;get LCD buffer
FD48   3E 20                  LD   a," "   ;add space
FD4A   FD 77 00               LD   (iy),a   
FD4D   FD 23                  INC   iy   
FD4F   CD 24 FB               CALL   getDate   
FD52   7C                     LD   a,h   ;save day
FD53   32 04 09               LD   (RTC_DAY),a   
FD56   7D                     LD   a,l   ;save month
FD57   32 05 09               LD   (RTC_MONTH),a   
FD5A   ED 53 06 09            LD   (RTC_YEAR),de   ;save year
FD5E   CD 16 FC               CALL   formatDate   
FD61                             ; display date on LCD
FD61   21 08 09               LD   hl,RTC_BUFF   
FD64   0E 0D                  LD   c,13   ;string to LCD
FD66   D7                     RST   10H   
FD67                             ; display help on LCD
FD67   06 94                  LD   b,94H   ;Cursor to row 3
FD69   0E 0F                  LD   c,15   ;command to LCD
FD6B   D7                     RST   10H   
FD6C   21 87 FF               LD   hl,helpList   ;Load HL help text
FD6F   0E 0D                  LD   c,13   ;string to LCD
FD71   D7                     RST   10H   
FD72   06 D4                  LD   b,0D4H   ;Cursor to row 4
FD74   0E 0F                  LD   c,15   ;command to LCD
FD76   D7                     RST   10H   
FD77   0E 0D                  LD   c,13   ;string to LCD
FD79   D7                     RST   10H   
FD7A                             ; keystroke handling section
FD7A                KEYRTC:      
FD7A   11 48 FF               LD   de,segDisp   
FD7D   E7                     RST   20H   
FD7E   D2 14 FD               JP   nc,clockLoop   ;loop if no key or repeat key
FD81   FE 13                  CP   13H   ;Addr key?
FD83   C8                     RET   z   ;exit program
FD84                KEYTRYF:      
FD84   FE 0F                  CP   0FH   ;F = reset clock
FD86   20 06                  JR   nz,keyTry0   
FD88   CD B8 FA               CALL   resetDS1302   
FD8B   C3 14 FD               JP   clockLoop   
FD8E                KEYTRY0:      
FD8E   B7                     OR   a   ;Hours adjust
FD8F   20 33                  JR   nz,keyTry1   
FD91   3A 03 09               LD   a,(RTC_HOURS)   
FD94   CB 7F                  BIT   7,a   ;check if 24 hours
FD96   20 09                  JR   nz,set12   
FD98   3C                     INC   a   ;set to next hour
FD99   27                     DAA      
FD9A   FE 24                  CP   24H   ;is it 24
FD9C   20 17                  JR   nz,saveTime   
FD9E   AF                     XOR   a   
FD9F   18 14                  JR   saveTime   
FDA1   4F           SET12:    LD   c,a   
FDA2   E6 A0                  AND   0A0H   ;mask out bits 7 and 5
FDA4   57                     LD   d,a   
FDA5   79                     LD   a,c   ;restore A
FDA6   E6 1F                  AND   1FH   ;mask off junk bits
FDA8   3C                     INC   a   
FDA9   27                     DAA      
FDAA   FE 13                  CP   13H   ;is it 13 o'clock?
FDAC   20 06                  JR   nz,noflip   
FDAE   7A                     LD   a,d   ;get AM/PM bits
FDAF   EE 20                  XOR   20H   ;toggle bit 5
FDB1   3C                     INC   a   ;make it 1 o'clock
FDB2   18 01                  JR   saveTime   
FDB4   B2           NOFLIP:   OR   d   ;add AM/PM bits
FDB5                SAVETIME:      
FDB5   67                     LD   h,a   ;save adjusted hours
FDB6   3A 02 09               LD   a,(RTC_MINS)   ;save minutes
FDB9   6F                     LD   l,a   
FDBA   3A 00 09               LD   a,(RTC_SECS)   ;save seconds
FDBD   57                     LD   d,a   
FDBE                             ;Set the time with HL,D
FDBE                STTIME:      
FDBE   CD 08 FB               CALL   setTime   ;set time
FDC1   C3 24 FD               JP   RTCUpdate   
FDC4                KEYTRY1:      
FDC4   FE 01                  CP   1   ;minutes adjust
FDC6   20 0E                  JR   nz,keyTry2   
FDC8   CD F2 FA               CALL   getTime   
FDCB   7D                     LD   a,l   ;get minutes
FDCC   3C                     INC   a   
FDCD   27                     DAA      
FDCE   FE 60                  CP   60H   ;is it over 59?
FDD0   20 01                  JR   nz,$+3   ;skip xor
FDD2   AF                     XOR   a   ;reset to zero
FDD3   6F                     LD   l,a   ;save minutes
FDD4   18 E8                  JR   stTime   
FDD6                KEYTRY2:      
FDD6   FE 02                  CP   2   ;seconds adjust
FDD8   20 07                  JR   nz,keyTry3   
FDDA   CD F2 FA               CALL   getTime   
FDDD   16 00                  LD   d,0   ;reset to zero seconds
FDDF   18 DD                  JR   stTime   
FDE1                KEYTRY3:      
FDE1   FE 03                  CP   3   ;12/24 hour mode
FDE3   20 18                  JR   nz,keyTry4   
FDE5   06 01                  LD   b,01H   ;clear LCD screen to fix AM/PM sign
FDE7   0E 0F                  LD   c,15   ;command to LCD
FDE9   D7                     RST   10H   
FDEA   3A 03 09               LD   a,(RTC_HOURS)   ;get hours
FDED   CB 7F                  BIT   7,a   ;is it 12 hour mode?
FDEF   20 06                  JR   nz,to24   
FDF1   CD 88 FB               CALL   set12HrMode   
FDF4   C3 24 FD               JP   RTCUpdate   
FDF7   CD AE FB     TO24:     CALL   set24HrMode   
FDFA   C3 24 FD               JP   RTCUpdate   
FDFD                KEYTRY4:      
FDFD   FE 04                  CP   4   ;get day
FDFF   20 17                  JR   nz,keyTry5   
FE01   CD 4F FB               CALL   getDay   
FE04   7A                     LD   a,d   
FE05   3C                     INC   a   
FE06   FE 08                  CP   8   
FE08   20 02                  JR   nz,$+4   
FE0A   3E 01                  LD   a,1   
FE0C   57                     LD   d,a   
FE0D   CD 6A FB               CALL   setDay   
FE10   06 01                  LD   b,01H   ;clear LCD screen to fix AM/PM sign
FE12   0E 0F                  LD   c,15   ;command to LCD
FE14   D7                     RST   10H   
FE15   C3 24 FD               JP   RTCUpdate   
FE18                KEYTRY5:      
FE18   FE 05                  CP   5   ;get day of month
FE1A   20 16                  JR   nz,keyTry6   
FE1C   3A 04 09               LD   a,(RTC_DAY)   
FE1F   3C                     INC   a   
FE20   27                     DAA      
FE21   FE 32                  CP   32H   
FE23   20 02                  JR   nz,$+4   
FE25   3E 01                  LD   a,1   
FE27   67                     LD   h,a   
FE28   3A 05 09               LD   a,(RTC_MONTH)   
FE2B   6F                     LD   l,a   
FE2C   ED 5B 06 09            LD   de,(RTC_YEAR)   
FE30   18 32                  JR   setYear   
FE32                KEYTRY6:      
FE32   FE 06                  CP   6   ;get month
FE34   20 16                  JR   nz,keyTry7   
FE36   3A 05 09               LD   a,(RTC_MONTH)   
FE39   3C                     INC   a   
FE3A   27                     DAA      
FE3B   FE 13                  CP   13H   
FE3D   20 02                  JR   nz,$+4   
FE3F   3E 01                  LD   a,1   
FE41   6F                     LD   l,a   
FE42   3A 04 09               LD   a,(RTC_DAY)   
FE45   67                     LD   h,a   
FE46   ED 5B 06 09            LD   de,(RTC_YEAR)   
FE4A   18 18                  JR   setYear   
FE4C                KEYTRY7:      
FE4C   FE 07                  CP   7   ;get year
FE4E   20 1A                  JR   nz,keyTry8   
FE50   ED 5B 06 09            LD   de,(RTC_YEAR)   
FE54   7B                     LD   a,e   
FE55   3C                     INC   a   
FE56   27                     DAA      
FE57   5F                     LD   e,a   
FE58   ED 53 06 09            LD   (RTC_YEAR),de   
FE5C   3A 04 09               LD   a,(RTC_DAY)   
FE5F   67                     LD   h,a   
FE60   3A 05 09               LD   a,(RTC_MONTH)   
FE63   6F                     LD   l,a   
FE64                SETYEAR:      
FE64   CD 3C FB               CALL   setDate   
FE67   C3 24 FD               JP   RTCUpdate   
FE6A                KEYTRY8:      
FE6A   FE 08                  CP   8   ;PRAM view
FE6C   C2 14 FD               JP   nz,clockLoop   
FE6F   CD 75 FE               CALL   dumpRAM   ;Display PRAM
FE72   C3 14 FD               JP   clockLoop   
FE75                             ; Display the contents of the RTC RAM (PRAM) bytes (31 bytes) on the LCD
FE75                DUMPRAM:      
FE75   21 1D 09               LD   hl,RTC_RAM   
FE78   CD 53 FC               CALL   burstRTCRead   ;put RAM data in RTC_RAM location
FE7B   AF                     XOR   a   
FE7C   32 3C 09               LD   (RAM_PTR),a   
FE7F                DUMPLOOP:      
FE7F   3A 3C 09               LD   a,(RAM_PTR)   ;get pointer (0,1 or 2)
FE82   87                     ADD   a,a   ;x2
FE83   47                     LD   b,a   
FE84   87                     ADD   a,a   ;x4
FE85   80                     ADD   a,b   ;x6
FE86   21 1D 09               LD   hl,RTC_RAM   ;index HL to pointer position
FE89   85                     ADD   a,l   
FE8A   6F                     LD   l,a   
FE8B   06 01                  LD   b,01H   ;clear LCD
FE8D   0E 0F                  LD   c,15   ;command to LCD
FE8F   D7                     RST   10H   
FE90   CD DC FE               CALL   displayRAMline   
FE93   06 C0                  LD   b,0C0H   ;set second row
FE95   0E 0F                  LD   c,15   ;command to LCD
FE97   D7                     RST   10H   
FE98   CD DC FE               CALL   displayRAMline   
FE9B   06 94                  LD   b,94H   ;set third row
FE9D   0E 0F                  LD   c,15   ;command to LCD
FE9F   D7                     RST   10H   
FEA0   CD DC FE               CALL   displayRAMline   
FEA3   06 D4                  LD   b,0D4H   ;set forth row
FEA5   0E 0F                  LD   c,15   ;command to LCD
FEA7   D7                     RST   10H   
FEA8   CD DC FE               CALL   displayRAMline   
FEAB                             ;get key input
FEAB                DUMPKEY:      
FEAB   11 48 FF               LD   de,segDisp   
FEAE   E7                     RST   20H   
FEAF   30 FA                  JR   nc,dumpKey   
FEB1   FE 13                  CP   13H   ;is it Addr?
FEB3   20 06                  JR   nz,keyTryPlus   
FEB5   06 01                  LD   b,01H   ;clear LCD
FEB7   0E 0F                  LD   c,15   ;command to LCD
FEB9   D7                     RST   10H   
FEBA   C9                     RET      
FEBB                KEYTRYPLUS:      
FEBB   FE 10                  CP   10H   ;is it plus key?
FEBD   20 0D                  JR   nz,keyTryMinus   
FEBF   3A 3C 09               LD   a,(RAM_PTR)   ;get pointer
FEC2   FE 02                  CP   2   ;is it at bottom?
FEC4   28 E5                  JR   z,dumpKey   ;yet, get key again
FEC6   3C                     INC   a   
FEC7   32 3C 09               LD   (RAM_PTR),a   ;save it
FECA   18 B3                  JR   dumpLoop   
FECC                KEYTRYMINUS:      
FECC   FE 11                  CP   11H   ;is it minus key?
FECE   20 DB                  JR   nz,dumpKey   ;get key again
FED0   3A 3C 09               LD   a,(RAM_PTR)   ;get pointer
FED3   B7                     OR   a   ;is it at top?
FED4   28 D5                  JR   z,dumpKey   ;yet, get key again
FED6   3D                     DEC   a   
FED7   32 3C 09               LD   (RAM_PTR),a   ;save it
FEDA   18 A3                  JR   dumpLoop   
FEDC                DISPLAYRAMLINE:      
FEDC   CD E5 FE               CALL   genRAMline   ;input HL, output DE
FEDF   EB                     EX   de,hl   
FEE0   0E 0D                  LD   c,13   ;string to LCD
FEE2   D7                     RST   10H   
FEE3   EB                     EX   de,hl   
FEE4   C9                     RET      
FEE5                             ; fill RTC_BUFF with line to display on LCD
FEE5                             ; someting like this 06:06 07 08 09 0A 0B
FEE5                             ; input: HL = address of first byte to display
FEE5                             ; outptu: DE = address of LCD ASCII line
FEE5                GENRAMLINE:      
FEE5                             ;get index
FEE5   11 1D 09               LD   de,RTC_RAM   
FEE8   B7                     OR   a   
FEE9   ED 52                  SBC   hl,de   ;get index difference
FEEB   7D                     LD   a,l   ;store index in a
FEEC   19                     ADD   hl,de   ;restore HL
FEED   06 06                  LD   b,6   ;six bytes by default
FEEF   FE 1E                  CP   1EH   ;is it on the last line?
FEF1   20 02                  JR   nz,$+4   ;yes, only display one byte
FEF3   06 01                  LD   b,1   ;one byte
FEF5   0E 09                  LD   c,9   ;A to string
FEF7   11 08 09               LD   de,RTC_BUFF   ;convert A to "AA"
FEFA   D7                     RST   10H   
FEFB   3E 3A                  LD   a,":"   ;add colon
FEFD   12                     LD   (de),a   
FEFE   13                     INC   de   
FEFF                RAMDISPLOOP:      
FEFF   7E                     LD   a,(hl)   
FF00   23                     INC   hl   
FF01   0E 09                  LD   c,9   ;A to string
FF03   D7                     RST   10H   
FF04   3E 20                  LD   a," "   ;add space
FF06   12                     LD   (de),a   
FF07   13                     INC   de   
FF08   10 F5                  DJNZ   RAMdisploop   
FF0A   1B                     DEC   de   
FF0B   AF                     XOR   a   
FF0C   12                     LD   (de),a   ;terminate with zero
FF0D   11 08 09               LD   de,RTC_BUFF   ;reset to start of buffer
FF10   C9                     RET      
FF11                             ; Get current time and save in local RAM.
FF11                             ; Returns: H = hour      ; bit 5 = am/pm flag (in 12 hr mode). 1=PM
FF11                             ;          L = minute
FF11                             ;          D = second
FF11                GETRTCTIME:      
FF11   CD F2 FA               CALL   getTime   
FF14   7A                     LD   a,d   ;save seconds
FF15   32 00 09               LD   (RTC_SECS),a   
FF18   7D                     LD   a,l   ;save minutes
FF19   32 02 09               LD   (RTC_MINS),a   
FF1C                             ; check if 12 or 24 hours
FF1C   CD 7D FB               CALL   get1224Mode   ;A = 00H, 24 hour mode, 80h, 12 hr mode
FF1F   B4                     OR   h   ;set bit 7 if 12 hour mode in hours data and save it
FF20   67                     LD   h,a   
FF21   32 03 09               LD   (RTC_HOURS),a   
FF24   C9                     RET      
FF25                             ; Checks the state of the RTC checksum (RAM at 31 slot).  Checksum is the twos
FF25                             ; compliment of the first 16 bytes of RAM.  It will then compare the result
FF25                             ; with the stored checksum in slot 31.
FF25                             ; Input: none
FF25                             ; Output: A = 00 if match or something else if no match
FF25                             ;         Zero Flag = set if calculated checksum = stored checksum
FF25                             ; Destroy: A
FF25                CHECKRTCCHECKSUM:      
FF25   CD 30 FF               CALL   getRTCChecksum   
FF28   6F                     LD   l,a   
FF29   16 1E                  LD   d,30   
FF2B   CD 37 FC               CALL   readRTCByte   ;get stored checksum
FF2E   95                     SUB   l   
FF2F   C9                     RET      ;Zero flag set if checksum = stored checksum
FF30                             ; Calculate checksum for MON3 stored values.  First 16 bytes of RAM are reserved
FF30                             ; for MON3.  Calculate the checksum of the first 16 bytes.  Checksum is the
FF30                             ; twos compliment of the sum of the 16 bytes
FF30                             ; Input: none
FF30                             ; Output: A = calculated checksum
FF30                GETRTCCHECKSUM:      
FF30   E5                     PUSH   hl   
FF31   C5                     PUSH   bc   
FF32   21 1D 09               LD   hl,RTC_RAM   
FF35   CD 53 FC               CALL   burstRTCRead   ;put RAM data in RTC_RAM location
FF38   21 1D 09               LD   hl,RTC_RAM   ;index HL to start position
FF3B   06 10                  LD   b,16   ;B=16 bytes to parse
FF3D   AF                     XOR   a   ;A=initial checksum
FF3E                CHECKSUMLOOP:      
FF3E   4E                     LD   c,(hl)   ;get RAM value
FF3F   81                     ADD   a,c   
FF40   23                     INC   hl   ;move to next RAM value
FF41   10 FB                  DJNZ   checksumloop   
FF43   ED 44                  NEG      ;get the twos compliment
FF45   C1                     POP   bc   
FF46   E1                     POP   hl   
FF47   C9                     RET      ;Zero flag set if checksum = stored checksum
FF48                             ; ----------------------------------------------------------------------------
FF48                             ; RAM Locations
FF48                             ; ----------------------------------------------------------------------------
FF48                RTC_BASE:   EQU   0900H   ;Start of RAM location
FF48                RTC_SECS:   EQU   RTC_BASE   ;Seconds (1-byte)
FF48                RTC_OSEC:   EQU   RTC_BASE+1   ;Old Seconds (1-byte)
FF48                RTC_MINS:   EQU   RTC_BASE+2   ;Minutes (1-byte)
FF48                RTC_HOURS:   EQU   RTC_BASE+3   ;Hours (1-byte)
FF48                RTC_DAY:   EQU   RTC_BASE+4   ;Day of Week (1-byte)
FF48                RTC_MONTH:   EQU   RTC_BASE+5   ;Month (1-byte)
FF48                RTC_YEAR:   EQU   RTC_BASE+6   ;Year (2-bytes)
FF48                RTC_BUFF:   EQU   RTC_BASE+8   ;LCD Buffer (21-bytes)
FF48                RTC_RAM:   EQU   RTC_BASE+29   ;RAM Data (31-byte)
FF48                RAM_PTR:   EQU   RTC_BASE+60   ;RAM Pointer (1-byte)
FF48                             ; ----------------------------------------------------------------------------
FF48                             ; constants
FF48                             ; ----------------------------------------------------------------------------
FF48                RTC_PORT:   EQU   0FCH   
FF48   A7 C7 C6 4B C6 C3 SEGDISP:   DB   0A7H,0C7H,0C6H,4BH,0C6H,0C3H   
FF4E   4D 6F 6E 64 61 79 00 DAYSLIST:   DB   "Monday",0   
FF55   54 75 65 73 64 61 79 00 DB   "Tuesday",0   
FF5D   57 65 64 6E 65 73 64 61 79 00 DB   "Wednesday",0   
FF67   54 68 75 72 73 64 61 79 00 DB   "Thursday",0   
FF70   46 72 69 64 61 79 00   DB   "Friday",0   
FF77   53 61 74 75 72 64 61 79 00 DB   "Saturday",0   
FF80   53 75 6E 64 61 79 00   DB   "Sunday",0   
FF87   48 3A 4D 3A 53 20 50 4D 3A 30 2D 33 2C 20 50 52 41 4D 3A 38 00 HELPLIST:   DB   "H:M:S PM:0-3, PRAM:8",0   
FF9C   57 44 20 44 2F 4D 2F 59 3A 34 2D 37 2C 20 52 53 45 54 3A 46 00 DB   "WD D/M/Y:4-7, RSET:F",0   
FFB1   93 FA        DSAPIFUNCTIONS:   DW   checkDS1302Present   
FFB3   B8 FA                  DW   resetDS1302   
FFB5   F2 FA                  DW   getTime   
FFB7   08 FB                  DW   setTime   
FFB9   24 FB                  DW   getDate   
FFBB   3C FB                  DW   setDate   
FFBD   4F FB                  DW   getDay   
FFBF   6A FB                  DW   setDay   
FFC1   7D FB                  DW   get1224Mode   
FFC3   88 FB                  DW   set12HrMode   
FFC5   AE FB                  DW   set24HrMode   
FFC7   37 FC                  DW   readRTCByte   
FFC9   46 FC                  DW   writeRTCByte   
FFCB   53 FC                  DW   burstRTCRead   
FFCD   C2 FC                  DW   bcdToBin   
FFCF   D5 FC                  DW   binToBcd   
FFD1   D9 FB                  DW   formatTime   
FFD3   16 FC                  DW   formatDate   
FFD5   E8 FC                  DW   RTCSetup   
FFD7                DSAPIFNMAX:   EQU   ($-DSAPIFunctions)/2   
FFD7                             ; 
FFEC                          .ORG   BASE_ADDR+3FECH   ; 16k
FFEC                             ; 
FFEC   E9 07        RELMAJOR:   DW   07E9h   ; 2025 - for the API
FFEE   16 00        RELMINOR:   DW   0016h   
FFF0   4D 4F 4E 33 2E 31 47 00 SOFTWARE:   DB   "MON3.1G",0   
FFF8   32 30 32 35 2E 31 36 00 RELEASE:   DB   REL_TXT,0   
10000               REL_TXT:   EQU   "2025.16"   
10000                            ; 
10000                         .END      
10000                            ; 
10000                         .BINFROM   0C000H   


