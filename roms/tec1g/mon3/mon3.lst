D800                          .ORG   BASE_ADDR+1800H   
D800                             ; MON3 Additional Packages
D800                             ; Include packages are to be placed in memory from 0D000H to 0FFECH
D800                             ; Disassembler code
D800                             ; Graphical LCD 128 x 64 Library
D800                             ; ------------------------------
D800                             ; By B. Chiha May-2023
D800                             ; 
D800                             ; This is a native Z80 Graphics library to be used with 128x64 Graphical LCD Screens
D800                             ; 
D800                             ; There are a few variants of these LCD screens, but they must all must use the ST7920
D800                             ; LCD Controller.  The LCD Screen that I used is the QC12864B.  This screen has two
D800                             ; ST7921 Panels (128 x 32) stacked one above the other.
D800                             ; 
D800                             ; These screens have DDRAM (Graphics) and CGRAM (Text) areas.  Both RAM areas can
D800                             ; be displayed at the same time.
D800                             ; 
D800                             ; The Pinout for the QC12864B board is as follows:
D800                             ; 
D800                             ; Pin	Name	Desc                    Serial  Parallel
D800                             ; ---   ----    -------------           ------  -------------
D800                             ; 1     VSS     Ground                  GND     GND
D800                             ; 2     VDD     Power                   5v      5v
D800                             ; 3     V0      Contrast                N/A     N/A
D800                             ; 4     D/I     IR/DR (CS)              5v      A7
D800                             ; 5     R/W     R/W (SID)               D0      RD (inverted)
D800                             ; 6     E       Enable (SCLK)           D1      Port 7 (inverted)
D800                             ; 7     DB0     Data                    N/A     D0
D800                             ; 8     DB1     Data                    N/A     D1
D800                             ; 9     DB2     Data                    N/A     D2
D800                             ; 10    DB3     Data                    N/A     D3
D800                             ; 11    DB4     Data                    N/A     D4
D800                             ; 12    DB5     Data                    N/A     D5
D800                             ; 13    DB6     Data                    N/A     D6
D800                             ; 14    DB7     Data                    N/A     D7
D800                             ; 15    PSB     Serial/Para             GND     5v
D800                             ; 16    NC
D800                             ; 17    RST     Reset                   RST     RST
D800                             ; 18    VEE     LCD Drive               N/A     N/A
D800                             ; 19    A       Backlight               5v/NC   5v/NC
D800                             ; 20    K       Backlight               GND/NC  GND/NC
D800                             ; 
D800                             ; 
D800                             ; Modifiable values.  Thse three values can be modified to suit your own set up
D800                             ; GLCD_INST and GLCD_DATA are the output ports to send an Instruction or Data value.
D800                             ; V_DELAY_US is the minimum delay needed for a command to be processed by the
D800                             ; LCD board.  If only some of the data is being sent, make this value larger
D800                             ;Port 7 on TEC is connected to LCD Enable (Pin 6)
D800                             ;A7 is connected to Register select (Pin 4).  (A7=0 for Instruction, A7=1 for Data)
D800                V_DELAY_US:   EQU   000AH   ;Delay for 76us on your system
D800                             ; Dont need to modify anything else below.
D800                UP:       EQU   05H   ; Up Arrow
D800                DN:       EQU   06H   ; Down Arrow
D800                FF:       EQU   0CH   ; Form Feed
D800                CURSOR:   EQU   8FH   ; Cursor
D800                             ; Initialise LCD
D800                INITLCD:      
D800   21 97 DD               LD   HL,INIT_BASIC   ;POINT HL TO LCD INITIALIZE TABLE
D803   06 04                  LD   B,04H   ;B=4 BYTES
D805                NEXT_CMD:      
D805   7E                     LD   A,(HL)   
D806   D3 07                  OUT   (GLCD_INST),A   
D808   CD 02 DB               CALL   delayUS   
D80B   23                     INC   HL   
D80C   10 F7                  DJNZ   NEXT_CMD   
D80E   11 40 01               LD   DE,0140H   ;1.6 ms
D811   CD 05 DB               CALL   delayMS   
D814   21 00 0A               LD   HL,GBUF   ;Set viewport
D817   22 13 0E               LD   (VPORT),HL   ;to GBUF
D81A   CD 2D D8               CALL   clearGrLCD   
D81D                             ; Clears the Graphics Memory Buffer
D81D                CLEARGBUF:      
D81D   2A 13 0E               LD   HL,(VPORT)   
D820   ED 5B 13 0E            LD   DE,(VPORT)   
D824   13                     INC   DE   
D825   AF                     XOR   A   
D826   77                     LD   (HL),A   
D827   01 FF 03               LD   BC,03FFH   
D82A   ED B0                  LDIR      
D82C   C9                     RET      
D82D                             ; Clears the Graphics LCD Buffer
D82D                CLEARGRLCD:      
D82D   CD 6D D8               CALL   setGrMode   
D830   0E 00                  LD   C,00H   
D832                CLR_X:       
D832   3E 80                  LD   A,80H   
D834   B1                     OR   C   
D835   D3 07                  OUT   (GLCD_INST),A   
D837   CD 02 DB               CALL   delayUS   
D83A   3E 80                  LD   A,80H   
D83C   D3 07                  OUT   (GLCD_INST),A   
D83E   CD 02 DB               CALL   delayUS   
D841   AF                     XOR   A   ;Clear Byte
D842   06 10                  LD   B,10H   
D844                CLR_Y:       
D844   D3 87                  OUT   (GLCD_DATA),A   
D846   CD 02 DB               CALL   delayUS   
D849   D3 87                  OUT   (GLCD_DATA),A   
D84B   CD 02 DB               CALL   delayUS   
D84E   10 F4                  DJNZ   CLR_Y   
D850   0C                     INC   C   
D851   79                     LD   A,C   
D852   FE 20                  CP   20H   
D854   20 DC                  JR   NZ,CLR_X   
D856   C9                     RET      
D857                             ; Clears the ASCII Text LCD
D857                CLEARTXTLCD:      
D857   CD 7B D8               CALL   setTxtMode   
D85A   3E 80                  LD   A,80H   
D85C   D3 07                  OUT   (GLCD_INST),A   
D85E   CD 02 DB               CALL   delayUS   
D861   06 40                  LD   B,40H   
D863                CLR_ROWS:      
D863   3E 20                  LD   A," "   
D865   D3 87                  OUT   (GLCD_DATA),A   
D867   CD 02 DB               CALL   delayUS   
D86A   10 F7                  DJNZ   CLR_ROWS   
D86C   C9                     RET      
D86D                             ; Set Graphics Mode
D86D                SETGRMODE:      
D86D   3E 34                  LD   A,34H   
D86F   D3 07                  OUT   (GLCD_INST),A   
D871   CD 02 DB               CALL   delayUS   
D874   3E 36                  LD   A,36H   
D876   D3 07                  OUT   (GLCD_INST),A   
D878   C3 02 DB               JP   delayUS   
D87B                             ; Set Text Mode
D87B                SETTXTMODE:      
D87B   3E 30                  LD   A,30H   
D87D   D3 07                  OUT   (GLCD_INST),A   
D87F   C3 02 DB               JP   delayUS   
D882                             ;Draw Box
D882                             ;Inputs: BC = X0,Y0
D882                             ;        DE = X1,Y1
D882                             ;Destroys: HL
D882                DRAWBOX:      
D882   C5                     PUSH   BC   
D883                TOP:         
D883   CD 3D DA               CALL   drawPixel   
D886   7A                     LD   A,D   
D887   04                     INC   B   
D888   B8                     CP   B   
D889   30 F8                  JR   NC,TOP   
D88B   C1                     POP   BC   
D88C   C5                     PUSH   BC   
D88D   4B                     LD   C,E   
D88E                BOTTOM:      
D88E   CD 3D DA               CALL   drawPixel   
D891   7A                     LD   A,D   
D892   04                     INC   B   
D893   B8                     CP   B   
D894   30 F8                  JR   NC,BOTTOM   
D896   C1                     POP   BC   
D897   C5                     PUSH   BC   
D898                LEFT:        
D898   CD 3D DA               CALL   drawPixel   
D89B   7B                     LD   A,E   
D89C   0C                     INC   C   
D89D   B9                     CP   C   
D89E   30 F8                  JR   NC,LEFT   
D8A0   C1                     POP   BC   
D8A1   C5                     PUSH   BC   
D8A2   42                     LD   B,D   
D8A3                RIGHT:       
D8A3   CD 3D DA               CALL   drawPixel   
D8A6   7B                     LD   A,E   
D8A7   0C                     INC   C   
D8A8   B9                     CP   C   
D8A9   30 F8                  JR   NC,RIGHT   
D8AB   C1                     POP   BC   
D8AC   C9                     RET      
D8AD                             ;Fill Box
D8AD                             ;Draws vertical lines from X0,Y0 to X0,Y1 and increase X0 to X1 until X0=X1
D8AD                             ;Inputs: BC = X0,Y0
D8AD                             ;        DE = X1,Y1
D8AD                             ;Destroys: HL
D8AD                FILLBOX:      
D8AD   C5                     PUSH   BC   
D8AE                NEXT_PIXEL:      
D8AE   CD 3D DA               CALL   drawPixel   
D8B1   7B                     LD   A,E   
D8B2   0C                     INC   C   
D8B3   B9                     CP   C   
D8B4   30 F8                  JR   NC,NEXT_PIXEL   
D8B6   C1                     POP   BC   
D8B7   7A                     LD   A,D   
D8B8   04                     INC   B   
D8B9   B8                     CP   B   
D8BA   30 F1                  JR   NC,fillBox   
D8BC   C9                     RET      
D8BD                             ;Draw a line between two points using Bresenham Line Algorithm
D8BD                             ; void plotLine(int x0, int y0, int x1, int y1)
D8BD                             ; {
D8BD                             ;    int dx =  abs(x1-x0), sx = x0<x1 ? 1 : -1;
D8BD                             ;    int dy = -abs(y1-y0), sy = y0<y1 ? 1 : -1;
D8BD                             ;    int err = dx+dy, e2; /* error value e_xy */
D8BD                             ;    for(;;){  /* loop */
D8BD                             ;       setPixel(x0,y0);
D8BD                             ;       if (x0==x1 && y0==y1) break;
D8BD                             ;       e2 = 2*err;
D8BD                             ;       if (e2 >= dy) 00bbIGVyciArPSBkeTsgeDAgKz0gc3g7IA== /* e_xy+e_x > 0 */
D8BD                             ;       if (e2 <= dx) 00bbIGVyciArPSBkeDsgeTAgKz0gc3k7IA== /* e_xy+e_y < 0 */
D8BD                             ;    }
D8BD                             ; }
D8BD                             ;Inputs: BC = X0,Y0
D8BD                             ;        DE = X1,Y1
D8BD                DRAWLINE:      
D8BD                             ;check that points are in range
D8BD   79                     LD   A,C   
D8BE   FE 40                  CP   40H   
D8C0   D0                     RET   NC   
D8C1   78                     LD   A,B   
D8C2   FE 80                  CP   80H   
D8C4   D0                     RET   NC   
D8C5   7B                     LD   A,E   
D8C6   FE 40                  CP   40H   
D8C8   D0                     RET   NC   
D8C9   7A                     LD   A,D   
D8CA   FE 80                  CP   80H   
D8CC   D0                     RET   NC   
D8CD                             ;sx = x0<x1 ? 1 : -1
D8CD   26 01                  LD   H,01H   
D8CF   78                     LD   A,B   
D8D0   BA                     CP   D   
D8D1   38 02                  JR   C,$ + 4   
D8D3   26 FF                  LD   H,0FFH   
D8D5   7C                     LD   A,H   
D8D6   32 02 0E               LD   (SX),A   
D8D9                             ;sy = y0<y1 ? 1 : -1
D8D9   26 01                  LD   H,01H   
D8DB   79                     LD   A,C   
D8DC   BB                     CP   E   
D8DD   38 02                  JR   C,$ + 4   
D8DF   26 FF                  LD   H,0FFH   
D8E1   7C                     LD   A,H   
D8E2   32 03 0E               LD   (SY),A   
D8E5   ED 53 00 0E            LD   (ENDPT),DE   
D8E9                             ;dx =  abs(x1-x0)
D8E9   C5                     PUSH   BC   
D8EA   6A                     LD   L,D   
D8EB   26 00                  LD   H,0   
D8ED   48                     LD   C,B   
D8EE   06 00                  LD   B,0   
D8F0   B7                     OR   A   
D8F1   ED 42                  SBC   HL,BC   
D8F3   CD 5E D9               CALL   ABSHL   
D8F6   22 04 0E               LD   (DX),HL   
D8F9   C1                     POP   BC   
D8FA                             ;dy = -abs(y1-y0)
D8FA   C5                     PUSH   BC   
D8FB   6B                     LD   L,E   
D8FC   26 00                  LD   H,0   
D8FE   06 00                  LD   B,0   
D900   B7                     OR   A   
D901   ED 42                  SBC   HL,BC   
D903   CD 5E D9               CALL   ABSHL   
D906   AF                     XOR   A   
D907   95                     SUB   L   
D908   6F                     LD   L,A   
D909   9F                     SBC   A,A   
D90A   94                     SUB   H   
D90B   67                     LD   H,A   
D90C   22 06 0E               LD   (DY),HL   
D90F   C1                     POP   BC   
D910                             ;err = dx+dy,
D910   ED 5B 04 0E            LD   DE,(DX)   
D914   19                     ADD   HL,DE   
D915   22 08 0E               LD   (ERR),HL   
D918                LINE_LOOP:      
D918                             ;setPixel(x0,y0)
D918   CD 3D DA               CALL   drawPixel   
D91B                             ;if (x0==x1 && y0==y1) break;
D91B   3A 01 0E               LD   A,(ENDPT + 1)   
D91E   B8                     CP   B   
D91F   20 05                  JR   NZ,$ + 7   
D921   3A 00 0E               LD   A,(ENDPT)   
D924   B9                     CP   C   
D925   C8                     RET   Z   
D926                             ;e2 = 2*err;
D926   2A 08 0E               LD   HL,(ERR)   
D929   29                     ADD   HL,HL   ;E2
D92A                             ;if (e2 >= dy)  err += dy; x0 += sx;
D92A   ED 5B 06 0E            LD   DE,(DY)   
D92E   B7                     OR   A   
D92F   ED 52                  SBC   HL,DE   
D931   19                     ADD   HL,DE   
D932   FA 43 D9               JP   M,LL2   
D935   E5                     PUSH   HL   
D936   2A 08 0E               LD   HL,(ERR)   
D939   19                     ADD   HL,DE   
D93A   22 08 0E               LD   (ERR),HL   
D93D   3A 02 0E               LD   A,(SX)   
D940   80                     ADD   A,B   
D941   47                     LD   B,A   
D942   E1                     POP   HL   
D943                LL2:         
D943                             ;if (e2 <= dx)  err += dx; y0 += sy;
D943   ED 5B 04 0E            LD   DE,(DX)   
D947   B7                     OR   A   
D948   ED 52                  SBC   HL,DE   
D94A   19                     ADD   HL,DE   
D94B   28 03                  JR   Z,LL3   
D94D   F2 18 D9               JP   P,LINE_LOOP   
D950                LL3:         
D950   2A 08 0E               LD   HL,(ERR)   
D953   19                     ADD   HL,DE   
D954   22 08 0E               LD   (ERR),HL   
D957   3A 03 0E               LD   A,(SY)   
D95A   81                     ADD   A,C   
D95B   4F                     LD   C,A   
D95C   18 BA                  JR   LINE_LOOP   
D95E                ABSHL:       
D95E   CB 7C                  BIT   7,H   
D960   C8                     RET   Z   
D961   AF                     XOR   A   
D962   95                     SUB   L   
D963   6F                     LD   L,A   
D964   9F                     SBC   A,A   
D965   94                     SUB   H   
D966   67                     LD   H,A   
D967   C9                     RET      
D968                             ;Draw a circle from a midpoint to a radius using Bresenham Line Algorithm
D968                             ; void plotCircle(int xm, int ym, int r)
D968                             ; {
D968                             ;    int x = -r, y = 0, err = 2-2*r, i = 0; /* II. Quadrant */
D968                             ;    printf("Midpoint = (%X,%X), Radius = %X\n", xm, ym, r);
D968                             ;    do {
D968                             ;       printf("(%X,%X) ", xm-x, ym+y); /*   I. Quadrant */
D968                             ;       printf("(%X,%X) ", xm-y, ym-x); /*  II. Quadrant */
D968                             ;       printf("(%X,%X) ", xm+x, ym-y); /* III. Quadrant */
D968                             ;       printf("(%X,%X) ", xm+y, ym+x); /*  IV. Quadrant */
D968                             ;       r = err;
D968                             ;       if (r <= y) err += ++y*2+1;           /* e_xy+e_y < 0 */
D968                             ;       if (r > x || err > y) err += ++x*2+1; /* e_xy+e_x > 0 or no 2nd y-step */
D968                             ;       printf("x = %d, r = %d, y = %d, err =%d\n", x, r, y, err);
D968                             ;    } while (x < 0);
D968                             ; }
D968                             ;Inputs BC = xm,ym (Midpoint)
D968                             ;       E = radius
D968                DRAWCIRCLE:      
D968                             ;   int x = -r, err = 2-2*r; /* II. Quadrant */
D968   AF                     XOR   A   
D969   93                     SUB   E   
D96A   32 02 0E               LD   (SX),A   ;x
D96D                             ;   y = 0
D96D   AF                     XOR   A   
D96E   32 03 0E               LD   (SY),A   ;y
D971                             ;   RAD = r
D971   16 00                  LD   D,00H   
D973   7B                     LD   A,E   
D974   ED 53 0A 0E            LD   (RAD),DE   ;r
D978                             ;   err = 2-2*r
D978   EB                     EX   DE,HL   
D979   29                     ADD   HL,HL   
D97A   EB                     EX   DE,HL   
D97B   21 02 00               LD   HL,0002H   
D97E   B7                     OR   A   
D97F   ED 52                  SBC   HL,DE   ;err
D981   22 08 0E               LD   (ERR),HL   
D984                CIRCLE_LOOP:      
D984                             ;       setPixel(xm-x, ym+y); /*   I. Quadrant */
D984   C5                     PUSH   BC   
D985   3A 02 0E               LD   A,(SX)   
D988   ED 44                  NEG      
D98A   80                     ADD   A,B   
D98B   47                     LD   B,A   
D98C   3A 03 0E               LD   A,(SY)   
D98F   81                     ADD   A,C   
D990   4F                     LD   C,A   
D991   CD 3D DA               CALL   drawPixel   
D994   C1                     POP   BC   
D995                             ;       setPixel(xm+x, ym-y); /* III. Quadrant */
D995   C5                     PUSH   BC   
D996   3A 02 0E               LD   A,(SX)   
D999   80                     ADD   A,B   
D99A   47                     LD   B,A   
D99B   3A 03 0E               LD   A,(SY)   
D99E   ED 44                  NEG      
D9A0   81                     ADD   A,C   
D9A1   4F                     LD   C,A   
D9A2   CD 3D DA               CALL   drawPixel   
D9A5   C1                     POP   BC   
D9A6                             ;       setPixel(xm-y, ym-x); /*  II. Quadrant */
D9A6   C5                     PUSH   BC   
D9A7   3A 03 0E               LD   A,(SY)   
D9AA   ED 44                  NEG      
D9AC   80                     ADD   A,B   
D9AD   47                     LD   B,A   
D9AE   3A 02 0E               LD   A,(SX)   
D9B1   ED 44                  NEG      
D9B3   81                     ADD   A,C   
D9B4   4F                     LD   C,A   
D9B5   CD 3D DA               CALL   drawPixel   
D9B8   C1                     POP   BC   
D9B9                             ;       setPixel(xm+y, ym+x); /*  IV. Quadrant */
D9B9   C5                     PUSH   BC   
D9BA   3A 03 0E               LD   A,(SY)   
D9BD   80                     ADD   A,B   
D9BE   47                     LD   B,A   
D9BF   3A 02 0E               LD   A,(SX)   
D9C2   81                     ADD   A,C   
D9C3   4F                     LD   C,A   
D9C4   CD 3D DA               CALL   drawPixel   
D9C7   C1                     POP   BC   
D9C8                             ;       r = err;
D9C8   2A 08 0E               LD   HL,(ERR)   
D9CB   22 0A 0E               LD   (RAD),HL   
D9CE                             ;       if (r <= y) err += ++y*2+1;           /* e_xy+e_y < 0 */
D9CE   3A 03 0E               LD   A,(SY)   
D9D1   5F                     LD   E,A   
D9D2   16 00                  LD   D,0   
D9D4   B7                     OR   A   
D9D5   ED 52                  SBC   HL,DE   
D9D7   19                     ADD   HL,DE   
D9D8   28 03                  JR   Z,$ + 5   
D9DA   F2 F0 D9               JP   P,DS1   
D9DD   3A 03 0E               LD   A,(SY)   
D9E0   3C                     INC   A   
D9E1   32 03 0E               LD   (SY),A   
D9E4   87                     ADD   A,A   
D9E5   3C                     INC   A   
D9E6   5F                     LD   E,A   
D9E7   16 00                  LD   D,0   
D9E9   2A 08 0E               LD   HL,(ERR)   
D9EC   19                     ADD   HL,DE   
D9ED   22 08 0E               LD   (ERR),HL   
D9F0                             ;       if (r > x || err > y) err += ++x*2+1; /* e_xy+e_x > 0 or no 2nd y-step */
D9F0                DS1:         
D9F0   2A 0A 0E               LD   HL,(RAD)   
D9F3   3A 02 0E               LD   A,(SX)   
D9F6   16 FF                  LD   D,0FFH   
D9F8   5F                     LD   E,A   
D9F9   B7                     OR   A   
D9FA   ED 52                  SBC   HL,DE   
D9FC   19                     ADD   HL,DE   
D9FD   28 03                  JR   Z,$ + 5   
D9FF   F2 14 DA               JP   P,DS2   
DA02   2A 08 0E               LD   HL,(ERR)   
DA05   3A 03 0E               LD   A,(SY)   
DA08   16 00                  LD   D,0   
DA0A   5F                     LD   E,A   
DA0B   B7                     OR   A   
DA0C   ED 52                  SBC   HL,DE   
DA0E   19                     ADD   HL,DE   
DA0F   28 16                  JR   Z,DS3   
DA11   FA 27 DA               JP   M,DS3   
DA14                DS2:         
DA14   3A 02 0E               LD   A,(SX)   
DA17   3C                     INC   A   
DA18   32 02 0E               LD   (SX),A   
DA1B   87                     ADD   A,A   
DA1C   3C                     INC   A   
DA1D   5F                     LD   E,A   
DA1E   16 FF                  LD   D,0FFH   
DA20   2A 08 0E               LD   HL,(ERR)   
DA23   19                     ADD   HL,DE   
DA24   22 08 0E               LD   (ERR),HL   
DA27                             ;   } while (x < 0);
DA27                DS3:         
DA27   3A 02 0E               LD   A,(SX)   
DA2A   B7                     OR   A   
DA2B   C2 84 D9               JP   NZ,CIRCLE_LOOP   
DA2E   C9                     RET      
DA2F                             ;Fill Circle
DA2F                             ;Fills a circle by increasing radius until Radius = Original Radius E
DA2F                             ;Inputs BC = xm,ym (Midpoint)
DA2F                             ;       E = radius
DA2F                FILLCIRCLE:      
DA2F   16 01                  LD   D,01H   ;Start radius
DA31                NEXT_CIRCLE:      
DA31   D5                     PUSH   DE   ;Save end Radius
DA32   5A                     LD   E,D   
DA33   CD 68 D9               CALL   drawCircle   
DA36   D1                     POP   DE   ;Restore Radius
DA37   7B                     LD   A,E   
DA38   14                     INC   D   
DA39   BA                     CP   D   
DA3A   30 F5                  JR   NC,NEXT_CIRCLE   
DA3C   C9                     RET      
DA3D                             ;Draw Pixel in position X Y
DA3D                             ;Input B = column/X (0-127), C = row/Y (0-63)
DA3D                             ;destroys HL
DA3D                DRAWPIXEL:      
DA3D   79                     LD   A,C   
DA3E   FE 40                  CP   40H   
DA40   D0                     RET   NC   
DA41   78                     LD   A,B   
DA42   FE 80                  CP   80H   
DA44   D0                     RET   NC   
DA45   D5                     PUSH   DE   
DA46   CD 71 DA               CALL   SET_GBUF   
DA49   7A                     LD   A,D   
DA4A   B6                     OR   (HL)   
DA4B   77                     LD   (HL),A   
DA4C   D1                     POP   DE   
DA4D   C9                     RET      
DA4E                             ;Clear Pixel in position X Y
DA4E                             ;Input B = column/X (0-127), C = row/Y (0-63)
DA4E                             ;destroys HL
DA4E                CLEARPIXEL:      
DA4E   79                     LD   A,C   
DA4F   FE 40                  CP   40H   
DA51   D0                     RET   NC   
DA52   78                     LD   A,B   
DA53   FE 80                  CP   80H   
DA55   D0                     RET   NC   
DA56   D5                     PUSH   DE   
DA57   CD 71 DA               CALL   SET_GBUF   
DA5A   7A                     LD   A,D   
DA5B   2F                     CPL      
DA5C   A6                     AND   (HL)   
DA5D   77                     LD   (HL),A   
DA5E   D1                     POP   DE   
DA5F   C9                     RET      
DA60                             ;Flip Pixel in position X Y
DA60                             ;Input B = column/X (0-127), C = row/Y (0-63)
DA60                             ;destroys HL
DA60                FLIPPIXEL:      
DA60   79                     LD   A,C   
DA61   FE 40                  CP   40H   
DA63   D0                     RET   NC   
DA64   78                     LD   A,B   
DA65   FE 80                  CP   80H   
DA67   D0                     RET   NC   
DA68   D5                     PUSH   DE   
DA69   CD 71 DA               CALL   SET_GBUF   
DA6C   7A                     LD   A,D   
DA6D   AE                     XOR   (HL)   
DA6E   77                     LD   (HL),A   
DA6F   D1                     POP   DE   
DA70   C9                     RET      
DA71                             ;Helper routine to set HL to the correct GBUF address given X and Y
DA71                             ;Input B = column/X (0-127), C = row/Y (0-63)
DA71                             ;Output HL = address of GBUF X,Y byte, D = Byte with Pixel Bit Set
DA71                             ;Destroys E
DA71                SET_GBUF:      
DA71   69                     LD   L,C   
DA72   26 00                  LD   H,00H   
DA74   29                     ADD   HL,HL   
DA75   29                     ADD   HL,HL   
DA76   29                     ADD   HL,HL   
DA77   29                     ADD   HL,HL   
DA78   ED 5B 13 0E            LD   DE,(VPORT)   
DA7C   1B                     DEC   DE   
DA7D   19                     ADD   HL,DE   
DA7E   78                     LD   A,B   
DA7F   16 08                  LD   D,08H   
DA81                BASE_COL:      
DA81   23                     INC   HL   
DA82   92                     SUB   D   
DA83   30 FC                  JR   NC,BASE_COL   
DA85   2F                     CPL      
DA86   16 01                  LD   D,01H   
DA88   B7                     OR   A   
DA89   C8                     RET   Z   
DA8A                SHIFT_BIT:      
DA8A   CB 22                  SLA   D   
DA8C   3D                     DEC   A   
DA8D   20 FB                  JR   NZ,SHIFT_BIT   
DA8F   C9                     RET      
DA90                             ;Main draw routine.  Moves GBUF to LCD and clears buffer
DA90                             ;Destroys all
DA90                PLOTTOLCD:      
DA90   2A 13 0E               LD   HL,(VPORT)   
DA93   0E 80                  LD   C,80H   
DA95                PLOT_ROW:      
DA95   79                     LD   A,C   
DA96   E6 9F                  AND   9FH   
DA98   D3 07                  OUT   (GLCD_INST),A   ;Vertical
DA9A   CD 02 DB               CALL   delayUS   
DA9D   3E 80                  LD   A,80H   
DA9F   CB 69                  BIT   5,C   
DAA1   28 02                  JR   Z,$ + 4   
DAA3   F6 08                  OR   08H   
DAA5   D3 07                  OUT   (GLCD_INST),A   ;Horizontal
DAA7   CD 02 DB               CALL   delayUS   
DAAA   06 10                  LD   B,10H   ;send eight double bytes (16 bytes)
DAAC                PLOT_COLUMN:      
DAAC   7E                     LD   A,(HL)   
DAAD   D3 87                  OUT   (GLCD_DATA),A   
DAAF   CD 02 DB               CALL   delayUS   
DAB2   3A 0C 0E               LD   A,(CLRBUF)   
DAB5   B7                     OR   A   
DAB6   28 02                  JR   Z,$ + 4   
DAB8   36 00                  LD   (HL),00H   ;Clear Buffer if CLRBUF is non zero
DABA   23                     INC   HL   
DABB   10 EF                  DJNZ   PLOT_COLUMN   
DABD   0C                     INC   C   
DABE   CB 71                  BIT   6,C   ;Is Row = 64?
DAC0   28 D3                  JR   Z,PLOT_ROW   
DAC2   C9                     RET      
DAC3                             ; Print ASCII text on a given row
DAC3                             ; Inputs: C = 0 to 3 Row Number
DAC3                             ;         .db "String" on next line, terminate with 0
DAC3                             ; EG:
DAC3                             ;   LD C,2
DAC3                             ;   CALL printString
DAC3                             ;   .db "This Text",0
DAC3                             ; 
DAC3                PRINTSTRING:      
DAC3   41                     LD   B,C   
DAC4   CD 7B D8               CALL   setTxtMode   
DAC7   21 93 DD               LD   HL,ROWS   
DACA   78                     LD   A,B   
DACB   85                     ADD   A,L   
DACC   30 01                  JR   NC,$ + 3   
DACE   24                     INC   H   
DACF   6F                     LD   L,A   
DAD0   7E                     LD   A,(HL)   
DAD1   D3 07                  OUT   (GLCD_INST),A   
DAD3   CD 02 DB               CALL   delayUS   
DAD6   E1                     POP   HL   
DAD7                DS_LOOP:      
DAD7   7E                     LD   A,(HL)   
DAD8   23                     INC   HL   
DAD9   B7                     OR   A   
DADA   28 07                  JR   Z,DS_EXIT   
DADC   D3 87                  OUT   (GLCD_DATA),A   
DADE   CD 02 DB               CALL   delayUS   
DAE1   18 F4                  JR   DS_LOOP   
DAE3                DS_EXIT:      
DAE3   E9                     JP   (HL)   
DAE4                             ;Print Characters at a position X,Y
DAE4                             ;Even though there are 16 columns, only every second column can be written
DAE4                             ;to and two characters are to be printed.  IE: if you want to print one
DAE4                             ;character in column 2, then you must set B=0 and print " x", putting
DAE4                             ;a space before the character.
DAE4                             ;Input B = column/X (0-7), C = row/Y (0-3)
DAE4                             ;      HL = Start address of text to display, terminate with 0
DAE4                PRINTCHARS:      
DAE4   CD 7B D8               CALL   setTxtMode   
DAE7   11 93 DD               LD   DE,ROWS   
DAEA   79                     LD   A,C   
DAEB   83                     ADD   A,E   
DAEC   30 01                  JR   NC,$ + 3   
DAEE   14                     INC   D   
DAEF   5F                     LD   E,A   
DAF0   1A                     LD   A,(DE)   
DAF1   80                     ADD   A,B   
DAF2   D3 07                  OUT   (GLCD_INST),A   
DAF4   CD 02 DB               CALL   delayUS   
DAF7                PC_LOOP:      
DAF7   7E                     LD   A,(HL)   
DAF8   23                     INC   HL   
DAF9   B7                     OR   A   
DAFA   C8                     RET   Z   
DAFB   D3 87                  OUT   (GLCD_DATA),A   
DAFD   CD 02 DB               CALL   delayUS   
DB00   18 F5                  JR   PC_LOOP   
DB02                             ; Delay for LCD write
DB02                DELAYUS:      
DB02   11 0A 00               LD   DE,V_DELAY_US   ;DELAY BETWEEN, was 0010H
DB05                DELAYMS:      
DB05   1B                     DEC   DE   ;EACH BYTE
DB06   7A                     LD   A,D   ;AS PER
DB07   B3                     OR   E   ;LCD MANUFACTER'S
DB08   20 FB                  JR   NZ,delayMS   ;INSTRUCTIONS
DB0A   C9                     RET      
DB0B                             ; Set Buffer Clearing after outputting to LCD
DB0B                             ; Input: A = 0 Buffer to be cleared, A <> 0 Buffer kept
DB0B                SETBUFCLEAR:      
DB0B   3E FF                  LD   A,0FFH   
DB0D   32 0C 0E               LD   (CLRBUF),A   
DB10   C3 1D D8               JP   clearGBUF   
DB13                SETBUFNOCLEAR:      
DB13   AF                     XOR   A   
DB14   32 0C 0E               LD   (CLRBUF),A   
DB17   C9                     RET      
DB18                             ;Initialise the GLCD Terminal
DB18                             ;Clears the GBUF, sets cursor to top left and displays cursor.
DB18                             ;This must be called prior to any Terminal routine.  This routine
DB18                             ;will as call INIT_LCD.
DB18                INITTERMINAL:      
DB18   CD 00 D8               CALL   initLCD   ;Clear LCD GBUF
DB1B   CD 6D D8               CALL   setGrMode   ;Graphics mode
DB1E   CD 13 DB               CALL   setBufNoClear   ;Retain screen
DB21   21 C0 13               LD   HL,TGBUF   ;Reset VPORT and BUFF_TOP to TGBUF
DB24   22 13 0E               LD   (VPORT),HL   ;to GBUF
DB27   22 15 0E               LD   (TBUF),HL   
DB2A   CD 1D D8               CALL   clearGBUF   
DB2D   AF                     XOR   A   ;Clear A
DB2E   32 10 0E               LD   (CURSOR_ON),A   ;Cursor ON
DB31   32 11 0E               LD   (INVERSE),A   ;Inverse OFF
DB34   32 18 0E               LD   (AUTO_LF),A   ;Auto LF ON
DB37   32 17 0E               LD   (ULINE),A   ;UnderLine OFF
DB3A   32 19 0E               LD   (PLOT_ALWAYS),A   ;Plot always ON
DB3D   01 00 00               LD   BC,0000H   
DB40   CD 0A DC               CALL   setCursor   ;Move cursor to top left
DB43   18 67                  JR   DRAW_CURSOR   ;Draw Cursor and exit
DB45                             ;Send or handle ASCII characters to the GLCD screen.  This routines displays
DB45                             ;ASCII characters to the GLCD screen and handles some special control characters
DB45                             ;It also handles scrolling history of 10 lines.  Characters are drawn at the
DB45                             ;current cursor position.  Cursor increments if character is drawn.
DB45                             ;       CR / 0DH = will move the cursor down and reset it column
DB45                             ;       LF / 0AH = is ignored
DB45                             ;       FF / 0CH = clears the terminal (restarts)
DB45                             ;       BS / 08H = will delete the character at the cursor and move cursor back one
DB45                             ;       HT / 09H = will TAB 4 spaces
DB45                             ;       UP / 05H = will scroll up one line if any
DB45                             ;       DN / 06H = will scroll down one line if any
DB45                             ;Input: C = ASCII character to send to the GLCD screen.
DB45                             ;       C = 0  cursor drawn only
DB45                SENDCHARTOLCD:      
DB45                             ;Check for special characters
DB45   79                     LD   A,C   
DB46   B7                     OR   A   ;Zero?
DB47   28 63                  JR   Z,DRAW_CURSOR   
DB49                DO_SCRL_UP:      
DB49   FE 05                  CP   UP   ;Up Arrow
DB4B   20 07                  JR   NZ,DO_SCRL_DN   
DB4D   AF                     XOR   A   
DB4E   CD 7B DC               CALL   MOVE_VPORT   
DB51   C3 90 DA               JP   plotToLCD   
DB54                DO_SCRL_DN:      
DB54   FE 06                  CP   DN   ;Down Arrow
DB56   20 04                  JR   NZ,DO_CR   
DB58   3E 01                  LD   A,1   
DB5A   18 F2                  JR   $-12   ;Move VPORT above
DB5C                DO_CR:       
DB5C                             ;Key is now a drawing character, reset VPORT first
DB5C   21 C0 13               LD   HL,TGBUF   
DB5F   22 13 0E               LD   (VPORT),HL   
DB62   FE 0A                  CP   LF   ;LF
DB64   C8                     RET   Z   
DB65   FE 0D                  CP   CR   ;CR
DB67   20 14                  JR   NZ,DO_FF   
DB69   3A 0E 0E               LD   A,(CURSOR_X)   ;Are we on the first column?
DB6C   B7                     OR   A   
DB6D   F5                     PUSH   AF   
DB6E   CC 58 DD               CALL   Z,drawCursor   
DB71   F1                     POP   AF   
DB72   C4 7A DD               CALL   NZ,drawBlank   ;Clear cursor
DB75   CD 28 DC               CALL   INC_ROW   
DB78   32 0F 0E               LD   (CURSOR_YS),A   ;Save start row
DB7B   18 2F                  JR   DRAW_CURSOR   
DB7D                DO_FF:       
DB7D   FE 0C                  CP   FF   ;Form Feed / Clear Screen
DB7F   28 97                  JR   Z,initTerminal   ;Reset All.
DB81                DO_BS:       
DB81   FE 08                  CP   BKSP   ;Backspace
DB83   20 0B                  JR   NZ,DO_TAB   
DB85   CD 7A DD               CALL   drawBlank   ;Clear cursor
DB88   CD 9B DC               CALL   DEC_CURSOR   
DB8B   CD 7A DD               CALL   drawBlank   
DB8E   18 1C                  JR   DRAW_CURSOR   
DB90                DO_TAB:      
DB90   FE 09                  CP   TAB   ;Horizontal Tab
DB92   20 11                  JR   NZ,DO_CHAR   
DB94   CD 7A DD               CALL   drawBlank   ;Clear cursor
DB97   CD 1B DC               CALL   INC_CURSOR   
DB9A   CD 1B DC               CALL   INC_CURSOR   
DB9D   CD 1B DC               CALL   INC_CURSOR   
DBA0   CD 1B DC               CALL   INC_CURSOR   
DBA3   18 07                  JR   DRAW_CURSOR   
DBA5                DO_CHAR:      
DBA5   57                     LD   D,A   ;get character
DBA6   CD EA DC               CALL   drawGraphic   
DBA9   CD 1B DC               CALL   INC_CURSOR   
DBAC                DRAW_CURSOR:      
DBAC   CD 58 DD               CALL   drawCursor   ;Attempt to Draw cursor
DBAF                JUST_PLOT:      
DBAF   3A 19 0E               LD   A,(PLOT_ALWAYS)   ;Only plot if set
DBB2   B7                     OR   A   
DBB3   C0                     RET   NZ   ;Exit if not set
DBB4   C3 90 DA               JP   plotToLCD   ;Plot screen and exit
DBB7                             ;Send a string of characters to the GLCD.  Prints a string pointed
DBB7                             ;by DE.  It stops printing and returns when either a CR is printed or
DBB7                             ;when the next byte is the same as what is in register C
DBB7                             ;Inputs: DE = address of string to print
DBB7                             ;        C = character to stop printing.
DBB7                             ;Destroy: All
DBB7                SENDSTRINGTOLCD:      
DBB7   41                     LD   B,C   ;Save cp in B
DBB8                NEXT_CHAR:      
DBB8   1A                     LD   A,(DE)   ;Get character
DBB9   13                     INC   DE   ;Move pointer
DBBA   B8                     CP   B   ;Same as B?
DBBB   28 F2                  JR   Z,JUST_PLOT   ;Yes exit and plot LCD screen
DBBD   FE 0D                  CP   CR   ;Is it a CR?
DBBF   20 0E                  JR   NZ,CHECK_FF   
DBC1   21 C0 13               LD   HL,TGBUF   
DBC4   22 13 0E               LD   (VPORT),HL   
DBC7   CD 28 DC               CALL   INC_ROW   
DBCA   32 0F 0E               LD   (CURSOR_YS),A   ;Save start row
DBCD   18 E0                  JR   JUST_PLOT   
DBCF                CHECK_FF:      
DBCF   FE 0C                  CP   FF   ;Is it a FF?
DBD1   28 AA                  JR   Z,DO_FF   ;Yes do a Form Feed and plot LCD screen and exit
DBD3   D9                     EXX      ;Save bulk registers
DBD4   57                     LD   D,A   ;Get Character
DBD5   CD EA DC               CALL   drawGraphic   ;Draw the character
DBD8   CD 1B DC               CALL   INC_CURSOR   ;Move cursor by one
DBDB   D9                     EXX      ;Restore bulk registers
DBDC   18 DA                  JR   NEXT_CHAR   ;Repeat for next character
DBDE   C9                     RET      
DBDF                             ;Display a register in ASCII on the GLCD
DBDF                             ;Input: C = value to convert and display
DBDF                SENDREGTOLCD:      
DBDF   79                     LD   A,C   
DBE0   CD E5 DB               CALL   DRAW_A   ;Do the conversion
DBE3   18 C7                  JR   DRAW_CURSOR   ;exit and plot LCD screen
DBE5                DRAW_A:      
DBE5   F5                     PUSH   AF   ;Save AF
DBE6   0F                     RRCA      ;move high
DBE7   0F                     RRCA      ;nibble to low nibble
DBE8   0F                     RRCA      
DBE9   0F                     RRCA      
DBEA   CD EE DB               CALL   NIBBLE_TO_LCD   ;Convert and display
DBED   F1                     POP   AF   ;Restore AF
DBEE                NIBBLE_TO_LCD:      
DBEE   E6 0F                  AND   0FH   ;mask out high nibble
DBF0   C6 90                  ADD   A,90H   ;convert to
DBF2   27                     DAA      ;ASCII
DBF3   CE 40                  ADC   A,40H   ;using this
DBF5   27                     DAA      ;amazing routine
DBF6   57                     LD   D,A   ;get character
DBF7   CD EA DC               CALL   drawGraphic   ;Draw the character
DBFA   CD 1B DC               CALL   INC_CURSOR   ;Move cursor by one
DBFD   C9                     RET      
DBFE                             ;Display the register HL in ASCII on the GLCD
DBFE                             ;Input: HL = value to convert and display
DBFE                SENDHLTOLCD:      
DBFE   E5                     PUSH   HL   ;Save HL
DBFF   7C                     LD   A,H   ;get H
DC00   CD E5 DB               CALL   DRAW_A   ;Do the conversion
DC03   E1                     POP   HL   
DC04   7D                     LD   A,L   ;get L
DC05   CD E5 DB               CALL   DRAW_A   ;Do the conversion
DC08   18 A2                  JR   DRAW_CURSOR   ;exit and plot LCD screen
DC0A                             ;Set the Graphic cursor position
DC0A                             ;Inputs: BC = X,Y where X = 0..127, Y = 0..63
DC0A                             ;Ignores update if one of the X,Y values are out of range
DC0A                             ;Destroys: A
DC0A                SETCURSOR:      
DC0A                             ;Check range. Exit if X,Y out of range
DC0A   79                     LD   A,C   
DC0B   FE 40                  CP   40H   
DC0D   D0                     RET   NC   
DC0E   78                     LD   A,B   
DC0F   FE 80                  CP   80H   
DC11   D0                     RET   NC   
DC12                             ;Set Cursor and initial start row
DC12   ED 43 0D 0E            LD   (CURSOR_XY),BC   ;Save cursor
DC16   79                     LD   A,C   
DC17   32 0F 0E               LD   (CURSOR_YS),A   ;And initial Y Start
DC1A   C9                     RET      
DC1B                             ;Increment the cursor by one font character
DC1B                             ;A Font Character is 6x6 Pixels.  Move column 6 across until it can't then reset
DC1B                             ;column back to 0 and move 6 down.
DC1B                             ;If can't go down any further then keep on last row but move column back to 0
DC1B                             ;Font Characters maximum 20 across and 10 down
DC1B                             ;Output: Carry Set = No screen overflow
DC1B                             ;Destroys: A
DC1B                INC_CURSOR:      
DC1B   3A 0E 0E               LD   A,(CURSOR_X)   ;Get X
DC1E   C6 06                  ADD   A,6   ;Add 6
DC20   FE 7E                  CP   126   ;Is it >= 126?
DC22   30 04                  JR   NC,INC_ROW   ;Yes, reset column and increment row
DC24   32 0E 0E               LD   (CURSOR_X),A   ;Save new column
DC27   C9                     RET      
DC28                INC_ROW:      
DC28   AF                     XOR   A   
DC29   32 0E 0E               LD   (CURSOR_X),A   ;reset column to 0
DC2C   3A 18 0E               LD   A,(AUTO_LF)   ;Check for AutoLF
DC2F   B7                     OR   A   
DC30   C0                     RET   NZ   ;Don't CR and exit
DC31   3A 0D 0E               LD   A,(CURSOR_Y)   ;get row
DC34   C6 06                  ADD   A,6   ;Add 6
DC36   FE 3C                  CP   60   ;Is it >= 60
DC38   38 07                  JR   C,SAVE_ROW   ;No, save new row
DC3A   F5                     PUSH   AF   
DC3B   CD 45 DC               CALL   SHIFT_BUFFER   ;Shift buffer up one row
DC3E   F1                     POP   AF   
DC3F   D6 06                  SUB   6   ;overflow, just leave the same
DC41                SAVE_ROW:      
DC41   32 0D 0E               LD   (CURSOR_Y),A   ;Save new row
DC44   C9                     RET      
DC45                             ;Shift the graphics buffer (GBUF) into the scroll buffer (SBUF) by
DC45                             ;one row (6 lines).  Move the top buffer address to the new top of
DC45                             ;the scroll buffer
DC45                SHIFT_BUFFER:      
DC45                             ;Check if anymore buffer left
DC45   2A 15 0E               LD   HL,(TBUF)   ;Get top buffer address
DC48   11 00 10               LD   DE,TGBUF-SBUF   ;Get scroll buffer address
DC4B   B7                     OR   A   ;Clear carry
DC4C   ED 52                  SBC   HL,DE   ;TBUF-SBUF
DC4E   28 09                  JR   Z,SKIP_TBUF   
DC50   19                     ADD   HL,DE   ;restore HL
DC51   11 60 00               LD   DE,16*6   ;Six pixel rows
DC54   ED 52                  SBC   HL,DE   ;Move TBUF down by 6 rows
DC56   22 15 0E               LD   (TBUF),HL   ;Save new TBUF
DC59                SKIP_TBUF:      
DC59   21 60 10               LD   HL,TGBUF-SBUF+(16*6)   ;Top of scroll buffer less one row
DC5C   11 00 10               LD   DE,TGBUF-SBUF   ;Top of scroll buffer
DC5F   01 20 07               LD   BC,16*6*19   ;19 rows
DC62   ED B0                  LDIR      
DC64   21 20 17               LD   HL,TGBUF+0360H   ;clear last row (9*16)
DC67   11 21 17               LD   DE,TGBUF+0361H   
DC6A   01 5F 00               LD   BC,5FH   
DC6D   AF                     XOR   A   
DC6E   77                     LD   (HL),A   
DC6F   ED B0                  LDIR      
DC71                             ;Move Y Start up one row
DC71   3A 0F 0E               LD   A,(CURSOR_YS)   ;Get Y Start row
DC74   D6 06                  SUB   6   
DC76   D8                     RET   C   ;Ignore if less than zero
DC77   32 0F 0E               LD   (CURSOR_YS),A   
DC7A   C9                     RET      
DC7B                             ;Move the VPORT vertically between TBUF and end of GBUB.  VPORT will be
DC7B                             ;shifted by a standard termial row of 6 lines.
DC7B                             ;input: A = 0 shift up else shift down
DC7B                MOVE_VPORT:      
DC7B   2A 13 0E               LD   HL,(VPORT)   ;get viewport
DC7E   EB                     EX   DE,HL   
DC7F   B7                     OR   A   ;check move
DC80   20 0E                  JR   NZ,MOVE_DOWN   ;shift down
DC82                MOVE_UP:      
DC82   2A 15 0E               LD   HL,(TBUF)   ;get top of buffer
DC85   ED 52                  SBC   HL,DE   ; 
DC87   C8                     RET   Z   ;if the same, then at top already
DC88   21 A0 FF               LD   HL,0-60H   ;one row up
DC8B                SAVE_VPORT:      
DC8B   19                     ADD   HL,DE   ;get new VPORT value
DC8C   22 13 0E               LD   (VPORT),HL   
DC8F   C9                     RET      
DC90                MOVE_DOWN:      
DC90   21 C0 13               LD   HL,TGBUF   ;get top of graphics buffer
DC93   ED 52                  SBC   HL,DE   ; 
DC95   C8                     RET   Z   ;if the same, then at top already
DC96   21 60 00               LD   HL,60H   ;one row down
DC99   18 F0                  JR   SAVE_VPORT   
DC9B                             ;Decrement the cursor by one font character up to the current row start
DC9B                             ;Used to help with Backspace character or left arrow?
DC9B                             ;Destroys: A
DC9B                DEC_CURSOR:      
DC9B   3A 0E 0E               LD   A,(CURSOR_X)   ;Get X
DC9E   D6 06                  SUB   6   ;subract 6
DCA0                SAVE_COL:      
DCA0   32 0E 0E               LD   (CURSOR_X),A   ;Save new column
DCA3                             ;if < 0 then just make 0 or 20 depending on Y Start
DCA3   D0                     RET   NC   
DCA4   C5                     PUSH   BC   
DCA5   3A 0F 0E               LD   A,(CURSOR_YS)   ;Get Y Start
DCA8   47                     LD   B,A   
DCA9   3A 0D 0E               LD   A,(CURSOR_Y)   ;Get Y
DCAC   90                     SUB   B   
DCAD   C1                     POP   BC   
DCAE   3E 00                  LD   A,0   ;reset to 0
DCB0   28 EE                  JR   Z,SAVE_COL   
DCB2   3E 78                  LD   A,6*20   ;last column
DCB4   32 0E 0E               LD   (CURSOR_X),A   ;Save new column
DCB7   3A 0D 0E               LD   A,(CURSOR_Y)   
DCBA   D6 06                  SUB   6   ;move row one line up
DCBC   32 0D 0E               LD   (CURSOR_Y),A   ;Save new row
DCBF   C9                     RET      
DCC0                             ;Get cursor position
DCC0                             ;Outputs: BC = X,Y where X = 0..127, Y = 0..63
DCC0                GETCURSOR:      
DCC0   ED 4B 0D 0E            LD   BC,(CURSOR_XY)   
DCC4   C9                     RET      
DCC5                             ;Display Cursor
DCC5                             ;Input: C = 0, Turn cursor on, C = non zero, Turn cursor off
DCC5                             ;Default is Cursor ON
DCC5                DISPLAYCURSOR:      
DCC5   79                     LD   A,C   
DCC6   32 10 0E               LD   (CURSOR_ON),A   
DCC9   B7                     OR   A   
DCCA   C2 7A DD               JP   NZ,drawBlank   
DCCD   C3 AC DB               JP   DRAW_CURSOR   
DCD0                             ;Inverse Graphic Drawing
DCD0                             ;Initial state is normal.  Calling this routine will TOGGLE the inverse drawing flag
DCD0                             ;Destroys: A
DCD0                INVGRAPHIC:      
DCD0   3A 11 0E               LD   A,(INVERSE)   
DCD3   2F                     CPL      ;flip bits
DCD4   32 11 0E               LD   (INVERSE),A   
DCD7   C9                     RET      
DCD8                             ;Display underline on character
DCD8                             ;Initial state is no underline.  Calling this routine will TOGGLE the underline flag
DCD8                             ;Destroys: A
DCD8                UNDERLINE:      
DCD8   3A 17 0E               LD   A,(ULINE)   
DCDB   2F                     CPL      ;flip bits
DCDC   32 17 0E               LD   (ULINE),A   
DCDF   C9                     RET      
DCE0                             ;Automatic Line Feed when cursor reaches the end of the row
DCE0                             ;Input: C = 0, Automatic Line Feed, C = non zero, No Automatic Line Feed
DCE0                             ;Default is AutoLF ON
DCE0                AUTOLF:      
DCE0   79                     LD   A,C   
DCE1   32 18 0E               LD   (AUTO_LF),A   
DCE4   C9                     RET      
DCE5                             ;When sendCharToLCD is called, determine if character should be sent to the GLCD
DCE5                             ;or not.  If not sent, then a call to plotToLCD will be made to update the GLCD
DCE5                             ;Input: C = 0, Plot Always, C = non zero, Do not plot
DCE5                             ;Default is Plot Always
DCE5                PLOTALWAYS:      
DCE5   79                     LD   A,C   
DCE6   32 19 0E               LD   (PLOT_ALWAYS),A   
DCE9   C9                     RET      
DCEA                             ;Draw Graphic at the current cursor.  Draw either an ASCII character or
DCEA                             ;a custom sprite/picture
DCEA                             ;Input: D = ASCII number or
DCEA                             ;    if D=0 Then
DCEA                             ;       HL = Address of graphic data
DCEA                             ;       B = width of graphic in pixels (1-128)
DCEA                             ;       C = height of graphic in pixels (1-64)
DCEA                             ;Destroys: All
DCEA                DRAWGRAPHIC:      
DCEA   7A                     LD   A,D   
DCEB   B7                     OR   A   ;is A=0
DCEC   28 10                  JR   Z,PLOT_GRAPHIC   ;yes, use data pointing to HL
DCEE                             ;Use internal font table and index it to value in A
DCEE   3D                     DEC   A   ;fix for A = 0..255
DCEF   26 00                  LD   H,0   
DCF1   6F                     LD   L,A   
DCF2   29                     ADD   HL,HL   ;Multipy A by 2
DCF3   54                     LD   D,H   
DCF4   5D                     LD   E,L   ;Save in DE
DCF5   29                     ADD   HL,HL   ;Multipy A by 4
DCF6   19                     ADD   HL,DE   ;Multiply by 6
DCF7   11 9B DD               LD   DE,FONT_DATA   ;Font Table
DCFA   19                     ADD   HL,DE   ;Add index (A*8) to HL
DCFB   01 06 06               LD   BC,0606H   ;Six pixels across, Six pixels down
DCFE                PLOT_GRAPHIC:      
DCFE   50                     LD   D,B   ;D=Column pixel count
DCFF   7A                     LD   A,D   
DD00   32 12 0E               LD   (PIXEL_X),A   ;Save original pixel length
DD03   59                     LD   E,C   ;E=Row pixel count
DD04   ED 4B 0D 0E            LD   BC,(CURSOR_XY)   ;Get graphics cursor position
DD08                PLOT_BYTE:      
DD08   7A                     LD   A,D   ;Get column bit count
DD09   D6 08                  SUB   8   
DD0B   57                     LD   D,A   
DD0C   D5                     PUSH   DE   
DD0D   F5                     PUSH   AF   
DD0E                             ;underline check
DD0E   7B                     LD   A,E   
DD0F   FE 01                  CP   1   ;are we on the last row?
DD11   20 0A                  JR   NZ,GET_ROW_DATA   ;no, just continue
DD13   3A 17 0E               LD   A,(ULINE)   ;check underline flag
DD16   B7                     OR   A   ;is it set?
DD17   28 04                  JR   Z,GET_ROW_DATA   ;no, just continue
DD19   1E FF                  LD   E,0FFH   ;yes, set to all ones
DD1B   18 01                  JR   $+3   
DD1D                GET_ROW_DATA:      
DD1D   5E                     LD   E,(HL)   ;get pixel data
DD1E   F1                     POP   AF   
DD1F   30 0A                  JR   NC,INV_BIT   
DD21   C6 08                  ADD   A,8   ;Restore column bit count
DD23   57                     LD   D,A   
DD24   7A                     LD   A,D   
DD25                             ;D = Rotate adjust count
DD25   CB 0B                  RRC   E   ;rotate it to get first bit in bit 7
DD27   15                     DEC   D   
DD28   20 FB                  JR   NZ,$-3   
DD2A   57                     LD   D,A   ;reset D to actual bit count
DD2B                INV_BIT:      
DD2B   3A 11 0E               LD   A,(INVERSE)   ;check inverse flag
DD2E   AB                     XOR   E   ;flip bits
DD2F   5F                     LD   E,A   ;save new data
DD30                PLOT_BIT:      
DD30   CB 03                  RLC   E   
DD32   E5                     PUSH   HL   
DD33   30 05                  JR   NC,REMOVE_PIXEL   
DD35   CD 3D DA               CALL   drawPixel   
DD38   18 03                  JR   $+5   
DD3A                REMOVE_PIXEL:      
DD3A   CD 4E DA               CALL   clearPixel   
DD3D   E1                     POP   HL   
DD3E   04                     INC   B   ;move X to the right by one
DD3F   15                     DEC   D   
DD40   20 EE                  JR   NZ,PLOT_BIT   
DD42                             ;All bits are plotted check if D <= 0
DD42   23                     INC   HL   ;move to next pixel byte
DD43   D1                     POP   DE   ;restore Column/Row bit count
DD44   7A                     LD   A,D   
DD45   B7                     OR   A   ;check for zero or lessor
DD46   28 03                  JR   Z,$+5   
DD48   F2 08 DD               JP   P,PLOT_BYTE   ;its greater or zero, do next byte
DD4B                             ;Move down a row and set column to the start
DD4B   1D                     DEC   E   ;move column pixel count down by one
DD4C   C8                     RET   Z   ;if its zero no more to do, just exit
DD4D   0C                     INC   C   ;move down a row
DD4E   3A 0E 0E               LD   A,(CURSOR_X)   
DD51   47                     LD   B,A   ;reset column
DD52   3A 12 0E               LD   A,(PIXEL_X)   
DD55   57                     LD   D,A   ;reset pixel length per row
DD56   18 B0                  JR   PLOT_BYTE   
DD58                             ;Draw a cursor at the current cursor position.  This will XOR the bits underneith
DD58                             ;the cursor position.  The cursor is a 6x6 pixel square.
DD58                DRAWCURSOR:      
DD58   3A 10 0E               LD   A,(CURSOR_ON)   
DD5B   B7                     OR   A   
DD5C   C0                     RET   NZ   ;exit if cursor off
DD5D   11 06 06               LD   DE,0606H   ;Six pixels across, Six pixels down
DD60   ED 4B 0D 0E            LD   BC,(CURSOR_XY)   ;Get graphics cursor position
DD64                FLIP_BIT:      
DD64   3A 11 0E               LD   A,(INVERSE)   ;check inverse flag
DD67   B7                     OR   A   
DD68   CC 60 DA               CALL   Z,flipPixel   ;Flip the bit at the cursor position if not inverse
DD6B   04                     INC   B   ;move X to the right by one
DD6C   15                     DEC   D   
DD6D   20 F5                  JR   NZ,FLIP_BIT   
DD6F   1D                     DEC   E   ;move column pixel count down by one
DD70   C8                     RET   Z   ;if its zero no more to do, just exit
DD71   0C                     INC   C   ;move down a row
DD72   16 06                  LD   D,6   ;reset pixel length per row
DD74   3A 0E 0E               LD   A,(CURSOR_X)   ;restore original column
DD77   47                     LD   B,A   ;reset column
DD78   18 EA                  JR   FLIP_BIT   
DD7A                             ;Draw a blank at the current cursor position.  This is for DELETE character
DD7A                DRAWBLANK:      
DD7A   11 06 06               LD   DE,0606H   ;Six pixels across, Six pixels down
DD7D   ED 4B 0D 0E            LD   BC,(CURSOR_XY)   ;Get graphics cursor position
DD81                FLIP_BIT1:      
DD81   CD 4E DA               CALL   clearPixel   ;clear the bit at the cursor position
DD84   04                     INC   B   ;move X to the right by one
DD85   15                     DEC   D   
DD86   20 F9                  JR   NZ,FLIP_BIT1   
DD88   1D                     DEC   E   ;move column pixel count down by one
DD89   C8                     RET   Z   ;if its zero no more to do, just exit
DD8A   0C                     INC   C   ;move down a row
DD8B   16 06                  LD   D,6   ;reset pixel length per row
DD8D   3A 0E 0E               LD   A,(CURSOR_X)   ;restore original column
DD90   47                     LD   B,A   ;reset column
DD91   18 EE                  JR   FLIP_BIT1   
DD93                             ; Contstants
DD93   80 90 88 98  ROWS:     DB   80H,90H,88H,98H   ;Text Row start position
DD97                INIT_BASIC:      
DD97   30                     DB   30H   ;8 Bit interface, basic instruction
DD98   0C                     DB   0CH   ;display on, cursor & blink off
DD99   06                     DB   06H   ;cursor move to right ,no shift
DD9A   01                     DB   01H   ;clear RAM
DD9B                             ;General Graphic Data
DD9B                             ;Byte n = Pixel data where set bits represent pixels.  Read from LSB
DD9B                             ; 256 Character Font
DD9B                FONT_DATA:      
DD9B                             ;001
DD9B   1E                     DB   00011110b   ;  ####
DD9C   21                     DB   00100001b   ; #    #
DD9D   21                     DB   00100001b   ; #    #
DD9E   21                     DB   00100001b   ; #    #
DD9F   21                     DB   00100001b   ; #    #
DDA0   1E                     DB   00011110b   ;  ####
DDA1                             ;002
DDA1   1E                     DB   00011110b   ;  ####
DDA2   3F                     DB   00111111b   ; ######
DDA3   3F                     DB   00111111b   ; ######
DDA4   3F                     DB   00111111b   ; ######
DDA5   3F                     DB   00111111b   ; ######
DDA6   1E                     DB   00011110b   ;  ####
DDA7                             ;003 Up Arrow
DDA7   0C                     DB   00001100b   ;   ##
DDA8   1E                     DB   00011110b   ;  ####
DDA9   3F                     DB   00111111b   ; ######
DDAA   0C                     DB   00001100b   ;   ##
DDAB   0C                     DB   00001100b   ;   ##
DDAC   0C                     DB   00001100b   ;   ##
DDAD                             ;004 Down Arrow
DDAD   0C                     DB   00001100b   ;   ##
DDAE   0C                     DB   00001100b   ;   ##
DDAF   0C                     DB   00001100b   ;   ##
DDB0   3F                     DB   00111111b   ; ######
DDB1   1E                     DB   00011110b   ;  ####
DDB2   0C                     DB   00001100b   ;   ##
DDB3                             ;005 Left Arrow
DDB3   08                     DB   00001000b   ;   #
DDB4   18                     DB   00011000b   ;  ##
DDB5   3F                     DB   00111111b   ; ######
DDB6   3F                     DB   00111111b   ; ######
DDB7   18                     DB   00011000b   ;  ##
DDB8   08                     DB   00001000b   ;   #
DDB9                             ;006 Right Arrow
DDB9   04                     DB   00000100b   ;    #
DDBA   06                     DB   00000110b   ;    ##
DDBB   3F                     DB   00111111b   ; ######
DDBC   3F                     DB   00111111b   ; ######
DDBD   06                     DB   00000110b   ;    ##
DDBE   04                     DB   00000100b   ;    #
DDBF                             ;007 Up Hat
DDBF   0C                     DB   00001100b   ;   ##
DDC0   1E                     DB   00011110b   ;  ####
DDC1   3F                     DB   00111111b   ; ######
DDC2   00                     DB   00000000b   ; 
DDC3   00                     DB   00000000b   ; 
DDC4   00                     DB   00000000b   ; 
DDC5                             ;008 Down Hat
DDC5   00                     DB   00000000b   ; 
DDC6   00                     DB   00000000b   ; 
DDC7   00                     DB   00000000b   ; 
DDC8   3F                     DB   00111111b   ; ######
DDC9   1E                     DB   00011110b   ;  ####
DDCA   0C                     DB   00001100b   ;   ##
DDCB                             ;009 Left Hat
DDCB   08                     DB   00001000b   ;   #
DDCC   18                     DB   00011000b   ;  ##
DDCD   38                     DB   00111000b   ; ###
DDCE   38                     DB   00111000b   ; ###
DDCF   18                     DB   00011000b   ;  ##
DDD0   08                     DB   00001000b   ;   #
DDD1                             ;010 Right Hat
DDD1   04                     DB   00000100b   ;    #
DDD2   06                     DB   00000110b   ;    ##
DDD3   07                     DB   00000111b   ;    ###
DDD4   07                     DB   00000111b   ;    ###
DDD5   06                     DB   00000110b   ;    ##
DDD6   04                     DB   00000100b   ;    #
DDD7                             ;011 Note 1
DDD7   04                     DB   00000100b   ;    #
DDD8   04                     DB   00000100b   ;    #
DDD9   04                     DB   00000100b   ;    #
DDDA   1C                     DB   00011100b   ;  ###
DDDB   3C                     DB   00111100b   ; ####
DDDC   18                     DB   00011000b   ;  ##
DDDD                             ;012 Note 2
DDDD   04                     DB   00000100b   ;    #
DDDE   06                     DB   00000110b   ;    ##
DDDF   05                     DB   00000101b   ;    # #
DDE0   1C                     DB   00011100b   ;  ###
DDE1   3C                     DB   00111100b   ; ####
DDE2   18                     DB   00011000b   ;  ##
DDE3                             ;013 Rocket
DDE3   0C                     DB   00001100b   ;   ##
DDE4   0C                     DB   00001100b   ;   ##
DDE5   0C                     DB   00001100b   ;   ##
DDE6   0C                     DB   00001100b   ;   ##
