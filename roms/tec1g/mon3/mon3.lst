D2D0                             ; 
D2D0                             ; 
D2D0                             ; RGB LED 8x8 Scan routine
D2D0                             ; This routine scans the RGB LED 8x8 matrix and outputs the data to the
D2D0                             ; LED8x8V, LED8x8G and LED8x8B ports.  It uses the REDSCR, GRNSCR and BLUSCR
D2D0                             ; buffers to get the data for each row.  The LED8x8H port is used to select the
D2D0                             ; row to be lit.  The RGB LED matrix is scanned in a loop, lighting each
D2D0                             ; row in turn and outputting the corresponding RGB data for that row.
D2D0                             ; The RGB LED matrix is scanned at a rate of 40Hz, which is fast enough
D2D0                             ; Inputs: IY = Pointer to REDSCR, GRNSCR and BLUSCR buffers
D2D0                             ; Outputs: None
D2D0                RGBSCAN:      
D2D0   C5                     PUSH   bc   ; Save registers
D2D1   FD E5                  PUSH   iy   ; Save IY register
D2D3   0E 01                  LD   c,01H   ; Row counter (bitmask starts at row 1)
D2D5                RGBLOOP:      
D2D5   FD 7E 00               LD   a,(iy+0)   ; Get red data from REDSCR
D2D8   D3 06                  OUT   (LED8X8V),a   ; Output to red port
D2DA   FD 7E 08               LD   a,(iy+8)   ; Get green data from GRNSCR
D2DD   D3 F8                  OUT   (LED8X8G),a   ; Output to green port
D2DF   FD 7E 10               LD   a,(iy+16)   ; Get blue data from BLUSCR
D2E2   D3 F9                  OUT   (LED8X8B),a   ; Output to blue port
D2E4   79                     LD   a,c   ; Current row select bitmask
D2E5   D3 05                  OUT   (LED8X8H),a   ; Select the row
D2E7   06 40                  LD   b,40H   ; ON time counter
D2E9   10 FE                  DJNZ   $   ; Delay for 40 cycles to keep row lit
D2EB   AF                     XOR   a   ; Clear A for next row
D2EC   D3 05                  OUT   (LED8X8H),a   ; Turn off red row to prevent ghosting
D2EE   FD 23                  INC   iy   ; Move to next row in red buffer
D2F0   CB 11                  RL   c   ; Shift row bitmask left
D2F2   30 E1                  JR   nc,RGBLoop   ; Continue until all 8 rows are done
D2F4   FD E1                  POP   iy   ; Restore IY register
D2F6   C1                     POP   bc   ; Restore BC register
D2F7   C9                     RET      
