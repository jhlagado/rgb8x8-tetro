0000                             ; MONITOR 3 for the TEC-1G
0000                             ; ------------------------
0000                             ;  _______ ______ _____     __  _____   __  __  ____  _   _ ____
0000                             ; |__   __|  ____/ ____|   /_ |/ ____| |  \/  |/ __ \| \ | |___ \
0000                             ;    | |  | |__ | |   ______| | |  __  | \  / | |  | |  \| | __) |
0000                             ;    | |  |  __|| |  |______| | | |_ | | |\/| | |  | | . ` ||__ <
0000                             ;    | |  | |___| |____     | | |__| | | |  | | |__| | |\  |___) |
0000                             ;    |_|  |______\_____|    |_|\_____| |_|  |_|\____/|_| \_|____/
0000                             ;                 Coding by Brian Chiha, Oct-2023
0000                             ; 
0000                             ; With help from Craig Hart, Mark Jelic, Ian McLean and James Elphick
0000                             ; 
0000                             ; Constants
0000                             ; ---------
0000                             ; Ports
0000                KEYB:     EQU   00H   ;Keyboard
0000                DIGITS:   EQU   01H   ;Seven Segment Digits
0000                SEGS:     EQU   02H   ;Seven Segment Display
0000                SYS_INPUT:   EQU   03H   ;System Input
0000                LCD_INST:   EQU   04H   ;LCD Instruction
0000                LCD_DATA:   EQU   84H   ;LCD Data
0000                LED8X8H:   EQU   05H   ;LED 8x8 Horizontal
0000                LED8X8V:   EQU   06H   ;LED 8x8 Vertical
0000                GLCD_INST:   EQU   07H   ;Graphics LCD Instruction
0000                GLCD_DATA:   EQU   87H   ;Graphics LCD Data
0000                LED8X8G:   EQU   0F8H   ;LED 8x8 Green
0000                LED8X8B:   EQU   0F9H   ;LED 8x8 Blue
0000                SDIO:     EQU   0FDH   ;SD Card IO
0000                MATRIX:   EQU   0FEH   ;QWERTY Keyboard Matrix
0000                SYS_CTRL:   EQU   0FFH   ;System Control
0000                             ; 
0000                             ; SYSCTRL  port bits
0000                SHADOW:   EQU   01H   ;Shadow ROM
0000                PROTECT:   EQU   02H   ;Memory Protect
0000                EXPAND:   EQU   04H   ;Expand
0000                CART:     EQU   10H   ;Cartridge
0000                CAPSLOCK:   EQU   80H   ;Caps lock for Keyboard
0000                             ; 
0000                             ; Monitor Control Bit
0000                             ;MCB = Bits 0,1 = Data Nibbles Entered
0000                             ;      Bit 2 = Address=H/Data=L mode
0000                             ;      Bit 3 = LCD=H/Segment=L mode
0000                             ;      Bit 4 = Disassembler View=H/Data Entry View=L mode (for segment mode only)
0000                             ;      Bit 5 = Menu=L/Parameter=H Format for Menu handler (for LCD mode only)
0000                             ;      Bit 6 = RTC Add-On Present=H
0000                             ;      Bit 7 = SD Card Add-On Present=H
0000                MCB_AD_DATA:   EQU   04H   ;Address=H/Data=L mode
0000                MCB_LCD_SEG:   EQU   08H   ;LCD=H/Segment=L mode
0000                MCB_DIS_DE:   EQU   10H   ;Disassembler View=H/Data Entry View=L mode
0000                MCB_MEN_PAR:   EQU   20H   ;Menu=L/Parameter=H Format for Menu handler
0000                MCB_RTC:   EQU   40H   ;RTC Add-On Present=H
0000                MCB_SD_CARD:   EQU   80H   ;SD Card Add-On Present=H
0000                             ; 
0000                             ; Serial Constants Delay
0000                BAUD_1200:   EQU   80H   ;BAUD 1200 Delay
0000                BAUD_2400:   EQU   3FH   ;BAUD 2400 Delay
0000                BAUD_4800:   EQU   1BH   ;BAUD 4800 Delay
0000                BAUD_9600:   EQU   0BH   ;BAUD 9600 Delay
0000                BAUD_14400:   EQU   05H   ;BAUD 14400 Delay
0000                             ; 
0000                             ; ASCII Constants
0000                BKSP:     EQU   08H   ;Back space
0000                TAB:      EQU   09H   ;Horizontal Tab
0000                CR:       EQU   0DH   ;Carriage Return
0000                LF:       EQU   0AH   ;Line Feed
0000                SPACE:    EQU   " "   ;Space
0000                COLON:    EQU   ":"   ;Colon
0000                             ; 
0000                             ; Keyboard reference
0000                K_FN:     EQU   02H   ;Fn key on Keyboard Matrix
0000                K_PLUS:   EQU   10H   ;+ Key
0000                K_MINUS:   EQU   11H   ;- Key
0000                K_GO:     EQU   12H   ;GO Key
0000                K_ADDR:   EQU   13H   ;Address Key
0000                             ; 
0000                             ; Constants
0000                KEY_SPEED:   EQU   20H   ;Speed of auto repeat press (lower=faster)
0000                USER_ADDR:   EQU   4000H   ;User starting address
0000                BASE_ADDR:   EQU   0C000H   ;Start Address of monitor
0000                LCD_ROW1:   EQU   80H   ;LCD Row 1, Column 1
0000                LCD_ROW2:   EQU   0C0H   ;LCD Row 2, Column 1
0000                LCD_ROW3:   EQU   94H   ;LCD Row 3, Column 1
0000                LCD_ROW4:   EQU   0D4H   ;LCD Row 4, Column 1
0000                MENU_PTR:   EQU   7EH   ;LCD Right Arrow
0000                             ; 
0000                             ; RAM Locations
0000                MON_RAM:   EQU   0800H   ;Monitor RAM start
0000                STACK_SIZE:   EQU   80H   ;128 Bytes
0000                STACK_TOP:   EQU   MON_RAM+STACK_SIZE   
0000                TOP_RAM:   EQU   7FFFH   ;Highest RAM location (no expansion)
0000                             ; 
0000                ROMSIG:   EQU   MON_RAM   ;16 byte buffer holding the ROM signature; used for cold start detection
0000                             ; 
0000                             ; Monitor Configuration and display data
0000                DISP_BUFF:   EQU   STACK_TOP   ;Display Buffer for Segments
0000                DISP_DATA:   EQU   STACK_TOP+4   ;Display Buffer Data for Segments
0000                CEL:      EQU   STACK_TOP+6   ;Current Editing location
0000                MCB:      EQU   STACK_TOP+8   ;Monitor Control Byte
0000                KEY_BUFF:   EQU   STACK_TOP+9   ;Keypress Buffer
0000                KEY_PRESS:   EQU   STACK_TOP+10   ;Keypress Flag
0000                KEY_REPEAT:   EQU   STACK_TOP+11   ;Key Auto Repeat timer
0000                KEY_AUTO:   EQU   STACK_TOP+12   ;Key Auto Increment Flag
0000                KEY_BEEP:   EQU   STACK_TOP+13   ;Keypress Beep flag
0000                KEY_SECOND:   EQU   STACK_TOP+14   ;Matrix Keyboard second key Buffer
0000                GLCD_TERM:   EQU   STACK_TOP+15   ;GLCD Terminal Enable Flag
0000                DIS_ADDR:   EQU   STACK_TOP+16   ;Base Disassembler/Editing address
0000                USER_INT:   EQU   STACK_TOP+18   ;User defined INT routine
0000                USER_NMI:   EQU   STACK_TOP+20   ;User defined NMI routine
0000                MENU_POS:   EQU   STACK_TOP+22   ;Menu listing position
0000                MENU_SEL:   EQU   STACK_TOP+23   ;Menu pointer selection
0000                MENU_CNT:   EQU   STACK_TOP+24   ;Menu listing count
0000                MENU_CFG:   EQU   STACK_TOP+25   ;Menu configuration address
0000                MENU_IDX:   EQU   STACK_TOP+27   ;Menu depth index
0000                CAPS_LOCK:   EQU   STACK_TOP+28   ;Caps Lock Flag
0000                SYS_MODE:   EQU   STACK_TOP+29   ;SYS_CTRL current monitor state
0000                PROT_MODE:   EQU   STACK_TOP+30   ;Use Protect at GO
0000                XPND_MODE:   EQU   STACK_TOP+31   ;Expand Mode
0000                             ; 
0000                             ; Free Monitor RAM area for specific functions (08A0H).  Areas can overlap
0000                MON_FRAM:   EQU   STACK_TOP+32   ;Free Monitor RAM Starts Here
0000                             ; 
0000                             ; Parameter Base Address.  All parameters are two bytes long from this address
0000                PARAM_DATA:   EQU   MON_FRAM+32   ;Start of Parameter storage (08C0H)
0000                             ; 
0000                             ; ASCII string for data entry area  ;IE "4000: 23 34 45 56 78"
0000                DATA_BASE:   EQU   MON_FRAM   ;Base address for Data view (08A0H)
0000                DATA_ROW:   EQU   DATA_BASE+96   ;Start of ASCII data entry string (0900H)
0000                             ; 
0000                             ; Current Editing Location Quick Jump locations
0000                CEL_QJMP:   EQU   MON_FRAM+2   ;Location 1,2, and 3 (08A2H,08A4H,08A6H)
0000                             ; 
0000                             ; Menu depth pointers to remember nested menus
0000                MENU_CFG_D:   EQU   MON_FRAM+8   ;Menu Config. depth (08A8H,08AAH,08ACH,08AEH) 
0000                             ; 
0000                             ; RNG Seed
0000                RNG_SEED:   EQU   MON_FRAM+16   ;Random Number Seed (08B0H)
0000                BAUD:     EQU   MON_FRAM+17   ;Baud Rate (08B1H-08B2H)
0000                             ; 
0000                             ; RAM for Smart Copy
0000                COPY_START:   EQU   PARAM_DATA   ;Start (08C0H)
0000                COPY_END:   EQU   COPY_START+2   ;End
0000                COPY_DEST:   EQU   COPY_START+4   ;Destination
0000                COPY_PTR:   EQU   COPY_START+6   ;Pointer
0000                COPY_EBLK:   EQU   COPY_START+8   ;End Block
0000                COPY_CORR:   EQU   COPY_START+10   ;Correction
0000                REST_START:   EQU   COPY_START+12   ;Restore Start
0000                REST_END:   EQU   COPY_START+14   ;Restore End
0000                REST_DEST:   EQU   COPY_START+16   ;Restore Destination
0000                TEMP_START:   EQU   COPY_START+18   ;Temporary Start
0000                TEMP_END:   EQU   COPY_START+20   ;Temporary End
0000                TEMP_DEST:   EQU   COPY_START+22   ;Temporary Destination
0000                             ; 
0000                             ; RAM for To/From Addresses
0000                DATA_FROM:   EQU   PARAM_DATA   ;From (08C0H)
0000                DATA_TO:   EQU   DATA_FROM+2   ;To
0000                             ; 
0000                             ; Breakpoint register save area.
0000                BP_BASE_SP:   EQU   MON_FRAM+96   ;Start of Register save area (0900H)   
0000                BP_HL:    EQU   BP_BASE_SP+2   ;HL position in BP stack
0000                BP_REGS:   EQU   BP_BASE_SP+20   ;Top of Stack (Goes down towards MON_RAM)
0000                BP_PC:    EQU   BP_BASE_SP+20   ;Calling Program Counter
0000                BP_ORIG_SP:   EQU   BP_BASE_SP+22   ;Original hardware stack pointer
0000                BP_LCD:   EQU   BP_BASE_SP+24   ;LCD Screen Buffer (20x4 or 80 bytes)
0000                             ; 
0000                             ; -----------------------------------------------------------------------------
0000                             ; CODE start here, with code running at 0000H
0000                             ; -----------------------------------------------------------------------------
0000                             ; 
C000                          .ORG   BASE_ADDR   
C000                BOOT:        
C000   C3 00 C1               JP   preInit   
C003                             ; 
C008                          .ORG   BASE_ADDR+08H   
C008                RST08:       ;Key Read and Wait for key release.  (Halt simulation)
C008                             ;Output: A = Key pressed
C008   C3 56 C6               JP   scanKeysWait   ;Wait and Scan key routine
C00B                             ; 
C010                          .ORG   BASE_ADDR+10H   
C010                RST10:       ;API Call Entry
C010   C3 70 00               JP   APICall-BASE_ADDR   ;API Call routine
C013                             ; 
C018                          .ORG   BASE_ADDR+18H   
C018                RST18:       ;API Call 2 Entry
C018   C3 40 00               JP   APICall2-BASE_ADDR   ;API Call 2 routine
C01B                             ; 
C020                          .ORG   BASE_ADDR+20H   
C020                RST20:       ;Scan Segments and Keyboard.  Must be called constantly
C020                             ;Input: DE = Pointer to LCD Segment code (Must be 6 bytes)
C020                             ;Output: A = Key pressed if Zero flag is set
C020   CD 6B C5               CALL   scanSegments   ;Multiplex the seven segments
C023   CD D1 C5               CALL   scanKeys   ;Scan for key press
C026                             ; 
C028                          .ORG   BASE_ADDR+28H   
C028                RST28:       ;LCD Busy
C028   F5                     PUSH   af   ;save af
C029                BUSYLOOP:      
C029   DB 04                  IN   a,(LCD_INST)   ;Read status bit on LCD
C02B   07                     RLCA      ;put bit 7 (status) in carry
C02C   38 FB                  JR   c,busyLoop   ;loop if LCD is busy
C02E   F1                     POP   af   ;restore af
C02F   C9                     RET      
C030                             ; 
C030                          .ORG   BASE_ADDR+30H   
C030                RST30:       ;Breakpoint Entry
C030   E3                     EX   (sp),hl   ;get return address
C031   22 14 09               LD   (BP_PC),hl   ;save it
C034   E3                     EX   (sp),hl   ;fix stack
C035   C3 7A CC               JP   breakPoint   
C038                             ; 
C038                          .ORG   BASE_ADDR+38H   
C038                RST38:       
C038   E5                     PUSH   hl   ;save HL
C039   2A 92 08               LD   hl,(USER_INT)   ;get address at USER_INT
C03C   E3                     EX   (sp),hl   ;restore HL and put INT routine on stack
C03D   C9                     RET      
C03E                             ; 
C040                          .ORG   BASE_ADDR+40H   
C040                             ;API Call Routine
C040                             ; Input:   A = Function index
C040                             ;          BC, DE, HL = Parameters if needed
C040                             ; Corrupt: IX
C040                APICALL2:      
C040   FE 22                  CP   API_COUNT2/2   ;Adjust for real count
C042   38 03                  JR   c,APIGood2   
C044   C3 2E CC               JP   displayError   ;exit with Error Message
C047                APIGOOD2:      
C047   C5                     PUSH   bc   ;save BC
C048   E5                     PUSH   hl   ;save HL
C049   21 80 D2               LD   hl,APITable2   ;API Function Table
C04C   87                     ADD   a,a   ;double it
C04D   4F                     LD   c,a   ;store index in
C04E   06 00                  LD   b,0   ;bc
C050   09                     ADD   hl,bc   ;index table
C051   7E                     LD   a,(hl)   ;store jump
C052   23                     INC   hl   ;address
C053   66                     LD   h,(hl)   ;back into
C054   6F                     LD   l,a   ;HL
C055   E5                     PUSH   hl   ;IX = HL
C056   DD E1                  POP   ix   
C058   E1                     POP   hl   ;restore HL
C059   C1                     POP   bc   ;restore BC
C05A   DD E9                  JP   (ix)   ;Jump to API Routine
C05C                             ; 
C066                          .ORG   BASE_ADDR+66H   
C066                NMI:         
C066   E5                     PUSH   hl   ;save HL
C067   2A 94 08               LD   hl,(USER_NMI)   ;get address at USER_NMI
C06A   E3                     EX   (sp),hl   ;restore HL and put INT routine on stack
C06B   C9                     RET      
C06C                             ; 
C070                          .ORG   BASE_ADDR+70H   
C070                             ;API Call Routine
C070                             ; Input:   C = Function index
C070                             ;          A, B, DE, HL = Parameters if needed
C070                             ; Corrupt: IX
C070                APICALL:      
C070   F5                     PUSH   af   ;save AF
C071   79                     LD   a,c   ;Check index is within range
C072   FE 3F                  CP   API_COUNT/2   ;Adjust for real count
C074   38 04                  JR   c,APIGood   
C076   F1                     POP   af   ;restore AF
C077   C3 2E CC               JP   displayError   ;exit with Error Message
C07A                APIGOOD:      
C07A   C5                     PUSH   bc   ;save BC
C07B   E5                     PUSH   hl   ;save HL
C07C   21 00 D3               LD   hl,APITable   ;API Function Table
C07F   87                     ADD   a,a   ;double it
C080   4F                     LD   c,a   ;store index in
C081   06 00                  LD   b,0   ;bc
C083   09                     ADD   hl,bc   ;index table
C084   7E                     LD   a,(hl)   ;store jump
C085   23                     INC   hl   ;address
C086   66                     LD   h,(hl)   ;back into
C087   6F                     LD   l,a   ;HL
C088   E5                     PUSH   hl   ;IX = HL
C089   DD E1                  POP   ix   
C08B   E1                     POP   hl   ;restore HL
C08C   C1                     POP   bc   ;restore BC
C08D   F1                     POP   af   ;restore AF
C08E   DD E9                  JP   (ix)   ;Jump to API Routine
C090                             ; 
C090                             ; Restart Handler (temp)
C090                RESTARTHANDLE:      
C090   C9                     RET      
C091                             ; 
C091                             ;Interrupt Handler Stub (just return)
C091                INTHANDLER:      
C091   ED 4D                  RETI      ;Exit cleanly
C093                             ; 
C093                             ;NMI Handler Stub (just return)
C093                NMIHANDLER:      
C093   ED 45                  RETN      ;Exit cleanly
C095                             ; 
C095                             ; 
C095                             ; -----------------------------------------------------------------------------
C095                             ; CODE running in ROM proper, at C000H upwards
C095                             ; -----------------------------------------------------------------------------
C095                             ; 
C100                          .ORG   BASE_ADDR+100H   
C100                             ; 
C100                PREINIT:      
C100   31 80 08               LD   sp,STACK_TOP   ;Set the Hardware Stack to top of stack in RAM
C103   21 00 40               LD   hl,4000H   ;Long delay to ensure reset of latches are complete
C106   CD 03 C7               CALL   timeDelay   
C109   AF                     XOR   a   ;Blank the 8x8 display to prevent LED burnout
C10A   D3 05                  OUT   (LED8X8H),a   
C10C   D3 06                  OUT   (LED8X8V),a   
C10E   3E 05                  LD   a,05H   ;Set SD Card to Idle; turns off activity LED
C110   D3 FD                  OUT   (SDIO),a   
C112   DB 03                  IN   a,(SYS_INPUT)   ;Check for CART presence
C114   47                     LD   b,a   
C115   E6 10                  AND   CART   ;Check bit 4
C117   C2 00 80               JP   nz,08000H   ;Launch CARTridge code if CART present
C11A   78                     LD   a,b   ;Honor PROTECT bit
C11B   E6 02                  AND   PROTECT   
C11D   32 9E 08               LD   (PROT_MODE),a   
C120   3A 9F 08               LD   a,(XPND_MODE)   
C123   E6 04                  AND   EXPAND   
C125   4F                     LD   c,a   
C126   3A 9C 08               LD   a,(CAPS_LOCK)   
C129   E6 80                  AND   CAPSLOCK   
C12B   81                     ADD   a,c   
C12C   06 01                  LD   b,SHADOW   ;Force Shadow mode OFF
C12E   80                     ADD   a,b   
C12F   D3 FF                  OUT   (SYS_CTRL),a   
C131   32 9D 08               LD   (SYS_MODE),a   ;Update MONitors idea of the config
C134   3A 9D 08               LD   a,(SYS_MODE)   ;Is shadow disabled ? (should be yes it is)
C137   E6 01                  AND   SHADOW   
C139   28 0B                  JR   z,hardBoot   ;if enabled, skip memcopy
C13B   21 00 C0               LD   hl,0C000H   ;copy bottom 256 bytes of ROM to RAM at 0000
C13E   11 00 00               LD   de,0000H   ;so RST vectors etc. are in RAM now
C141   01 00 01               LD   bc,0100H   
C144   ED B0                  LDIR      
C146                             ; 
C146                             ;Place initialisation routines here.  MemCheck, RAM defaults
C146                HARDBOOT:      
C146   CD A3 C5               CALL   LCDinitialise   ;reset LCD Screen always on reset
C149   21 00 40               LD   hl,USER_ADDR   ;fixup edit location for startup
C14C   22 86 08               LD   (CEL),hl   
C14F   22 A0 08               LD   (DATA_BASE),hl   ;update base address
C152   DB 00                  IN   a,(KEYB)   ;Check for Fn key press when RESET key is released
C154   E6 20                  AND   20H   ;Check bit 5
C156   28 1D                  JR   z,hardInit   ;Fn Key pressed, do a hard initialise
C158   DB 03                  IN   a,(SYS_INPUT)   ;read simp buffer for keyboard input type
C15A   0F                     RRCA      ;check bit 0
C15B   30 0A                  JR   nc,skipMatrix   ;if set, matrix keyboard in use
C15D   CD 40 CC               CALL   matrixScan   
C160   20 05                  JR   nz,$+7   ;no key pressed, skip hard init       
C162   7B                     LD   a,e   ;grab first key pressed
C163   FE 02                  CP   K_FN   ;is it the FN key?
C165   28 0E                  JR   z,hardInit   ;Fn Key pressed, do a hard initialise
C167                SKIPMATRIX:      
C167                             ;Look for hard reset flag
C167   21 F0 FF               LD   hl,SOFTWARE   
C16A   11 00 08               LD   de,ROMSIG   
C16D   06 10                  LD   b,10H   
C16F   CD 97 C8               CALL   stringCompare   
C172   CA F5 C1               JP   z,preSoftBoot   ;Yes, just softboot
C175                HARDINIT:      
C175                             ;Honour Expand
C175   DB 03                  IN   a,(SYS_INPUT)   ;read simp buffer for real expand bit
C177   CD 1D D0               CALL   setExpand   ;honor EXPAND bit
C17A                             ;Set Capslock to OFF
C17A   AF                     XOR   a   ;A = 0
C17B   CD E4 CF               CALL   setCaps   ;set caps lock flag
C17E                             ;Copy ROMSTR into RAM - warm boot flag
C17E   21 F0 FF               LD   hl,SOFTWARE   
C181   11 00 08               LD   de,ROMSIG   
C184   01 10 00               LD   bc,10H   
C187   ED B0                  LDIR      
C189                             ;Default monitor RAM variables
C189   21 00 D4               LD   hl,defaults   ;Start from MCB
C18C   11 86 08               LD   de,CEL   ;Set to CEL and onwards in RAM
C18F   01 17 00               LD   bc,defaultsSize   ;Load defaultsSize bytes
C192   ED B0                  LDIR      
C194                             ;Check if RTC Add-On is installed
C194   CD 93 FA               CALL   checkDS1302Present   ;Carry set = No RTC
C197   38 12                  JR   c,skipRTC   ;skip RTC config as no RTC Add-on found
C199   21 88 08               LD   hl,MCB   ;set MCB
C19C   CB F6                  SET   6,(hl)   ;bit 6 RTC present
C19E   CD 25 FF               CALL   checkRTCchecksum   ;check if PRAM is not corrupt
C1A1   28 03                  JR   z,$+5   ;all good, skip resetting PRAM
C1A3   CD 45 CE               CALL   resetRTCPRAM   ;reset RTC PRAM
C1A6   CD 97 CE               CALL   RTCFillRAM   ;fill RTC PRAM to Mon3 RAM
C1A9   18 12                  JR   checkSDCard   
C1AB                SKIPRTC:      
C1AB                             ;Default CEL Jump Table
C1AB   21 00 40               LD   hl,USER_ADDR   ;default to initial CEL
C1AE   22 A2 08               LD   (CEL_QJMP),hl   
C1B1   22 A4 08               LD   (CEL_QJMP+2),hl   
C1B4   22 A6 08               LD   (CEL_QJMP+4),hl   
C1B7                             ;default baud rate delay
C1B7   21 1B 00               LD   hl,BAUD_4800   ;4800 baud delay
C1BA                             ;ld hl,BAUD_14400     ;14400 baud delay
C1BA   22 B1 08               LD   (BAUD),hl   ;save it
C1BD                CHECKSDCARD:      
C1BD                             ;Check if SD Card Add-On is installed
C1BD   CD 71 F7               CALL   checkSDCardPresent   ;Zero set = SD Card
C1C0   20 05                  JR   nz,LCDbanners   ;skip SD Card config as no SD Card Add-on found
C1C2   21 88 08               LD   hl,MCB   ;set MCB
C1C5   CB FE                  SET   7,(hl)   ;bit 7 SD Card present
C1C7                LCDBANNERS:      
C1C7                             ;Display Welcome Message
C1C7   21 61 D5               LD   hl,hardResetMessage   
C1CA   CD 83 C5               CALL   stringToLCD   ;print line to LCD
C1CD                             ;send a welcome message to the Serial Terminal if connected
C1CD   21 29 D5               LD   hl,serialStartup   
C1D0   CD 8C C5               CALL   stringToSerial   
C1D3                             ;send a welcome banner to the GLCD (disabled for now)
C1D3   CD 00 D8               CALL   initLCD   ;Initialise the GLCD (default graphics mode)
C1D6   21 9B E3               LD   hl,GLCD_BANNER   ;point to welcome banner
C1D9   11 00 0A               LD   de,GBUF   ;internal graphics buffer
C1DC   01 00 04               LD   bc,16*64   ;full screen
C1DF   ED B0                  LDIR      
C1E1   CD 90 DA               CALL   plotToLCD   ;Display it
C1E4                             ;play a tone...
C1E4   11 51 D5               LD   de,hardResetTune   ;Set DE to tune data
C1E7   CD 75 EF               CALL   playTune   
C1EA                             ;wait a bit
C1EA   21 EE FE               LD   hl,0FEEEH   ;delay
C1ED   CD 03 C7               CALL   timeDelay   
C1F0                             ;random number seed
C1F0   ED 5F                  LD   a,r   ;get R value
C1F2   32 B0 08               LD   (RNG_SEED),a   ;save it
C1F5                             ;TODO add more here...
C1F5                             ; 
C1F5                PRESOFTBOOT:      
C1F5                             ;get current GLCD Term status
C1F5   CD CE CF               CALL   getGLCDTerm   ;get flag
C1F8   CD F8 CF               CALL   setGLCDTerm   ;set GLCD status
C1FB                             ;set up initial menu if RESET is pressed
C1FB   21 B2 D5               LD   hl,mainMenuCFG   ;set up 1G Menu
C1FE   CD F7 CE               CALL   menuReset   ;clear menu flags
C201   3E FF                  LD   a,0FFH   ;reset menu index
C203   32 9B 08               LD   (MENU_IDX),a   ;save it
C206   CD DD CE               CALL   menuInit   
C209                             ; 
C209                             ;Soft Reset call and fallthrough for Hard Reset and GO return address
C209                SOFTBOOT:      
C209   31 80 08               LD   sp,STACK_TOP   ;Set the Hardware Stack to top of stack in RAM
C20C   3A 9D 08               LD   a,(SYS_MODE)   ;reset hardware to MONitor mode
C20F   D3 FF                  OUT   (SYS_CTRL),a   
C211                             ;reset MCB
C211   3A 88 08               LD   a,(MCB)   ;Get MCB
C214                RESETMCB:      
C214   E6 D8                  AND   0D8H   ;Mask out params, nibble and mode bits
C216                UPDATEMCB:      
C216   32 88 08               LD   (MCB),a   ;Save MCB back
C219                             ; 
C219                             ;fill display buffer with current editing location
C219                SETDISPBUFFER:      
C219   CD 0C C5               CALL   beep   ;beep the speaker bit
C21C   ED 5B 86 08            LD   de,(CEL)   ;load DE with current editing location
C220   CD 25 C5               CALL   CELToSeg   ;convert CEL and its value to display buffer
C223   CD 46 C5               CALL   setDots   ;set decimal point on segments
C226                             ;update LCD screen
C226                SETLCD:      
C226   CD 14 C4               CALL   updateLCD   ;Update LCD screen (and also DISP_BUFF if LCD)
C229                             ; 
C229                             ;main system loop
C229                MAINLOOP:      
C229   CD 68 C5               CALL   scanDisplayBuff   ;Multiplex the seven segments
C22C   CD D1 C5               CALL   scanKeys   ;Scan for key press
C22F   21 8B 08               LD   hl,KEY_REPEAT   ;get the key repeat timer
C232   28 04                  JR   z,keyDelay   ;key has been pressed
C234   36 00                  LD   (hl),00H   ;reset delay counter
C236   18 F1                  JR   mainLoop   ;loop back to the main loop
C238                KEYDELAY:      
C238   38 05                  JR   c,keyFirst   ;new key press first detection
C23A   35                     DEC   (hl)   ;key held, decrease timer
C23B   20 EC                  JR   nz,mainLoop   ;loop back to the main loop if timer is not zero
C23D   36 20                  LD   (hl),KEY_SPEED   ;short timer set for subsequent presses
C23F                KEYFIRST:      
C23F   35                     DEC   (hl)   ;set timer off
C240                             ;key has been detected handle it
C240   21 88 08               LD   hl,MCB   ;get the MCB
C243   CB 5E                  BIT   3,(hl)   ;is bit 3 set? LCD/Segment
C245   C2 47 C3               JP   nz,keyProcessLCD   ;yes, process key for LCD
C248                             ; 
C248                             ;process key press for segment data entry (A = key, HL = MCB)
C248                             ;set C=key pressed, B=MCB, HL=CEL
C248                KEYPROCESSSEGS:      
C248   4F                     LD   c,a   ;store key pressed
C249   CB A9                  RES   5,c   ;reset Fn key bit if set
C24B   7E                     LD   a,(HL)   ;get MCB
C24C   47                     LD   b,a   ;save in B
C24D   79                     LD   a,c   ;restore key pressed
C24E   2A 86 08               LD   hl,(CEL)   ;load Current Editing location in HL
C251                KEYPLUS:      
C251   FE 10                  CP   K_PLUS   ;Plus key press
C253   20 0D                  JR   nz,keyMinus   ;no, Check Minus key
C255   CD 04 C4               CALL   checkFnKey   ;check for Function key
C258   CA EE C2               JP   z,fnPlus   ;handle Fn+Plus key
C25B   23                     INC   hl   ;move to next CEL
C25C                UPDATECEL:      
C25C   22 86 08               LD   (CEL),hl   ;save CEL
C25F   78                     LD   a,b   ;get MCB
C260   18 B2                  JR   resetMCB   ;reset MCB and jump to Main loop
C262                KEYMINUS:      
C262   FE 11                  CP   K_MINUS   ;Minus key press
C264   20 09                  JR   nz,keyAddress   ;no, Check Address key
C266   CD 04 C4               CALL   checkFnKey   ;check for Function key
C269   CA 15 C3               JP   z,fnMinus   ;handle Fn+Minus key
C26C   2B                     DEC   hl   ;move to previous address
C26D   18 ED                  JR   updateCEL   ;update CEL and return
C26F                KEYADDRESS:      
C26F   FE 13                  CP   K_ADDR   ;Address key press
C271   20 0D                  JR   nz,keyGo   ;no, Check Go key
C273   CD 04 C4               CALL   checkFnKey   ;check for Function key
C276   CA 3B C3               JP   z,fnAd   ;handle Fn+AD key
C279   78                     LD   a,b   ;get MCB
C27A   EE 04                  XOR   MCB_AD_DATA   ;flip Address/Data bit
C27C   E6 FC                  AND   0FCH   ;clear nibble counter
C27E   18 96                  JR   updateMCB   ;update MCB and jump to Main loop
C280                KEYGO:       
C280   FE 12                  CP   K_GO   ;Go key press
C282   20 1F                  JR   nz,keyHex   ;no, Must be Hex key
C284   06 01                  LD   b,01H   ;clear LCD instruction
C286   CD 9C C5               CALL   commandToLCD   ;update LCD
C289   C3 AC C3               JP   lcdRunning   ;display Code running at on LCD
C28C                RUNROUTINE:      
C28C   CD 0C C5               CALL   beep   ;indicate key press
C28F   3A 9D 08               LD   a,(SYS_MODE)   ;reset hardware to MONitor mode
C292   47                     LD   b,a   
C293   3A 9E 08               LD   a,(PROT_MODE)   ;enable PROTECT if configured
C296   B0                     OR   b   
C297   D3 FF                  OUT   (SYS_CTRL),a   
C299   3E FF                  LD   a,0FFH   
C29B   32 89 08               LD   (KEY_BUFF),a   ;remove GO from key Buffer to avoid GO held
C29E   11 09 C2               LD   de,softBoot   ;get return address
C2A1   D5                     PUSH   de   ;put return address on stack
C2A2   E9                     JP   (hl)   ;jump to CEL and execute it
C2A3                KEYHEX:      
C2A3   78                     LD   a,b   ;get MCB
C2A4   CB 57                  BIT   2,a   ;check mode Address or Data
C2A6   20 25                  JR   nz,updateAddress   ;update address
C2A8   CD 04 C4               CALL   checkFnKey   ;check for Function key
C2AB   28 2F                  JR   z,keyFn   ;jump to Function key routine
C2AD                             ;update data and set nibble decimal point and auto address increment
C2AD   78                     LD   a,b   ;get MCB
C2AE   E6 03                  AND   03H   ;mask out to nibble counter
C2B0   FE 02                  CP   02H   ;is this the second nibble?
C2B2   78                     LD   a,b   ;get original MCB
C2B3   20 0E                  JR   nz,enterNibble   ;no, just enter the nibble into (CEL)
C2B5   F5                     PUSH   af   ;save MCB
C2B6   3A 8C 08               LD   a,(KEY_AUTO)   ;check for auto address increment flag
C2B9   B7                     OR   a   ;is it zero?
C2BA   20 04                  JR   nz,skipAutoInc   ;no, don't update CEL
C2BC   23                     INC   hl   ;move to next CEL to enter nibble
C2BD   22 86 08               LD   (CEL),hl   ;store it
C2C0                SKIPAUTOINC:      
C2C0   F1                     POP   af   ;restore MCB
C2C1   E6 FC                  AND   0FCH   ;clear nibble counter
C2C3                ENTERNIBBLE:      
C2C3   3C                     INC   a   ;add one to nibble counter
C2C4   32 88 08               LD   (MCB),a   ;store it
C2C7   79                     LD   a,c   ;get key
C2C8   ED 6F                  RLD      ;shift key into CEL
C2CA   C3 19 C2               JP   setDispBuffer   ;jump back to main loop
C2CD                             ;update address
C2CD                UPDATEADDRESS:      
C2CD   21 86 08               LD   hl,CEL   ;set hl to address of CEL
C2D0   79                     LD   a,c   ;load a with hex key pressed
C2D1   ED 6F                  RLD      ;shift key into lower byte of CEL
C2D3   23                     INC   hl   ;move to upper byte
C2D4   ED 6F                  RLD      ;shift carry nibble into upper byte
C2D6   CD 01 C5               CALL   setDataBase   ;set the DATA_BASE variable
C2D9   C3 19 C2               JP   setDispBuffer   ;jump back to main loop
C2DC                             ;function key handler
C2DC                KEYFN:       
C2DC   11 2F D4               LD   de,functionJumpTable   ;reference jump table
C2DF   79                     LD   a,c   ;load a with hex key pressed
C2E0   87                     ADD   a,a   ;double it
C2E1   6F                     LD   l,a   ;store index in
C2E2   26 00                  LD   h,0   ;hl
C2E4   19                     ADD   hl,de   ;index DE with HL
C2E5   7E                     LD   a,(hl)   ;store jump
C2E6   23                     INC   hl   ;address
C2E7   66                     LD   h,(hl)   ;back into
C2E8   6F                     LD   l,a   ;HL
C2E9   11 09 C2               LD   de,softBoot   ;get return address
C2EC   D5                     PUSH   de   ;put return address on stack
C2ED   E9                     JP   (hl)   ;jump to HL and execute it
C2EE                             ;function + Plus handler
C2EE                FNPLUS:      
C2EE                             ;shift from CEL to High RAM 1 byte up, make CEL=0
C2EE   ED 5B 86 08            LD   de,(CEL)   ;get current CEL
C2F2   21 FF 7F               LD   hl,TOP_RAM   ;get high ram
C2F5   B7                     OR   a   ;clear carry
C2F6   ED 52                  SBC   hl,de   ;get difference
C2F8   FA 19 C2               JP   m,setDispBuffer   ;high ram < cel, exit
C2FB   EB                     EX   de,hl   ;set hl to CEL
C2FC   22 C0 08               LD   (COPY_START),hl   ;move from CEL
C2FF   23                     INC   hl   
C300   22 C4 08               LD   (COPY_DEST),hl   ;save from CEL+1
C303   21 FF 7F               LD   hl,TOP_RAM   ;HL = 7FFEH
C306   2B                     DEC   hl   
C307   22 C2 08               LD   (COPY_END),hl   ;save from TOP_RAM-1
C30A   CD 2B CA               CALL   smartCopyDirect   ;do the smart update
C30D   2A 86 08               LD   hl,(CEL)   ;get CEL
C310   36 00                  LD   (hl),00H   ;put zero in CEL
C312   C3 19 C2               JP   setDispBuffer   ;jump back to main loop
C315                FNMINUS:      
C315                             ;shift from CEL to High RAM 1 byte down, make High RAM=0
C315   ED 5B 86 08            LD   de,(CEL)   ;get current CEL
C319   21 FF 7F               LD   hl,TOP_RAM   ;get high ram
C31C   B7                     OR   a   ;clear carry
C31D   ED 52                  SBC   hl,de   ;get difference
C31F   FA 19 C2               JP   m,setDispBuffer   ;high ram < cel, exit
C322   EB                     EX   de,hl   ;set hl to CEL
C323   22 C4 08               LD   (COPY_DEST),hl   ;move to CEL
C326   23                     INC   hl   
C327   22 C0 08               LD   (COPY_START),hl   ;save from CEL+1
C32A   21 FF 7F               LD   hl,TOP_RAM   ;HL = 7FFFH
C32D   22 C2 08               LD   (COPY_END),hl   ;save from TOP_RAM
C330   CD 2B CA               CALL   smartCopyDirect   ;do the smart update
C333   21 FF 7F               LD   hl,TOP_RAM   ;get High RAM
C336   36 00                  LD   (hl),00H   ;put zero in High RAM
C338   C3 19 C2               JP   setDispBuffer   ;jump back to main loop
C33B                FNAD:        
C33B                             ;display main menu
C33B   21 B2 D5               LD   hl,mainMenuCFG   ;set up 1G Menu
C33E   CD DD CE               CALL   menuInit   
C341   CD 65 C6               CALL   switchMode   
C344   C3 19 C2               JP   setDispBuffer   
C347                             ; 
C347                             ;process key press for segment data entry (A = key, HL = MCB)
C347                KEYPROCESSLCD:      
C347   FE 10                  CP   K_PLUS   ;is it the plus key
C349   20 26                  JR   nz,keyMinusLCD   ;no, try -
C34B                KEYPLUSLCD:      
C34B   3A 98 08               LD   a,(MENU_CNT)   ;get menu count
C34E   3D                     DEC   a   ;adjust for 0
C34F   47                     LD   b,a   ;save it in B
C350   3A 97 08               LD   a,(MENU_SEL)   ;get current menu selection
C353   B8                     CP   b   ;is count = selection?
C354   CA 29 C2               JP   z,mainLoop   ;yes, ignore and return to menu
C357   3C                     INC   a   ;move to next item
C358   32 97 08               LD   (MENU_SEL),a   ;save it
C35B   4F                     LD   c,a   ;save for later
C35C   3A 96 08               LD   a,(MENU_POS)   ;get menu display position
C35F   C6 03                  ADD   a,3   ;add 3
C361   47                     LD   b,a   ;B = menu pos
C362   79                     LD   a,c   ;A = menu sel
C363   B8                     CP   b   ;if b+3>a then no change
C364   DA 19 C2               JP   c,setDispBuffer   ;yes return to menu
C367   3A 96 08               LD   a,(MENU_POS)   ;get menu display position
C36A   3C                     INC   a   ;update it
C36B   32 96 08               LD   (MENU_POS),a   ;save it
C36E   C3 19 C2               JP   setDispBuffer   ;exit and update LCD
C371                KEYMINUSLCD:      
C371   FE 11                  CP   K_MINUS   ;is it the minus key
C373   20 1A                  JR   nz,keyGoLCD   ;no, try GO
C375   3A 97 08               LD   a,(MENU_SEL)   ;get current menu selection
C378   3D                     DEC   a   ;decrease it by 1
C379   FA 29 C2               JP   m,mainLoop   ;if negative exit
C37C   32 97 08               LD   (MENU_SEL),a   ;save it
C37F   4F                     LD   c,a   ;save for later
C380   3A 96 08               LD   a,(MENU_POS)   ;get menu display position
C383   47                     LD   b,a   ;B = menu pos
C384   79                     LD   a,c   ;A = menu sel
C385   B8                     CP   b   ;if b<a then no change
C386   D2 19 C2               JP   nc,setDispBuffer   ;return
C389   32 96 08               LD   (MENU_POS),a   ;save it
C38C   C3 19 C2               JP   setDispBuffer   ;exit
C38F                KEYGOLCD:      
C38F   FE 12                  CP   K_GO   ;is it the GO key
C391   20 2C                  JR   nz,keyAddressLCD   ;no, try AD
C393   CB 6E                  BIT   5,(hl)   ;check MCB for Parameter Entry
C395   28 03                  JR   z,menuGo   ;if Zero, it must be a menu
C397                             ;Parameter GO needs to pop menu and just return
C397   C3 06 CF               JP   menuPop   ;restore to the previous menu and return back
C39A                MENUGO:      
C39A   3A 97 08               LD   a,(MENU_SEL)   ;get current menu selection
C39D   CD 9A CF               CALL   menuIndex   ;set HL to menu config at index A
C3A0   06 01                  LD   b,01H   ;clear LCD instruction
C3A2   CD 9C C5               CALL   commandToLCD   ;update LCD
C3A5   CD 83 C5               CALL   stringToLCD   ;Display Message on LCD
C3A8                             ;HL is now at address to jump to
C3A8   7E                     LD   a,(hl)   ;fix HL
C3A9   23                     INC   hl   ;for executing
C3AA   66                     LD   h,(hl)   ;and displaying
C3AB   6F                     LD   l,a   
C3AC                LCDRUNNING:      
C3AC   E5                     PUSH   hl   ;save HL
C3AD   06 D6                  LD   b,0D6H   ;set cursor to Row 4,Col 3
C3AF   CD 9C C5               CALL   commandToLCD   ;update LCD
C3B2   21 1C D5               LD   hl,menuGoText   ;display "  Running at: 1234  "
C3B5   CD 83 C5               CALL   stringToLCD   ;write text
C3B8   E1                     POP   hl   ;restore HL
C3B9   CD B6 C5               CALL   HLtoLCD   ;display HL as a string on LCD
C3BC   C3 8C C2               JP   runRoutine   ;execute it safely
C3BF                KEYADDRESSLCD:      
C3BF   FE 13                  CP   K_ADDR   ;is key AD?
C3C1   C2 CA C3               JP   nz,keyHexLCD   ;no, try Hex key
C3C4   CD 06 CF               CALL   menuPop   ;restore to previous menu
C3C7   C3 09 C2               JP   softBoot   ;and return
C3CA                KEYHEXLCD:      
C3CA                             ;only applicable in Parameter mode
C3CA   CB 6E                  BIT   5,(hl)   ;check MCB
C3CC   CA 29 C2               JP   z,mainLoop   ;in Menu Mode, ignore key
C3CF   4F                     LD   c,a   ;save key press
C3D0   3A 97 08               LD   a,(MENU_SEL)   ;get current menu selection
C3D3   CD 9A CF               CALL   menuIndex   ;set HL to menu config at index A
C3D6   7E                     LD   a,(hl)   ;skip menu label
C3D7   23                     INC   hl   
C3D8   B7                     OR   a   ;is it zero
C3D9   20 FB                  JR   nz,$-3   ;repeat until zero found
C3DB   7E                     LD   a,(hl)   ;fix HL
C3DC   23                     INC   hl   ;for updating
C3DD   66                     LD   h,(hl)   
C3DE   6F                     LD   l,a   
C3DF   79                     LD   a,c   ;restore key pressed
C3E0   ED 6F                  RLD      ;shift key into lower byte of CEL
C3E2   23                     INC   hl   ;move to upper byte
C3E3   ED 6F                  RLD      ;shift carry nibble into upper byte
C3E5                             ;check if HL=COPY_START/END/DEST for RTC update
C3E5   3A 88 08               LD   a,(MCB)   ;check if RTC installed
C3E8   E6 40                  AND   MCB_RTC   ;is bit 6 set
C3EA   CA 19 C2               JP   z,setDispBuffer   ;no, just exit back
C3ED   2B                     DEC   hl   ;move HL back to original address
C3EE   3E 08                  LD   a,08H   
C3F0   94                     SUB   h   ;is address 08?
C3F1   C2 19 C2               JP   nz,setDispBuffer   
C3F4   7D                     LD   a,l   
C3F5   D6 C0                  SUB   0C0H   ;is address C0-C4?
C3F7   FE 05                  CP   05H   ;is it > 4
C3F9   D2 19 C2               JP   nc,setDispBuffer   
C3FC                             ;all good to update RTC
C3FC   C6 06                  ADD   a,06H   ;index A for RTC slot
C3FE   CD 86 CE               CALL   RTCSetPRAM   ;save it 
C401   C3 19 C2               JP   setDispBuffer   ;exit
C404                             ; 
C404                             ; Check for Fn key pressed.
C404                             ; Output: Zero is set if Fn key is pressed
C404                CHECKFNKEY:      
C404   DB 03                  IN   a,(SYS_INPUT)   ;read simp buffer
C406   0F                     RRCA      ;check bit 0
C407   38 05                  JR   c,checkSecond   ;if set, matrix keyboard in use
C409   DB 00                  IN   a,(KEYB)   ;check keyboard latch
C40B   E6 20                  AND   20H   ;is bit 5 set
C40D   C9                     RET      
C40E                CHECKSECOND:      
C40E   3A 8E 08               LD   a,(KEY_SECOND)   ;get second key if any
C411   FE 02                  CP   K_FN   ;is it the FN key?
C413   C9                     RET      
C414                             ; 
C414                             ; Update LCD screen.  Either show a menu if LCD mode or byte information if
C414                             ; segment mode
C414                UPDATELCD:      
C414   06 0C                  LD   b,0CH   ;display on, cursor off
C416   CD 9C C5               CALL   commandToLCD   ;update LCD
C419   06 01                  LD   b,01H   ;clear LCD instruction
C41B   CD 9C C5               CALL   commandToLCD   ;update LCD
C41E   21 88 08               LD   hl,MCB   ;get the MCB
C421   CB 5E                  BIT   3,(hl)   ;is bit 3 set? LCD/Segment
C423   C2 20 CF               JP   nz,menuDraw   ;LCD menu mode is set, draw the menu and return
C426   CB 66                  BIT   4,(hl)   ;is bit 4 set? Disassembly / Data view
C428   C2 C5 C4               JP   nz,LCDDisView   ;display Disassembly View
C42B                LCDDATAVIEW:      
C42B   CD 01 C5               CALL   setDataBase   ;set the DATA_BASE variable
C42E   11 FC FF               LD   de,0FFFCH   ;set DE to -4
C431   19                     ADD   hl,de   ;set HL = HL - 4
C432   01 04 03               LD   bc,0304H   ;three lines, four bytes
C435   11 1B D4               LD   de,LCDBaseRows   ;set de to first row
C438                LCDDATAROW:      
C438   C5                     PUSH   bc   ;save BC
C439   1A                     LD   a,(de)   ;get row value
C43A   13                     INC   de   ;move to next row
C43B   47                     LD   b,a   ;set B as LCD row
C43C   CD 9C C5               CALL   commandToLCD   ;update LCD
C43F   41                     LD   b,c   ;load byte count in B
C440   D5                     PUSH   de   ;save row table
C441   11 00 09               LD   de,DATA_ROW   ;point to Data Entry RAM
C444   CD F6 C8               CALL   genDataDump   ;fill DE with data dump line
C447   E5                     PUSH   hl   ;save HL
C448   21 00 09               LD   hl,DATA_ROW   ;point to Data Entry RAM start
C44B   CD 83 C5               CALL   stringToLCD   ;print line to LCD
C44E   E1                     POP   hl   ;get current address
C44F   D1                     POP   de   ;restore row table
C450   C1                     POP   bc   ;restore BC
C451   10 E5                  DJNZ   LCDDataRow   ;do for all three rows
C453                             ; 
C453                             ;draw disassembly line
C453   1A                     LD   a,(de)   ;get row value
C454   47                     LD   b,a   ;set B as LCD row
C455   CD 9C C5               CALL   commandToLCD   ;update LCD
C458   CD 52 CB               CALL   calcDisAddress   ;get actual dis address from CEL
C45B   2A 90 08               LD   hl,(DIS_ADDR)   ;set DE to DIS_ADDR
C45E   22 29 09               LD   (DISFROM),hl   ;user DIS_ADDR as start address for disassembler
C461   CD DE C4               CALL   drawDisRow   ;Draw the Disassembly line
C464                             ; 
C464                             ;draw state information
C464   06 91                  LD   b,091H   ;move cursor
C466   CD 9C C5               CALL   commandToLCD   ;to top right
C469   3E 7C                  LD   a,"|"   
C46B   CD 98 C5               CALL   charToLCD   
C46E   3A 88 08               LD   a,(MCB)   
C471   4F                     LD   c,a   
C472   3E 64                  LD   a,"d"   
C474   06 05                  LD   b,05h   ;special flip bit xor "a" <-> "d"
C476   CB 51                  BIT   2,c   ;is in Data or Address mode?
C478   28 01                  JR   z,$+3   
C47A   A8                     XOR   b   
C47B   CD 98 C5               CALL   charToLCD   ;Display the byte
C47E   A8                     XOR   b   ;flip it back to a or d
C47F   CD 98 C5               CALL   charToLCD   ;Display the byte
C482                             ; 
C482   06 D1                  LD   b,0D1H   ;move cursor
C484   CD 9C C5               CALL   commandToLCD   ;to far right
C487   3E 7C                  LD   a,"|"   
C489   CD 98 C5               CALL   charToLCD   
C48C   3E 20                  LD   a," "   
C48E   CD 98 C5               CALL   charToLCD   
C491   2A 86 08               LD   hl,(CEL)   ;get current byte
C494   7E                     LD   a,(HL)   ;get byte
C495   CD 98 C5               CALL   charToLCD   ;Display the byte
C498                             ; 
C498   06 A5                  LD   b,0A5H   ;move cursor
C49A   CD 9C C5               CALL   commandToLCD   ;to far right
C49D   3E 7C                  LD   a,"|"   
C49F   CD 98 C5               CALL   charToLCD   
C4A2   3E 6E                  LD   a,"n"   
C4A4   CD 98 C5               CALL   charToLCD   ;Display the byte
C4A7   79                     LD   a,c   ;mask out lower MCB
C4A8   E6 03                  AND   03H   
C4AA   C6 30                  ADD   a,"0"   ;convert binary to ascii value
C4AC   CD 98 C5               CALL   charToLCD   ;display the byte count
C4AF                             ; 
C4AF                             ;set cursor
C4AF   ED 4B A0 08            LD   bc,(DATA_BASE)   ;load BC with DATA_BASE
C4B3   B7                     OR   a   ;reset carry
C4B4   ED 42                  SBC   hl,bc   ;get difference between HL and BC
C4B6   7D                     LD   a,l   ;load difference in a
C4B7   4F                     LD   c,a   ;save to C
C4B8   87                     ADD   a,a   ;double A
C4B9   81                     ADD   a,c   ;add C
C4BA   C6 C5                  ADD   a,LCD_ROW2+5   ;add 5 to set row 1, col 5
C4BC   47                     LD   b,a   ;set LCD command
C4BD   CD 9C C5               CALL   commandToLCD   ;move cursor to correct position
C4C0   3E 7E                  LD   a,MENU_PTR   ;display ->
C4C2   C3 98 C5               JP   charToLCD   ;update LCD
C4C5                             ; 
C4C5                             ; Work out valid Disassembly start based on where CEL is.
C4C5                LCDDISVIEW:      
C4C5   CD 52 CB               CALL   calcDisAddress   ;work out Actual disassembly address from CEL
C4C8                             ;Display disassembly in 4 rows
C4C8   22 29 09               LD   (DISFROM),hl   ;Store it in the disassembler start address
C4CB   06 04                  LD   b,4   ;four lines
C4CD   11 1B D4               LD   de,LCDBaseRows   ;set DE to second row
C4D0                LCDDISROW:      
C4D0   C5                     PUSH   bc   ;save BC
C4D1   1A                     LD   a,(de)   ;get row value
C4D2   13                     INC   de   ;move to next row
C4D3   47                     LD   b,a   ;set B as LCD row
C4D4   CD 9C C5               CALL   commandToLCD   ;update LCD
C4D7   CD DE C4               CALL   drawDisRow   ;Draw the Disassembly line
C4DA   C1                     POP   bc   ;restore BC
C4DB   10 F3                  DJNZ   LCDDisRow   ;do for all four rows
C4DD   C9                     RET      
C4DE                             ; 
C4DE                             ; Update LCD with Disassembly Line: 
C4DE                             ; Input: DISFROM is to be be set, IE , ld (DISFROM),hl
C4DE                             ; Output: On LCD as current cursor: IE: "4000: LD A,34"
C4DE                             ; Destroy: HL,A
C4DE                DRAWDISROW:      
C4DE   D5                     PUSH   de   ;save row table
C4DF   CD 9B E7               CALL   disStart   ;Generate disassembly from command after CEL
C4E2   21 00 09               LD   hl,DISLINE1   ;Point to first line
C4E5   3E 3A                  LD   a,COLON   ;load A with colon
C4E7   32 04 09               LD   (DISLINE1+4),a   ;place colon after address
C4EA   3E 20                  LD   a,SPACE   ;load A with space
C4EC   32 05 09               LD   (DISLINE1+5),a   ;just display address
C4EF   AF                     XOR   a   ;zero A
C4F0   32 06 09               LD   (DISLINE1+6),a   ;just display address
C4F3   CD 83 C5               CALL   stringToLCD   ;update LCD
C4F6   21 13 09               LD   hl,DISLINE2   ;Point to second line
C4F9   CD A1 C8               CALL   stringZeroSpace   ;Place 0 at actual end of string
C4FC   CD 83 C5               CALL   stringToLCD   ;update LCD
C4FF   D1                     POP   de   ;restore row table
C500   C9                     RET      
C501                             ; 
C501                             ; Set the DATA_BASE variable with the CEL rounded down to base hex value
C501                             ; Input: none
C501                             ; Output: DATA_BASE set
C501                             ; Destroy: HL
C501                SETDATABASE:      
C501   2A 86 08               LD   hl,(CEL)   ;get CEL
C504   7D                     LD   a,l   ;get lower byte
C505   E6 FC                  AND   0FCH   ;mask out two lowest bits
C507   6F                     LD   l,a   ;store it back to get read base address
C508   22 A0 08               LD   (DATA_BASE),hl   ;store new Base
C50B   C9                     RET      
C50C                             ; 
C50C                             ; Monitor routines
C50C                             ; ----------------
C50C                             ; 
C50C                             ; Product a short Beep from the speaker
C50C                             ; Input: N/A
C50C                             ; Destroys: A
C50C                BEEP:        
C50C   3A 8D 08               LD   a,(KEY_BEEP)   ;check sound flag
C50F   B7                     OR   a   ;is it zero?
C510   C0                     RET   nz   ;exit if not zero
C511                BEEPALWAYS:      
C511   C5                     PUSH   bc   ;save BC
C512   0E 40                  LD   c,40H   ;Tone count
C514   AF                     XOR   a   ;clear A
C515                BEEPLOOP:      
C515   D3 01                  OUT   (DIGITS),a   ;output to segment latch
C517   06 40                  LD   b,40H   ;set delay
C519   10 FE                  DJNZ   $   ;delay
C51B   EE 80                  XOR   80H   ;toggle speaker bit
C51D   0D                     DEC   c   ;decrease count
C51E   20 F5                  JR   nz,beepLoop   ;repeat until c is zero
C520   C1                     POP   bc   ;restore BC
C521   AF                     XOR   a   ;clear A
C522   D3 01                  OUT   (DIGITS),a   ;output to segment latch
C524   C9                     RET      
C525                             ; 
C525                             ; Move Current Editing Location in Display Buffer
C525                             ; Input: DE = current editing location
C525                             ; Destroys: HL, DE, BC
C525                CELTOSEG:      
C525   EB                     EX   de,hl   ;swap DE with HL
C526   11 80 08               LD   de,DISP_BUFF   ;point DE to display buffer
C529   7C                     LD   a,h   ;get high byte
C52A   CD 32 C5               CALL   convAToSeg   ;convert A to segment
C52D   7D                     LD   a,l   ;get low byte
C52E   CD 32 C5               CALL   convAToSeg   ;convert A to segment
C531   7E                     LD   a,(hl)   ;get data value to convert
C532                             ; 
C532                             ; Convert register A to Seven Segment
C532                             ; Inputs: A = byte to convert, DE = address to store segment values (2 bytes)
C532                             ; Destroys: BC
C532                CONVATOSEG:      
C532   F5                     PUSH   af   ;save AF
C533   07                     RLCA      ;move upper nibble to lower
C534   07                     RLCA      
C535   07                     RLCA      
C536   07                     RLCA      
C537   CD 3B C5               CALL   convNibToSeg   ;convert lower nibble to segment
C53A   F1                     POP   af   ;restore AF
C53B                CONVNIBTOSEG:      
C53B   E6 0F                  AND   0FH   ;mask out upper nibble
C53D   01 1F D4               LD   bc,hexToSegmentTable   ;point BC to segment table
C540   81                     ADD   a,c   ;index table with A
C541   4F                     LD   c,a   
C542   0A                     LD   a,(bc)   ;get segment data
C543   12                     LD   (de),a   ;store segment data in DE
C544   13                     INC   de   ;move to next DE address
C545   C9                     RET      
C546                             ; 
C546                             ; Sets the Segment decimal point depending on what mode the TEC is in.
C546                             ; Either Address edit or Data edit.  And nibble data entry
C546                             ; Destroys: A, B, HL
C546                SETDOTS:      
C546   21 80 08               LD   hl,DISP_BUFF   ;point HL to address location in display buffer
C549   06 04                  LD   b,04H   ;four dots for address
C54B   3A 88 08               LD   a,(MCB)   ;get monitor control byte
C54E   CB 57                  BIT   2,a   ;check address/data bit status
C550   20 10                  JR   nz,setDot   ;Address mode, set 4 dots
C552   06 02                  LD   b,02H   ;two dots for data
C554   21 84 08               LD   hl,DISP_DATA   ;point HL to data location in display buffer
C557   E6 03                  AND   03H   ;mask out nibble bits
C559   B7                     OR   a   ;is it zero?
C55A   28 06                  JR   z,setDot   ;yes, display two dots
C55C   3D                     DEC   a   ;subtract 1
C55D   B7                     OR   a   ;is it zero
C55E   20 01                  JR   nz,$+3   ;no, skip buffer move
C560   23                     INC   hl   ;move to lower nibble of display
C561   05                     DEC   b   ;set only one dot
C562                SETDOT:      
C562   CB E6                  SET   4,(hl)   ;set segment decimal place dot ON
C564   23                     INC   hl   ;move to next segment
C565   10 FB                  DJNZ   setDot   ;repeat if necessary
C567   C9                     RET      
C568                             ; 
C568                             ; Entry to multiplex the monitor display buffer
C568                SCANDISPLAYBUFF:      
C568   11 80 08               LD   de,DISP_BUFF   ;point DE to display buffer location
C56B                             ; 
C56B                             ; Multiplex the Seven Segment displays with the contents of DE
C56B                             ; Inputs: DE = 6 byte location of segment data
C56B                             ; Destroys: A, B, DE = DE + 6
C56B                SCANSEGMENTS:      
C56B   06 20                  LD   b,00100000B   ;left most digit port address
C56D                SCANLOOP:      
C56D   1A                     LD   a,(de)   ;load A with Segment data
C56E   D3 02                  OUT   (SEGS),a   ;send it to LED Segment
C570   78                     LD   a,b   ;get digit port address
C571   D3 01                  OUT   (DIGITS),a   ;light up digit
C573   06 40                  LD   b,40H   ;set on delay
C575   10 FE                  DJNZ   $   ;delay
C577   13                     INC   de   ;move to next buffer location
C578   47                     LD   b,a   ;save current digit reference
C579   AF                     XOR   a   ;zero A
C57A   D3 01                  OUT   (DIGITS),a   ;blank digits
C57C   CB 08                  RRC   b   ;rotate digit port bit to the right
C57E   30 ED                  JR   nc,scanLoop   ;if not on last digit repeat
C580   D3 02                  OUT   (SEGS),a   ;clear LED Segment
C582   C9                     RET      
C583                             ; 
C583                             ; ASCII string to LCD.  Writes a string to the current cursor location on the LCD
C583                             ; Inputs: HL = ASCII string terminated with zero byte
C583                             ; Destroys: A, HL (moves to end of list)
C583                STRINGTOLCD:      
C583   7E                     LD   a,(hl)   ;get ASCII character
C584   23                     INC   hl   ;move to next ASCII character
C585   B7                     OR   a   ;is it zero?
C586   C8                     RET   z   ;yes, exit
C587   EF                     RST   28H   ;wait until LCD is not busy
C588   D3 84                  OUT   (LCD_DATA),a   ;send ASCII to LCD Data port
C58A   18 F7                  JR   stringToLCD   ;repeat
C58C                             ; 
C58C                             ; ASCII string to Serial.  Writes a string to the FTDI serial port 
C58C                             ; Inputs: HL = ASCII string terminated with zero byte
C58C                             ; Destroys: A, HL (moves to end of list)
C58C                STRINGTOSERIAL:      
C58C   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C58F                STRSERIALLOOP:      
C58F   7E                     LD   a,(hl)   ;get ASCII character
C590   23                     INC   hl   ;move to next ASCII character
C591   B7                     OR   a   ;is it zero?
C592   C8                     RET   z   ;yes, exit
C593   CD A8 C6               CALL   txByte   ;send ASCII to serial port
C596   18 F7                  JR   strSerialLoop   ;repeat
C598                             ; 
C598                             ; ASCII character to LCD.  Writes one character to the LCD as the current curso locaiton
C598                             ; Inputs: A = ASCII character
C598                             ; Destroys: none
C598                CHARTOLCD:      
C598   EF                     RST   28H   ;wait until LCD is not busy
C599   D3 84                  OUT   (LCD_DATA),a   ;send ASCII to LCD Data port
C59B   C9                     RET      
C59C                             ; 
C59C                             ; Command to LCD.  Sends an LCD instruction to the LCD
C59C                             ; Inputs: B = Instruction byte
C59C                             ; Destroys: none
C59C                COMMANDTOLCD:      
C59C   F5                     PUSH   af   ;save AF
C59D   EF                     RST   28H   ;wait until LCD is not busy
C59E   78                     LD   a,b   ;move instruction into A
C59F   D3 04                  OUT   (LCD_INST),a   ;send byte to instruction port
C5A1   F1                     POP   af   ;restore AF
C5A2   C9                     RET      
C5A3                             ; 
C5A3                             ; LCD initialise routine to set up LCD for correct use after a reset
C5A3                             ; Inputs: nothing
C5A3                             ; Destroys: all
C5A3                LCDINITIALISE:      
C5A3   01 04 04               LD   bc,400H+LCD_INST   ;4 instructions, LCD Instruction port
C5A6   21 17 D4               LD   hl,LCDInitTable   ;LCD instructions table
C5A9   11 00 10               LD   de,1000H   
C5AC   1B                     DEC   de   
C5AD   7B                     LD   a,e   
C5AE   B2                     OR   d   
C5AF   20 FB                  JR   nz,$-3   
C5B1   ED A3                  OUTI      ;send it to LCD
C5B3   20 F4                  JR   nz,$-10   ;loop again
C5B5   C9                     RET      
C5B6                             ; 
C5B6                             ; HL to LCD.  Dipslay the contents of HL as a string on the LCD at the current
C5B6                             ; cursor location
C5B6                             ; Inputs: HL
C5B6                             ; Destroy: A
C5B6                HLTOLCD:      
C5B6   E5                     PUSH   hl   ;save HL
C5B7   D5                     PUSH   de   ;save DE
C5B8   11 00 09               LD   de,DATA_ROW   ;tmp memory storage
C5BB   CD C9 C8               CALL   HLToString   ;convert HL to ASCII string in (DE)
C5BE   AF                     XOR   a   ;set A = 0
C5BF   12                     LD   (de),a   ;terminate string with zero
C5C0   21 00 09               LD   hl,DATA_ROW   ;set HL to text address
C5C3   CD 83 C5               CALL   stringToLCD   ;write text
C5C6   D1                     POP   de   ;restore DE
C5C7   E1                     POP   hl   ;restore HL to address
C5C8   C9                     RET      
C5C9                             ; 
C5C9                             ; LCD busy check.  Checks the LCD busy flag and loops until LCD isn't busy
C5C9                             ; Inputs: nothing
C5C9                             ; Destorys: none
C5C9                LCDBUSY:      
C5C9   F5                     PUSH   af   ;save af
C5CA   DB 04                  IN   a,(LCD_INST)   ;Read status bit on LCD
C5CC   07                     RLCA      ;put bit 7 (status) in carry
C5CD   38 FB                  JR   c,$-3   ;loop if LCD is busy
C5CF   F1                     POP   af   ;restore af
C5D0   C9                     RET      
C5D1                             ; 
C5D1                             ; Universal Key input detection routine.  Responds to Hex keypad or Matrix Keyboard
C5D1                             ; Return: A = key value
C5D1                             ;         zero flag set if a key is pressed
C5D1                             ;         carry flag set if press detected of a new key
C5D1                             ;         carry flag not set for key pressed and held
C5D1                             ; Destroys: DE if using Matrix Keyboard
C5D1                SCANKEYS:      
C5D1                             ;Detect keyboard input method
C5D1   DB 03                  IN   a,(SYS_INPUT)   ;read simp buffer
C5D3   0F                     RRCA      ;check bit 0
C5D4   38 20                  JR   c,keyboardScan   ;if set, matrix keyboard in use
C5D6                             ;Check keypad for press via keyboard decoder
C5D6   E6 20                  AND   20H   ;check bit 6 (now 5) for keypress on keypad
C5D8   28 04                  JR   z,keyPress   ;bit is low, a key is pressed
C5DA   32 8A 08               LD   (KEY_PRESS),a   ;set key press to non zero
C5DD   C9                     RET      ;return non zero for no key press
C5DE                KEYPRESS:      
C5DE   3A 8A 08               LD   a,(KEY_PRESS)   ;get key press flag
C5E1   B7                     OR   a   ;has it been already pressed (held down)?
C5E2   3A 89 08               LD   a,(KEY_BUFF)   ;set a to current key pressed if returning
C5E5   C8                     RET   z   ;key pressed and held, return zero and carry not set
C5E6   AF                     XOR   a   ;clear a
C5E7   32 8A 08               LD   (KEY_PRESS),a   ;set key press flag to zero
C5EA                             ;Universal key reader
C5EA   DB 00                  IN   a,(KEYB)   ;read key pressed
C5EC   E6 3F                  AND   3FH   ;mask out high bits
C5EE   EE 20                  XOR   20H   ;flip bit 5 (Fn-key)
C5F0                KEYEXIT:      
C5F0   BF                     CP   a   ;set zero flag
C5F1   37                     SCF      ;set carry flag
C5F2   32 89 08               LD   (KEY_BUFF),a   ;save key pressed into key buffer
C5F5   C9                     RET      
C5F6                             ; 
C5F6                             ; Matrix Keyboard handler.  If no key or invalid key press
C5F6                KEYBOARDSCAN:      
C5F6   CD 40 CC               CALL   matrixScan   ;detect if key has been pressed
C5F9   28 04                  JR   z,keyboardFetch   ;yes, continue with a key press flow
C5FB   32 8A 08               LD   (KEY_PRESS),a   ;set key press to non zero
C5FE   C9                     RET      ;return non zero for no key press
C5FF                KEYBOARDFETCH:      
C5FF                             ;E = key, D = second key
C5FF   7A                     LD   a,d   ;get seocnd key press if any
C600   32 8E 08               LD   (KEY_SECOND),a   ;store second key press
C603   7B                     LD   a,e   ;get first key press
C604                             ;Need to check if key is 0-F, +, -, GO or AD
C604                             ;0-9 = 13H-1CH, A-F = 24H-29H
C604                             ;AD = 3 or C, GO = 4 or A, - = 5, + = 6
C604   FE 2A                  CP   2AH   ;is it greater than 29H?
C606   30 4B                  JR   nc,keyBad   ;yes, return with non zero
C608   FE 24                  CP   24H   ;is it greater than 24H? (in range)
C60A   38 04                  JR   c,keyNumber   ;no, could be a number
C60C   D6 1A                  SUB   1AH   ;adjust alpha to be A-F
C60E   18 2A                  JR   keyGood   ;clean exit
C610                KEYNUMBER:      
C610   FE 1D                  CP   1DH   ;is it greater than 1CH?
C612   30 3F                  JR   nc,keyBad   ;yes, return with non zero
C614   FE 13                  CP   13H   ;is it greater than 13H? (in range)
C616   38 04                  JR   c,keySpecial   ;no, could be special key
C618   D6 13                  SUB   13H   ;adjust for number 0-9
C61A   18 1E                  JR   keyGood   ;clean exit
C61C                KEYSPECIAL:      
C61C   FE 0C                  CP   0CH   ;is it ESC?
C61E   20 04                  JR   nz,$+6   ;no, keep checking
C620   3E 13                  LD   a,K_ADDR   ;set key to AD
C622   18 16                  JR   keyGood   ;clean exit
C624   FE 0A                  CP   0AH   ;is it Enter?
C626   20 04                  JR   nz,$+6   ;no, keep checking
C628   3E 12                  LD   a,K_GO   ;set key to GO
C62A   18 0E                  JR   keyGood   ;clean exit
C62C   FE 07                  CP   07H   ;is it greater than 06H?
C62E   30 23                  JR   nc,keyBad   ;yes, return with non zero
C630   FE 05                  CP   05H   ;is it less than 5?
C632   38 1F                  JR   c,keyBad   ;yes, return with non zero
C634   D6 03                  SUB   3   ;subtract 3
C636   EE 03                  XOR   03H   ;flip bits
C638   C6 10                  ADD   a,10H   ;adjust special to be 10H-13H
C63A                KEYGOOD:      
C63A   5F                     LD   e,a   ;store key
C63B   3A 8A 08               LD   a,(KEY_PRESS)   ;get key press flag
C63E   B7                     OR   a   ;has it been already pressed (held down)?
C63F   3A 89 08               LD   a,(KEY_BUFF)   ;set a to current key pressed if returning
C642   C8                     RET   z   ;key pressed and held, return zero and carry not set
C643   AF                     XOR   a   ;clear a
C644   32 8A 08               LD   (KEY_PRESS),a   ;set key press flag to zero
C647   7A                     LD   a,d   ;check for Fn key
C648   FE 02                  CP   K_FN   ;is it function?
C64A   3E 00                  LD   a,0   ;reset A but not flags
C64C   20 02                  JR   nz,$+4   ;skip adding function
C64E   3E 20                  LD   a,00100000B   ;set bit 5
C650   83                     ADD   a,e   ;restore key
C651   18 9D                  JR   keyExit   ;clean exit
C653                KEYBAD:      
C653   F6 01                  OR   1   ;reset zero flag
C655   C9                     RET      ;return non zero for invalid key press
C656                             ; 
C656                             ; Scan keys and wait until key released to get next key
C656                             ; Input: none
C656                             ; Return: A = key pressed
C656                             ;         Zero flag is set
C656                             ; Destroys: DE if using Matrix Keyboard
C656                SCANKEYSWAIT:      
C656   CD D1 C5               CALL   scanKeys   ;check for key pressed
C659   3A 8A 08               LD   a,(KEY_PRESS)   ;is a key currently pressed?
C65C   B7                     OR   a   ;is it zero (pressed)
C65D   28 F7                  JR   z,scanKeysWait   ;repeat until key is released
C65F   CD D1 C5               CALL   scanKeys   ;check for key pressed
C662   20 FB                  JR   nz,$-3   ;repeat scanKeys until a key is pressed
C664   C9                     RET      
C665                             ; 
C665                             ; Toggles LCD Menu or Segment Data entry mode
C665                SWITCHMODE:      
C665   3A 88 08               LD   a,(MCB)   ;get MCB
C668   EE 08                  XOR   MCB_LCD_SEG   ;toggle Bit 3
C66A   CB AF                  RES   5,a   ;reset Parameter bit
C66C   32 88 08               LD   (MCB),a   ;save it back
C66F   C9                     RET      
C670                             ; 
C670                             ; Toggles Data Entry View or Disassembler View
C670                SWITCHVIEW:      
C670   3A 88 08               LD   a,(MCB)   ;get MCB
C673   EE 10                  XOR   MCB_DIS_DE   ;toggle Bit 4
C675   32 88 08               LD   (MCB),a   ;save it back
C678   C9                     RET      
C679                             ; 
C679                             ; ASCII to Segment.  Converts an ASCII character to Seven Segment character
C679                             ; Input: A = ASCII character
C679                             ; Return: A = Segment character or 0 if out of range
C679                             ; Destroys: none
C679                ASCIITOSEGMENT:      
C679   D6 20                  SUB   20H   ;adjust for table lookup
C67B   38 04                  JR   c,a2sExit   ;out of range
C67D   FE 60                  CP   60H   ;check upper range
C67F   38 02                  JR   c,a2sLookup   ;okay
C681                A2SEXIT:      
C681   AF                     XOR   a   ;set return value to zero
C682   C9                     RET      
C683                A2SLOOKUP:      
C683   E5                     PUSH   hl   ;save HL
C684   21 4F D4               LD   hl,ASCIISegTable   ;point hl to ASCII segment table
C687   85                     ADD   a,l   ;index l
C688   6F                     LD   l,a   ;save l
C689   7E                     LD   a,(hl)   ;get value in table
C68A   E1                     POP   hl   ;restore HL
C68B   C9                     RET      ;exit
C68C                             ; 
C68C                             ; Software ID.  Get Software ID String
C68C                             ; Input: nothing
C68C                             ; Return: HL = Pointer to SOFTWARE ASCIIZ String
C68C                             ; Destroys: none
C68C                SOFTWAREID:      
C68C   21 F0 FF               LD   hl,SOFTWARE   ;return the ID string pointer
C68F   C9                     RET      
C690                             ; 
C690                             ; Version ID.  Get Version Number and Version String
C690                             ; Input: nothing
C690                             ; Return: HL = Pointer to Release ASCIIZ String
C690                             ;         BC = Release major version number
C690                             ;         DE = Release minor version number
C690                             ; Destroys: none
C690                VERSIONID:      
C690   21 F8 FF               LD   hl,RELEASE   ;return the ID string pointerB
C693   ED 4B EC FF            LD   bc,(RELMAJOR)   ;return major version as a number
C697   ED 5B EE FF            LD   de,(RELMINOR)   ;return minor version as a number
C69B   C9                     RET      
C69C                             ; 
C69C                             ; Set serial for Ready To Transmit.  Must be called prior to any TEC to Serial
C69C                             ; routine
C69C                             ; Input: none
C69C                             ; Destroy: A
C69C                READYTOTRANSMIT:      
C69C   CD 23 CE               CALL   serialEnable   ;enable serial
C69F   E5                     PUSH   hl   ;save hl
C6A0   21 00 20               LD   hl,2000H   ;small
C6A3   CD 03 C7               CALL   timeDelay   ;delay
C6A6   E1                     POP   hl   ;restore HL
C6A7   C9                     RET      
C6A8                             ; 
C6A8                             ; Bit Bang FTDI USB tranmit routine.  Transmit one byte via the FTDI USB serial
C6A8                             ; connection.  It assumes a uart connection of 4800-8-N-2
C6A8                             ; Input: A = byte to transmit
C6A8                             ; Output: nothing
C6A8                             ; Destroy: none
C6A8                TXBYTE:      
C6A8   F5                     PUSH   af   ;save AF
C6A9   C5                     PUSH   bc   ;save BC
C6AA   E5                     PUSH   hl   ;save HL
C6AB   2A B1 08               LD   hl,(BAUD)   ;set HL to Baud delay
C6AE   4F                     LD   c,a   ;save transmit byte in C
C6AF                             ;transmit the start bit
C6AF   AF                     XOR   a   ;clear A
C6B0   D3 01                  OUT   (DIGITS),a   ;pull D6 low
C6B2   D3 02                  OUT   (SEGS),a   ;output to disco leds
C6B4   CD 03 C7               CALL   timeDelay   ;do a baud delay
C6B7                             ;transmit the byte
C6B7   06 08                  LD   b,8   ;eight bits to send
C6B9   CB 09                  RRC   c   ;move fist bit into carry flag
C6BB                SENDBIT:      
C6BB   CB 09                  RRC   c   ;shift to bit 6
C6BD   79                     LD   a,c   ;load byte in A
C6BE   E6 40                  AND   40H   ;mask out all bits except 6
C6C0   D3 01                  OUT   (DIGITS),a   ;output the bit
C6C2   D3 02                  OUT   (SEGS),a   ;output to disco leds
C6C4   CD 03 C7               CALL   timeDelay   ;do a baud delay
C6C7   10 F2                  DJNZ   sendBit   ;send next bit
C6C9                             ;transmit stop bits
C6C9   3E 40                  LD   a,40H   ;set bit
C6CB   D3 01                  OUT   (DIGITS),a   ;output the bit
C6CD   D3 02                  OUT   (SEGS),a   ;output to disco leds
C6CF   CD 03 C7               CALL   timeDelay   ;do a baud delay
C6D2   CD 03 C7               CALL   timeDelay   ;do a baud delay x2 (two stop bits)
C6D5   E1                     POP   hl   ;restore HL
C6D6   C1                     POP   bc   ;restore BC
C6D7   F1                     POP   af   ;restore AF
C6D8   C9                     RET      
C6D9                             ; 
C6D9                             ; Bit Bang FTDI USB receive routine.  Receive one byte via the FTDI USB serial
C6D9                             ; connection.  It assumes a uart connection of 4800-8-N-2
C6D9                             ; Input: nothing
C6D9                             ; Return: A = byte received
C6D9                             ; Destroy: none
C6D9                RXBYTE:      
C6D9   C5                     PUSH   bc   ;save BC
C6DA   E5                     PUSH   hl   ;save HL
C6DB                STARTBIT:      
C6DB   DB 03                  IN   a,(SYS_INPUT)   ;read system input for High to Low on Bit 7
C6DD   07                     RLCA      ;put bit 7 (TX line) in carry
C6DE   38 FB                  JR   c,startBit   ;loop if TX line is high
C6E0                             ;start bit detected
C6E0   2A B1 08               LD   hl,(BAUD)   ;set HL to Baud delay
C6E3   CB 3C                  SRL   h   ;half the delay
C6E5   CB 1D                  RR   l   
C6E7   CD 03 C7               CALL   timeDelay   ;do a baud delay
C6EA   DB 03                  IN   a,(SYS_INPUT)   ;get start bit
C6EC   07                     RLCA      ;move bit 7 into carry
C6ED   38 EC                  JR   c,startBit   ;start bit too short, try again
C6EF                             ;valid start bit detected
C6EF   06 08                  LD   b,8   ;eight bits to receive
C6F1                GETBIT:      
C6F1   2A B1 08               LD   hl,(BAUD)   ;set HL to Baud delay
C6F4   CD 03 C7               CALL   timeDelay   ;do a baud delay
C6F7   DB 03                  IN   a,(SYS_INPUT)   ;get data bit
C6F9   07                     RLCA      ;move bit 7 into carry
C6FA   CB 19                  RR   c   ;rotate register C and put carry in bit 7
C6FC   10 F3                  DJNZ   getBit   ;get next bit
C6FE   79                     LD   a,c   ;load byte C to A
C6FF   B7                     OR   a   ;clear carry flag
C700   E1                     POP   hl   ;restore HL
C701   C1                     POP   bc   ;restore BC
C702   C9                     RET      
C703                             ; 
C703                             ; Time delay.  16-bit Delay routine
C703                             ; Input: HL = delay amount
C703                             ; Destroy: none
C703                TIMEDELAY:      
C703   E5                     PUSH   hl   ;save HL
C704   D5                     PUSH   de   ;save DE
C705   11 01 00               LD   de,1   ;load DE with 1
C708   ED 52                  SBC   hl,de   ;subtract 1 from HL
C70A   D2 08 C7               JP   nc,$-2   ;repeat subtraction until HL=0
C70D   D1                     POP   de   ;restore DE
C70E   E1                     POP   hl   ;restore HL
C70F   C9                     RET      
C710                             ; 
C710                             ; INTEL Hex Load Routine.
C710                             ; Intel Hex file format is a string of ASCII with the following parts:
C710                             ; MARK | LENGTH | ADDRESS | RECORD TYPE | DATA | CHECKSUM
C710                             ; :10200000210621CD7D20CD98203A00213C320021AF <- EXAMPLE LINE
C710                             ; MARK is a colon character, LENGTH is the number of bytes per line, ADDRESS  is
C710                             ; the 2 byte address of where the data is to be stored.  RECORD TYPE is 00 for
C710                             ; Data and 01 for EOF.  DATA is the bytes to be stored.  CHECKSUM is the addition of
C710                             ; all bytes in the one line.
C710                             ; Input: nothing
C710                             ; Output: nothing
C710                             ; Destroy: HL,DE,BC,A
C710                INTELHEXLOAD:      
C710   3A 9D 08               LD   a,(SYS_MODE)   ;reset hardware to MONitor mode
C713   47                     LD   b,a   
C714   3E 02                  LD   a,PROTECT   ;Disable PROTECT during load
C716   2F                     CPL      
C717   A0                     AND   b   
C718   D3 FF                  OUT   (SYS_CTRL),a   
C71A   CD 28 C7               CALL   intelLoader   ;call the load routine, set zero if passed
C71D   3A 9D 08               LD   a,(SYS_MODE)   ;reset hardware to MONitor mode
C720   D3 FF                  OUT   (SYS_CTRL),a   
C722   CA 34 CC               JP   z,displayPass   ;if checksum good then display pass
C725   C3 2E CC               JP   displayError   ;else display error
C728                             ; 
C728                             ; Intel Hex Load Routine.
C728                             ; Returns: Zero Flag set = Pass, Zero Flag not set = Fail
C728                INTELLOADER:      
C728   AF                     XOR   a   ;zero A
C729   4F                     LD   c,a   ;clear checksum
C72A                             ;Get header information
C72A                INTELMARK:      
C72A   CD D9 C6               CALL   rxByte   ;Get Byte from FTDI USB driver
C72D   FE 3A                  CP   ":"   ;Is byte received a colon?
C72F   20 F9                  JR   nz,intelMark   ;No, loop until a colon is found
C731   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Length)
C734   47                     LD   b,a   ;Store Record Length in B
C735   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Destination address)
C738   67                     LD   h,a   ;Store High Address byte in H
C739   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Destination address)
C73C   6F                     LD   l,a   ;Store Low Address byte in L
C73D                             ; 
C73D                             ;Display indication that file is loading
C73D   D3 02                  OUT   (SEGS),a   ;load low address byte to segments
C73F   3E 01                  LD   a,1   ;set first segment
C741   D3 01                  OUT   (DIGITS),a   ;light up first segment
C743                             ; 
C743   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Record Type)
C746   20 11                  JR   nz,intelCheckSum   ;Anything non zero treat as EOF
C748                             ; 
C748                             ;C=checksum, B=number of bytes, HL=destination address
C748                             ;Load bytes to (HL), B times
C748                INTELLOAD:      
C748   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Data)
C74B   77                     LD   (hl),a   ;store data in RAM
C74C   57                     LD   d,a   ;copy A to D for later checking
C74D   7E                     LD   a,(hl)   ;read back value stored
C74E   BA                     CP   d   ;check if we stored the value successfully
C74F   C0                     RET   nz   ;exit with ZF not set if the store value check failed
C750   23                     INC   hl   ;move to next RAM location
C751   10 F5                  DJNZ   intelLoad   ;repeat until B=0
C753   CD 59 C7               CALL   intelCheckSum   ;Get checksum value
C756   28 D0                  JR   z,intelLoader   ;Line is processed and okay, get next line
C758   C9                     RET      ;Exit with zero flag not set (load error)
C759                             ; 
C759                INTELCHECKSUM:      
C759   CD 5F C7               CALL   getHexByte   ;Convert ASCII to Byte (Checksum)
C75C   79                     LD   a,c   ;Final Checksum is zero if okay
C75D   B7                     OR   a   ;set zero flag
C75E   C9                     RET      ;get next line or exit
C75F                             ; 
C75F                             ;Get ASCII character from FTDI AND convert it to a byte
C75F                             ;IE: "D3" -> 0D3H
C75F                GETHEXBYTE:      
C75F   CD 70 C7               CALL   getHexChar   ;Get first Hex character from FTDI
C762   07                     RLCA      ;Move lower nibble
C763   07                     RLCA      ;(first character)
C764   07                     RLCA      ;to upper
C765   07                     RLCA      ;nibble in A
C766   57                     LD   d,a   ;store it in D
C767   CD 70 C7               CALL   getHexChar   ;Get second Hex character from FTDI
C76A   B2                     OR   d   ;make a byte
C76B                             ;add byte to checksum
C76B   F5                     PUSH   af   ;save AF
C76C   81                     ADD   a,c   ;add existing checksum C to current byte
C76D   4F                     LD   c,a   ;load total back to C
C76E   F1                     POP   af   ;restore AF
C76F   C9                     RET      
C770                GETHEXCHAR:      
C770   CD D9 C6               CALL   rxByte   ;Get Byte from FTDI USB driver
C773   CB 77                  BIT   6,a   ;is the chracter 0-9 or A-F?
C775   28 02                  JR   z,$+4   ;Its 0-9 skip A-F adjustment
C777   C6 09                  ADD   a,9   ;add 9 to fix A-F
C779   E6 0F                  AND   0FH   ;mask out high nibble and convert to binary
C77B   C9                     RET      
C77C                             ; 
C77C                             ; SIO Hex Dump.  Transfer data on the TEC to a serial terminal
C77C                             ; Destroys: A,HL,DE,BC
C77C                DATATOSERIAL:      
C77C   CD A3 C7               CALL   getToFrom   ;collect parameters
C77F                             ; transmits data from HL for BC bytes
C77F                SENDTOSERIAL:      
C77F   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C782                SENDLOOP:      
C782   7E                     LD   a,(hl)   ;load A with data
C783   CD A8 C6               CALL   txByte   ;transmit it to FTDI
C786   ED A1                  CPI      ;inc HL, dec BC
C788   EA 82 C7               JP   pe,sendLoop   ;repeat until BC=0
C78B   C9                     RET      ;all done
C78C                             ; send to serial Entry for API
C78C                             ; Input: HL = start address
C78C                             ;        DE = length in bytes
C78C                SENDTOSERIALAPI:      
C78C   D5                     PUSH   de   ;make BC = DE
C78D   C1                     POP   bc   
C78E   C3 7F C7               JP   sendToSerial   
C791                             ; 
C791                             ; SIO receive data.  Receive binary data from FTDI
C791                DATAFROMSERIAL:      
C791   CD A3 C7               CALL   getToFrom   ;collect parameters
C794                RECEIVEFROMSERIAL:      
C794   CD D9 C6               CALL   rxByte   ;get byte from serial
C797   77                     LD   (hl),a   ;load byte into HL
C798   ED A1                  CPI      ;inc HL, dec BC
C79A   EA 94 C7               JP   pe,receiveFromSerial   ;repeat until BC=0
C79D   C9                     RET      ;all done
C79E                             ; receive from serial Entry for API
C79E                             ; Input: HL = start address
C79E                             ;        DE = length in bytes
C79E                RECEIVEFROMSERIALAPI:      
C79E   D5                     PUSH   de   ;make BC = DE
C79F   C1                     POP   bc   
C7A0   C3 94 C7               JP   receiveFromSerial   
C7A3                             ; 
C7A3                             ; Collect Address To and From information from user via the LCD interface
C7A3                             ; Stores From at DATA_FROM (08C0H) and To at DATA_TO (08C2H)
C7A3                             ; Output: HL = start address
C7A3                             ;         BC = length of end - start+1
C7A3                             ; Note: if end < start (error) then call error handler
C7A3                             ; Destroys: DE
C7A3                GETTOFROM:      
C7A3   21 B4 C7               LD   hl,dataRangeParams   
C7A6   CD BD CF               CALL   paramDriver   ;collect parameters
C7A9   21 C0 08               LD   hl,DATA_FROM   ;check parameters
C7AC   CD 0D C9               CALL   checkStartEnd   ; 
C7AF   D0                     RET   nc   ;All good, continue
C7B0   E1                     POP   hl   ;remove call return from stack
C7B1   C3 2E CC               JP   displayError   ;display error if end < start
C7B4                             ; 
C7B4                DATARANGEPARAMS:      
C7B4   02                     DB   2   ;Three parameters
C7B5   45 6E 74 65 72 20      DB   "Enter "   ;7seg Text
C7BB   3D 20 45 6E 74 65 72 20 50 61 72 61 6D 65 74 65 72 73 20 3D 00 DB   "= Enter Parameters =",0   ;Parameter title
C7D0   46 72 6F 6D 20 41 64 64 72 65 73 73 3A 00 DB   "From Address:",0   ;Text and Address
C7DE   C0 08                  DW   DATA_FROM   
C7E0   54 6F 20 41 64 64 72 65 73 73 3A 00 DB   "To Address:",0   ;Text and Address
C7EC   C2 08                  DW   DATA_TO   
C7EE                             ; 
C7EE                             ; Send Disassembly to serial terminal
C7EE                             ; Destroys: All
C7EE                ASSEMBLYTOSERIAL:      
C7EE   CD A3 C7               CALL   getToFrom   ;collect parameters
C7F1                             ; prints assemblybetween DATA_FROM / DATA_TO to the serial terminal.  Can
C7F1                             ; be called externally provided DATA_FROM/TO (08C0-08C3) are populated.
C7F1                SENDASSEMBLY:      
C7F1   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C7F4   2A C0 08               LD   hl,(DATA_FROM)   ;get start address
C7F7   22 29 09               LD   (DISFROM),hl   ;save start in DIS_FROM
C7FA                ASSEMBLYLOOP:      
C7FA   CD 9B E7               CALL   disStart   ;generate Disassembly
C7FD   21 00 09               LD   hl,DISLINE1   ;get string
C800   06 26                  LD   b,38   ;38 characters
C802   7E                     LD   a,(hl)   ;load A with data
C803   CD A8 C6               CALL   txByte   ;transmit it to FTDI
C806   23                     INC   hl   ;move to next location
C807   10 F9                  DJNZ   $-5   ;repeat 38 times
C809   3E 0D                  LD   a,CR   ;carriage return
C80B   CD A8 C6               CALL   txByte   ;send CR
C80E   3E 0A                  LD   a,LF   ;line feed
C810   CD A8 C6               CALL   txByte   ;send LF
C813   2A 29 09               LD   hl,(DISFROM)   ;get current start
C816   ED 5B C2 08            LD   de,(DATA_TO)   ;get end address
C81A   B7                     OR   a   ;clear carry
C81B   ED 52                  SBC   hl,de   ;check difference between
C81D   19                     ADD   hl,de   ;start and end address
C81E   38 DA                  JR   c,assemblyLoop   ;if not zero then loop
C820   C9                     RET      ;all done
C821                             ; send assembly to serial Entry for API
C821                             ; Input: HL = start address
C821                             ;        DE = length in bytes
C821                SENDASSEMBLYAPI:      
C821   22 29 09               LD   (DISFROM),hl   ;save start in DIS_FROM
C824   19                     ADD   hl,de   ;get end address
C825   22 C2 08               LD   (DATA_TO),hl   ;get end address
C828   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C82B   C3 FA C7               JP   assemblyLoop   
C82E                             ; Send a traditional HEX dump to the serial terminal.
C82E                             ; Input: none
C82E                             ; Output: text to  serial
C82E                             ; Destroy: All
C82E                HEXDUMPTOSERIAL:      
C82E   CD A3 C7               CALL   getToFrom   ;collect parameters
C831   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C834                SENDHEX:      
C834   E5                     PUSH   hl   ;store current address
C835   C5                     PUSH   bc   ;store byte count
C836   E1                     POP   hl   ;HL = BC
C837   11 F0 FF               LD   de,-16   ;load DE with minus 16
C83A   19                     ADD   hl,de   ;reduce hl by 16
C83B   1E 10                  LD   e,16   
C83D   38 03                  JR   c,hexMore   
C83F   C5                     PUSH   bc   
C840   E1                     POP   hl   
C841   59                     LD   e,c   
C842                HEXMORE:      
C842   E3                     EX   (sp),hl   ;get current address, store bytes remaining
C843   43                     LD   b,e   ;byte count
C844   11 00 09               LD   de,DATA_ROW   ;point to Data Entry RAM
C847   CD F6 C8               CALL   genDataDump   ;fill DE with data dump line
C84A   E5                     PUSH   hl   ;store next address
C84B   21 00 09               LD   hl,DATA_ROW   ;make HL = start or data row
C84E                HEXTEXTLOOP:      
C84E   7E                     LD   a,(hl)   ;get ASCII
C84F   23                     INC   hl   ;move to next address
C850   B7                     OR   a   ;is it zero
C851   28 05                  JR   z,skipHex   ;yes, skip sending to serial
C853   CD A8 C6               CALL   txByte   ;send byte to serial
C856   18 F6                  JR   hexTextloop   ;repeat
C858                SKIPHEX:      
C858   3E 0D                  LD   a,CR   ;carriage return
C85A   CD A8 C6               CALL   txByte   ;send CR
C85D   3E 0A                  LD   a,LF   ;line feed
C85F   CD A8 C6               CALL   txByte   ;send LF
C862   D1                     POP   de   ;restore next start address
C863   C1                     POP   bc   ;restore bytes remaining
C864   2A C2 08               LD   hl,(DATA_TO)   ;get end address
C867   B7                     OR   a   
C868   ED 52                  SBC   hl,de   ;check difference
C86A   C8                     RET   z   ;return if all done
C86B   D8                     RET   c   ;return if all done
C86C   EB                     EX   de,hl   ;set hl to new start address
C86D   18 C5                  JR   sendHex   ;repeat until all bytes are printed
C86F                             ; send hex dump to serial Entry for API
C86F                             ; Input: HL = start address
C86F                             ;        DE = length in bytes
C86F                SENDHEXAPI:      
C86F   D5                     PUSH   de   ;make BC = DE
C870   C1                     POP   bc   
C871   EB                     EX   de,hl   ;set HL for add
C872   19                     ADD   hl,de   ;get end address
C873   22 C2 08               LD   (DATA_TO),hl   ;put end address in RAM
C876   EB                     EX   de,hl   ;restore HL  
C877   CD 9C C6               CALL   readyToTransmit   ;set up serial for transmit
C87A   C3 34 C8               JP   sendHex   
C87D                             ; 
C87D                             ; Display 7Seg Message.  Display data on the Seven Segment Display and 
C87D                             ; maintain display until a key is pressed
C87D                             ; Input: HL = 6 byte Segment Data pointer
C87D                             ; Destroy: ALL
C87D                DISPLAY7SEGS:      
C87D   11 80 08               LD   de,DISP_BUFF   ;set destination to display buffer
C880   01 06 00               LD   bc,6   ;size bytes
C883   ED B0                  LDIR      ;fill display buffer with text
C885   CD D1 C5               CALL   scanKeys   ;check for key pressed
C888   3A 8A 08               LD   a,(KEY_PRESS)   ;is a key currently pressed?
C88B   B7                     OR   a   ;is it zero (pressed)
C88C   28 F7                  JR   z,$-7   ;repeat until key is released
C88E                DISPLAYLOOP:      
C88E   CD 68 C5               CALL   scanDisplayBuff   ;Multiplex the seven segments
C891   CD D1 C5               CALL   scanKeys   ;Scan for key press
C894   20 F8                  JR   nz,displayLoop   ;Repeat scan until key pressed
C896   C9                     RET      
C897                             ; 
C897                             ; Compare strings utility
C897                             ; HL = source
C897                             ; DE = target
C897                             ; B = #bytes to compare (up to 256)
C897                             ; 
C897                             ; Z = compare match
C897                             ; NZ = compare fail
C897                             ; 
C897                             ; destroys HL, DE, A, BC
C897                STRINGCOMPARE:      
C897   7E                     LD   a,(hl)   ;Load Source into A
C898   4F                     LD   c,a   ;Store in C
C899   1A                     LD   a,(de)   ;Load compare into A
C89A   B9                     CP   c   ;A==C ?
C89B   C0                     RET   nz   ;No - so edxt with Z flag reset
C89C   23                     INC   hl   ;Yes - move on to next byte
C89D   13                     INC   de   ;Next byte
C89E   10 F7                  DJNZ   stringCompare   ;Loop around till B=0 (check whole string)
C8A0   C9                     RET      ;Matched, so return with Z flag set
C8A1                             ; 
C8A1                             ; Defaults to check for double ASCII space
C8A1                STRINGZEROSPACE:      
C8A1   3E 20                  LD   a,SPACE   ;Space and fall through.         
C8A3                             ; Place a zero at then end of a string.  Routine checks for two bytes
C8A3                             ; in a row that are the same and when found, will place a zero in the first 
C8A3                             ; byte found.  If no byte found within 20 characters then exit with no update
C8A3                             ; Input: A = byte value to check, usually 0 or " "
C8A3                             ;        HL = pointer to ASCII string
C8A3                             ; Output: Zero Set = Updated HL
C8A3                             ;         Zero not set = No match found
C8A3                             ; Destroys: A
C8A3                STRINGZERO:      
C8A3   C5                     PUSH   bc   ;save BC
C8A4   E5                     PUSH   hl   ;save HL
C8A5   01 14 00               LD   bc,20   ;twenty goes (LCD width)
C8A8                SZ1:         
C8A8   ED B1                  CPIR      ;find a matching byte
C8AA   20 06                  JR   nz,sZ2   ;if non zero here, no byte match and BC=0, just exit
C8AC   BE                     CP   (hl)   ;compare with next value
C8AD   20 F9                  JR   nz,sZ1   ;Nope, try again
C8AF   2B                     DEC   hl   ;go back to first match
C8B0   AF                     XOR   a   ;set A=0
C8B1   77                     LD   (hl),a   ;make it zero
C8B2                SZ2:         
C8B2   E1                     POP   hl   ;restore HL
C8B3   C1                     POP   bc   ;restore BC
C8B4   C9                     RET      
C8B5                             ; 
C8B5                             ; Count the number of ASCII spaces in a zero terminated string
C8B5                             ; Input: HL = pointer to string
C8B5                             ; Output: A = number of spaces
C8B5                STRINGSPACES:      
C8B5   C5                     PUSH   bc   ;save BC
C8B6   E5                     PUSH   hl   ;save HL
C8B7   0E 00                  LD   c,0   ;counter
C8B9                STRSPLOOP:      
C8B9   7E                     LD   a,(hl)   ;get value
C8BA   B7                     OR   a   ;is it zero?
C8BB   20 04                  JR   nz,strSpCheck   ;no
C8BD   79                     LD   a,c   ;set return value
C8BE   E1                     POP   hl   ;restore HL
C8BF   C1                     POP   bc   ;restore BC
C8C0   C9                     RET      ;exit
C8C1                STRSPCHECK:      
C8C1   FE 20                  CP   SPACE   ;is it a space
C8C3   23                     INC   hl   ;move to next address
C8C4   20 F3                  JR   nz,strSpLoop   ;loop again if not space
C8C6   0C                     INC   c   ;increase space counter
C8C7   18 FB                  JR   $-3   ;loop again, c = non zero
C8C9                             ; 
C8C9                             ; Convert HL to ASCII string. IE: 2CH -> "2C"
C8C9                             ; Input: HL = value to convert
C8C9                             ;        DE = address of string destination
C8C9                             ; Output: DE = address one after last ASCII entry
C8C9                             ; Destroys: A
C8C9                HLTOSTRING:      
C8C9   7C                     LD   a,h   ;get H
C8CA   CD CE C8               CALL   AToString   ;convert to String
C8CD   7D                     LD   a,l   ;get L
C8CE                             ; 
C8CE                             ; Convert A to ASCII string
C8CE                             ; Input: A = byte to convert
C8CE                             ;        DE = address of string destination
C8CE                             ; Output: DE = address one after last ASCII entry
C8CE                             ; Destroys: A
C8CE                ATOSTRING:      
C8CE   F5                     PUSH   af   ;save AF
C8CF   1F                     RRA      ;move high
C8D0   1F                     RRA      ;nibble to low nibble
C8D1   1F                     RRA      
C8D2   1F                     RRA      
C8D3   CD D7 C8               CALL   lowNibToString   ;get lower nibble and save in DE
C8D6   F1                     POP   af   ;restore AF
C8D7                LOWNIBTOSTRING:      
C8D7   E6 0F                  AND   0FH   ;mask out high nibble
C8D9   C6 90                  ADD   a,90H   ;convert to
C8DB   27                     DAA      ;ASCII
C8DC   CE 40                  ADC   a,40H   ;using this
C8DE   27                     DAA      ;amazing routine
C8DF   12                     LD   (de),a   ;save in DE
C8E0   13                     INC   de   ;move to next DE
C8E1   C9                     RET      ;exit back
C8E2                             ; 
C8E2                             ; convert register A to ASCII. IE: 2CH -> "2C"
C8E2                             ; Input: A = byte to convert
C8E2                             ; Output: HL = two byte ASCII string
C8E2                             ; Destroys: A
C8E2                REGATOASCII:      
C8E2   F5                     PUSH   af   ;save AF
C8E3   0F                     RRCA      ;move high 
C8E4   0F                     RRCA      ;nibble to
C8E5   0F                     RRCA      ;low
C8E6   0F                     RRCA      ;nibble
C8E7   CD EC C8               CALL   nibble2ASCII   ;call nib to ASCII routine
C8EA   65                     LD   h,l   ;move upper nibble to H
C8EB   F1                     POP   af   
C8EC                NIBBLE2ASCII:      
C8EC   E6 0F                  AND   0FH   ;mask out high nibble
C8EE   C6 90                  ADD   a,90H   ;convert to
C8F0   27                     DAA      ;ASCII
C8F1   CE 40                  ADC   a,40H   ;using this
C8F3   27                     DAA      ;amazing routine
C8F4   6F                     LD   l,a   ;store in L
C8F5   C9                     RET      ;exit
C8F6                             ; 
C8F6                             ; Generate data dump in ASCII.  Print Address and then C number of bytes
C8F6                             ; Input: B = number of bytes to display
C8F6                             ;        HL = start address of data dump
C8F6                             ;        DE = address of string destination
C8F6                             ; Output: DE = zero terminated address one after last ASCII entry
C8F6                             ;           IE: "4000: 23 34 45 56 78 9A BC DE",0
C8F6                             ; Destroys: A, HL (moves to next address after last byte)
C8F6                GENDATADUMP:      
C8F6   C5                     PUSH   bc   ;save BC
C8F7   CD C9 C8               CALL   HLToString   ;convert HL to address in ASCII
C8FA   3E 3A                  LD   a,COLON   ;set A = colon
C8FC   12                     LD   (de),a   ;write a colon after address
C8FD   13                     INC   de   
C8FE                DATADUMPLOOP:      
C8FE   3E 20                  LD   a,SPACE   ;set A = space
C900   12                     LD   (de),a   ;write a space
C901   13                     INC   de   
C902   7E                     LD   a,(hl)   ;get byte at HL
C903   CD CE C8               CALL   AToString   ;convert A to string
C906   23                     INC   hl   ;move HL to next address
C907   10 F5                  DJNZ   dataDumpLoop   ;if not zero get next byte
C909   AF                     XOR   a   ;set A = 0
C90A   12                     LD   (de),a   ;terminate string with zero
C90B   C1                     POP   bc   ;restore BC
C90C   C9                     RET      
C90D                             ; 
C90D                             ; Check start and end address difference.
C90D                             ; Input: HL = address location of START value
C90D                             ;        HL+2 = address location of END value
C90D                             ; Output: HL = start address
C90D                             ;         BC = length of end-start
C90D                             ;         Carry = set if end is less than start
C90D                             ; Destroys: DE
C90D                CHECKSTARTEND:      
C90D   5E                     LD   e,(HL)   ;move start
C90E   23                     INC   hl   ;address into DE
C90F   56                     LD   d,(HL)   ;move end
C910   23                     INC   hl   ;address into HL
C911   4E                     LD   c,(HL)   
C912   23                     INC   hl   
C913   66                     LD   h,(HL)   
C914   69                     LD   l,c   
C915   B7                     OR   a   ;clear carry
C916   ED 52                  SBC   hl,de   ;is END > START (it should be)
C918   4D                     LD   c,l   ;move byte count
C919   44                     LD   b,h   ;into BC
C91A   03                     INC   bc   ;if END < START then carry is set
C91B   EB                     EX   de,hl   ;HL is start address
C91C   C9                     RET      
C91D                             ; 
C91D                             ; Block Move generic routine.  Move a block of code between start and end
C91D                             ; to destination.
C91D                             ; NOTE: Must have COPY_START,COPY_END and COPY_DEST filled
C91D                             ; Destroys HL, DE, A, BC
C91D                BLOCKMOVE:      
C91D   21 C0 08               LD   hl,COPY_START   ;get start location
C920   CD 0D C9               CALL   checkStartEnd   ;check start < end
C923   DA 2E CC               JP   c,displayError   ;if carry is set exit and error
C926   ED 5B C4 08            LD   de,(COPY_DEST)   ;load DE with destination address
C92A   ED 52                  SBC   hl,de   ;see if destination is < or > than start
C92C   30 0B                  JR   nc,mvup   ;jump if start > destination
C92E   EB                     EX   de,hl   ;add byte count to destination
C92F   09                     ADD   hl,bc   
C930   2B                     DEC   hl   
C931   EB                     EX   de,hl   
C932   2A C2 08               LD   hl,(COPY_END)   ;get end address
C935   ED B8                  LDDR      ;copy End to Start going backwards
C937   13                     INC   de   
C938   C9                     RET      ;move done
C939                MVUP:        
C939   19                     ADD   hl,de   ;make HL the difference between start and dest
C93A   ED B0                  LDIR      ;copy Start to End going forwards
C93C   1B                     DEC   de   
C93D   C9                     RET      ;move done
C93E                BLOCKMOVEPARAMS:      
C93E   03                     DB   3   ;Three parameters
C93F   42 41 43 4B 55 50      DB   "BACKUP"   ;7seg Text
C945   3D 20 20 20 42 6C 6F 63 6B 20 42 61 63 6B 75 70 20 20 20 3D 00 DB   "=   Block Backup   =",0   ;Parameter title
C95A   53 74 61 72 74 20 41 64 64 72 65 73 73 3A 00 DB   "Start Address:",0   ;Text and Address
C969   C0 08                  DW   COPY_START   
C96B   45 6E 64 20 41 64 64 72 65 73 73 3A 00 DB   "End Address:",0   ;Text and Address
C978   C2 08                  DW   COPY_END   
C97A   44 65 73 74 2E 20 41 64 64 72 65 73 73 3A 00 DB   "Dest. Address:",0   ;Text and Address
C989   C4 08                  DW   COPY_DEST   
C98B                BLOCKCOPYPARAMS:      
C98B   03                     DB   3   ;Three parameters
C98C   53 2D 43 4F 50 59      DB   "S-COPY"   ;7seg Text
C992   3D 20 53 6D 61 72 74 20 42 6C 6F 63 6B 20 43 6F 70 79 20 3D 00 DB   "= Smart Block Copy =",0   ;Parameter title
C9A7   53 74 61 72 74 20 41 64 64 72 65 73 73 3A 00 DB   "Start Address:",0   ;Text and Address
C9B6   C0 08                  DW   COPY_START   
C9B8   45 6E 64 20 41 64 64 72 65 73 73 3A 00 DB   "End Address:",0   ;Text and Address
C9C5   C2 08                  DW   COPY_END   
C9C7   44 65 73 74 2E 20 41 64 64 72 65 73 73 3A 00 DB   "Dest. Address:",0   ;Text and Address
C9D6   C4 08                  DW   COPY_DEST   
C9D8                BLOCKRESTOREPARAMS:      
C9D8   03                     DB   3   ;Three parameters
C9D9   52 45 53 54 4F 52      DB   "RESTOR"   ;7seg Text
C9DF   3D 20 20 52 65 73 74 6F 72 65 20 42 61 63 6B 75 70 20 20 3D 00 DB   "=  Restore Backup  =",0   ;Parameter title
C9F4   53 74 61 72 74 20 41 64 64 72 65 73 73 3A 00 DB   "Start Address:",0   ;Text and Address
CA03   CC 08                  DW   REST_START   
CA05   45 6E 64 20 41 64 64 72 65 73 73 3A 00 DB   "End Address:",0   ;Text and Address
CA12   CE 08                  DW   REST_END   
CA14   44 65 73 74 2E 20 41 64 64 72 65 73 73 3A 00 DB   "Dest. Address:",0   ;Text and Address
CA23   D0 08                  DW   REST_DEST   
CA25                             ; 
CA25                             ; Move a block of code AND update all absolute jumps and calls.
CA25                             ; Destroys HL, DE, A, BC
CA25                SMARTCOPY:      
CA25   21 8B C9               LD   hl,blockCopyParams   
CA28   CD BD CF               CALL   paramDriver   ;collect parameters
CA2B                SMARTCOPYDIRECT:      
CA2B   CD 1D C9               CALL   blockMove   ;move block
CA2E   2A C4 08               LD   hl,(COPY_DEST)   ;put destination in HL
CA31   ED 5B C0 08            LD   de,(COPY_START)   ;put start in DE
CA35   B7                     OR   a   ;clear carry
CA36   ED 52                  SBC   hl,de   ;get offset from start and destination
CA38   22 CA 08               LD   (COPY_CORR),HL   ;save offset in correction
CA3B   2A C2 08               LD   hl,(COPY_END)   ;put end in HL
CA3E   ED 5B C0 08            LD   de,(COPY_START)   ;put start in DE
CA42   B7                     OR   a   ;clear carry
CA43   ED 52                  SBC   hl,de   ;get byte count between start and end
CA45   23                     INC   hl   ;correct HL to real count
CA46   ED 5B C4 08            LD   de,(COPY_DEST)   ;put destination in DE
CA4A   19                     ADD   hl,de   ;find end of destination block
CA4B   22 C8 08               LD   (COPY_EBLK),hl   ;save it
CA4E   ED 53 C6 08            LD   (COPY_PTR),de   ;save destination to pointer
CA52                CHECKINST:      
CA52   2A C6 08               LD   hl,(COPY_PTR)   ;get pointer
CA55   7E                     LD   a,(hl)   ;get instruction
CA56   CD C5 CA               CALL   getInstLen   ;get instruction length in C
CA59   79                     LD   a,c   ;get instruction count
CA5A   FE 04                  CP   4   ;is it 4 bytes long?
CA5C   20 22                  JR   nz,check3   ;no, check 3
CA5E   7E                     LD   a,(hl)   ;get instruction
CA5F   FE ED                  CP   0EDH   ;is it extended instruciton?
CA61   28 17                  JR   z,fourByteAddr   ;yes, modify address
CA63   E6 DF                  AND   0DFH   ;check fo IX
CA65   FE DD                  CP   0DDH   ;and IY
CA67   20 56                  JR   nz,nextInst   ;skip, as its something else
CA69   23                     INC   hl   ;move to second byte
CA6A   46                     LD   b,(hl)   ;get instruction
CA6B   2B                     DEC   hl   ;move back one byte
CA6C   78                     LD   a,b   ;check A
CA6D   E6 CF                  AND   0CFH   ;is it 21H?
CA6F   FE 01                  CP   01H   ; 
CA71   28 07                  JR   z,fourByteAddr   ;yes, modify address
CA73   78                     LD   a,b   ;check A
CA74   E6 E7                  AND   0E7H   ;is it 22H
CA76   FE 22                  CP   22H   ;or 2AH?
CA78   20 45                  JR   nz,nextInst   ;no, skip instruction
CA7A                FOURBYTEADDR:      
CA7A   23                     INC   hl   ;move to make 3 bytes
CA7B   22 C6 08               LD   (COPY_PTR),hl   ;save destination to pointer
CA7E   18 02                  JR   $+4   ;continue
CA80                CHECK3:      
CA80   FE 03                  CP   3   ;is it 3 bytes long?
CA82   20 3B                  JR   nz,nextInst   ;no, just get next instruction
CA84   7E                     LD   a,(hl)   ;get instruction
CA85   E6 DF                  AND   0DFH   ;check fo IX
CA87   FE DD                  CP   0DDH   ;and IY
CA89   28 34                  JR   z,nextInst   ;skip, as its something else
CA8B   7E                     LD   a,(hl)   ;get instruction
CA8C   E5                     PUSH   hl   ;store instruction
CA8D   D1                     POP   de   ;put in DE
CA8E   23                     INC   hl   ;put address
CA8F   4E                     LD   c,(hl)   ;in
CA90   23                     INC   hl   ;BC
CA91   46                     LD   b,(hl)   
CA92   2A C0 08               LD   hl,(COPY_START)   ;load HL with start address
CA95   2B                     DEC   hl   
CA96   B7                     OR   a   ;clear carry
CA97   ED 42                  SBC   hl,bc   ;get target difference
CA99   30 11                  JR   nc,targetSkip   ;jump if target is less than start
CA9B   2A C2 08               LD   hl,(COPY_END)   ;load HL with end address
CA9E   B7                     OR   a   ;clear carry
CA9F   ED 42                  SBC   hl,bc   ;get target difference
CAA1   38 09                  JR   c,targetSkip   ;jump if target is higher than end
CAA3   2A CA 08               LD   hl,(COPY_CORR)   ;get correction factor
CAA6   09                     ADD   hl,bc   ;adjust target with correction
CAA7   EB                     EX   de,hl   ;put new address in DE
CAA8   23                     INC   hl   ;and store
CAA9   73                     LD   (hl),e   ;it
CAAA   23                     INC   hl   ;back
CAAB   72                     LD   (hl),d   ;to jump/call instruction
CAAC                TARGETSKIP:      
CAAC   2A C6 08               LD   hl,(COPY_PTR)   ;get pointer
CAAF   23                     INC   hl   ;increase to next instruction
CAB0   23                     INC   hl   
CAB1   23                     INC   hl   
CAB2                ENDTEST:      
CAB2   22 C6 08               LD   (COPY_PTR),hl   ;save new pointer
CAB5   ED 5B C8 08            LD   de,(COPY_EBLK)   ;get end block
CAB9   B7                     OR   a   ;clear carry
CABA   ED 52                  SBC   hl,de   ;test for finish
CABC   38 94                  JR   c,checkInst   ;not at end, check next instruction
CABE   C9                     RET      ;end, just return
CABF                NEXTINST:      
CABF   23                     INC   hl   ;move to next byte
CAC0   0D                     DEC   c   ;until new instruction
CAC1   20 FC                  JR   nz,nextInst   
CAC3   18 ED                  JR   endTest   ;jump to end test
CAC5                             ; 
CAC5                             ; Instruction byte count routine
CAC5                             ; Input: HL = address of first op code
CAC5                             ; Return: C = instruction length
CAC5                             ;         Carry Set = instruction is a RET,JP,CALL,RST
CAC5                             ; Destroys A, B
CAC5                GETINSTLEN:      
CAC5   0E 04                  LD   c,4   ;set length to longest instruction
CAC7   7E                     LD   a,(hl)   ;put first op code in A
CAC8   23                     INC   hl   
CAC9   46                     LD   b,(hl)   ;put second op code in B
CACA   2B                     DEC   hl   ;restore HL
CACB   E6 DF                  AND   0DFH   
CACD   FE DD                  CP   0DDH   ;is it an IX/IY instruction
CACF   20 12                  JR   nz,getIns2   
CAD1   78                     LD   a,b   
CAD2   FE CB                  CP   0CBH   ;is it a IX/IY Bit instruction
CAD4   30 05                  JR   nc,getIns1   
CAD6   FE 36                  CP   36H   
CAD8   C8                     RET   z   
CAD9   FE 21                  CP   21H   
CADB                GETINS1:      
CADB   C8                     RET   z   
CADC   E6 F7                  AND   0F7H   
CADE   FE 22                  CP   22H   
CAE0   C8                     RET   z   
CAE1   18 0F                  JR   getIns3   
CAE3                GETINS2:      
CAE3   7E                     LD   a,(hl)   
CAE4   FE ED                  CP   0EDH   ;is it an Misc Instruction
CAE6   20 1F                  JR   nz,getIns4   
CAE8   78                     LD   a,b   
CAE9   E6 C7                  AND   0C7H   
CAEB   FE 43                  CP   43H   ;does it have a 2 byte address?
CAED   C8                     RET   z   
CAEE   B7                     OR   a   
CAEF   0D                     DEC   c   
CAF0   0D                     DEC   c   
CAF1   C9                     RET      
CAF2                GETINS3:      
CAF2   0D                     DEC   c   
CAF3   78                     LD   a,b   
CAF4   E6 B8                  AND   0B8H   
CAF6   FE 30                  CP   30H   
CAF8   C8                     RET   z   
CAF9   78                     LD   a,b   
CAFA   E6 06                  AND   06H   
CAFC   FE 06                  CP   06H   
CAFE   C8                     RET   z   
CAFF   0D                     DEC   c   
CB00   78                     LD   a,b   
CB01   FE E9                  CP   0E9H   
CB03   37                     SCF      
CB04   C8                     RET   z   
CB05   3F                     CCF      
CB06   C9                     RET      
CB07                GETINS4:      
CB07   0D                     DEC   c   
CB08   7E                     LD   a,(hl)   
CB09   E6 CF                  AND   0CFH   
CB0B   FE 01                  CP   01H   
CB0D   C8                     RET   z   
CB0E   7E                     LD   a,(hl)   
CB0F   E6 E7                  AND   0E7H   
CB11   FE 22                  CP   22H   
CB13   C8                     RET   z   
CB14   7E                     LD   a,(hl)   
CB15   FE C3                  CP   0C3H   
CB17   37                     SCF      
CB18   C8                     RET   z   
CB19   FE CD                  CP   0CDH   
CB1B   37                     SCF      
CB1C   C8                     RET   z   
CB1D   E6 C7                  AND   0C7H   
CB1F   FE C2                  CP   0C2H   
CB21   37                     SCF      
CB22   C8                     RET   z   
CB23   FE C4                  CP   0C4H   
CB25   37                     SCF      
CB26   C8                     RET   z   
CB27   0D                     DEC   c   
CB28   FE 06                  CP   06H   
CB2A   C8                     RET   z   
CB2B   FE C6                  CP   0C6H   
CB2D   C8                     RET   z   
CB2E   0D                     DEC   c   
CB2F   37                     SCF      
CB30   C8                     RET   z   
CB31   7E                     LD   a,(hl)   
CB32   E6 F7                  AND   0F7H   
CB34   C8                     RET   z   
CB35   0C                     INC   c   
CB36   7E                     LD   a,(hl)   
CB37   E6 E7                  AND   0E7H   
CB39   FE C3                  CP   0C3H   
CB3B   C8                     RET   z   
CB3C   E6 C7                  AND   0C7H   
CB3E   37                     SCF      
CB3F   C8                     RET   z   
CB40   0D                     DEC   c   
CB41   7E                     LD   a,(hl)   
CB42   FE E9                  CP   0E9H   
CB44   37                     SCF      
CB45   C8                     RET   z   
CB46   FE C9                  CP   0C9H   
CB48   37                     SCF      
CB49   C8                     RET   z   
CB4A   E6 C1                  AND   0C1H   
CB4C   FE C0                  CP   0C0H   
CB4E   37                     SCF      
CB4F   C8                     RET   z   
CB50   3F                     CCF      
CB51   C9                     RET      
CB52                             ; 
CB52                             ; Calculate actual disassembly address from CEL
CB52                             ; Output: HL = Disassembly start address
CB52                             ; Destroy: A,DE
CB52                             ; Updates DIS_ADDR
CB52                CALCDISADDRESS:      
CB52   2A 86 08               LD   hl,(CEL)   ;get CEL
CB55   01 F9 FF               LD   bc,0FFF9H   ;set BC = -7
CB58   09                     ADD   hl,bc   ;modify HL with offset
CB59   38 03                  JR   c,disTestLoop   ;if HL <=3 then fix HL
CB5B   21 00 00               LD   hl,0   
CB5E                DISTESTLOOP:      
CB5E   22 90 08               LD   (DIS_ADDR),hl   ;update DIS_ADDR with current HL
CB61   22 29 09               LD   (DISFROM),hl   ;Store it in the disassembler start address
CB64   CD 9B E7               CALL   disStart   ;Work out next valid from address
CB67   ED 5B 86 08            LD   de,(CEL)   ;get CEL
CB6B   EB                     EX   de,hl   ;swap HL,DE
CB6C   B7                     OR   a   
CB6D   ED 52                  SBC   hl,de   ;Calculate CEL-DISFROM
CB6F   EB                     EX   de,hl   
CB70   F2 5E CB               JP   p,disTestLoop   ;If DISFROM < CEL then
CB73   2A 90 08               LD   hl,(DIS_ADDR)   ;Store HL with previous valid disassembly address
CB76   C9                     RET      
CB77                             ; 
CB77                             ; Just move a block from A to B with no 2 byte address updates
CB77                             ; Destroys HL, DE, A, BC
CB77                DUMBCOPY:      
CB77   21 3E C9               LD   hl,blockMoveParams   
CB7A   CD BD CF               CALL   paramDriver   ;collect parameters
CB7D   C3 1D C9               JP   blockMove   ;move block
CB80                             ; 
CB80                             ; Restore from backup.  This is the reverse of the Backup or Smart Copy
CB80                             ; Start = COPY_DEST
CB80                             ; End = COPY_DEST + (COPY_END - COPY_START + 1)
CB80                             ; Dest = COPY_START
CB80                RESTOREBACKUP:      
CB80   21 C0 08               LD   hl,COPY_START   
CB83   11 D0 08               LD   de,REST_DEST   
CB86   CD CB CB               CALL   HLtoDE   
CB89   21 C4 08               LD   hl,COPY_DEST   
CB8C   11 CC 08               LD   de,REST_START   
CB8F   CD CB CB               CALL   HLtoDE   
CB92   21 C0 08               LD   hl,COPY_START   
CB95   CD 0D C9               CALL   checkStartEnd   
CB98   0B                     DEC   bc   
CB99   2A CC 08               LD   hl,(REST_START)   
CB9C   09                     ADD   hl,bc   
CB9D   22 CE 08               LD   (REST_END),hl   
CBA0   21 D8 C9               LD   hl,blockRestoreParams   
CBA3   CD BD CF               CALL   paramDriver   ;collect parameters
CBA6   21 C0 08               LD   hl,COPY_START   
CBA9   11 D2 08               LD   de,TEMP_START   
CBAC   01 06 00               LD   bc,6   
CBAF   ED B0                  LDIR      
CBB1   21 CC 08               LD   hl,REST_START   
CBB4   11 C0 08               LD   de,COPY_START   
CBB7   01 06 00               LD   bc,6   
CBBA   ED B0                  LDIR      
CBBC   CD 1D C9               CALL   blockMove   ;move block
CBBF   21 D2 08               LD   hl,TEMP_START   
CBC2   11 C0 08               LD   de,COPY_START   
CBC5   01 06 00               LD   bc,6   
CBC8   ED B0                  LDIR      
CBCA   C9                     RET      
CBCB                             ; 
CBCB                HLTODE:      
CBCB   7E                     LD   a,(hl)   
CBCC   12                     LD   (de),a   
CBCD   23                     INC   hl   
CBCE   13                     INC   de   
CBCF   7E                     LD   a,(hl)   
CBD0   12                     LD   (de),a   
CBD1   C9                     RET      
CBD2                             ; 
CBD2                             ; Fill with NOP.  Fill data range with 00h or NOP instruction
CBD2                NOPFILL:      
CBD2   21 F1 CB               LD   hl,fillRangeParams   
CBD5   CD BD CF               CALL   paramDriver   ;collect parameters
CBD8   CD 32 CE               CALL   LCDConfirm   ;this is serious mum!
CBDB   C0                     RET   nz   ;no, just exit
CBDC   21 D2 08               LD   hl,TEMP_START   ;check parameters
CBDF   CD 0D C9               CALL   checkStartEnd   ; 
CBE2   30 04                  JR   nc,doFill   ;All good, continue
CBE4   E1                     POP   hl   ;remove call return from stack
CBE5   C3 2E CC               JP   displayError   ;display error if end < start
CBE8                DOFILL:      
CBE8   54                     LD   d,h   
CBE9   5D                     LD   e,l   
CBEA   13                     INC   de   
CBEB   AF                     XOR   a   
CBEC   77                     LD   (hl),a   
CBED   0B                     DEC   bc   
CBEE   ED B0                  LDIR      
CBF0   C9                     RET      
CBF1                             ; 
CBF1                FILLRANGEPARAMS:      
CBF1   02                     DB   2   ;Three parameters
CBF2   46 49 4C 4C 20 20      DB   "FILL  "   ;7seg Text
CBF8   3D 20 20 46 69 6C 6C 20 77 69 74 68 20 4E 4F 50 73 20 20 3D 00 DB   "=  Fill with NOPs  =",0   ;Parameter title
CC0D   46 72 6F 6D 20 41 64 64 72 65 73 73 3A 00 DB   "From Address:",0   ;Text and Address
CC1B   D2 08                  DW   TEMP_START   
CC1D   54 6F 20 41 64 64 72 65 73 73 3A 00 DB   "To Address:",0   ;Text and Address
CC29   D4 08                  DW   TEMP_END   
CC2B                             ; 
CC2B                             ; 
CC2B   CD A3 C7               CALL   getToFrom   ;collect parameters
CC2E                             ; 
CC2E                             ; 
CC2E                             ; Display ERROR/PASS on the 7Segs and wait for key press
CC2E                DISPLAYERROR:      
CC2E   21 B4 D4               LD   hl,errorText   ;error text
CC31   C3 7D C8               JP   display7Segs   ;display on 7Segs and exit when key is pressed
CC34                DISPLAYPASS:      
CC34   21 AE D4               LD   hl,passText   ;pass text
CC37   C3 7D C8               JP   display7Segs   ;display on 7Segs and exit when key is pressed
CC3A                DISPLAYNOFN:      
CC3A   21 BA D4               LD   hl,noFnText   ;no function text
CC3D   C3 7D C8               JP   display7Segs   ;display on 7Segs and exit when key is pressed
CC40                             ; 
CC40                             ; Key scan routine for the Matrix Keyboard.  This routine detects up to
CC40                             ; two key presses at the same time.  Key values stored in DE
CC40                             ; Note: Must be called repetatively
CC40                             ; Input: None
CC40                             ; Output: E = Key pressed between 00H-3FH (0-64)
CC40                             ;         D = Second key, FF=no key, 00=shift, 01=Ctrl, 02=Fn
CC40                             ;         zero flag set if a key is pressed or combination valid
CC40                MATRIXSCAN:      
CC40   2E FF                  LD   l,0FFH   ;Row value accumulator. Add 8 for each ROW
CC42   11 FF FF               LD   de,0FFFFH   ;Return Values if no key is pressed
CC45   01 FE FE               LD   bc,0FEFEH   ;Port = C, A8-A15 = B. B loaded with only A8 = 0 to start.
CC48                KLINE:       
CC48   ED 78                  IN   a,(c)   ;Check data bus for Port C and high address B
CC4A   2F                     CPL      ;Invert to check for zero
CC4B   E6 FF                  AND   0FFH   ;Masking of bits would happen here, but we use all 8
CC4D   28 0B                  JR   z,kDone   ;If Zero, no key press for Address line
CC4F   67                     LD   h,a   ;Save key(s) pressed data in H
CC50   7D                     LD   a,l   ;Load A with the current ROW count*8
CC51                KBITS:       
CC51   3C                     INC   a   ;Add one until data bit found
CC52   CB 3C                  SRL   h   ;Shift H right until bit is detected
CC54   30 FB                  JR   nc,kBits   ;If Carry is not set, shift again
CC56   53                     LD   d,e   ;Load first key detected into D
CC57   5F                     LD   e,a   ;Store key detected
CC58   20 F7                  JR   nz,kBits   ;Keep going until all bits are checked.
CC5A                KDONE:       
CC5A   3E 08                  LD   a,8   ; 
CC5C   85                     ADD   a,l   ;Increase L by 8 for each ROW checked
CC5D   6F                     LD   l,a   
CC5E   CB 00                  RLC   b   ;Move to next address line
CC60   38 E6                  JR   c,kLine   ;if more address lines needed repeat key check
CC62                             ; 
CC62   7B                     LD   a,e   ;Check for any key press
CC63   FE 40                  CP   40H   ;Is it a valid key?
CC65   D0                     RET   nc   ;No, exit with Zero flag false
CC66                             ; 
CC66   7A                     LD   a,d   ;Check if 1 or two key pressed
CC67   3C                     INC   a   
CC68   C8                     RET   z   ;If one key exit, D=FF, E=key
CC69                             ;Check for Shift/Ctrl/Fn keys pressed
CC69   3D                     DEC   a   
CC6A   C8                     RET   z   ;Exit zero if Shift pressed
CC6B   3D                     DEC   a   
CC6C   C8                     RET   z   ;Exit zero if Control pressed
CC6D   3D                     DEC   a   
CC6E   C9                     RET      ;Exit zero if Function pressed or non zero for anything else
CC6F                             ; 
CC6F                             ; Joystick port scan routines.  This routine will return a value based on the
CC6F                             ; movement / button of the joystick or any combination: IE: UP+DOWN = 03H
CC6F                             ; Note: Must be called repetatively
CC6F                             ; Input: None
CC6F                             ; Output: A = Joystick return value between 00H-5FH (0-95)
CC6F                             ;       01H = Up        10H = Fire 2
CC6F                             ;       02H = Down      20H = Comm2 (Pin 9)
CC6F                             ;       04H = Left      40H = Fire 1
CC6F                             ;       08H = Right     80H = Fire 3
CC6F                             ;         zero flag set if no joystick value returned
CC6F                             ; Destroy: none
CC6F                JOYSTICKSCAN:      
CC6F   C5                     PUSH   bc   ;save BC
CC70   01 FE F7               LD   bc,0F7FEH   ;Port = FE, B is only loaded with A11 = 0 (Joystick Line)
CC73   ED 78                  IN   a,(c)   ;read joystick port
CC75   2F                     CPL      ;Invert to check for zero
CC76   E6 FF                  AND   0FFH   ;Mask and set zero flag if A=0
CC78   C1                     POP   bc   ;restore BC
CC79   C9                     RET      ;Exit with A set and Zero flag
CC7A                             ; 
CC7A                             ; Breakpoint Entry.  Display flags and most registers on the LCD Screen.
CC7A                             ; Press GO to continue executing, AD to do a soft reset.  Entry to this
CC7A                             ; routine can be done by RST 30H or 0F7H
CC7A                BREAKPOINT:      
CC7A   CD 1D CD               CALL   saveRegisters   ;save all current registers to BP stack
CC7D   CD 65 CD               CALL   saveLCD   ;save contents of DDRAM into RAM
CC80   06 01                  LD   b,01H   ;clear LCD
CC82   CD 9C C5               CALL   commandToLCD   ;update LCD
CC85                             ; display register text on LCD
CC85   11 E6 D4               LD   de,breakPointRows   ;LCD row table
CC88   21 C6 D4               LD   hl,breakPointRegs   ;LCD resgister text
CC8B   0E 08                  LD   c,8   ;eight registers
CC8D                BPTEXT:      
CC8D   1A                     LD   a,(de)   ;get row position
CC8E   47                     LD   b,a   ;move to B
CC8F   CD 9C C5               CALL   commandToLCD   ;update LCD
CC92   13                     INC   de   
CC93   CD 83 C5               CALL   stringToLCD   ;output text (HL) to LCD
CC96   0D                     DEC   c   ;next register
CC97   20 F4                  JR   nz,bpText   ;repeat for all 8 registers
CC99                             ; 
CC99                             ;display register values next to text
CC99                BPDATA:      
CC99   11 E6 D4               LD   de,breakPointRows   ;LCD row table
CC9C   21 00 09               LD   hl,BP_BASE_SP   ;register memory location
CC9F   0E 06                  LD   c,6   ;six registers
CCA1   CD F8 CC               CALL   bpPrintData   
CCA4   21 14 09               LD   hl,BP_PC   ;start at PC
CCA7   0E 02                  LD   c,2   ;two registers
CCA9   CD F8 CC               CALL   bpPrintData   
CCAC                             ; 
CCAC                             ;display flags
CCAC   3A 00 09               LD   a,(BP_BASE_SP)   ;register AF
CCAF   4F                     LD   c,a   
CCB0   11 F6 D4               LD   de,breakPointFlagRows   
CCB3   21 EE D4               LD   hl,breakPointFlags   
CCB6                BPFLAGROW:      
CCB6   1A                     LD   a,(de)   
CCB7   B7                     OR   a   
CCB8   28 16                  JR   z,bpQuery   ;No more, go to key query
CCBA   47                     LD   b,a   ;move to B
CCBB   CD 9C C5               CALL   commandToLCD   ;update LCD
CCBE   13                     INC   de   
CCBF   06 02                  LD   b,2   ;two flags
CCC1                BPFLAGCOL:      
CCC1   7E                     LD   a,(hl)   
CCC2   23                     INC   HL   
CCC3   CB 01                  RLC   c   
CCC5   38 02                  JR   c,$+4   ;Skip lower case
CCC7   C6 20                  ADD   a,20H   ;Make lowercase
CCC9   CD 98 C5               CALL   charToLCD   ;send character to LCD
CCCC   10 F3                  DJNZ   bpFlagCol   
CCCE   18 E6                  JR   bpFlagRow   
CCD0                             ; 
CCD0                             ;handle keypress and exit. GO = continue, AD = Exit
CCD0                BPQUERY:      
CCD0   11 C0 D4               LD   de,breakText   ;set display buffer to Breakpoint display
CCD3   CD 6B C5               CALL   scanSegments   ;Multiplex the seven segments
CCD6   DB 03                  IN   a,(SYS_INPUT)   ;Get System input
CCD8   E6 20                  AND   20H   ;check if GIMP is set
CCDA   20 0B                  JR   nz,bpNoStop   ;simulate GO pressed
CCDC   CD D1 C5               CALL   scanKeys   ;Scan for key press
CCDF   20 EF                  JR   nz,bpQuery   ;Repeat scan until key pressed
CCE1   30 ED                  JR   nc,bpQuery   ;Skip if not new key
CCE3   FE 12                  CP   K_GO   ;is key GO
CCE5   20 07                  JR   nz,$+9   ;No, check if AD key pressed
CCE7                BPNOSTOP:      
CCE7   CD 82 CD               CALL   restoreLCD   ;restore content of LCD from RAM
CCEA   CD 49 CD               CALL   restoreRegisters   ;clean up stack and exit back to code execution
CCED   C9                     RET      ;return back to last execution location
CCEE   FE 13                  CP   K_ADDR   ;is it the AD key (Exit back to monitor)
CCF0   20 DE                  JR   nz,bpQuery   ;no, keep scanning
CCF2   31 80 08               LD   sp,STACK_TOP   ;reset the Hardware Stack to top of stack in RAM
CCF5   C3 09 C2               JP   softBoot   ;just do a softboot and exit
CCF8                             ; 
CCF8                BPPRINTDATA:      
CCF8   1A                     LD   a,(de)   ;get row position
CCF9   C6 03                  ADD   a,3   ;move three to the right
CCFB   47                     LD   b,a   ;move to B
CCFC   CD 9C C5               CALL   commandToLCD   ;update LCD
CCFF   13                     INC   de   ;move to next postion
CD00   D5                     PUSH   de   ;save DE
CD01   EB                     EX   de,hl   
CD02   06 02                  LD   b,2   
CD04   13                     INC   de   
CD05                BPDATAOUT:      
CD05   1A                     LD   a,(de)   
CD06   CD E2 C8               CALL   regAToASCII   
CD09   7C                     LD   a,h   
CD0A   CD 98 C5               CALL   charToLCD   ;send character to LCD
CD0D   7D                     LD   a,l   
CD0E   CD 98 C5               CALL   charToLCD   ;send character to LCD
CD11   1B                     DEC   de   
CD12   10 F1                  DJNZ   bpDataOut   
CD14   13                     INC   de   
CD15   13                     INC   de   
CD16   13                     INC   de   
CD17   EB                     EX   de,hl   
CD18   D1                     POP   de   
CD19   0D                     DEC   c   
CD1A   20 DC                  JR   nz,bpPrintData   
CD1C   C9                     RET      
CD1D                             ; 
CD1D                             ; Save registers to Break Point stack.  Registers are saved in memory in
CD1D                             ; this order: AF,HL,BC,DE,IX,IY,AF",HL",BC",DE",PC,SP
CD1D                             ; Input: none
CD1D                             ; Destroys: nothing
CD1D                             ; Note: need to set BP_PC prior to calling this routine to set actual program counter
CD1D                             ; Routine is to be called from previous CALL to get Actual SP. SP=SP-4.
CD1D                             ; IE: Actual Code > RST 30H > saveRegisters. 
CD1D                SAVEREGISTERS:      
CD1D   22 02 09               LD   (BP_HL),hl   ;save HL first so to use HL in routine
CD20   F5                     PUSH   af   ;store AF
CD21   E1                     POP   hl   ;HL = AF
CD22   22 00 09               LD   (BP_BASE_SP),hl   ;save AF as flags get corrupt below
CD25   21 04 00               LD   hl,4   ;set HL to calling SP
CD28   39                     ADD   hl,sp   ;HL = SP+4
CD29   22 16 09               LD   (BP_ORIG_SP),hl   ;save actual SP
CD2C   31 14 09               LD   sp,BP_REGS   ;set SP to use Break Point stack
CD2F   08                     EX   af,af'   ;start saving registers
CD30   D9                     EXX      
CD31   D5                     PUSH   de   
CD32   C5                     PUSH   bc   
CD33   E5                     PUSH   hl   
CD34   F5                     PUSH   af   
CD35   08                     EX   af,af'   
CD36   D9                     EXX      
CD37   FD E5                  PUSH   iy   
CD39   DD E5                  PUSH   ix   
CD3B   D5                     PUSH   de   
CD3C   C5                     PUSH   bc   
CD3D   2A 02 09               LD   hl,(BP_HL)   ;restore original hl
CD40   ED 7B 16 09            LD   sp,(BP_ORIG_SP)   ;restore hardware stack
CD44   3B                     DEC   sp   ;to 
CD45   3B                     DEC   sp   ;acutal 
CD46   3B                     DEC   sp   ;position prior
CD47   3B                     DEC   sp   ;to calling this routine
CD48   C9                     RET      
CD49                             ; 
CD49                             ; Restore registers.  Replace CPU registers with values stored in the BreakPoint buffer
CD49                             ; A call to saveRegisters is to be called prior
CD49                             ; Input: none
CD49                             ; Output: Updates registers AF,HL,BC,DE,IX,IY,AF",HL",BC" and DE"
CD49                RESTOREREGISTERS:      
CD49   ED 73 16 09            LD   (BP_ORIG_SP),sp   
CD4D   31 00 09               LD   sp,BP_BASE_SP   
CD50   F1                     POP   af   
CD51   E1                     POP   hl   
CD52   C1                     POP   bc   
CD53   D1                     POP   de   
CD54   DD E1                  POP   ix   
CD56   FD E1                  POP   iy   
CD58   08                     EX   af,af'   
CD59   D9                     EXX      
CD5A   F1                     POP   af   
CD5B   E1                     POP   hl   
CD5C   C1                     POP   bc   
CD5D   D1                     POP   de   
CD5E   08                     EX   af,af'   
CD5F   D9                     EXX      
CD60   ED 7B 16 09            LD   sp,(BP_ORIG_SP)   
CD64   C9                     RET      
CD65                             ; 
CD65                             ; Save LCD screen contents.  Copy LCD DDRAM contents to RAM location BP_LCD.  
CD65                             ; Input: none
CD65                             ; Output: Writes 80 bytes (20x4) of LCD DDRAM to BP_LCD address (08B8H-0908H)
CD65                             ; Destroys: A, BC, HL
CD65                SAVELCD:      
CD65   06 80                  LD   b,LCD_ROW1   ;Set DDRAM address counter to Row 1
CD67   CD 9C C5               CALL   commandToLCD   ;Send instruction to LCD
CD6A   21 18 09               LD   hl,BP_LCD   ;set HL to LCD RAM location
CD6D   01 84 28               LD   bc,40*100H+LCD_DATA   ;40 bytes to read, Port LCD_DATA
CD70   EF                     RST   28H   ;ensure LCD isn't busy
CD71   ED A2                  INI      ;read port C, into (HL), inc HL, dec B
CD73   20 FB                  JR   nz,$-3   ;Do unitl B=0
CD75                             ; 
CD75   06 C0                  LD   b,LCD_ROW2   ;Set DDRAM address counter to Row 2
CD77   CD 9C C5               CALL   commandToLCD   ;Send instruction to LCD
CD7A   06 28                  LD   b,40   ;40 bytes to read
CD7C   EF                     RST   28H   ;ensure LCD isn't busy
CD7D   ED A2                  INI      ;read port C, into (HL), inc HL, dec B
CD7F   20 FB                  JR   nz,$-3   ;Do unitl B=0
CD81   C9                     RET      
CD82                             ; 
CD82                             ; Restore LCD screen contents.  Copy RAM location BP_LCD to LCD DDRAM
CD82                             ; A call to saveLCD is to be called prior
CD82                             ; Input: none
CD82                             ; Output: Updates LCD with values at BP_LCD (08B8H-0908H)
CD82                             ; Destroys: A, BC, HL
CD82                RESTORELCD:      
CD82   06 80                  LD   b,LCD_ROW1   ;Set DDRAM address counter to Row 1
CD84   CD 9C C5               CALL   commandToLCD   ;Send instruction to LCD
CD87   21 18 09               LD   hl,BP_LCD   ;set HL to LCD RAM location
CD8A   01 84 28               LD   bc,40*100H+LCD_DATA   ;40 bytes to read, Port LCD_DATA
CD8D   EF                     RST   28H   ;ensure LCD isn't busy
CD8E   ED A3                  OUTI      ;write to port C, from (HL), inc HL, dec B
CD90   20 FB                  JR   nz,$-3   ;Do unitl B=0
CD92                             ; 
CD92   06 C0                  LD   b,LCD_ROW2   ;Set DDRAM address counter to Row 2
CD94   CD 9C C5               CALL   commandToLCD   ;Send instruction to LCD
CD97   06 28                  LD   b,40   ;40 bytes to read
CD99   EF                     RST   28H   ;ensure LCD isn't busy
CD9A   ED A3                  OUTI      ;write to port C, from (HL), inc HL, dec B
CD9C   20 FB                  JR   nz,$-3   ;Do unitl B=0
CD9E   C9                     RET      
CD9F                             ; 
CD9F                             ; Set the address of a Quick Jump CEL
CD9F                             ; Input: none
CD9F                             ; Destroys: All
CD9F                SETCELQUICKJUMP:      
CD9F   CD 0C C5               CALL   beep   ;beep the speaker bit
CDA2   06 01                  LD   b,01H   ;clear LCD
CDA4   CD 9C C5               CALL   commandToLCD   ;update LCD
CDA7   21 FB D4               LD   hl,CELJumpText   ;point to CEL Jump text
CDAA   CD 83 C5               CALL   stringToLCD   ;write text
CDAD   06 C9                  LD   b,0C9H   ;set cursor to Row 2,Col 9
CDAF   CD 9C C5               CALL   commandToLCD   ;update LCD
CDB2   21 10 D5               LD   hl,CELHelpText   ;point to CEL Help text
CDB5   CD 83 C5               CALL   stringToLCD   ;write text
CDB8   0E 03                  LD   c,3   ;three values
CDBA   11 1E D4               LD   de,LCDBaseRows+3   ;set de to last row
CDBD   21 A7 08               LD   hl,CEL_QJMP+5   ;move to last entry
CDC0                PRINTCELROW:      
CDC0   1A                     LD   a,(de)   ;get column
CDC1   47                     LD   b,a   ;set B as LCD row
CDC2   CD 9C C5               CALL   commandToLCD   ;update LCD
CDC5   79                     LD   a,c   ;get location value
CDC6   C6 30                  ADD   a,30H   ;adjust for ascii
CDC8   CD 98 C5               CALL   charToLCD   ;send character to LCD
CDCB   3E 3A                  LD   a,COLON   
CDCD   CD 98 C5               CALL   charToLCD   ;send character to LCD
CDD0   06 02                  LD   b,2   ;two nibbles
CDD2                PRINTHL:      
CDD2   E5                     PUSH   hl   ;save CEL jump table
CDD3   7E                     LD   a,(hl)   ;get nibble
CDD4   CD E2 C8               CALL   regAToASCII   
CDD7   7C                     LD   a,h   
CDD8   CD 98 C5               CALL   charToLCD   ;send character to LCD
CDDB   7D                     LD   a,l   
CDDC   CD 98 C5               CALL   charToLCD   ;send character to LCD
CDDF   E1                     POP   hl   ;restore CEL jump table
CDE0   2B                     DEC   hl   ;move to next nibble
CDE1   10 EF                  DJNZ   printHL   
CDE3   1B                     DEC   de   ;move to next column
CDE4   0D                     DEC   c   ;move to next location
CDE5   20 D9                  JR   nz,printCELRow   ;do next row
CDE7                             ; LCD displayed, now get key
CDE7                CELKEYPRESS:      
CDE7   CF                     RST   08H   ;get key and wait
CDE8   FE 13                  CP   K_ADDR   ;is it address?
CDEA   C8                     RET   z   ;yes, just exit
CDEB   3D                     DEC   a   ;adjust key for index
CDEC   FE 03                  CP   3   ;check for range 0-2
CDEE   30 F7                  JR   nc,CELKeyPress   ;loop again until 1-3,AD is pressed
CDF0   21 86 08               LD   hl,CEL   ;get CEL
CDF3   11 A2 08               LD   de,CEL_QJMP   ;point to table
CDF6                QJMPTOCEL:      
CDF6   87                     ADD   a,a   ;double for index
CDF7   83                     ADD   a,e   ;index it
CDF8   5F                     LD   e,a   
CDF9   01 02 00               LD   bc,2   ;two bytes
CDFC   ED B0                  LDIR      
CDFE                             ; Check for RTC installed
CDFE   3A 88 08               LD   a,(MCB)   ;get MCB
CE01   E6 40                  AND   MCB_RTC   ;is bit 6 set?
CE03   C8                     RET   z   ;no just exit
CE04   1B                     DEC   de   
CE05   1B                     DEC   de   
CE06   EB                     EX   de,hl   ;reset QJMP address and make it HL
CE07   7D                     LD   a,l   
CE08   D6 A2                  SUB   0A2H   ;take base off to get RTC slot
CE0A   CD 86 CE               CALL   RTCSetPRAM   ;save it to RTC
CE0D   C9                     RET      
CE0E                             ; 
CE0E                GETCELQUICKJUMP:      
CE0E   11 86 08               LD   de,CEL   ;get CEL
CE11   21 A2 08               LD   hl,CEL_QJMP   ;point to table
CE14                             ;reg c=key
CE14   79                     LD   a,c   ;get key pressed
CE15   3D                     DEC   a   ;adjust for index
CE16   87                     ADD   a,a   ;double for index
CE17   85                     ADD   a,l   ;index it
CE18   6F                     LD   l,a   
CE19   7E                     LD   a,(hl)   ;hl = (hl)
CE1A   23                     INC   hl   
CE1B   66                     LD   h,(hl)   
CE1C   6F                     LD   l,a   
CE1D   22 86 08               LD   (CEL),hl   
CE20   C3 01 C5               JP   setDataBase   ;set the DATA_BASE variable
CE23                             ; 
CE23                             ; Serial Enable.  Sets the TX line to high ready for serial transfer
CE23                             ; Input: none
CE23                             ; Destroys: A
CE23                SERIALENABLE:      
CE23   3E 40                  LD   a,40H   ;Serial TX bit
CE25   D3 01                  OUT   (DIGITS),a   ;Set it high
CE27   3E 44                  LD   a,44H   ;Set Tri colour LEDs to Disco Blue
CE29   D3 02                  OUT   (SEGS),a   ;output it
CE2B   C9                     RET      
CE2C                             ; 
CE2C                             ; Serial Disable.  Sets the TX line to low disabling serial transfer
CE2C                             ; Input: none
CE2C                             ; Destroys: A
CE2C                SERIALDISABLE:      
CE2C   AF                     XOR   a   ;clear A
CE2D   D3 01                  OUT   (DIGITS),a   ;Set it segment display off
CE2F   D3 02                  OUT   (SEGS),a   ;Clear segment leds
CE31   C9                     RET      
CE32                             ; 
CE32                             ; Confirmation LCD Question.  Press "C" to confirm or any other key to not confirm
CE32                             ; Input: none
CE32                             ; Return: Zero Flag Set === Confirmed
CE32                LCDCONFIRM:      
CE32   21 3C D5               LD   hl,confirmText   
CE35   06 01                  LD   b,01H   ;clear LCD instruction
CE37   CD 9C C5               CALL   commandToLCD   ;update LCD
CE3A   CD 83 C5               CALL   stringToLCD   ;Display Message on LCD
CE3D   CF                     RST   08H   ;get key and wait
CE3E   FE 0C                  CP   0CH   ;is it C? Set Zero Flag
CE40   C9                     RET      
CE41                             ; 
CE41                             ; Real Time Clock (RTC) Routines
CE41                             ; ------------------------------
CE41                             ; 
CE41                             ; Nicely reset RTC PRAM by asking the question first!
CE41                RTCRESET:      
CE41   CD 32 CE               CALL   LCDConfirm   ;check before proceding TISM
CE44   C0                     RET   nz   ;no, just exit
CE45                             ;fall through to next routine
CE45                             ; 
CE45                             ; Reset Mon3 RTC PRAM data to default values.
CE45                             ; Input: none
CE45                             ; Destroys: none
CE45                RESETRTCPRAM:      
CE45   CD B8 FA               CALL   resetDS1302   ;Reset RTC Time/Date to start it off
CE48   01 00 08               LD   bc,0800H   ;B=eight 2 byte addresses, C=slot 0
CE4B   21 00 40               LD   hl,USER_ADDR   ;default to 4000H
CE4E                RTCRESETLOOP1:      
CE4E   51                     LD   d,c   ;load slot
CE4F   5D                     LD   e,l   ;load LSB
CE50   CD 46 FC               CALL   writeRTCByte   ; 
CE53   0C                     INC   c   ;next slot
CE54   51                     LD   d,c   ;load slot
CE55   5C                     LD   e,h   ;load MSB
CE56   CD 46 FC               CALL   writeRTCByte   ; 
CE59   0C                     INC   c   ;next slot
CE5A   3E 0C                  LD   a,0CH   ;are we on slot 12?
CE5C   B9                     CP   c   ;yes, check if slot 12
CE5D   20 03                  JR   nz,$+5   ;no, ignore
CE5F   21 1B 00               LD   hl,BAUD_4800   ;set baud rate to 4800
CE62   3E 0E                  LD   a,0EH   ;are we on slot 14?
CE64   B9                     CP   c   ;yes, check if slot 14
CE65   20 03                  JR   nz,$+5   ;no, ignore
CE67   21 00 00               LD   hl,0000h   ;set beep and auto address inc to on
CE6A   10 E2                  DJNZ   RTCResetLoop1   
CE6C   CD 97 CE               CALL   RTCfillRAM   ;fill RTC PRAM to Mon3 Ram
CE6F                             ; 
CE6F                             ;get checksum
CE6F                RTCSAVECHECKSUM:      
CE6F   CD 30 FF               CALL   getRTCChecksum   ;get new checksum
CE72   16 1E                  LD   d,30   ;load slot 30
CE74   5F                     LD   e,a   ;load with new checksum
CE75   C3 46 FC               JP   writeRTCByte   ;save checksum
CE78                             ; 
CE78                             ; Get two byte value from PRAM
CE78                             ; Input: A = first slot value
CE78                             ; Output: HL = two byte value where L=slot, H=slot+1
CE78                RTCGETPRAM:      
CE78   F5                     PUSH   af   
CE79   57                     LD   d,a   
CE7A   CD 37 FC               CALL   readRTCByte   
CE7D   6F                     LD   l,a   
CE7E   F1                     POP   af   
CE7F   3C                     INC   a   
CE80   57                     LD   d,a   
CE81   CD 37 FC               CALL   readRTCByte   
CE84   67                     LD   h,a   
CE85   C9                     RET      
CE86                             ; 
CE86                             ; Set two byte value to PRAM
CE86                             ; Input: A = first slot value
CE86                             ;        HL = address of value to write to
CE86                RTCSETPRAM:      
CE86   F5                     PUSH   af   
CE87   57                     LD   d,a   
CE88   5E                     LD   e,(hl)   
CE89   CD 46 FC               CALL   writeRTCByte   
CE8C   F1                     POP   af   
CE8D   23                     INC   hl   
CE8E   3C                     INC   a   
CE8F   57                     LD   d,a   
CE90   5E                     LD   e,(hl)   
CE91   CD 46 FC               CALL   writeRTCByte   
CE94   C3 6F CE               JP   RTCSaveChecksum   
CE97                             ; 
CE97                             ; Copy the RTC PRAM to Mon3 RAM locations
CE97                RTCFILLRAM:      
CE97                             ;Set CEL Jump Table from PRAM (Ugly code here!!)
CE97   3E 00                  LD   a,0   ;get 1st slot
CE99   CD 78 CE               CALL   RTCGetPRAM   
CE9C   22 A2 08               LD   (CEL_QJMP),hl   
CE9F   3E 02                  LD   a,2   ;get 3rd slot
CEA1   CD 78 CE               CALL   RTCGetPRAM   
CEA4   22 A4 08               LD   (CEL_QJMP+2),hl   
CEA7   3E 04                  LD   a,4   ;get 5th slot
CEA9   CD 78 CE               CALL   RTCGetPRAM   
CEAC   22 A6 08               LD   (CEL_QJMP+4),hl   
CEAF                             ;Set Copy/To/Dest from PRAM
CEAF   3E 06                  LD   a,6   ;get 7th slot
CEB1   CD 78 CE               CALL   RTCGetPRAM   
CEB4   22 C0 08               LD   (COPY_START),hl   
CEB7   3E 08                  LD   a,8   ;get 9th slot
CEB9   CD 78 CE               CALL   RTCGetPRAM   
CEBC   22 C2 08               LD   (COPY_END),hl   
CEBF   3E 0A                  LD   a,10   ;get 11th slot
CEC1   CD 78 CE               CALL   RTCGetPRAM   
CEC4   22 C4 08               LD   (COPY_DEST),hl   
CEC7   3E 0C                  LD   a,12   ;get 13th slot
CEC9   CD 78 CE               CALL   RTCGetPRAM   
CECC   22 B1 08               LD   (BAUD),hl   
CECF   3E 0E                  LD   a,14   ;get 15th slot
CED1   CD 78 CE               CALL   RTCGetPRAM   
CED4   7C                     LD   a,h   
CED5   32 8D 08               LD   (KEY_BEEP),a   
CED8   7D                     LD   a,l   
CED9   32 8C 08               LD   (KEY_AUTO),a   
CEDC   C9                     RET      
CEDD                             ; 
CEDD                             ; Menu Initialise.  Set a custom user menu on the LCD. 
CEDD                             ; Input: HL = Pointer to Menu configuration.
CEDD                             ; Destroys: A, HL
CEDD                MENUINIT:      
CEDD   CD F7 CE               CALL   menuReset   ;reset menu variables
CEE0   D5                     PUSH   de   ;store DE
CEE1   3A 9B 08               LD   a,(MENU_IDX)   ;get menu index
CEE4   3C                     INC   a   ;move to next index
CEE5   E6 03                  AND   03H   ;reset to 0 if 4
CEE7   32 9B 08               LD   (MENU_IDX),a   ;save it
CEEA   87                     ADD   a,a   ;double it
CEEB   11 A8 08               LD   de,MENU_CFG_D   ;get config depth table
CEEE   83                     ADD   a,e   ;index table
CEEF   5F                     LD   e,a   ;to index postion
CEF0   7D                     LD   a,l   ;(DE) = HL
CEF1   12                     LD   (de),a   
CEF2   13                     INC   de   
CEF3   7C                     LD   a,h   
CEF4   12                     LD   (de),a   
CEF5   D1                     POP   de   ;restore DE
CEF6   C9                     RET      
CEF7                             ; 
CEF7                             ; Reset the menu variables for setting up a new menu
CEF7                             ; Input: HL = Pointer to Menu configuration.
CEF7                             ; Destroys: A
CEF7                MENURESET:      
CEF7   AF                     XOR   a   ;clear A
CEF8   32 96 08               LD   (MENU_POS),a   ;set menu position to first
CEFB   32 97 08               LD   (MENU_SEL),a   ;set first item to be selected
CEFE   7E                     LD   a,(hl)   ;get menu count
CEFF   32 98 08               LD   (MENU_CNT),a   ;save menu count
CF02   22 99 08               LD   (MENU_CFG),hl   ;store new menu configuration
CF05   C9                     RET      
CF06                             ; 
CF06                             ; Revert the menu to the previous one if any.
CF06                             ; Input: none
CF06                             ; Destroy: A
CF06                MENUPOP:      
CF06   3A 9B 08               LD   a,(MENU_IDX)   ;get current menu index
CF09   3D                     DEC   a   ;reduce by one
CF0A   32 9B 08               LD   (MENU_IDX),a   ;save it back
CF0D   FA 65 C6               JP   m,switchMode   ;if a < 0, switch to Data mode and return
CF10   87                     ADD   a,a   ;double it
CF11   E5                     PUSH   hl   ;save HL
CF12   21 A8 08               LD   hl,MENU_CFG_D   ;get config depth table
CF15   85                     ADD   a,l   ;index table
CF16   6F                     LD   l,a   ;to index postion
CF17   7E                     LD   a,(hl)   ;get low byte
CF18   23                     INC   hl   
CF19   66                     LD   h,(hl)   ;get high byte
CF1A   6F                     LD   l,a   ;make HL = (HL)
CF1B   CD F7 CE               CALL   menuReset   ;reset menu to new menu
CF1E   E1                     POP   hl   ;restore HL
CF1F   C9                     RET      
CF20                             ; 
CF20                             ; Menu Draw routine.  Title, then menu items from MENU_POS
CF20                MENUDRAW:      
CF20   06 01                  LD   b,01H   ;clear LCD instruction
CF22   CD 9C C5               CALL   commandToLCD   ;update LCD
CF25   2A 99 08               LD   hl,(MENU_CFG)   ;load menu config
CF28   23                     INC   hl   ;move to seven segment text
CF29                             ;set segment text
CF29   11 80 08               LD   de,DISP_BUFF   ;store in Monitor 7seg Buffer
CF2C   06 06                  LD   b,6   
CF2E                LCDSEGLOOP:      
CF2E   7E                     LD   a,(hl)   
CF2F   CD 79 C6               CALL   ASCIItoSegment   ;convert A to segment code
CF32   12                     LD   (de),a   
CF33   23                     INC   hl   
CF34   13                     INC   de   
CF35   10 F7                  DJNZ   LCDSegLoop   
CF37                             ;HL is now at menu title
CF37   CD 83 C5               CALL   stringToLCD   ;send Title to LCD
CF3A   3A 96 08               LD   a,(MENU_POS)   ;get current menu selection
CF3D   CD 9A CF               CALL   menuIndex   ;set HL to menu config at index A
CF40   0E 03                  LD   c,3   ;three rows
CF42   3A 98 08               LD   a,(MENU_CNT)   ;get menu count
CF45   B9                     CP   c   ;is it 3 or less?
CF46   30 01                  JR   nc,$+3   ;yes, skip setting b=count
CF48   4F                     LD   c,a   ;set rows to max count
CF49   11 1C D4               LD   de,LCDBaseRows+1   ;LCD rows 2,3,4
CF4C                DRAWLOOP:      
CF4C   1A                     LD   a,(de)   ;get row value
CF4D   47                     LD   b,a   ;set B as LCD row
CF4E   04                     INC   b   ;move one to the right
CF4F   CD 9C C5               CALL   commandToLCD   ;update LCD
CF52   CD 83 C5               CALL   stringToLCD   ;write menu item
CF55   3A 88 08               LD   a,(MCB)   ;get MCB
CF58   E6 20                  AND   MCB_MEN_PAR   ;check to see if menu or parameter structure
CF5A   28 21                  JR   z,drawHLSkip   ;menu so skip HL draw
CF5C   1A                     LD   a,(de)   ;get row value
CF5D   C6 10                  ADD   a,16   ;right justify
CF5F   47                     LD   b,a   ;set B as LCD row/column
CF60   CD 9C C5               CALL   commandToLCD   ;update LCD                
CF63   E5                     PUSH   hl   ;save HL
CF64   7E                     LD   a,(hl)   ;store ram
CF65   23                     INC   hl   ;address
CF66   66                     LD   h,(hl)   ;back into
CF67   6F                     LD   l,a   ;HL
CF68   23                     INC   hl   ;move to high byte
CF69   06 02                  LD   b,2   ;type bytes
CF6B                DRAWHL:      
CF6B   7E                     LD   a,(hl)   ;get byte
CF6C   E5                     PUSH   hl   ;save HL
CF6D   CD E2 C8               CALL   regAToASCII   
CF70   7C                     LD   a,h   
CF71   CD 98 C5               CALL   charToLCD   ;send character to LCD
CF74   7D                     LD   a,l   
CF75   CD 98 C5               CALL   charToLCD   ;send character to LCD
CF78   E1                     POP   hl   ;restore HL
CF79   2B                     DEC   hl   ;move to low byte
CF7A   10 EF                  DJNZ   drawHL   ;do next byte
CF7C   E1                     POP   hl   ;restore HL
CF7D                DRAWHLSKIP:      
CF7D   23                     INC   hl   ;skip jump
CF7E   23                     INC   hl   
CF7F   13                     INC   de   ;move to next row
CF80   0D                     DEC   c   ;get next row
CF81   20 C9                  JR   nz,drawLoop   ;if any
CF83                             ;draw pointer
CF83   3A 96 08               LD   a,(MENU_POS)   ;get menu text pos
CF86   47                     LD   b,a   
CF87   3A 97 08               LD   a,(MENU_SEL)   ;get selection
CF8A   90                     SUB   b   ;A = 0,1 or 2
CF8B   11 1C D4               LD   de,LCDBaseRows+1   ;LCD rows 2,3,4
CF8E   83                     ADD   a,e   ;index DE (same page!)
CF8F   5F                     LD   e,a   
CF90   1A                     LD   a,(de)   ;get row index
CF91   47                     LD   b,a   
CF92   CD 9C C5               CALL   commandToLCD   ;update LCD
CF95   3E 7E                  LD   a,MENU_PTR   ;display ->
CF97   C3 98 C5               JP   charToLCD   ;display it and exit
CF9A                             ; 
CF9A                             ; Index menu configuration with A
CF9A                             ; Input: A = index
CF9A                             ; Output: HL = position of menu entry text.
CF9A                MENUINDEX:      
CF9A   47                     LD   b,a   ;save index
CF9B   2A 99 08               LD   hl,(MENU_CFG)   ;get configuration
CF9E   7E                     LD   a,(hl)   ;skip menu title and 7seg/count data (can't be zero)
CF9F   23                     INC   hl   
CFA0   B7                     OR   a   ;is it zero
CFA1   20 FB                  JR   nz,$-3   ;repeat until zero found
CFA3   78                     LD   a,b   ;is index zero?
CFA4   B7                     OR   a   ;yes
CFA5   C8                     RET   z   ;HL in correct spot
CFA6                INDEXLOOP:      
CFA6   7E                     LD   a,(hl)   ;skip menu entry
CFA7   23                     INC   hl   
CFA8   B7                     OR   a   ;is it zero
CFA9   20 FB                  JR   nz,$-3   ;repeat until zero found
CFAB   23                     INC   hl   ;move to next menu entry
CFAC   23                     INC   hl   
CFAD   10 F7                  DJNZ   indexLoop   ;keep going until done
CFAF   C9                     RET      
CFB0                             ; 
CFB0                             ; Menu driver for external applications.  Creates a selectable custom menu
CFB0                             ; Keys: Go = Select menu item, AD = Exit Menu, +/- = Navigate menu
CFB0                             ; Input: HL = Pointer to Menu configuration. (See Note)
CFB0                             ; Destroys: A, HL
CFB0                             ; Note: Menu configuration is as follows.  All strings are ZERO terminated!
CFB0                             ; <Menu Entries>, <7Seg Text>, <Menu Text Title>,
CFB0                             ;        [<Menu Text Label>, <Menu Routine Address>]+
CFB0                             ; EG: .db 2             ;Two menu items
CFB0                             ;     .db "Games "      ;7Seg Text
CFB0                             ;     .db "Games",0     ;Menu title
CFB0                             ;     .db "TEC Invaders",0  ;Text and Routine
CFB0                             ;     .dw invaders
CFB0                             ;     .db "TEC Maze",0  ;Text and routine
CFB0                             ;     .dw maze
CFB0                MENUDRIVER:      
CFB0   CD DD CE               CALL   menuInit   ;Initialise the internal memory with menu config
CFB3   21 88 08               LD   hl,MCB   ;set MCB
CFB6   CB DE                  SET   3,(hl)   ;into LCD mode
CFB8   E1                     POP   hl   ;pop return address of rst 10
CFB9   E1                     POP   hl   ;pop return address of GO call
CFBA   C3 26 C2               JP   setLCD   ;hook into monitor menu controller
CFBD                             ; 
CFBD                             ; Parameter data entry driver.  Creates a list of editable two byte parameters
CFBD                             ; utilising the menu handler.
CFBD                             ; Keys: Go = Continue, AD = Exit, +/- = Navigate, 0-F = enter values
CFBD                             ; Input: HL = Pointer to Parameter configuration. (See Note)
CFBD                             ; Note: Parameter configuration is as follows.  All strings are ZERO terminated!
CFBD                             ; Parameter text can be no longer than 14 characters
CFBD                             ; <No. of Entries>, <7Seg Text>, <Parameter Title Text>,
CFBD                             ;      [<Param Text Label>, <Param RAM Address>]+
CFBD                             ; EG: .db 3             ;Three parameters
CFBD                             ;     .db "Params"      ;7seg text
CFBD                             ;     .db "= Enter Parameters =",0     ;Parameter title
CFBD                             ;     .db "Start Address:",0  ;Text and Address
CFBD                             ;     .dw COPY_START
CFBD                             ;     .db "End Address:",0  ;Text and Address
CFBD                             ;     .dw COPY_END
CFBD                             ;     .db "Dest. Address:",0  ;Text and Address
CFBD                             ;     .dw COPY_DEST
CFBD                PARAMDRIVER:      
CFBD   CD DD CE               CALL   menuInit   ;Initialise the internal memory with param config
CFC0   21 88 08               LD   hl,MCB   ;set MCB
CFC3   CB DE                  SET   3,(hl)   ;into LCD mode
CFC5   CB EE                  SET   5,(hl)   ;and Parameter Entry mode
CFC7   C3 26 C2               JP   setLCD   ;hook into monitor menu controller    
CFCA                             ; 
CFCA                             ; Get Caps lock state
CFCA                             ; Input: none
CFCA                             ; Output: A = caps lock state; 0 = off, CAPSLOCK = on
CFCA                GETCAPS:      
CFCA   3A 9C 08               LD   a,(CAPS_LOCK)   ; fetch current value
CFCD   C9                     RET      
CFCE                             ; 
CFCE                             ; Get GLCD Terminal state
CFCE                             ; Input: none
CFCE                             ; Output: A = GLCD Terminal state; 0 = off, FF = on
CFCE                GETGLCDTERM:      
CFCE   3A 8F 08               LD   a,(GLCD_TERM)   ; fetch current value
CFD1   C9                     RET      
CFD2                             ; 
CFD2                             ; Get SHADOW state
CFD2                             ; Input: none
CFD2                             ; Output: A = shadow state; 0 = off, SHADOW = on
CFD2                GETSHADOW:      
CFD2   3A 9D 08               LD   a,(SYS_MODE)   ; fetch current value
CFD5   E6 01                  AND   SHADOW   ; return SHADOW bit only
CFD7   EE 01                  XOR   SHADOW   ; flip bit becuase active low
CFD9   C9                     RET      
CFDA                             ; 
CFDA                             ; Get PROTECT state
CFDA                             ; Input: none
CFDA                             ; Output: A = protect state; 0 = off
CFDA                GETPROTECT:      
CFDA   3A 9E 08               LD   a,(PROT_MODE)   ; fetch current value
CFDD   C9                     RET      
CFDE                             ; 
CFDE                             ; Get EXPAND state
CFDE                             ; Input: none
CFDE                             ; Output: A = expand state; 0 = off
CFDE                GETEXPAND:      
CFDE   3A 9D 08               LD   a,(SYS_MODE)   ; fetch current value
CFE1   E6 04                  AND   EXPAND   ; return EXPAND bit only
CFE3   C9                     RET      
CFE4                             ; 
CFE4                             ; Set Caps lock state
CFE4                             ; Input: A = Desired caps lock state; 0 = off, CAPSLOCK = on
CFE4                             ; Destroy: A
CFE4                SETCAPS:      
CFE4   C5                     PUSH   bc   
CFE5   E6 80                  AND   CAPSLOCK   ; ensure only correct bit is accepted
CFE7   32 9C 08               LD   (CAPS_LOCK),a   ; save caps lock
CFEA   47                     LD   b,a   ; save A in B
CFEB   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
CFEE   E6 7F                  AND   CAPSLOCK-1   ; clear bit
CFF0                UPDATEMODE:      
CFF0   B0                     OR   b   ; set new bit state from B
CFF1   D3 FF                  OUT   (SYS_CTRL),a   
CFF3   32 9D 08               LD   (SYS_MODE),a   
CFF6   C1                     POP   bc   
CFF7   C9                     RET      
CFF8                             ; 
CFF8                             ; Set GLCD Terminal state
CFF8                             ; Input: A = Desired GLCD Terminal state; 0 = off, FF = on
CFF8                             ; Destroy: A
CFF8                SETGLCDTERM:      
CFF8   B7                     OR   a   ; check for zero
CFF9   28 02                  JR   z,$+4   ; yes, skip force FF
CFFB   3E FF                  LD   a,0FFH   ; set to FF
CFFD   32 8F 08               LD   (GLCD_TERM),a   ; save glcd termnial flag
D000   C3 54 D0               JP   initGLCDTerminal   ; set GLCD based on flag
D003                             ; 
D003                             ; Set SHADOW state
D003                             ; Input: A = Desired SHADOW state; 0 = off, SHADOW = on
D003                             ; Destroy: A
D003                SETSHADOW:      
D003   C5                     PUSH   bc   
D004   E6 01                  AND   SHADOW   ; ensure only correct is accepted
D006   AF                     XOR   a   ; flip bit because active low
D007   47                     LD   b,a   ; save A in B
D008   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
D00B   E6 FE                  AND   -SHADOW-1   ; clear bit
D00D   18 E1                  JR   updateMode   ; set mode and exit
D00F                             ; 
D00F                             ; Set PROTECT state
D00F                             ; Input: A = Desired Protect state; 0 = off, PROTECT = on
D00F                             ; Destroy: A
D00F                SETPROTECT:      
D00F   C5                     PUSH   bc   
D010   E6 02                  AND   PROTECT   ; ensure only correct bit is accepted
D012   32 9E 08               LD   (PROT_MODE),a   ; save prot mode
D015   47                     LD   b,a   ; save A in B
D016   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
D019   E6 FD                  AND   -PROTECT-1   ; clear bit
D01B   18 D3                  JR   updateMode   ; set mode and exit
D01D                             ; 
D01D                             ; Set EXPAND state
D01D                             ; Input: A = Desired Expand state; 0 = off, EXPAND = on
D01D                             ; Destroy: A
D01D                SETEXPAND:      
D01D   C5                     PUSH   bc   
D01E   E6 04                  AND   EXPAND   ; ensure only correct bit is accepted
D020   32 9F 08               LD   (XPND_MODE),a   ; Save expand
D023   47                     LD   b,a   ; save A in B
D024   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
D027   E6 FB                  AND   -EXPAND-1   ; clear bit
D029   18 C5                  JR   updateMode   ; set mode and exit
D02B                             ; 
D02B                             ; Toggle Caps Lock
D02B                             ; Input: none
D02B                             ; Destroy: A
D02B                TOGGLECAPS:      
D02B   3A 9C 08               LD   a,(CAPS_LOCK)   ; get caps lock mode status
D02E   EE 80                  XOR   CAPSLOCK   ; toggle bit
D030   32 9C 08               LD   (CAPS_LOCK),a   ; return it back
D033   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
D036   EE 80                  XOR   CAPSLOCK   ; toggle bit
D038                UPDATECTL:      
D038   D3 FF                  OUT   (SYS_CTRL),a   ; update latch
D03A   32 9D 08               LD   (SYS_MODE),a   ; save state
D03D   C9                     RET      
D03E                             ; 
D03E                             ; Toggle EXPAND
D03E                             ; Input: none
D03E                             ; Destroy: A
D03E                TOGGLEEXPAND:      
D03E   3A 9F 08               LD   a,(XPND_MODE)   ; get expand mode status
D041   EE 04                  XOR   EXPAND   ; toggle bit
D043   32 9F 08               LD   (XPND_MODE),a   ; return it back
D046   3A 9D 08               LD   a,(SYS_MODE)   ; get current state
D049   EE 04                  XOR   EXPAND   ; toggle bit
D04B   18 EB                  JR   updateCTL   
D04D                             ; 
D04D                             ; Toggle GLCD Terminal Flag
D04D                             ; Input: none
D04D                             ; Destroy: A
D04D                TOGGLEGLCDTERMINAL:      
D04D   3A 8F 08               LD   a,(GLCD_TERM)   ; get glcd terminal status
D050   2F                     CPL      ; twos complement
D051   32 8F 08               LD   (GLCD_TERM),a   ; save it back
D054                INITGLCDTERMINAL:      
D054   C5                     PUSH   bc   
D055   D5                     PUSH   de   
D056   E5                     PUSH   hl   
D057   F5                     PUSH   af   
D058   B7                     OR   a   
D059   28 05                  JR   z,$+7   
D05B   CD 18 DB               CALL   initTerminal   ; set GLCD as terminal
D05E   18 03                  JR   $+5   
D060   CD 00 D8               CALL   initLCD   ; set GLCD as normal
D063   F1                     POP   af   
D064   E1                     POP   hl   
D065   D1                     POP   de   
D066   C1                     POP   bc   
D067   C9                     RET      
D068                             ; 
D068                             ; Toggle Key Press Beep
D068                             ; Input: none
D068                             ; Destroy: A
D068                TOGGLEBEEP:      
D068   3A 8D 08               LD   a,(KEY_BEEP)   ; get current state
D06B   2F                     CPL      ; twos complement
D06C   32 8D 08               LD   (KEY_BEEP),a   ; save it back
D06F   18 07                  JR   toggleRTCUpdate   
D071                             ; 
D071                             ; Toggle Auto increment address after second nibble keyed
D071                             ; Input: none
D071                             ; Destroy: A
D071                TOGGLEAUTOADDRESS:      
D071   3A 8C 08               LD   a,(KEY_AUTO)   ; get current state
D074   2F                     CPL      ; twos complement
D075   32 8C 08               LD   (KEY_AUTO),a   ; save it back
D078                TOGGLERTCUPDATE:      
D078   3A 88 08               LD   a,(MCB)   ;get MCB
D07B   E6 40                  AND   MCB_RTC   ;is bit 6 set?
D07D   C8                     RET   z   ;no just exit
D07E   E5                     PUSH   hl   
D07F   D5                     PUSH   de   
D080   C5                     PUSH   bc   
D081   21 8C 08               LD   hl,KEY_AUTO   ;get current state
D084   3E 0E                  LD   a,14   ;index A for RTC slot
D086   CD 86 CE               CALL   RTCSetPRAM   ;save it 
D089   C1                     POP   bc   
D08A   D1                     POP   de   
D08B   E1                     POP   hl   
D08C   C9                     RET      
D08D                             ; 
D08D                             ; Display credits via menu
D08D                DISPLAYCREDITS:      
D08D   21 31 D7               LD   hl,creditsCFG   
D090   CD B0 CF               CALL   menuDriver   
D093                             ; 
D093                             ; Display setting menu
D093                DISPLAYSETTINGS:      
D093   21 98 D6               LD   hl,settingsCFG   
D096   CD B0 CF               CALL   menuDriver   
D099                             ; 
D099                             ; Display baud rate menu
D099                DISPLAYBAUD:      
D099   21 A2 D1               LD   hl,baudCFG   
D09C   CD B0 CF               CALL   menuDriver   
D09F                             ; 
D09F                             ; Display Drive menu
D09F                DISPLAYDRIVE:      
D09F   21 DB D1               LD   hl,driveCFG   
D0A2   CD B0 CF               CALL   menuDriver   
D0A5                             ; 
D0A5                             ; Random Number generator.
D0A5                             ; Input: note
D0A5                             ; Output: A = pseudo random number
D0A5                             ; Destroy: B
D0A5                RANDOM:      
D0A5   3A B0 08               LD   a,(RNG_SEED)   ;Random RAM seed
D0A8   47                     LD   b,a   
D0A9   CB 20                  SLA   b   
D0AB   9F                     SBC   a,a   
D0AC   E6 5F                  AND   5FH   
D0AE   A8                     XOR   b   
D0AF   32 B0 08               LD   (RNG_SEED),a   
D0B2   47                     LD   b,a   
D0B3   ED 5F                  LD   a,r   
D0B5   80                     ADD   a,b   
D0B6   C9                     RET      
D0B7                             ; 
D0B7                             ; Set Disassembly Start Address.  Set the first address for disassembler output
D0B7                             ; Input: HL = start address
D0B7                             ; Output: none
D0B7                             ; Destroy: none
D0B7                SETDISSTART:      
D0B7   22 29 09               LD   (DISFROM),hl   ;save start in DIS_FROM
D0BA   C9                     RET      
D0BB                             ; 
D0BB                             ; Get Disassembly Next Address.  Get the next disassembly address
D0BB                             ; Input: none
D0BB                             ; Output: HL = next disassembly address
D0BB                             ; Destroy: none
D0BB                GETDISNEXT:      
D0BB   2A 29 09               LD   hl,(DISFROM)   ;get next address from DIS_FROM
D0BE   C9                     RET      
D0BF                             ; 
D0BF                             ; Generate Disassembly line
D0BF                             ; Input: None (but must call setDisStart first)
D0BF                             ; Output: HL = pointer to disassembly ASCII output, zero terminated
D0BF                             ; Destroy: All
D0BF                GETDISASSEMBLY:      
D0BF   CD 9B E7               CALL   disStart   ;generate Disassembly
D0C2   21 26 09               LD   hl,DISPTR   ;get end of output string
D0C5   36 00                  LD   (hl),0   ;place zero at end of string
D0C7   21 00 09               LD   hl,DISLINE1   ;reset HL to point to start of string
D0CA   C9                     RET      
D0CB                             ; 
D0CB                             ; Convert the output of the matrixScan routine to ASCII.  matrixScan returns values between 0 and 64
D0CB                             ; these represent key presses on the keyboard.  This routine will convert the output of matrixScan, DE
D0CB                             ; to the actual key pressed in ASCII.  If key doesn't map to an ASCII character then the
D0CB                             ; matrix key value is returned.
D0CB                             ; Input: DE = value return from matrixScan. E = key, D = secondary key
D0CB                             ; Output: A = key pressed in ASCII
D0CB                             ; Destroy: BC, HL
D0CB                MATRIXSCANASCII:      
D0CB   7B                     LD   a,e   ;get key pressed
D0CC                             ;handle ESC, CR, Space, Single Quote and Backslash
D0CC   21 EF D0               LD   hl,KMOD_TABLE   ;point to mod table
D0CF   01 05 00               LD   bc,0005H   ;five keys to check
D0D2   ED A1        KCPI:     CPI      ;compare A to value in Table
D0D4   28 06                  JR   z,kModA   ;yes, mod it
D0D6   23                     INC   hl   ;skip the next table entry
D0D7   EA D2 D0               JP   pe,kCPI   ;does BC=0, no check again
D0DA   18 1D                  JR   kNumChar   ;key doesn't need modding, move to next check
D0DC                KMODA:       
D0DC   7E                     LD   a,(hl)   ;save A with new modded value
D0DD   FE 26                  CP   26H   ;is it either a quote or back slash?
D0DF   D8                     RET   c   ;no, then just cleanly exit as shift doesn't apply
D0E0   47                     LD   b,a   ;save A in B
D0E1   7A                     LD   a,d   ;check second key
D0E2   B7                     OR   a   ;is A a SHIFT? Shift = 0
D0E3   20 5B                  JR   nz,kAlpEnd   ;No, exit cleanly with modded value
D0E5   21 10 D1               LD   hl,KSHIFT_TABLE   ;point to shift table
D0E8   3E 12                  LD   a,12H   ;set base index
D0EA   81                     ADD   a,c   ;add key index
D0EB                KSHIFTINDEX:      
D0EB   85                     ADD   a,l   ;index table
D0EC   6F                     LD   l,a   ;set L
D0ED   7E                     LD   a,(hl)   ;get shifted value for quote or backslash
D0EE   C9                     RET      ;cleanly exit
D0EF                KMOD_TABLE:      
D0EF                             ;First value is key, second value is modded ASCII, 5 keys in total
D0EF   0A 0D 0C 1B 0D 20 0E 27 3F 5C DB   0AH,0DH,0CH,1BH,0DH,20H,0EH,27H,3FH,5CH   
D0F9                KNUMCHAR:      
D0F9                             ;Handle number and Characters
D0F9   FE 21                  CP   21H   ;check key range below A-Z
D0FB   30 27                  JR   nc,kAlpha   ;its higher, check for Chracter
D0FD   FE 0F                  CP   0FH   ;is it greater than Comma?
D0FF   38 23                  JR   c,kAlpha   ;yes, check for Character
D101   C6 1D                  ADD   a,1DH   ;index to get correct ASCII
D103   47                     LD   b,a   ;save key
D104   7A                     LD   a,d   ;check second key
D105   B7                     OR   a   ;is it a SHIFT? Shift = 0
D106   20 38                  JR   nz,kAlpEnd   ;No, exit cleanly with new value
D108   21 10 D1               LD   hl,KSHIFT_TABLE   ;point to shift table
D10B   78                     LD   a,b   ;get key value
D10C   D6 2C                  SUB   2CH   ;set base index
D10E   18 DB                  JR   kShiftIndex   ;do index and cleanly exit
D110                KSHIFT_TABLE:      
D110                             ;Characters when shift is pressed.  22H is double quote
D110   3C 5F 3E 3F 29 21 40 23 24 25 5E 26 2A 28 20 3A 20 2B 7C 22 DB   "<_>?)!@#$%^&*( : +|",22H   
D124                KALPHA:      
D124                             ;Handle Alphabet characters A-Z
D124   FE 24                  CP   24H   ;is key is A or over
D126   D8                     RET   c   ;no, no mod just exit cleanly
D127   C6 3D                  ADD   a,3DH   ;index key to get correct ASCII
D129   47                     LD   b,a   ;save key
D12A   7A                     LD   a,d   ;check second key
D12B   3D                     DEC   a   ;is it CTRL?
D12C   20 04                  JR   nz,kCaps   ;no, check for caps lock
D12E   78                     LD   a,b   ;get correct key
D12F   D6 60                  SUB   60H   ;adjust for CTRL-? keys
D131   C9                     RET      ;exit
D132                KCAPS:       
D132   CD CA CF               CALL   getCaps   ;get CAPS lock state
D135   B7                     OR   a   ;is it set or not?
D136   20 04                  JR   nz,kUpper   ;yes, make upper case
D138   7A                     LD   a,d   ;check second key
D139   B7                     OR   a   ;is it SHIFT?
D13A   20 04                  JR   nz,kAlpEnd   ;no, cleanly exit
D13C                KUPPER:      
D13C   78                     LD   a,b   ;get key
D13D   D6 20                  SUB   "a"-"A"   ;subtract 20H to adjust for upper case
D13F   C9                     RET      ;exit cleanly
D140                KALPEND:      
D140   78                     LD   a,b   ;save correct key
D141   C9                     RET      ;exit
D142                             ; 
D142                             ; Parse matrix keyboard input.  This routine checks the key(s) pressed on
D142                             ; the Matrix Keyboard and either returns the key pressed in ASCII or handle
D142                             ; special cases.  The special cases are Key Bounce/Repeat and Caps lock.  This routine
D142                             ; is designed to come directly after matrixScan and included in the Scan loop.
D142                             ; Input: DE = value return from matrixScan. E = key, D = secondary key
D142                             ;        Zero Flag = Set if key pressed. (From matrixScan output)
D142                             ; Output: A = key pressed in ASCII
D142                             ;         Carry Flag = Set if ASCII returned.
D142                             ;         Carry Flag = Not Set if special case and no ASCII returned
D142                             ; Destroy: BC, HL
D142                PARSEMATRIXSCAN:      
D142   21 8B 08               LD   hl,KEY_REPEAT   ;get the key repeat timer
D145   28 0E                  JR   z,parseKey   ;Key has been pressed, check it
D147   36 00                  LD   (hl),00H   ;reset delay counter
D149   AF                     XOR   a   ;no key pressed, clear the key buffer
D14A   32 89 08               LD   (KEY_BUFF),a   
D14D                PARSESPECIAL:      
D14D   06 00                  LD   b,00H   ;delay to slow this
D14F   10 FE                  DJNZ   $   ;shit down.
D151   10 FE                  DJNZ   $   ;shit down.
D153   B7                     OR   a   ;Clear carry flag
D154   C9                     RET      
D155                PARSEKEY:      
D155                             ;check for previous key
D155   3A 89 08               LD   a,(KEY_BUFF)   ;Check previous key
D158   BB                     CP   e   ;is the key pressed
D159   20 05                  JR   nz,parseNewKey   ;New key, parse it
D15B   35                     DEC   (hl)   ;key held, decrease timer
D15C   20 EF                  JR   nz,parseSpecial   ;loop back to exit as if no key pressed
D15E   36 20                  LD   (hl),KEY_SPEED   ;short timer set for subsequent presses
D160                PARSENEWKEY:      
D160                             ;different key, save it
D160   7B                     LD   a,e   
D161   32 89 08               LD   (KEY_BUFF),a   ;save key to key buffer
D164   FE 03                  CP   03H   ;ignore Shift/Ctrl/Fn if first key pressed
D166   38 E5                  JR   c,parseSpecial   ;exit cleanly
D168   35                     DEC   (hl)   ;set timer off
D169                             ;check for Caps lock pressed (need to fix auto repeat issue)
D169   3E 07                  LD   a,07H   ;caps lock key value
D16B   BB                     CP   e   
D16C   20 05                  JR   nz,parseMatrix   ;no, then convert key pressed
D16E   CD 2B D0               CALL   toggleCaps   
D171   18 DA                  JR   parseSpecial   ;exit cleanly
D173                PARSEMATRIX:      
D173   CD CB D0               CALL   matrixScanASCII   
D176                             ;All good, A=ASCII key pressed,
D176   37                     SCF      ;set carry for good exit
D177   C9                     RET      
D178                             ; 
D178                             ; Baud Rate Selection entries
D178                BAUD2400:      
D178   3E 3F                  LD   a,BAUD_2400   ;2400
D17A   18 0A                  JR   saveBaud   
D17C                BAUD4800:      
D17C   3E 1B                  LD   a,BAUD_4800   ;4800
D17E   18 06                  JR   saveBaud   
D180                BAUD9600:      
D180   3E 0B                  LD   a,BAUD_9600   ;9600
D182   18 02                  JR   saveBaud   
D184                BAUD14400:      
D184   3E 05                  LD   a,BAUD_14400   ;14400
D186                SAVEBAUD:      
D186   32 B1 08               LD   (BAUD),a   ;save in RAM (most significant byte)
D189   3A 88 08               LD   a,(MCB)   ;get MCB
D18C   E6 40                  AND   MCB_RTC   ;is bit 6 set?
D18E   CA 06 CF               JP   z,menuPop   ;no just exit
D191   E5                     PUSH   hl   
D192   D5                     PUSH   de   
D193   C5                     PUSH   bc   
D194   21 B1 08               LD   hl,BAUD   ;get current state
D197   3E 0C                  LD   a,12   ;index A for RTC slot
D199   CD 86 CE               CALL   RTCSetPRAM   ;save it 
D19C   C1                     POP   bc   
D19D   D1                     POP   de   
D19E   E1                     POP   hl   
D19F   C3 06 CF               JP   menuPop   ;pop off baud menu and return the prevous menu
