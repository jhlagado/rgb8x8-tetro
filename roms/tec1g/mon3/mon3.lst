E79B                             ; RAM Locations
E79B                             ;--------------
E79B                GBUF:     EQU   0A00H   ;Graphics Buffer 16 * 64 = 1024 byte
E79B                ENDPT:    EQU   0E00H   ;End Point for Line
E79B                SX:       EQU   0E02H   ;Sign of X
E79B                SY:       EQU   0E03H   ;Sign of Y
E79B                DX:       EQU   0E04H   ;Change of X
E79B                DY:       EQU   0E06H   ;Change of Y
E79B                ERR:      EQU   0E08H   ;Error Rate
E79B                RAD:      EQU   0E0AH   ;Radius
E79B                CLRBUF:   EQU   0E0CH   ;Clear Buffer Flag on LCD Displaying
E79B                CURSOR_XY:   EQU   0E0DH   ;Cursor Address X,Y
E79B                CURSOR_Y:   EQU   CURSOR_XY   ;Cursor Y
E79B                CURSOR_X:   EQU   CURSOR_XY+1   ;Cursor X
E79B                CURSOR_YS:   EQU   0E0FH   ;Start Y row for new line
E79B                CURSOR_ON:   EQU   0E10H   ;Cursor on/off flag
E79B                INVERSE:   EQU   0E11H   ;Inverse Flag
E79B                PIXEL_X:   EQU   0E12H   ;Pixel X length
E79B                VPORT:    EQU   0E13H   ;View port start address
E79B                TBUF:     EQU   0E15H   ;Top of Buffer pointer
E79B                ULINE:    EQU   0E17H   ;Underline flag
E79B                AUTO_LF:   EQU   0E18H   ;Auto line feed flag
E79B                PLOT_ALWAYS:   EQU   0E19H   ;Plot always flag
E79B                SBUF:     EQU   16 * 60   ;Scroll Buffer size  16 * 60 = 960 byte (10 lines)
E79B                TGBUF:    EQU   1000H + SBUF   ;Terminal GBUF
E79B                             ; jims disassembler source code
E79B                             ; -----------------------------
E79B                             ; 
E79B                             ; note: this file was updated so i can place it in any memory location.
E79B                             ; for full annotation please look at the pdf "disassembler_listing.pdf"
E79B                             ; 
E79B                             ; edits by craig hart: removed junk code
E79B                             ; fixed two remaining fixed memory references; code can now run anywhere in address apce
E79B                             ; update to add in (xx),a and out (xx),a brackets
E79B                             ; update to add "," in call/jp/jr <flag> opcodes
E79B                             ; optimze by removing code such as jp => jp => dest.
E79B                             ; 
E79B                             ; edit by brian chiha: formatted code
E79B                             ; remove extra space from call/jp/jr <flag> opcodes
E79B                             ; fixed missing opcode LD SP,IX and LD SP,IY
E79B                             ; note: LD (XY+d),n isn't working yet....
E79B                             ; 
E79B                             ; local variables
E79B                DISRAM:   EQU   0900H   
E79B                DISLINE1:   EQU   DISRAM   ;DIS STRING START
E79B                DISLINE2:   EQU   DISRAM + 19   ;DIS SECOND LINE
E79B                DISPTR:   EQU   DISRAM + 38   ;DIS STRING END
E79B                DISFLAG:   EQU   DISRAM + 40   ;DIS FLAG FOR HL,IX,IY
E79B                DISFROM:   EQU   DISRAM + 41   ;DIS START ADDRESS
E79B                             ; 
E79B                DISSTART:      
E79B   21 00 09               LD   hl,disline1   
E79E   AF                     XOR   a   
E79F   32 28 09               LD   (disflag),a   
E7A2   22 26 09               LD   (disptr),hl   
E7A5   2A 29 09               LD   hl,(disfrom)   
E7A8   E5                     PUSH   hl   
E7A9   CD 31 E9               CALL   l0x318a   ; write address to disline1
E7AC   06 22                  LD   b,22H   
E7AE   CD 60 E9               CALL   l0x31b9   ;fill rest with spaces
E7B1                             ; 
E7B1   21 00 09               LD   hl,disline1   ; patch to fix absoute memory addressing
E7B4   01 05 00               LD   bc,5   
E7B7   09                     ADD   hl,bc   
E7B8                             ; 
E7B8   22 26 09               LD   (disptr),hl   
E7BB   E1                     POP   hl   
E7BC   7E                     LD   a,(hl)   
E7BD   E5                     PUSH   hl   
